# Normalize line endings on commit; keep CRLF/LF on disk per platform
* text=auto eol=lf

# Explicit text files
*.astro    text eol=lf
*.md       text eol=lf
*.mdx      text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.xml      text eol=lf
*.svg      text eol=lf
*.txt      text eol=lf

# Binary files - never normalize
*.png      binary
*.jpg      binary
*.jpeg     binary
*.webp     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.xlsx     binary
*.xls      binary
*.docx     binary
*.pptx     binary
