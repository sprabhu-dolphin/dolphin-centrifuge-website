---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Sharples P 3400 Decanter | Applications & Specifications",
  "description": "Sharples P 3400 decanter centrifuge is a large capacity decanter that finds multiple uses for sludge thickening, biomass extraction & wastewater treatment",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  },
  "datePublished": "2020-10-27",
  "dateModified": "2025-04-03"
};

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Sharples P 3400 Decanter Centrifuge",
  "description": "Sharples P 3400 decanter centrifuge is a large capacity decanter that finds multiple uses for sludge thickening, biomass extraction & wastewater treatment",
  "image": "https://dolphincentrifuge.com/images/sharples-p-3400-decanter/sharples-p3400-oilfield-decanter.webp",
  "brand": { "@type": "Brand", "name": "Sharples" },
  "model": "P-3400",
  "additionalProperty": [
    { "@type": "PropertyValue", "name": "Rated Capacity", "value": "50 GPM on Ethanol Biomass Separation" },
    { "@type": "PropertyValue", "name": "Bowl Speed", "value": "4000 RPM (3,150 Gs RCF)" },
    { "@type": "PropertyValue", "name": "Drive Motor Power", "value": "25 HP" },
    { "@type": "PropertyValue", "name": "Auger Differential Speed", "value": "1 ~ 42 RPM" },
    { "@type": "PropertyValue", "name": "Gearbox Ratio", "value": "1: 95" },
    { "@type": "PropertyValue", "name": "Conveyor Protection", "value": "Carbide Tile or Tungsten Carbide Hard-Surfacing" }
  ]
};

const jsonLd = [articleJsonLd, productJsonLd];

const toc = [
  { id: 'applications', label: 'Applications' },
  { id: 'specifications', label: 'Specifications' },
];

const relatedApplications = [
  { label: 'Decanter Centrifuge', href: '/decanter-centrifuge/' },
  { label: 'Wastewater Centrifuge', href: '/wastewater-centrifuge/' },
  { label: 'Waste Oil Centrifuge', href: '/waste-oil-centrifuge/' },
  { label: 'Liquid Humus Fertilizer', href: '/liquid-humus-centrifuge/' },
  { label: 'Hemp Solvent Extraction', href: '/hemp-extraction-centrifuge/' },
];

const relatedProducts = [
  { label: 'Sharples P-3000 Decanter', href: '/sharples-p-3000-decanter/', description: 'Standard-capacity Sharples decanter' },
  { label: 'Alfa Laval NX 418 Decanter', href: '/alfa-laval-nx-418-decanter-centrifuge/', description: '418 mm high-performance decanter' },
  { label: 'Decanter Centrifuge Rental', href: '/decanter-centrifuge-rental/', description: 'Temporary units during rebuild' },
];
---

<ApplicationLayout
  title="Sharples P 3400 Decanter | Applications & Specifications"
  disableTitleSuffix={true}
  description="Sharples P 3400 decanter centrifuge is a large capacity decanter that finds multiple uses for sludge thickening, biomass extraction & wastewater treatment"
  heroImage="/images/sharples-p-3400-decanter/dolphin-sharples-P-3400-decanter-centrifuge-hero-2000.webp"
  heroImageAlt="Sharples P3400 Oilfield Decanter Centrifuge"
  category="products"
  categoryLabel="Products"
  canonicalUrl="https://dolphincentrifuge.com/sharples-p-3400-decanter/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <!-- Intro paragraphs (verbatim legacy) -->
  <div class="prose prose-lg max-w-none mb-8">
    <p>The Sharples P-3400 <a href="/decanter-centrifuge/">Decanter Centrifuge</a> is a horizontal de-sludging centrifuge built for the two-phase separation of crude oil tank bottoms, refinery slop sludge, industrial sludge-thickening, municipal sludge dewatering, paint sludge handling, etc.</p>
    <p>With a 25 HP Motor, the P 3400 decanter has a bowl RPM of 4,000 and can process 50 GPM on ethanol hemp biomass separation.</p>
  </div>

  <!-- Product Image (centered) -->
  <div class="flex flex-col items-center mb-10">
    <img
      src="/images/sharples-p-3400-decanter/Dolphin-Centrifuge-Sharples-P-3400-Decanter-Centrifuge-800.webp"
      alt="Sharples P3400 Oilfield Decanter Centrifuge"
      width="800"
      height="800"
      loading="lazy"
      class="rounded-lg border border-gray-200 bg-white object-contain img-cap-800"
    />
    <p class="text-gray-500 text-sm mt-2 text-center"><strong>Sharples P 3400 Oilfield Decanter Centrifuge</strong></p>
  </div>

  <!-- Applications -->
  <h2 id="applications">Applications</h2>

  <div class="overflow-x-auto mb-8">
    <table>
      <tbody>
        <tr>
          <td><a href="/hemp-extraction-centrifuge/">Hemp Solvent Extraction</a></td>
          <td>Hemp biomass &amp; ethanol separation (Explosion Proof)</td>
        </tr>
        <tr>
          <td><a href="/ethanol-extraction-centrifuges-technical-comparison/">Ethanol Extraction</a></td>
          <td>Ethanol extraction of THC or CBD Oil</td>
        </tr>
        <tr>
          <td><a href="/crude-oil-centrifuge/">Crude Oil Tank Bottom Sludge</a></td>
          <td>Tank bottom BS&amp;W separation</td>
        </tr>
        <tr>
          <td><a href="/wastewater-centrifuge/">Municipal Wastewater</a></td>
          <td>Sludge thickening</td>
        </tr>
        <tr>
          <td><a href="/liquid-humus-centrifuge/">Liquid Humus Fertilizer</a></td>
          <td>Humus biomass separation</td>
        </tr>
        <tr>
          <td><a href="/wastewater-centrifuge/">Fish Meal Separation</a></td>
          <td>Fish oil &amp; fish meal separation from stickwater</td>
        </tr>
        <tr>
          <td><a href="/centrifuge-pyrolysis-oil/">Pyrolysis Sludge Separation</a></td>
          <td>Bio-oil separation from bio-char sludge</td>
        </tr>
        <tr>
          <td><a href="/waste-oil-centrifuge/">Waste Oil De-sludging</a></td>
          <td>Industrial waste oil de-sludging</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Specifications -->
  <h2 id="specifications">Specifications</h2>

  <div class="overflow-x-auto mb-8">
    <table>
      <tbody>
        <tr>
          <td>Model Type</td>
          <td>Sharples P-3400</td>
        </tr>
        <tr>
          <td>Rated Capacity</td>
          <td>50 GPM on Ethanol Biomass Separation</td>
        </tr>
        <tr>
          <td>Auger Differential Speed</td>
          <td>1 ~ 42 RPM</td>
        </tr>
        <tr>
          <td>Drive Motor Power</td>
          <td>25 HP</td>
        </tr>
        <tr>
          <td>Gearbox Ratio</td>
          <td>1: 95</td>
        </tr>
        <tr>
          <td>A<sub>E</sub> (Area Equivalent)</td>
          <td>1,500</td>
        </tr>
        <tr>
          <td>Bowl Speed</td>
          <td>4000 RPM (3,150 Gs <a href="/centrifuge-rcf-rpm-difference-calculation/">RCF</a>)</td>
        </tr>
        <tr>
          <td>Conveyor Protection</td>
          <td>Carbide Tile or Tungsten Carbide Hard-Surfacing</td>
        </tr>
      </tbody>
    </table>
  </div>

</ApplicationLayout>
