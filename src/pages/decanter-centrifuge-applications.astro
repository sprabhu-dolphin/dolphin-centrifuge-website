          <div class="flex flex-wrap gap-4">
            <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-[#E8A317] hover:bg-amber-600 text-white font-semibold py-3 px-6 rounded-lg transition-colors">
              Discuss Your Application
            </a>
            <a href="tel:+12485222573" class="inline-block border-2 border-white hover:bg-white hover:text-[#1B3A5C] text-white font-semibold py-3 px-6 rounded-lg transition-colors">
              (248) 522-2573
            </a>
          </div>
        </div>
        <div>
          <img
            src="/images/decanter-centrifuge-applications/Alfa-Laval-ALDEC-406-Decanter-Dewatering-Centrifuge-for-Sludge-Thickening-600.jpg"
            alt="Alfa Laval ALDEC-406 Decanter Dewatering Centrifuge for Sludge Thickening"
            width="600"
            height="400"
            class="rounded-lg w-full shadow-lg"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="bg-[#F5F5F0]">
    <div class="container mx-auto px-4 py-12 md:py-16 max-w-4xl">

      <div class="bg-navy/5 border-l-4 border-[#E8A317] rounded-r-lg p-4 mb-6">
        <p class="text-sm text-[#555] leading-relaxed italic">Dolphin Centrifuge supplies Alfa Laval NX-314, NX-418, and G2-40 decanter centrifuges for over 40 industrial applications — from food processing and rendering to crude oil recovery, municipal wastewater, and hemp extraction. Decanters generate 2,000–4,000 Gs for high-solids applications requiring continuous cake discharge. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in decanter centrifuge applications.</p>
      </div>
      <!-- Table of Contents -->
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold font-['Plus_Jakarta_Sans'] text-[#2D2D2D] mb-4">Table of Contents</h2>
        <nav class="columns-1 md:columns-2 gap-8">
          <ul class="text-[#1B3A5C] space-y-2 font-['Source_Sans_3']">
            <li><a href="#overview" class="hover:text-[#E8A317] underline">Overview</a></li>
            <li><a href="#decanter-centrifuge-operation" class="hover:text-[#E8A317] underline">Decanter Centrifuge Operation</a></li>
            <li><a href="#applications" class="hover:text-[#E8A317] underline">Applications</a></li>
            <li><a href="#apple-sauce" class="hover:text-[#E8A317] underline">Apple Sauce</a></li>
            <li><a href="#beef-tallow-rendering" class="hover:text-[#E8A317] underline">Beef Tallow Rendering</a></li>
            <li><a href="#cbd-oil" class="hover:text-[#E8A317] underline">CBD Oil</a></li>
            <li><a href="#carbon-black" class="hover:text-[#E8A317] underline">Carbon Black</a></li>
            <li><a href="#chemical-precipitate" class="hover:text-[#E8A317] underline">Chemical Precipitate</a></li>
            <li><a href="#distilled-liquors" class="hover:text-[#E8A317] underline">Distilled Liquors</a></li>
