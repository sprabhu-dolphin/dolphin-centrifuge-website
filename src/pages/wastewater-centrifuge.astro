---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      "name": "Wastewater Centrifuge Systems",
      "url": "https://dolphincentrifuge.com/wastewater-centrifuge/",
      "description": "Industrial wastewater centrifuges for sludge dewatering, thickening, oily water separation, and mining effluent clarification. Decanter and disc-stack centrifuge options with full specifications and real application examples.",
      "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
      "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
      "category": "Industrial Centrifuges",
      "image": "https://dolphincentrifuge.com/images/wastewater-centrifuge/Alfa-Laval-NX-418-Decanter-for-Wastewater-Sludge-Thickening.jpg",
      "offers": {
        "@type": "Offer",
        "availability": "https://schema.org/InStock",
        "priceCurrency": "USD",
        "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
      },
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a wastewater centrifuge and how does it work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A wastewater centrifuge is a separation machine that utilizes centrifugal force of up to 3,100 Gs to separate sludge and contaminants from wastewater. The wastewater enters a rapidly rotating bowl. Heavy sludge particles are pushed to the bowl wall by centrifugal force, and an internal scroll auger continuously conveys the accumulated sludge toward the discharge ports. Clarified water exits from the opposite end of the bowl in a continuous process."
          }
        },
        {
          "@type": "Question",
          "name": "What types of wastewater centrifuges are available?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Three main types of wastewater centrifuges are available: (1) Sludge dewatering/thickening decanters for high-sludge wastewater from municipal sewage, livestock farms, car washes, and oilfield drilling; (2) Clarifier disc-stack centrifuges for mining effluent with fine silt and clay particles; and (3) Three-phase separators for industrial oily wastewater that contains both sludge and oil."
          }
        },
        {
          "@type": "Question",
          "name": "What capacity can a wastewater centrifuge handle?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Wastewater centrifuge capacity depends on the model and sludge content. Decanter centrifuges range from 3 GPM up to 170 GPM on clean water, with reduced throughput at higher sludge loads (e.g., 60-100 GPM at 5% sludge, 25-60 GPM at 10% sludge). Disc-stack clarifier centrifuges handle up to 100 GPM rated capacity, with 12-80 GPM at 5% sludge content."
          }
        },
        {
          "@type": "Question",
          "name": "What are the benefits of using a centrifuge for wastewater treatment?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Key benefits include: reduced transportation and disposal costs (up to 50% savings from dry sludge cake), equipment durability and longevity (decades of service with stainless steel construction), low operating expenses (no filter media costs, only bearing maintenance), fully automatic operation with minimal operator requirements, and compact size relative to processing capacity compared to belt presses and filter presses."
          }
        },
        {
          "@type": "Question",
          "name": "Can a wastewater centrifuge separate oil from water?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. A three-phase disc-stack centrifuge can separate oil, water, and sludge simultaneously. For industrial oily wastewater containing both sludge and oil, a two-step system is often used: a decanter centrifuge first removes bulk sludge, followed by a self-cleaning three-phase disc-stack centrifuge to polish the water and remove oil. This makes the water safe for disposal or discharge."
          }
        }
      ]
    }
  ]
};
