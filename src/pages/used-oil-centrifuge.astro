  <!-- ── Definition of Used Oil ── -->
  <h2 id="definition-of-used-oil">Definition of Used Oil</h2>

  <figure>
    <img
      src="/images/used-oil-centrifuge/DMPX-014-Disc-Centrifuge-for-Used-Oil-De-Watering-600.webp"
