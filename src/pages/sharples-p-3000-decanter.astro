---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const articleJsonLd = {
  "@type": "Article",
  "headline": "Sharples P-3000 Decanter | Applications & Specifications",
  "description": "Sharples P-3000 decanter centrifuge is a small capacity decanter that finds multiple uses for sludge thickening, biomass extraction & wastewater treatment",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  }
};

const jsonLd = [articleJsonLd];

const toc = [
  { id: 'applications', label: 'Applications' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'units-for-sale', label: 'Sharples P 3000 Photo Gallery' },
];

const relatedApplications = [
  { label: 'Decanter Centrifuge', href: '/decanter-centrifuge/' },
  { label: 'Wastewater Centrifuge', href: '/wastewater-centrifuge/' },
  { label: 'Waste Oil Centrifuge', href: '/waste-oil-centrifuge/' },
  { label: 'Liquid Humus Centrifuge', href: '/liquid-humus-centrifuge/' },
  { label: 'Hemp Extraction Centrifuge', href: '/hemp-extraction-centrifuge/' },
];
---

<ApplicationLayout
  title="Sharples P-3000 Decanter | Applications & Specifications"
  disableTitleSuffix={true}
  description="Sharples P-3000 decanter centrifuge is a small capacity decanter that finds multiple uses for sludge thickening, biomass extraction & wastewater treatment"
  heroImage="/images/sharples-p-3000-decanter/sharples-P3000-decanter-hero-2000.webp"
  heroImageAlt="Sharples P-3000 Decanter Centrifuge"
  category="products"
  categoryLabel="Products"
  canonicalUrl="https://dolphincentrifuge.com/sharples-p-3000-decanter/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
>

  <!-- Intro paragraphs (verbatim legacy) -->
  <div class="prose prose-lg max-w-none mb-8">
    <p>The Sharples P-3000 <a href="/decanter-centrifuge/">decanter centrifuge</a> is a horizontal de-sludging centrifuge built for the two-phase separation of liquid from voluminous sludge. With a 14" bowl rotating at 4,000 RPM, the P-3000 exerts 3,150 G-force for efficient solid-liquid separation.</p>
    <p>With a 15 HP Motor, the P 3000 decanter can process 25 GPM on wastewater sludge thickening.</p>
  </div>

  <!-- Applications -->
  <h2 id="applications">Applications</h2>

  <div class="overflow-x-auto mb-8">
    <table>
      <tbody>
        <tr>
          <td><a href="/hemp-extraction-centrifuge/">Hemp Solvent Extraction</a></td>
          <td>Hemp biomass &amp; ethanol separation (Explosion Proof)</td>
        </tr>
        <tr>
          <td><a href="/ethanol-extraction-centrifuges-technical-comparison/">Ethanol Extraction of THC</a></td>
          <td>Ethanol extraction of cannabidiol</td>
        </tr>
        <tr>
          <td><a href="/crude-oil-centrifuge/">Crude Oil Tank Bottom Sludge</a></td>
          <td>Tank bottom BS&amp;W separation</td>
        </tr>
        <tr>
          <td><a href="/wastewater-centrifuge/">Municipal Wastewater</a></td>
          <td>Sludge thickening</td>
        </tr>
        <tr>
          <td><a href="/liquid-humus-centrifuge/">Liquid Humus Fertilizer</a></td>
          <td>Humus biomass separation</td>
        </tr>
        <tr>
          <td><a href="/wastewater-centrifuge/">Fish Meal Separation</a></td>
          <td>Fish oil &amp; fish meal separation from stickwater</td>
        </tr>
        <tr>
          <td><a href="/centrifuge-pyrolysis-oil/">Pyrolysis Sludge Separation</a></td>
          <td>Bio-oil separation from bio-char sludge</td>
        </tr>
        <tr>
          <td><a href="/waste-oil-centrifuge/">Waste Oil De-sludging</a></td>
          <td>Industrial waste oil de-sludging</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Specifications -->
  <h2 id="specifications">Specifications</h2>

  <div class="overflow-x-auto mb-8">
    <table>
      <tbody>
        <tr>
          <td>Model Type</td>
          <td>Sharples P-3000</td>
        </tr>
        <tr>
          <td>Rated Capacity</td>
          <td>25 GPM on Municipal Sludge Thickening</td>
        </tr>
        <tr>
          <td>Auger Differential Speed</td>
          <td>1 ~ 40 RPM</td>
        </tr>
        <tr>
          <td>Drive Motor Power</td>
          <td>15 HP</td>
        </tr>
        <tr>
          <td>Gearbox Ratio</td>
          <td>1: 125</td>
        </tr>
        <tr>
          <td>A<sub>E</sub> (Area Equivalent)</td>
          <td>850</td>
        </tr>
        <tr>
          <td>Bowl Speed</td>
          <td>4000 RPM (3,150 Gs <a href="/centrifuge-rcf-rpm-difference-calculation/">RCF</a>)</td>
        </tr>
        <tr>
          <td>Conveyor Protection</td>
          <td>Carbide Tile or Tungsten Carbide Hard-Surfacing</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Units for Sale -->
  <h2 id="units-for-sale">Sharples P 3000 Photo Gallery</h2>

  <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">

    <div class="flex flex-col items-center">
      <a href="/images/sharples-p-3000-decanter/sharples-p-3000-decanter-400.webp" target="_blank" rel="noopener">
        <img
          src="/images/sharples-p-3000-decanter/sharples-p-3000-decanter-400.webp"
          alt="Sharples P-3000 Decanter Centrifuge"
          width="400"
          height="400"
          loading="lazy"
          class="rounded-lg border border-gray-200 bg-white object-contain"
          style="max-width:400px"
        />
      </a>
      <p class="text-gray-500 text-sm mt-2 text-center"><strong>Sharples P3000 Organic Wastewater Decanter</strong></p>
    </div>

    <div class="flex flex-col items-center">
      <a href="/images/sharples-p-3000-decanter/sharples-P3000-module-400.webp" target="_blank" rel="noopener">
        <img
          src="/images/sharples-p-3000-decanter/sharples-P3000-module-400.webp"
          alt="Sharples P 3000 Module"
          width="400"
          height="400"
          loading="lazy"
          class="rounded-lg border border-gray-200 bg-white object-contain"
          style="max-width:400px"
        />
      </a>
      <p class="text-gray-500 text-sm mt-2 text-center"><strong>Sharples P 3000 Module</strong></p>
    </div>

  </div>

</ApplicationLayout>
