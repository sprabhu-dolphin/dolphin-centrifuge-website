---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Can Dolphin Centrifuge still get parts for the Sharples P-3000?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Dolphin Centrifuge maintains parts inventory for the Sharples P-3000, including scroll assemblies, bearings, seals, and wear components. As the P-3000 is now part of the Alfa Laval portfolio, parts are sourced through both OEM and aftermarket channels." }
    },
    {
      "@type": "Question",
      "name": "How long does a Sharples P-3000 rebuild take?",
      "acceptedAnswer": { "@type": "Answer", "text": "A complete P-3000 mechanical rebuild typically takes 2–4 weeks depending on the scope of work — bowl inspection, scroll reconditioning, bearing replacement, gearbox overhaul, and seal replacement. Dolphin Centrifuge provides a detailed timeline after initial inspection." }
    },
    {
      "@type": "Question",
      "name": "Should I rebuild my P-3000 or upgrade to a newer decanter?",
      "acceptedAnswer": { "@type": "Answer", "text": "It depends on the unit's condition, age, and available budget. A rebuild extends service life at a fraction of replacement cost when the bowl and main structure are sound. If the bowl is cracked or corrosion is extensive, upgrading to a current-generation Alfa Laval decanter may be more cost-effective. Dolphin Centrifuge can provide a comparative analysis." }
    }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Sharples P-3000 Decanter Centrifuge",
  "description": "Sharples P-3000 decanter centrifuge — applications, specifications and rebuild services from Dolphin Centrifuge.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/sharples-p-3000-decanter/",
};
---

<BaseLayout
  title="Sharples P-3000 Decanter Centrifuge"
  description="Sharples P-3000 decanter centrifuge — parts, mechanical rebuilds, and complete repair. Wastewater sludge dewatering and chemical separation. Dolphin Centrifuge."
  canonicalUrl="https://dolphincentrifuge.com/sharples-p-3000-decanter/"
  breadcrumbs={[{label: 'Products', href: '/decanter-centrifuge/'}, {label: 'Sharples P-3000'}]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">Products</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">Sharples P-3000 Decanter Centrifuge</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">A proven industrial decanter centrifuge for wastewater, chemical, and industrial sludge processing. Dolphin Centrifuge stocks parts, performs rebuilds, and provides full repair services for the Sharples P-3000 — now part of the Alfa Laval portfolio.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Request a Quote</a>
        <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
      </div>
    </div>
  </section>

  <!-- Specs & Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-4xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge provides parts, mechanical rebuilds, and complete repair services for the Sharples P-3000 horizontal decanter centrifuge — now part of the Alfa Laval portfolio. The P-3000 is a two-phase liquid-solid decanter rated for wastewater sludge dewatering, chemical processing, and industrial separation. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of decanter centrifuge rebuild experience.</p>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">About the Sharples P-3000</h2>
      <p class="text-text-light mb-4">
        The Sharples P-3000 is a classic industrial horizontal <a href="/decanter-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">decanter centrifuge</a> that established itself as a workhorse in wastewater treatment, chemical processing, and industrial separation applications over many decades. The Sharples brand was acquired by Alfa Laval, and the P-3000 is now maintained and supported within the Alfa Laval service network — though many plants continue to operate original Sharples-branded units.
      </p>
      <p class="text-text-light mb-8">
        Dolphin Centrifuge has extensive experience with the P-3000 platform. We maintain a parts inventory for this model, perform complete mechanical rebuilds, and provide repair and refurbishment services to extend the service life of P-3000 units currently in operation. Whether you need a replacement scroll assembly, bowl inspection, bearing replacement, or a complete rebuild, our team can support your P-3000.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">P-3000 Specifications</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <tbody>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Centrifuge Model</td>
              <td class="px-4 py-3 font-mono text-text-light">Sharples P-3000</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Centrifuge Type</td>
              <td class="px-4 py-3 font-mono text-text-light">Horizontal Decanter, Two-Phase</td>
            </tr>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Separation Configuration</td>
              <td class="px-4 py-3 font-mono text-text-light">Liquid-Solid (Two-Phase)</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Current Brand Ownership</td>
              <td class="px-4 py-3 font-mono text-text-light">Alfa Laval (acquired)</td>
            </tr>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Service Support</td>
              <td class="px-4 py-3 font-mono text-text-light">Parts, Rebuild &amp; Repair — Dolphin Centrifuge</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Typical Applications</td>
              <td class="px-4 py-3 font-mono text-text-light">Wastewater, Chemical, Industrial Sludge</td>
            </tr>
            <tr class="bg-white">
              <td class="px-4 py-3 font-semibold text-navy">Voltages</td>
              <td class="px-4 py-3 font-mono text-text-light">230 / 460 V; 3-Phase</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Applications</h2>
      <p class="text-text-light mb-4">The P-3000 covers a broad range of <a href="/decanter-centrifuge-applications/" class="text-navy font-semibold hover:text-gold transition-colors">decanter centrifuge applications</a>:</p>
      <div class="grid md:grid-cols-2 gap-x-8 gap-y-2 mb-8">
        <ul class="text-text-light space-y-2">
          <li>&#8226; <a href="/wastewater-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Municipal wastewater sludge dewatering</a></li>
          <li>&#8226; Industrial effluent treatment</li>
          <li>&#8226; Chemical process sludge separation</li>
          <li>&#8226; Biological sludge thickening</li>
        </ul>
        <ul class="text-text-light space-y-2">
          <li>&#8226; Food processing waste dewatering</li>
          <li>&#8226; Mining and mineral slurry separation</li>
          <li>&#8226; Paper mill sludge dewatering</li>
          <li>&#8226; Rendering and by-product processing</li>
        </ul>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Dolphin Centrifuge P-3000 Rebuild Service</h2>
      <p class="text-text-light mb-4">
        Many P-3000 units remain in service across North American wastewater and industrial plants. Dolphin Centrifuge provides comprehensive mechanical support to keep these machines operating at peak performance:
      </p>
      <ul class="text-text-light space-y-2 mb-8">
        <li>&#8226; Complete bowl and scroll assembly inspection and reconditioning</li>
        <li>&#8226; Bearing replacement and alignment</li>
        <li>&#8226; Scroll wear surface hard-facing and replacement</li>
        <li>&#8226; Gearbox inspection and rebuild</li>
        <li>&#8226; Seal replacement and liquid end reconditioning</li>
        <li>&#8226; <a href="/industrial-disc-centrifuge-repair/" class="text-navy font-semibold hover:text-gold transition-colors">Full centrifuge repair and refurbishment services</a></li>
      </ul>

      <p class="text-text-light mb-8">
        For applications requiring higher throughput, see the <a href="/sharples-p-3400-decanter/" class="text-navy font-semibold hover:text-gold transition-colors">Sharples P-3400</a> — the larger capacity model in the Sharples decanter series. For a complete overview of decanter technology, visit our <a href="/decanter-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">decanter centrifuge guide</a>. If you need a temporary unit while your P-3000 is being rebuilt, ask about our <a href="/decanter-centrifuge-rental/" class="text-navy font-semibold hover:text-gold transition-colors">decanter centrifuge rental</a> program.
      </p>

      <!-- FAQ -->
      <div id="faq" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mt-10 mb-6">
        <h2 class="text-xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">Can Dolphin Centrifuge still get parts for the Sharples P-3000?</h3>
            <p class="text-text-light text-sm">Yes. Dolphin Centrifuge maintains parts inventory for the Sharples P-3000, including scroll assemblies, bearings, seals, and wear components. As the P-3000 is now part of the Alfa Laval portfolio, parts are sourced through both OEM and aftermarket channels.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">How long does a Sharples P-3000 rebuild take?</h3>
            <p class="text-text-light text-sm">A complete P-3000 mechanical rebuild typically takes 2–4 weeks depending on scope — bowl inspection, scroll reconditioning, bearing replacement, gearbox overhaul, and seal replacement. Dolphin Centrifuge provides a detailed timeline after initial inspection.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">Should I rebuild my P-3000 or upgrade to a newer decanter?</h3>
            <p class="text-text-light text-sm">It depends on the unit's condition, age, and budget. A rebuild extends service life at a fraction of replacement cost when the bowl and main structure are sound. If the bowl is cracked or corrosion is extensive, upgrading to a current-generation Alfa Laval decanter may be more cost-effective. Dolphin Centrifuge can provide a comparative analysis.</p>
          </div>
        </div>
      </div>
      <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

      <!-- Bottom CTA -->
      <div class="bg-navy rounded-xl p-8 text-center mt-12">
        <h2 class="text-2xl font-bold text-white mb-3">P-3000 Parts, Rebuild or Replacement?</h2>
        <p class="text-gray-300 mb-6 max-w-lg mx-auto">Contact our team for parts availability, rebuild quotes, and upgrade path recommendations.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Quote</a>
          <a href="tel:2485222573" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">(248) 522-2573</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
