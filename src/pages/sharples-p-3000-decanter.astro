---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqItems = [
  {
    question: "Can Dolphin Centrifuge still get parts for the Sharples P-3000?",
    answer: "Yes. Dolphin Centrifuge maintains parts inventory for the Sharples P-3000, including scroll assemblies, bearings, seals, and wear components. As the P-3000 is now part of the Alfa Laval portfolio, parts are sourced through both OEM and aftermarket channels."
  },
  {
    question: "How long does a Sharples P-3000 rebuild take?",
    answer: "A complete P-3000 mechanical rebuild typically takes 2–4 weeks depending on the scope of work — bowl inspection, scroll reconditioning, bearing replacement, gearbox overhaul, and seal replacement. Dolphin Centrifuge provides a detailed timeline after initial inspection."
  },
  {
    question: "Should I rebuild my P-3000 or upgrade to a newer decanter?",
    answer: "It depends on the unit's condition, age, and available budget. A rebuild extends service life at a fraction of replacement cost when the bowl and main structure are sound. If the bowl is cracked or corrosion is extensive, upgrading to a current-generation Alfa Laval decanter may be more cost-effective. Dolphin Centrifuge can provide a comparative analysis."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Sharples P-3000 Decanter Centrifuge",
  "description": "Sharples P-3000 decanter centrifuge — applications, specifications and rebuild services from Dolphin Centrifuge.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "telephone": "(248) 522-2573",
    "email": "sales@dolphincentrifuge.com",
    "url": "https://dolphincentrifuge.com"
  },
  "model": "P-3000",
  "url": "https://dolphincentrifuge.com/sharples-p-3000-decanter/",
  "offers": {
    "@type": "Offer",
    "seller": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const jsonLd = [productJsonLd, faqJsonLd];

const toc = [
  { id: 'about', label: 'About the Sharples P-3000' },
  { id: 'specifications', label: 'P-3000 Specifications' },
  { id: 'applications', label: 'Applications' },
  { id: 'rebuild-service', label: 'Rebuild Service' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedApplications = [
  { label: 'Decanter Centrifuge Applications', href: '/decanter-centrifuge-applications/' },
  { label: 'Wastewater Centrifuge', href: '/wastewater-centrifuge/' },
  { label: 'Dewatering Centrifuge', href: '/dewatering-centrifuge/' },
];

const relatedProducts = [
  { label: 'Sharples P-3400 Decanter', href: '/sharples-p-3400-decanter/', description: 'Higher-capacity Sharples decanter' },
  { label: 'Alfa Laval NX-314 Decanter', href: '/alfa-laval-nx-314-decanter-centrifuge/', description: '314 mm compact decanter' },
  { label: 'Decanter Centrifuge Rental', href: '/decanter-centrifuge-rental/', description: 'Temporary units during rebuild' },
];
---

<ApplicationLayout
  title="Sharples P-3000 Decanter Centrifuge | Dolphin Centrifuge"
  description="Sharples P-3000 decanter centrifuge — parts, rebuilds, and repair for wastewater sludge dewatering and industrial separation. Dolphin Centrifuge, Warren MI."
  heroImage="/images/sharples-p-3000-decanter/sharples-p3000-wastewater-decanter.webp"
  heroImageAlt="sharples-p3000-wastewater-decanter"
  category="products"
  categoryLabel="Products"
  canonicalUrl="https://dolphincentrifuge.com/sharples-p-3000-decanter/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <!-- AI Summary — 30-50 words -->
  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">The Sharples P-3000 is a 14-inch bowl, two-phase horizontal decanter centrifuge generating 3,150 Gs at 4,000 RPM for wastewater sludge dewatering and industrial separation. Dolphin Centrifuge provides parts, rebuilds, and repair from Warren, Michigan.</p>
  </div>

  <!-- About -->
  <h2 id="about">About the Sharples P-3000</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <p>
        The Sharples P-3000 is a classic industrial horizontal <a href="/decanter-centrifuge/">decanter centrifuge</a> that established itself as a workhorse in wastewater treatment, chemical processing, and industrial separation applications over many decades. The Sharples brand was acquired by Alfa Laval, and the P-3000 is now maintained and supported within the Alfa Laval service network — though many plants continue to operate original Sharples-branded units.
      </p>
      <p>
        Dolphin Centrifuge has extensive experience with the P-3000 platform. We maintain a parts inventory for this model, perform complete mechanical rebuilds, and provide repair and refurbishment services to extend the service life of P-3000 units currently in operation. Whether you need a replacement scroll assembly, bowl inspection, bearing replacement, or a complete rebuild, our team can support your P-3000.
      </p>
    </div>
    <img
      src="/images/sharples-p-3000-decanter/sharples-decanter-p3000-rotating-assembly.webp"
      alt="sharples-decanter-p3000-rotating-assembly"
      width="300"
      height="200"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
  </div>

  <!-- Specifications -->
  <h2 id="specifications">P-3000 Specifications</h2>

  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
      <tbody>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Centrifuge Model</td>
          <td class="px-4 py-3 font-mono text-text-light">Sharples P-3000</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Centrifuge Type</td>
          <td class="px-4 py-3 font-mono text-text-light">Horizontal Decanter, Two-Phase</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Separation Configuration</td>
          <td class="px-4 py-3 font-mono text-text-light">Liquid-Solid (Two-Phase)</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Current Brand Ownership</td>
          <td class="px-4 py-3 font-mono text-text-light">Alfa Laval (acquired)</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Rated Capacity</td>
          <td class="px-4 py-3 font-mono text-text-light">25 GPM on Municipal Sludge Thickening</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Bowl Speed</td>
          <td class="px-4 py-3 font-mono text-text-light">4,000 RPM (3,150 Gs RCF)</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Drive Motor</td>
          <td class="px-4 py-3 font-mono text-text-light">15 HP</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Auger Differential Speed</td>
          <td class="px-4 py-3 font-mono text-text-light">1&ndash;40 RPM</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Gearbox Ratio</td>
          <td class="px-4 py-3 font-mono text-text-light">1:125</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Area Equivalent (AE)</td>
          <td class="px-4 py-3 font-mono text-text-light">850</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Conveyor Protection</td>
          <td class="px-4 py-3 font-mono text-text-light">Carbide Tile or Tungsten Carbide Hard-Surfacing</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Service Support</td>
          <td class="px-4 py-3 font-mono text-text-light">Parts, Rebuild &amp; Repair — Dolphin Centrifuge</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Typical Applications</td>
          <td class="px-4 py-3 font-mono text-text-light">Wastewater, Chemical, Industrial Sludge</td>
        </tr>
        <tr class="bg-gray-50">
          <td class="px-4 py-3 font-semibold text-navy">Voltages</td>
          <td class="px-4 py-3 font-mono text-text-light">230 / 460 V; 3-Phase</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Applications -->
  <h2 id="applications">Applications</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <p>The P-3000 covers a broad range of <a href="/decanter-centrifuge-applications/">decanter centrifuge applications</a>:</p>
      <div class="grid md:grid-cols-2 gap-x-8 gap-y-2">
        <ul class="space-y-2">
          <li><a href="/wastewater-centrifuge/">Municipal wastewater sludge dewatering</a></li>
          <li>Industrial effluent treatment</li>
          <li>Chemical process sludge separation</li>
          <li>Biological sludge thickening</li>
        </ul>
        <ul class="space-y-2">
          <li>Food processing waste dewatering</li>
          <li>Mining and mineral slurry separation</li>
          <li>Paper mill sludge dewatering</li>
          <li>Rendering and by-product processing</li>
        </ul>
      </div>
    </div>
    <img
      src="/images/sharples-p-3000-decanter/sharples-p3000-waste-oil-decanter.webp"
      alt="sharples-p3000-waste-oil-decanter"
      width="300"
      height="200"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
  </div>

  <!-- Rebuild Service -->
  <h2 id="rebuild-service">Dolphin Centrifuge P-3000 Rebuild Service</h2>

  <p>
    Many P-3000 units remain in service across North American wastewater and industrial plants. Dolphin Centrifuge provides comprehensive mechanical support to keep these machines operating at peak performance:
  </p>
  <ul>
    <li>Complete bowl and scroll assembly inspection and reconditioning</li>
    <li>Bearing replacement and alignment</li>
    <li>Scroll wear surface hard-facing and replacement</li>
    <li>Gearbox inspection and rebuild</li>
    <li>Seal replacement and liquid end reconditioning</li>
    <li><a href="/industrial-disc-centrifuge-repair/">Full centrifuge repair and refurbishment services</a></li>
  </ul>

  <p>
    For applications requiring higher throughput, see the <a href="/sharples-p-3400-decanter/">Sharples P-3400</a> — the larger capacity model in the Sharples decanter series. For a complete overview of decanter technology, visit our <a href="/decanter-centrifuge/">decanter centrifuge guide</a>. If you need a temporary unit while your P-3000 is being rebuilt, ask about our <a href="/decanter-centrifuge-rental/">decanter centrifuge rental</a> program.
  </p>

  <!-- FAQ Section -->
  <h2 id="faq">Frequently Asked Questions</h2>

  <div class="space-y-4 not-prose">
    {faqItems.map(item => (
      <details class="bg-gray-50 rounded-xl border border-gray-200 p-5">
        <summary class="font-semibold text-navy cursor-pointer">{item.question}</summary>
        <p class="text-text-light mt-3 text-sm">{item.answer}</p>
      </details>
    ))}
  </div>

</ApplicationLayout>
