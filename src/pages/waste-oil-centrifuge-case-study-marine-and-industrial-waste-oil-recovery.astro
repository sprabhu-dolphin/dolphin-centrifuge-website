---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much oil can a disc stack centrifuge recover from waste oil?",
      "acceptedAnswer": { "@type": "Answer", "text": "A properly sized disc stack centrifuge can recover 95–99% of usable oil from waste oil streams. In the Guam case study, the DMPX-028 disc stack centrifuge achieved 20% higher oil recovery versus the previous heating-and-settling method, adding $380,000 per year in recoverable oil value." }
    },
    {
      "@type": "Question",
      "name": "What types of waste oil can a disc stack centrifuge process?",
      "acceptedAnswer": { "@type": "Answer", "text": "Disc stack centrifuges process marine waste oil (bilge oil, slop oil, fuel sludge), industrial lubricating oil, transformer oil, cutting oil, and coolant oil. The centrifuge removes water, fine solids, and contaminants without the long residence time and heat losses associated with gravity separation." }
    },
    {
      "@type": "Question",
      "name": "What is the ROI for a waste oil centrifuge system?",
      "acceptedAnswer": { "@type": "Answer", "text": "ROI depends on waste oil volume and recovered oil value. The Guam facility with 4.8 million gallons per year capacity recovered $380,000 per year in additional oil value using a DMPX-028 centrifuge. Payback periods for disc stack waste oil recovery systems typically range from 12–36 months depending on throughput and oil pricing." }
    },
    {
      "@type": "Question",
      "name": "What is a rag layer and how does a centrifuge remove it?",
      "acceptedAnswer": { "@type": "Answer", "text": "A rag layer (also called an emulsion layer) is a stable emulsion of oil and water that resists gravity separation. It forms when fine solids and surfactants stabilize the oil-water interface. A disc stack centrifuge generating 9,000+ Gs breaks through these emulsions by applying far greater force than gravity — separating the emulsion into clean oil and water phases, recovering up to 20% more usable oil compared to settling methods." }
    },
    {
      "@type": "Question",
      "name": "Can I test my waste oil before committing to a centrifuge system?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Dolphin Centrifuge offers a free pilot testing program. Send us a sample of your waste oil and our engineering team will process it through our lab centrifuge, providing a detailed report including separation efficiency, water and sediment reduction, and centrifuge sizing recommendations. This eliminates guesswork and confirms ROI projections before capital commitment." }
    }
  ]
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Waste Oil Centrifuge Case Study: Marine & Industrial Recovery",
    "description": "Case study: waste oil recovery using a DMPX-028 disc stack centrifuge in Guam. 4.8M gallons/year capacity, 20% higher oil recovery, $380K annual savings vs. heating and settling.",
    "author": {
      "@type": "Person",
      "name": "Sanjay Prabhu MSME",
      "jobTitle": "Centrifuge Applications Engineer",
      "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" }
    },
    "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
    "url": "https://dolphincentrifuge.com/waste-oil-centrifuge-case-study-marine-and-industrial-waste-oil-recovery/",
    "datePublished": "2023-01-01",
    "dateModified": "2024-01-01",
  },
  faqJsonLd,
];

const toc = [
  { id: "introduction", label: "Introduction to Waste Oil Recovery" },
  { id: "challenges", label: "Challenges with Traditional Methods" },
  { id: "solution", label: "DMPX-028 Centrifuge Solution" },
  { id: "how-it-works", label: "How the Waste Oil Purifier Works" },
  { id: "benefits", label: "Benefits of Oil Centrifuge Recovery" },
  { id: "results", label: "Results & Lab Data" },
  { id: "cost-benefit", label: "Cost-Benefit Analysis" },
  { id: "environmental", label: "Environmental Advantages" },
  { id: "conclusion", label: "Conclusion" },
  { id: "faq", label: "Frequently Asked Questions" },
];

const relatedProducts = [
  { label: "DMPX-028 Disc Stack Centrifuge", href: "/centrifuges/dmpx-028/", description: "20 GPM waste oil, self-cleaning, 8,000 RPM" },
  { label: "Waste Oil Centrifuge Systems", href: "/waste-oil-centrifuge/", description: "Marine & industrial waste oil recovery" },
  { label: "Used Oil Processing Plant", href: "/used-oil-centrifuge-plant/", description: "6 MGY turnkey plant case study" },
];

const relatedApplications = [
  { label: "Disc Stack Centrifuge Applications", href: "/disc-stack-centrifuge-applications/" },
  { label: "Remove Metals & Ash from Used Oil", href: "/disc-stack-centrifuge-remove-metals-ash-used-oil/" },
  { label: "Industrial Centrifuge Sample Testing", href: "/industrial-centrifuge-sample-testing/" },
