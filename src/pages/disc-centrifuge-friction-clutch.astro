  },
  "datePublished": "2021-06-01",
  "dateModified": "2024-06-01"
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a disc centrifuge friction clutch and what does it do?",
      "acceptedAnswer": { "@type": "Answer", "text": "A friction clutch is the drive coupling between the motor and bowl spindle in a disc centrifuge. It allows the motor to start under low load, then gradually transfers torque to accelerate the heavy bowl — preventing motor stall and reducing mechanical shock on startup. Without the clutch, the motor would be required to start under the full inertia of the bowl assembly." }
    },
    {
      "@type": "Question",
      "name": "How long does a disc centrifuge friction clutch last?",
      "acceptedAnswer": { "@type": "Answer", "text": "Under normal operating conditions, a friction clutch typically lasts 1–3 years. Premature wear is caused by excessive startup frequency, incorrect spring tension adjustment, oil or grease contamination of the friction shoes, or misalignment between the motor shaft and bowl spindle." }
