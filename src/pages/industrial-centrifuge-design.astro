---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';


const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Centrifuge System Design & Engineering",
  "description": "Custom industrial centrifuge system design and engineering. Turnkey systems with PLC controls, pumps, piping, and heating. 40+ years of expertise.",
  "provider": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "address": { "@type": "PostalAddress", "streetAddress": "24248 Gibson Dr.", "addressLocality": "Warren", "addressRegion": "MI", "postalCode": "48089", "addressCountry": "US" },
  },
  "areaServed": { "@type": "Country", "name": "United States" },
