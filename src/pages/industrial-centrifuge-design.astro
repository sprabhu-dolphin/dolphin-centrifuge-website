      },
      "description": "Master of Science in Mechanical Engineering, University of Arkansas, Fayetteville, Class of 1990"
    }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/industrial-centrifuge-design/",
  "mainEntityOfPage": "https://dolphincentrifuge.com/industrial-centrifuge-design/"
};

const jsonLd = [serviceJsonLd, articleJsonLd];

const toc = [
  { id: 'legacy-overview', label: 'Design & Engineering Overview' },
  { id: 'more-than-centrifuge', label: 'More Than Just a Centrifuge' },
  { id: 'turnkey', label: 'Turnkey System Design' },
  { id: 'controls', label: 'PLC & HMI Control Systems' },
  { id: 'testing-commissioning', label: 'Testing & Commissioning' },
  { id: 'containerized', label: 'Containerized Systems' },
  { id: 'deliverables', label: 'Engineering Deliverables' },
  { id: 'design-process', label: 'Our Design Process' },
  { id: 'industries', label: 'Industries We Serve' },
];

const relatedApplications = [
  { label: 'Oil Centrifuge', href: '/oil-centrifuge/' },
  { label: 'Wastewater Centrifuge', href: '/wastewater-centrifuge/' },
  { label: 'Food Grade Centrifuge', href: '/food-grade-centrifuge/' },
  { label: 'Centrifuge Controls', href: '/industrial-centrifuge-controls/' },
];

const relatedProducts = [
  { label: 'Disc Stack Centrifuge', href: '/disc-stack-centrifuge/', description: 'All DMPX & DMB models' },
  { label: 'Decanter Centrifuge', href: '/decanter-centrifuge/', description: 'NX, CHNX, G2 decanters' },
  { label: 'Centrifuge Sample Testing', href: '/industrial-centrifuge-sample-testing/', description: 'Lab testing before purchase' },
];
---

<ApplicationLayout
  title="Centrifuge Design & Engineering | Dolphin Centrifuge"
  description="Custom centrifuge system design by Dolphin Centrifuge. Turnkey skid-mounted systems with PLC controls, pumps, heaters, and piping. 40+ years experience."
  category="services"
  categoryLabel="Services"
  heroImage="/images/industrial-centrifuge-design/industrial-centrifuge-design-hero-2000.webp"
  heroImageAlt="Dolphin Centrifuge engineers reviewing system engineering drawings with a disc stack centrifuge and control panels in the background"
  ogImage="/images/industrial-centrifuge-design/industrial-centrifuge-design-hero-2000.webp"
  canonicalUrl="https://dolphincentrifuge.com/industrial-centrifuge-design/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
  hideBottomCTA={true}
>

  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge designs and builds custom turnkey industrial centrifuge systems. Each system integrates a disc stack or decanter centrifuge with feed pumps, heaters, PLC/HMI controls, instrumentation, and piping on a welded steel skid. We handle everything from initial process engineering and 3D CAD layout through fabrication, factory acceptance testing, and on-site commissioning. Based in Warren, Michigan, with over 40 years of centrifuge engineering expertise.</p>
  </div>

  <h2 id="legacy-overview">Centrifuge System Design &amp; Engineering</h2>
  <p>
    Dolphin Centrifuge is an engineering company specializing in custom <a href="/alfa-laval-industrial-centrifuges/">Alfa Laval industrial centrifuge</a> system design and manufacture. We do not simply sell centrifuges. We engineer complete separation systems, each designed to a customer's specific process requirements and built to industrial standards.
  </p>
  <p>
    Our engineering team develops full CAD layouts, P&amp;IDs, electrical schematics, and PLC/HMI control logic for every system. We select and size every component (pumps, heat exchangers, valves, sensors) to match the application, then fabricate, wire, pipe, and test the complete system at our Warren, Michigan facility before it ships.
  </p>

  <h3>The Centrifuge Design Process</h3>

  <figure class="not-prose mb-6">
    <img
      src="/images/industrial-centrifuge-design/Alfa-Laval-NX-314-Decanter-Module-3D-Cad-Model.webp"
      alt="Alfa Laval NX-314 Decanter Module - 3D CAD Model"
      width="600"
      height="507"
      loading="lazy"
      class="rounded-lg shadow-md img-cap-400"
    />
    <figcaption class="text-sm text-gray-600 mt-2 text-center">Alfa Laval NX-314 Decanter Module - 3D CAD Model</figcaption>
  </figure>

  <p>
    Our process typically starts with a <a href="/industrial-centrifuge-sample-testing/">lab-scale test</a> on a customer sample. We evaluate the results, and based on the separation efficiency, we recommend a centrifuge model with the appropriate options.
  </p>
  <p>
    If the customer decides to move ahead, Dolphin Centrifuge prepares a preliminary process flow diagram and P&amp;ID, which is sent to the customer for review and approval.
  </p>
  <p>
    We finalize the system scope at this point. Detailed mechanical, electrical, and controls drawings are generated and released for fabrication.
  </p>
  <p>
    During fabrication, all subsystems are assembled, wired, and piped to the approved engineering drawings.
  </p>
  <p>
    The completed system is tested per Dolphin Centrifuge's established procedures. We invite the customer to witness the final system testing at our facility before shipment.
  </p>

  <figure class="not-prose mb-6">
    <img
      src="/images/industrial-centrifuge-design/containerized-centrifuges-module-3d-model-800.webp"
      alt="Containerized centrifuge module 3D CAD model showing system layout inside a shipping container"
      width="800"
      height="256"
      loading="lazy"
      class="rounded-lg shadow-md img-cap-800"
    />
    <figcaption class="text-sm text-gray-600 mt-2 text-center">Containerized centrifuge module 3D CAD model</figcaption>
  </figure>

  <h3>Centrifuge System Design and Engineering include:</h3>
  <ul>
    <li>GA, Layout, P&amp;ID, Flow, and related drawings</li>
    <li>3D models of complete systems</li>
    <li><a href="/industrial-centrifuge-controls/">Electrical control system</a> design and build</li>
    <li>PLC &amp; HMI (Touchscreen) Programming</li>
    <li>Plant layout and piping design assistance</li>
    <li>Auxiliary system design and specification (Pumps, Heaters, etc.)</li>
  </ul>

  <h3>Site visit and consultancy</h3>
  <p>
    We conduct site visits to review your current processing setup and evaluate the suitability of an <a href="/industrial-centrifuge/">industrial centrifuge</a> for your process. Based on a site visit, our engineers can:
  </p>
  <ul>
    <li>Evaluate your product on-site to determine centrifuge applicability</li>
    <li>Discuss any operational efficiency that an industrial centrifuge may gain</li>
    <li>Identify the type and size of centrifuge needed</li>
    <li>Locate the point in your current process best suited to utilize a centrifuge</li>
    <li>Recommend any related process modifications to improve the existing process setup</li>
    <li>Provide a post-visit recommendations summary, as needed</li>
  </ul>
  <p>
    We highly recommend any prospective centrifuge buyer <a href="/contact-for-alfa-laval-centrifuges/">consult a reputed centrifuge company</a> with the experience and know-how to provide sound centrifuge-related advice before buying a capital-intensive centrifuge system.
  </p>

  <h2 id="more-than-centrifuge">More Than Just a Centrifuge</h2>
  <p>
    A centrifuge alone does not make a separation system. Effective industrial centrifuge installations require properly sized feed pumps, pre-heating systems, <a href="/industrial-centrifuge-controls/">control panels</a>, instrumentation, interconnecting piping, and a control strategy that ties everything together. Dolphin Centrifuge designs and fabricates these complete systems in-house at our Warren, Michigan facility.
  </p>
  <p>
    With over 40 years of application experience across industries from <a href="/oil-centrifuge/">oil purification</a> and <a href="/wastewater-centrifuge/">wastewater treatment</a> to <a href="/food-grade-centrifuge/">food-grade processing</a>, we engineer systems that solve real separation problems, not just sell centrifuges.
  </p>

  <div class="bg-navy/10 rounded-xl p-6 my-8 not-prose border border-navy/20">
    <p class="text-lg font-semibold text-navy mb-2">Need a Custom Centrifuge System?</p>
    <p class="text-text-light mb-4">Tell us about your application and our engineers will design a turnkey solution matched to your process requirements.</p>
    <div class="flex flex-wrap gap-4">
      <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-navy text-white px-6 py-2 rounded-lg font-semibold hover:bg-navy/90 transition-colors" style="color: white">Get a Quote</a>
      <a href="tel:+12485222573" class="inline-block border-2 border-navy text-navy px-6 py-2 rounded-lg font-semibold hover:bg-navy/5 transition-colors">(248) 522-2573</a>
    </div>
  </div>

  <h2 id="turnkey">Turnkey System Design</h2>

  <figure class="not-prose mb-6">
    <img
      src="/images/industrial-centrifuge-design/alfa-laval-brpx-213-stainless-steel-centrifuge-600x483.webp"
      alt="Alfa Laval BRPX 213 stainless steel centrifuge skid rendering"
      width="600"
      height="483"
      loading="lazy"
      class="rounded-lg shadow-md img-cap-400"
    />
    <figcaption class="text-sm text-gray-600 mt-2 text-center">Alfa Laval BRPX 213 stainless steel centrifuge skid rendering</figcaption>
  </figure>

  <p>
    Our turnkey centrifuge systems are designed, built, tested, and delivered ready to connect to your utilities and start processing. A typical turnkey system includes:
  </p>
  <ul>
    <li><strong>Centrifuge:</strong> <a href="/disc-stack-centrifuge/">Disc stack separator</a> (DMPX or DMB series) or <a href="/decanter-centrifuge/">decanter centrifuge</a></li>
    <li><strong>Feed System:</strong> Positive-displacement or centrifugal feed pump with VFD</li>
    <li><strong>Pre-Heating:</strong> <a href="/fluid-heating-systems/">Electric or steam heat exchanger</a></li>
    <li><strong>PLC/HMI Control Panel:</strong> Programmable logic controller with touchscreen</li>
    <li><strong>Instrumentation:</strong> Temperature sensors, pressure transmitters, flow meters</li>
    <li><strong>Piping &amp; Valves:</strong> All interconnecting piping and valves</li>
    <li><strong>Structural Frame:</strong> Welded steel skid or platform</li>
  </ul>

  <h2 id="controls">PLC &amp; HMI Control Systems</h2>

  <figure class="not-prose mb-6">
    <img
      src="/images/industrial-centrifuge-design/dolphin-centrifuge-plc-control-panel-800.webp"
      alt="Dolphin Centrifuge PLC control panel HMI touchscreen showing centrifuge system process diagram"
      width="800"
      height="600"
      loading="lazy"
      class="rounded-lg shadow-md img-cap-400"
    />
    <figcaption class="text-sm text-gray-600 mt-2 text-center">Dolphin Centrifuge PLC control panel with HMI touchscreen</figcaption>
  </figure>

  <p>
    Automation is critical for consistent separation performance and minimal operator involvement. Our in-house controls engineers design PLC-based control systems using industry-standard hardware (Allen-Bradley, Siemens, or equivalent). Control features include:
  </p>
  <ul>
    <li>Automated startup and shutdown sequences</li>
    <li>Bowl discharge timing control (time-based and solids-sensing)</li>
    <li>Feed flow rate and temperature regulation</li>
    <li>Operating water control for self-cleaning separators</li>
    <li>Alarm management with visual and audible alerts</li>
    <li>Data logging and trend display on the HMI touchscreen</li>
    <li>Remote monitoring capability via Ethernet or cellular connection</li>
    <li>Integration with plant-level DCS or SCADA systems</li>
  </ul>

  <h2 id="testing-commissioning">Factory Testing &amp; Commissioning</h2>
  <p>
    Every system Dolphin Centrifuge builds undergoes functional testing at our Warren, Michigan facility before shipment. We run each system through its startup, operating, and shutdown sequences to verify mechanical fit, electrical wiring, PLC logic, and instrument calibration. Customers are welcome to witness these tests at our shop.
  </p>
  <p>
    After delivery and site installation, our field technicians commission the system on-site. Commissioning includes a full mechanical and electrical check, initial startup with process fluid, operating-parameter optimization, and comprehensive <a href="/industrial-centrifuge-training/">operator training</a>. We do not consider a project complete until the customer's own operators can run the system independently.
  </p>

  <h2 id="containerized">Containerized Systems</h2>

  <figure class="not-prose mb-6">
    <img
      src="/images/industrial-centrifuge-design/containerized-industrial-centrifuge-800.webp"
      alt="Containerized industrial centrifuge system installed inside a shipping container"
      width="1200"
      height="400"
      loading="lazy"
      class="rounded-lg shadow-md img-cap-800"
    />
    <figcaption class="text-sm text-gray-600 mt-2 text-center">Containerized industrial centrifuge system</figcaption>
  </figure>

  <p>
    For applications requiring portability, weather protection, or rapid deployment, we design complete centrifuge systems inside standard 20-foot or 40-foot ISO shipping containers. Learn more about our <a href="/containerized-industrial-centrifuge/">containerized industrial centrifuge</a> systems. Containerized systems are ideal for:
  </p>
  <ul>
    <li>Remote or outdoor installations without an available building</li>
    <li>Oil field and wellsite deployments</li>
    <li>Rental and mobile service operations</li>
    <li>Disaster and emergency response</li>
    <li>International projects requiring easy shipping and customs clearance</li>
  </ul>
  <p>
    Each containerized system includes climate control (heating and ventilation), interior lighting, electrical distribution, and all process equipment pre-installed and piped. Simply connect utilities and start processing.
  </p>

  <h2 id="deliverables">Engineering Deliverables</h2>
  <p>Depending on your project scope, our engineering packages include:</p>
  <ul>
    <li><strong>P&amp;ID Drawings:</strong> Piping and instrumentation diagrams showing every component, connection, and instrument</li>
    <li><strong>GA Drawings:</strong> General arrangement and layout drawings with dimensions and clearance requirements</li>
    <li><strong>Electrical Schematics:</strong> Complete wiring diagrams for the control panel and field devices</li>
    <li><strong>Equipment Datasheets:</strong> Specifications for every component in the system</li>
    <li><strong>O&amp;M Manual:</strong> Operations and maintenance manual specific to your system configuration</li>
    <li><strong>Installation Guidelines:</strong> Foundation requirements, utility connections, and installation instructions</li>
  </ul>
  <p>
    For EPC bid packages that require formal SDRL/VDRL submittals, hazardous-area documentation, ITP/FAT records, and approval drawing cycles, see our <a href="/epc-industrial-centrifuge-systems/">EPC industrial centrifuge systems</a> page.
  </p>

  <h2 id="design-process">Our Design Process</h2>
  <ol>
    <li><strong>Application Review:</strong> We analyze your process requirements including fluid properties, flow rates, separation targets, and site conditions</li>
    <li><strong>Sample Testing:</strong> If needed, we run your material through our <a href="/industrial-centrifuge-sample-testing/">sample testing program</a> to verify separation performance</li>
    <li><strong>System Proposal:</strong> You receive a detailed proposal with scope of supply, system description, performance guarantees, timeline, and pricing</li>
    <li><strong>Engineering &amp; Fabrication:</strong> Upon order, our team completes detailed engineering, procures components, and fabricates the system</li>
    <li><strong>Factory Testing:</strong> Every system undergoes functional testing in our facility before shipment. Customers are welcome to witness testing on-site at our shop</li>
    <li><strong>Commissioning &amp; Training:</strong> We provide on-site commissioning, startup, and <a href="/industrial-centrifuge-training/">operator training</a> until your team can run the system independently</li>
  </ol>

  <h2 id="industries">Industries We Serve</h2>
  <p>Our engineered centrifuge systems operate in facilities worldwide across a range of industries:</p>
  <div class="grid md:grid-cols-2 gap-4 not-prose mb-4">
    <ul class="list-disc list-inside space-y-1 text-text-muted ml-4">
      <li>Oil &amp; gas production</li>
      <li>Petroleum refining</li>
      <li>Waste oil re-refining</li>
      <li>Marine and shipboard</li>
      <li>Power generation</li>
    </ul>
    <ul class="list-disc list-inside space-y-1 text-text-muted ml-4">
      <li>Wastewater treatment</li>
      <li>Food &amp; beverage processing</li>
      <li>Chemical manufacturing</li>
      <li>Metalworking &amp; machining</li>
      <li>Pharmaceutical and biotech</li>
    </ul>
  </div>

  <p>
    Please <a href="/contact-for-alfa-laval-centrifuges/">contact Dolphin Centrifuge</a> or call us at <a href="tel:+12485222573">(248) 522-2573</a> to discuss your centrifuge system design requirements with our engineers.
  </p>



</ApplicationLayout>
