---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Centrifuge System Design & Engineering",
  "description": "Custom industrial centrifuge system design and engineering. Turnkey systems with PLC controls, pumps, piping, and heating. 40+ years of expertise.",
  "provider": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "address": { "@type": "PostalAddress", "streetAddress": "24248 Gibson Dr.", "addressLocality": "Warren", "addressRegion": "MI", "postalCode": "48089", "addressCountry": "US" },
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "url": "https://dolphincentrifuge.com/industrial-centrifuge-design/",
};
---

<BaseLayout
  title="Centrifuge System Design & Engineering"
  description="Custom industrial centrifuge system design and engineering. Turnkey systems with PLC controls, pumps, piping, and heating. 40+ years of expertise."
  canonicalUrl="https://dolphincentrifuge.com/industrial-centrifuge-design/"
  breadcrumbs={[
    { label: 'Services', href: '/industrial-centrifuge-design/' },
    { label: 'Design & Engineering' },
  ]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">Services</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">Centrifuge System Design &amp; Engineering</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">
        Dolphin Centrifuge designs and builds complete, turnkey centrifuge separation systems tailored to your specific process requirements. From single centrifuge skids to multi-stage containerized plants, our engineering team delivers systems that are ready to install and operate from day one.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Get a Free Quote</a>
        <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-4xl">

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">More Than Just a Centrifuge</h2>
      <p class="text-text-muted mb-4">
        A centrifuge alone does not make a separation system. Effective industrial centrifuge installations require properly sized feed pumps, pre-heating systems, control panels, instrumentation, interconnecting piping, and a control strategy that ties everything together. Dolphin Centrifuge designs and fabricates these complete systems in-house at our Warren, Michigan facility.
      </p>
      <p class="text-text-muted mb-8">
        With over 40 years of application experience across industries from <a href="/oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">oil purification</a> and <a href="/wastewater-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">wastewater treatment</a> to <a href="/food-grade-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">food-grade processing</a>, we engineer systems that solve real separation problems&mdash;not just sell centrifuges.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Turnkey System Design</h2>
      <p class="text-text-muted mb-4">
        Our turnkey centrifuge systems are designed, built, tested, and delivered ready to connect to your utilities and start processing. A typical turnkey system includes:
      </p>
      <ul class="list-disc list-inside space-y-2 text-text-muted mb-8 ml-4">
        <li><strong>Centrifuge:</strong> Disc stack separator (DMPX or DMB series) or decanter centrifuge, sized for your flow rate and separation requirements</li>
        <li><strong>Feed System:</strong> Positive-displacement or centrifugal feed pump with VFD for precise flow control</li>
        <li><strong>Pre-Heating:</strong> Electric or steam heat exchanger to bring the feed to optimal separation temperature</li>
        <li><strong>PLC/HMI Control Panel:</strong> Programmable logic controller with touchscreen interface for automated operation, monitoring, and alarms</li>
        <li><strong>Instrumentation:</strong> Temperature sensors, pressure transmitters, flow meters, and vibration monitors</li>
        <li><strong>Piping &amp; Valves:</strong> All interconnecting piping, isolation valves, sample ports, and drain connections</li>
        <li><strong>Structural Frame:</strong> Welded steel skid or platform for compact, self-contained installation</li>
      </ul>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">PLC &amp; HMI Control Systems</h2>
      <p class="text-text-muted mb-4">
        Automation is critical for consistent separation performance and minimal operator involvement. Our in-house controls engineers design PLC-based control systems using industry-standard hardware (Allen-Bradley, Siemens, or equivalent). Control features include:
      </p>
      <ul class="list-disc list-inside space-y-2 text-text-muted mb-8 ml-4">
        <li>Automated startup and shutdown sequences</li>
        <li>Bowl discharge timing control (time-based and solids-sensing)</li>
        <li>Feed flow rate and temperature regulation</li>
        <li>Operating water control for self-cleaning separators</li>
        <li>Alarm management with visual and audible alerts</li>
        <li>Data logging and trend display on the HMI touchscreen</li>
        <li>Remote monitoring capability via Ethernet or cellular connection</li>
        <li>Integration with plant-level DCS or SCADA systems</li>
      </ul>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Containerized Systems</h2>
      <p class="text-text-muted mb-4">
        For applications requiring portability, weather protection, or rapid deployment, we design complete centrifuge systems inside standard 20-foot or 40-foot ISO shipping containers. Containerized systems are ideal for:
      </p>
      <ul class="list-disc list-inside space-y-2 text-text-muted mb-8 ml-4">
        <li>Remote or outdoor installations without an available building</li>
        <li>Oil field and wellsite deployments</li>
        <li>Rental and mobile service operations</li>
        <li>Disaster and emergency response</li>
        <li>International projects requiring easy shipping and customs clearance</li>
      </ul>
      <p class="text-text-muted mb-8">
        Each containerized system includes climate control (heating and ventilation), interior lighting, electrical distribution, and all process equipment pre-installed and piped. Simply connect utilities and start processing.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Engineering Deliverables</h2>
      <p class="text-text-muted mb-4">
        Depending on your project scope, our engineering packages include:
      </p>
      <ul class="list-disc list-inside space-y-2 text-text-muted mb-8 ml-4">
        <li><strong>P&amp;ID Drawings:</strong> Piping and instrumentation diagrams showing every component, connection, and instrument</li>
        <li><strong>GA Drawings:</strong> General arrangement and layout drawings with dimensions and clearance requirements</li>
        <li><strong>Electrical Schematics:</strong> Complete wiring diagrams for the control panel and field devices</li>
        <li><strong>Equipment Datasheets:</strong> Specifications for every component in the system</li>
        <li><strong>O&amp;M Manual:</strong> Operations and maintenance manual specific to your system configuration</li>
        <li><strong>Installation Guidelines:</strong> Foundation requirements, utility connections, and installation instructions</li>
      </ul>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Our Design Process</h2>
      <ol class="list-decimal list-inside space-y-3 text-text-muted mb-8 ml-4">
        <li><strong>Application Review:</strong> We analyze your process requirements including fluid properties, flow rates, separation targets, and site conditions</li>
        <li><strong>Sample Testing:</strong> If needed, we run your material through our <a href="/industrial-centrifuge-sample-testing/" class="text-navy font-semibold hover:text-gold transition-colors">sample testing program</a> to verify separation performance</li>
        <li><strong>System Proposal:</strong> You receive a detailed proposal with scope of supply, system description, performance guarantees, timeline, and pricing</li>
        <li><strong>Engineering &amp; Fabrication:</strong> Upon order, our team completes detailed engineering, procures components, and fabricates the system</li>
        <li><strong>Factory Testing:</strong> Every system undergoes functional testing in our facility before shipment</li>
        <li><strong>Installation Support:</strong> We provide on-site commissioning, startup, and <a href="/industrial-centrifuge-training/" class="text-navy font-semibold hover:text-gold transition-colors">operator training</a></li>
      </ol>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Industries We Serve</h2>
      <p class="text-text-muted mb-4">
        Our engineered centrifuge systems operate in facilities worldwide across a range of industries:
      </p>
      <div class="grid md:grid-cols-2 gap-4 mb-8">
        <ul class="list-disc list-inside space-y-1 text-text-muted ml-4">
          <li>Oil &amp; gas production</li>
          <li>Petroleum refining</li>
          <li>Waste oil re-refining</li>
          <li>Marine and shipboard</li>
          <li>Power generation</li>
        </ul>
        <ul class="list-disc list-inside space-y-1 text-text-muted ml-4">
          <li>Wastewater treatment</li>
          <li>Food &amp; beverage processing</li>
          <li>Chemical manufacturing</li>
          <li>Metalworking &amp; machining</li>
          <li>Pharmaceutical and biotech</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-navy">
    <div class="container-dolphin py-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Let's Design Your System</h2>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">Tell us about your separation challenge. Our engineers will design a centrifuge system optimized for your specific process.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3.5 rounded-lg transition-colors">Contact Us Today</a>
        <a href="/industrial-centrifuge-sample-testing/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3.5 rounded-lg transition-colors">Sample Testing</a>
      </div>
    </div>
  </section>
</BaseLayout>
