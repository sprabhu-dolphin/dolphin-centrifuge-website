---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "What does a turnkey centrifuge system from Dolphin Centrifuge include?",
    answer: "A Dolphin Centrifuge turnkey system includes the centrifuge (DMPX or decanter), feed pump, pre-filter, pre-heater (if required for viscous fluids), sludge tank, interconnecting piping, electrical panel with PLC controls, and startup commissioning. We design, build, test, and ship as a complete skid-mounted unit ready for site installation."
  },
  {
    question: "Can Dolphin Centrifuge design a system for a hazardous area?",
    answer: "Yes. Dolphin Centrifuge designs explosion-proof centrifuge systems for Class I Division 1 and Division 2 hazardous locations, including refinery tank farms, offshore platforms, fuel handling facilities, and chemical plants. Components are rated for the specific NEC hazardous area classification required."
  },
  {
    question: "How long does it take to design and build a custom centrifuge system?",
    answer: "Lead times vary by complexity. A standard DMPX skid with controls typically ships in 8–12 weeks from order. A custom multi-stage system with specialty materials or explosion-proof components may require 12–20 weeks. Contact Dolphin Centrifuge early in your project timeline to discuss scheduling."
  }
];

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Centrifuge System Design & Engineering",
  "description": "Custom industrial centrifuge system design and engineering. Turnkey systems with PLC controls, pumps, piping, and heating. 40+ years of expertise.",
  "provider": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "address": { "@type": "PostalAddress", "streetAddress": "24248 Gibson Dr.", "addressLocality": "Warren", "addressRegion": "MI", "postalCode": "48089", "addressCountry": "US" },
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "url": "https://dolphincentrifuge.com/industrial-centrifuge-design/",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const jsonLd = [serviceJsonLd, faqJsonLd];

const toc = [
  { id: 'legacy-overview', label: 'Design & Engineering Overview' },
  { id: 'more-than-centrifuge', label: 'More Than Just a Centrifuge' },
  { id: 'turnkey', label: 'Turnkey System Design' },
  { id: 'controls', label: 'PLC & HMI Control Systems' },
  { id: 'containerized', label: 'Containerized Systems' },
  { id: 'deliverables', label: 'Engineering Deliverables' },
  { id: 'design-process', label: 'Our Design Process' },
  { id: 'industries', label: 'Industries We Serve' },
  { id: 'faq', label: 'FAQ' },
];

const relatedApplications = [
  { label: 'Oil Centrifuge', href: '/oil-centrifuge/' },
  { label: 'Wastewater Centrifuge', href: '/wastewater-centrifuge/' },
  { label: 'Food Grade Centrifuge', href: '/food-grade-centrifuge/' },
  { label: 'Centrifuge Controls', href: '/industrial-centrifuge-controls/' },
];

const relatedProducts = [
  { label: 'Disc Stack Centrifuge', href: '/disc-stack-centrifuge/', description: 'All DMPX & DMB models' },
  { label: 'Decanter Centrifuge', href: '/decanter-centrifuge/', description: 'NX, CHNX, G2 decanters' },
  { label: 'Centrifuge Sample Testing', href: '/industrial-centrifuge-sample-testing/', description: 'Lab testing before purchase' },
];
---

<ApplicationLayout
  title="Centrifuge System Design & Engineering"
  description="Custom industrial centrifuge system design by Dolphin Centrifuge. Turnkey skid-mounted systems with PLC controls, pumps, heaters, and piping. 40+ years expertise."
  category="services"
  categoryLabel="Services"
  heroImage="/images/industrial-centrifuge-design/Alfa-Laval-BRPX-213-Stainless-Steel-Centrifuge-800.webp"
  heroImageAlt="Alfa Laval BRPX 213 Stainless Steel Centrifuge"
  canonicalUrl="https://dolphincentrifuge.com/industrial-centrifuge-design/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge specializes in custom industrial centrifuge system design and manufacture — engineering turnkey centrifuge skids to customer specifications for oil purification, fuel polishing, coolant recovery, wastewater clarification, and chemical processing. Each DMPX system integrates centrifuge selection, heating, pumping, controls, piping, and structural skid design as a complete package, factory tested before delivery. Based in Warren, Michigan, with over 40 years of centrifuge system engineering experience.</p>
  </div>

  <h2 id="legacy-overview">Centrifuge System Design &amp; Engineering</h2>
  <p>
    Dolphin Centrifuge is primarily an engineering company specializing in Alfa Laval industrial centrifuge system design &amp; manufacture. We engineer each system to customer specifications to ensure robust design and functionality.
  </p>

  <h3>The Centrifuge Design Process</h3>

  <div class="flex flex-col md:flex-row gap-6 items-start not-prose mb-6">
    <div class="md:w-1/2">
      <p class="text-text-light mb-4">
        Our process typically starts with a lab-scale test on a customer sample. We evaluate the results, and based on the separation efficiency, we suggest a suitable centrifuge (with recommended options) to the customer.
      </p>
      <p class="text-text-light mb-4">
        If the customer decides to move ahead with our proposed system, Dolphin Centrifuge designs a preliminary process flow diagram which is sent to the customer for review and changes, if desired.
      </p>
      <p class="text-text-light mb-4">
        We finalize the system scope at this point. Electrical &amp; mechanical drawings are also generated and sent to the relevant functions to execute.
      </p>
      <p class="text-text-light mb-4">
        In the final stage, all subsystems are checked and assembled to original drawings.
      </p>
      <p class="text-text-light">
        The completed system is wired and tested per Dolphin Centrifuge's established procedures. We invite the customer to witness the final system testing at our facility.
      </p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/industrial-centrifuge-design/Alfa-Laval-NX-314-Decanter-Module-3D-Cad-Model.webp"
        alt="Alfa Laval NX 314 Decanter Module 3D Cad Model"
        width="600"
        height="400"
        loading="lazy"
        class="rounded-lg shadow-md w-full"
      />
    </div>
  </div>

  <h3>Centrifuge System Design and Engineering include:</h3>
  <ul>
    <li>GA, Layout, P&amp;ID, Flow, and related drawings</li>
    <li>3D models of complete systems</li>
    <li>Electrical control system design and build</li>
    <li>PLC &amp; HIM (Touchscreen) Programming</li>
    <li>Plant layout and piping design assistance</li>
    <li>Auxiliary system design and specification (Pumps, Heaters, etc.)</li>
  </ul>

  <h3>Site visit and consultancy</h3>
  <p>
    We conduct site visits to review your current processing setup and evaluate the possibility of an industrial centrifuge to enhance your ongoing process. Based on a site visit, our engineers can
  </p>
  <ul>
    <li>Evaluate your product on-site to determine centrifuge applicability</li>
    <li>Discuss any operational efficiency that an industrial centrifuge may gain</li>
    <li>Identify the type and size of centrifuge needed</li>
    <li>Locate the point in your current process best suited to utilize a centrifuge</li>
    <li>Recommend any related process modifications to improve the existing process setup</li>
    <li>Provide a 'post-visit' recommendations summary, as needed</li>
  </ul>
  <p>
    We highly recommend any prospective centrifuge buyer consult a reputed centrifuge company with the experience and know-how to provide sound centrifuge-related advice before buying a capital-intensive centrifuge system.
  </p>

  <h2 id="more-than-centrifuge">More Than Just a Centrifuge</h2>
  <p>
    A centrifuge alone does not make a separation system. Effective industrial centrifuge installations require properly sized feed pumps, pre-heating systems, <a href="/industrial-centrifuge-controls/">control panels</a>, instrumentation, interconnecting piping, and a control strategy that ties everything together. Dolphin Centrifuge designs and fabricates these complete systems in-house at our Warren, Michigan facility.
  </p>
  <p>
    With over 40 years of application experience across industries from <a href="/oil-centrifuge/">oil purification</a> and <a href="/wastewater-centrifuge/">wastewater treatment</a> to <a href="/food-grade-centrifuge/">food-grade processing</a>, we engineer systems that solve real separation problems&mdash;not just sell centrifuges.
  </p>

  <h2 id="turnkey">Turnkey System Design</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start not-prose mb-6">
    <div class="md:w-1/2">
      <p class="text-text-light mb-4">
        Our turnkey centrifuge systems are designed, built, tested, and delivered ready to connect to your utilities and start processing. A typical turnkey system includes:
      </p>
      <ul class="text-text-light space-y-2">
        <li>&#8226; <strong>Centrifuge:</strong> <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Disc stack separator</a> (DMPX or DMB series) or <a href="/decanter-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">decanter centrifuge</a></li>
        <li>&#8226; <strong>Feed System:</strong> Positive-displacement or centrifugal feed pump with VFD</li>
        <li>&#8226; <strong>Pre-Heating:</strong> Electric or steam heat exchanger</li>
        <li>&#8226; <strong>PLC/HMI Control Panel:</strong> Programmable logic controller with touchscreen</li>
        <li>&#8226; <strong>Instrumentation:</strong> Temperature sensors, pressure transmitters, flow meters</li>
        <li>&#8226; <strong>Piping &amp; Valves:</strong> All interconnecting piping and valves</li>
        <li>&#8226; <strong>Structural Frame:</strong> Welded steel skid or platform</li>
      </ul>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/industrial-centrifuge-design/Centrifugal-Filter-Decanter.webp"
        alt="Centrifugal Filter Decanter"
        width="600"
        height="400"
        loading="lazy"
        class="rounded-lg shadow-md w-full"
      />
    </div>
  </div>

  <h2 id="controls">PLC &amp; HMI Control Systems</h2>
  <p>
    Automation is critical for consistent separation performance and minimal operator involvement. Our in-house controls engineers design PLC-based control systems using industry-standard hardware (Allen-Bradley, Siemens, or equivalent). Control features include:
  </p>
  <ul>
    <li>Automated startup and shutdown sequences</li>
    <li>Bowl discharge timing control (time-based and solids-sensing)</li>
    <li>Feed flow rate and temperature regulation</li>
    <li>Operating water control for self-cleaning separators</li>
    <li>Alarm management with visual and audible alerts</li>
    <li>Data logging and trend display on the HMI touchscreen</li>
    <li>Remote monitoring capability via Ethernet or cellular connection</li>
    <li>Integration with plant-level DCS or SCADA systems</li>
  </ul>

  <h2 id="containerized">Containerized Systems</h2>
  <p>
    For applications requiring portability, weather protection, or rapid deployment, we design complete centrifuge systems inside standard 20-foot or 40-foot ISO shipping containers. Containerized systems are ideal for:
  </p>
  <ul>
    <li>Remote or outdoor installations without an available building</li>
    <li>Oil field and wellsite deployments</li>
    <li>Rental and mobile service operations</li>
    <li>Disaster and emergency response</li>
    <li>International projects requiring easy shipping and customs clearance</li>
  </ul>
  <p>
    Each containerized system includes climate control (heating and ventilation), interior lighting, electrical distribution, and all process equipment pre-installed and piped. Simply connect utilities and start processing.
  </p>

  <h2 id="deliverables">Engineering Deliverables</h2>
  <p>Depending on your project scope, our engineering packages include:</p>
  <ul>
    <li><strong>P&amp;ID Drawings:</strong> Piping and instrumentation diagrams showing every component, connection, and instrument</li>
    <li><strong>GA Drawings:</strong> General arrangement and layout drawings with dimensions and clearance requirements</li>
    <li><strong>Electrical Schematics:</strong> Complete wiring diagrams for the control panel and field devices</li>
    <li><strong>Equipment Datasheets:</strong> Specifications for every component in the system</li>
    <li><strong>O&amp;M Manual:</strong> Operations and maintenance manual specific to your system configuration</li>
    <li><strong>Installation Guidelines:</strong> Foundation requirements, utility connections, and installation instructions</li>
  </ul>

  <h2 id="design-process">Our Design Process</h2>
  <ol>
    <li><strong>Application Review:</strong> We analyze your process requirements including fluid properties, flow rates, separation targets, and site conditions</li>
    <li><strong>Sample Testing:</strong> If needed, we run your material through our <a href="/industrial-centrifuge-sample-testing/">sample testing program</a> to verify separation performance</li>
    <li><strong>System Proposal:</strong> You receive a detailed proposal with scope of supply, system description, performance guarantees, timeline, and pricing</li>
    <li><strong>Engineering &amp; Fabrication:</strong> Upon order, our team completes detailed engineering, procures components, and fabricates the system</li>
    <li><strong>Factory Testing:</strong> Every system undergoes functional testing in our facility before shipment</li>
    <li><strong>Installation Support:</strong> We provide on-site commissioning, startup, and <a href="/industrial-centrifuge-training/">operator training</a></li>
  </ol>

  <h2 id="industries">Industries We Serve</h2>
  <p>Our engineered centrifuge systems operate in facilities worldwide across a range of industries:</p>
  <div class="grid md:grid-cols-2 gap-4 not-prose mb-4">
    <ul class="list-disc list-inside space-y-1 text-text-muted ml-4">
      <li>Oil &amp; gas production</li>
      <li>Petroleum refining</li>
      <li>Waste oil re-refining</li>
      <li>Marine and shipboard</li>
      <li>Power generation</li>
    </ul>
    <ul class="list-disc list-inside space-y-1 text-text-muted ml-4">
      <li>Wastewater treatment</li>
      <li>Food &amp; beverage processing</li>
      <li>Chemical manufacturing</li>
      <li>Metalworking &amp; machining</li>
      <li>Pharmaceutical and biotech</li>
    </ul>
  </div>

  <FAQ items={faqItems} />

</ApplicationLayout>
