---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqItems = [
  {
    question: "What separations can the G2-40 decanter centrifuge handle?",
    answer: "The G2-40 is a high-performance horizontal scroll decanter designed for demanding two-phase (solid-liquid) separation. It handles wastewater, crude oil tank bottom sludge, municipal sludge thickening, industrial sludge dewatering, paint sludge, pyrolysis sludge, and liquid humus fertilizer applications. With 3,150 G-Force and 160 GPM rated capacity, it is suited for high-solids processing."
  },
  {
    question: "How does the G2-40 compare to the NX-314 and NX-418 decanters?",
    answer: "The G2-40 is Alfa Laval's larger and higher-throughput decanter platform compared to the NX-314 and NX-418. With a 20 HP drive motor and 4,000 RPM bowl speed, the G2-40 delivers 160 GPM rated capacity for high-volume or high-solids applications. The NX-314 and NX-418 are well-suited for moderate-volume applications. Contact Dolphin Centrifuge to match the right model to your specific throughput and solids loading requirements."
  },
  {
    question: "Does Dolphin Centrifuge sell new or remanufactured G2-40 decanters?",
    answer: "Dolphin Centrifuge supplies both new and factory-rebuilt G2-40 decanter centrifuges. Rebuilt units are fully disassembled, inspected, worn components replaced, and reassembled to original specifications with a Dolphin warranty. Contact us for current availability and pricing."
  },
  {
    question: "What is the G2-40's gearbox ratio and why does it matter?",
    answer: "The Alfa Laval G2-40 uses a 1:52 DD (Direct Drive) gearbox with a torque rating of 3.5 kN-M. This ratio enables the auger differential speed range of 1–140 RPM — much wider than the NX-314 and NX-418's 1:159 ratio. The wider differential speed range gives operators greater flexibility to optimize cake dryness and throughput across different feed slurries and solids loadings."
  },
  {
    question: "How do I contact Dolphin Centrifuge about the G2-40 decanter?",
    answer: "Contact Dolphin Centrifuge at (248) 522-2573 or email sales@dolphincentrifuge.com. Our engineering team can review your application requirements, recommend the right decanter model, and provide a quote for a new or reconditioned G2-40 unit. You can also submit a request through our contact page at /contact-for-alfa-laval-centrifuges/."
  }
];

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Alfa Laval G2-40 Decanter Centrifuge — High Performance Industrial Separation",
  "description": "Technical guide to the Alfa Laval G2-40 two-phase decanter centrifuge: 160 GPM, 3,150 G-Force, 4,000 RPM. Supplied and serviced by Dolphin Centrifuge, Warren Michigan.",
  "url": "https://dolphincentrifuge.com/alfa-laval-g2-40-decanter/",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" }
};

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval G2-40 Decanter Centrifuge",
  "description": "Alfa Laval G2-40 high-performance decanter centrifuge for industrial two-phase solid-liquid separation. 160 GPM rated capacity, 4,000 RPM bowl speed, 3,150 G-Force.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "telephone": "(248) 522-2573",
    "email": "sales@dolphincentrifuge.com",
    "url": "https://dolphincentrifuge.com"
  },
  "model": "G2-40",
  "url": "https://dolphincentrifuge.com/alfa-laval-g2-40-decanter/",
  "offers": {
    "@type": "Offer",
    "seller": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const jsonLd = [articleJsonLd, productJsonLd, faqJsonLd];

const toc = [
  { id: 'operation', label: 'Operation' },
  { id: 'specifications', label: 'G2-40 Specifications' },
  { id: 'key-features', label: 'Key Features' },
  { id: 'dolphin-service', label: 'Dolphin G2-40 Service' },
  { id: 'applications', label: 'Applications' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedApplications = [
  { label: 'Decanter Centrifuge Applications', href: '/decanter-centrifuge-applications/' },
  { label: 'Three-Phase Decanter', href: '/three-phase-decanter/' },
  { label: 'Decanter vs Disc Stack', href: '/difference-between-decanter-centrifuge-disc-centrifuge/' },
];

const relatedProducts = [
  { label: 'Alfa Laval CHNX 418 Decanter', href: '/alfa-laval-chnx-418-decanter/', description: 'Nitrogen-purged hazardous duty decanter' },
  { label: 'Alfa Laval NX-314 Decanter', href: '/alfa-laval-nx-314-decanter-centrifuge/', description: '314 mm compact decanter' },
  { label: 'Alfa Laval NX 418 Decanter', href: '/alfa-laval-nx-418-decanter-centrifuge/', description: '418 mm industrial decanter' },
];
---

<ApplicationLayout
  title="Alfa Laval G2-40 Decanter Centrifuge | Dolphin Centrifuge"
  description="Alfa Laval G2-40 decanter centrifuge — 160 GPM rated capacity, 4,000 RPM, 3,150 G-Force for sludge dewatering and wastewater treatment. Dolphin Centrifuge."
  heroImage="/images/diagrams/Decanter-Cross-Section-nb.webp"
  heroImageAlt="Decanter Cross Section"
  category="products"
  categoryLabel="Products"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-g2-40-decanter/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <!-- AI Summary — 30-50 words -->
  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">The Alfa Laval G2-40 is a horizontal decanter centrifuge for two-phase solid-liquid separation, rated at 160 GPM with a 4,000 RPM bowl speed and 3,150 G-Force. Dolphin Centrifuge supplies new and rebuilt G2-40 units from Warren, Michigan.</p>
  </div>

  <!-- Operation -->
  <h2 id="operation">Alfa Laval G2-40 Two-Phase Decanter Centrifuge</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <p>
        The Alfa Laval G2-40 <a href="/decanter-centrifuge/">decanter centrifuge</a> is a horizontal de-sludging centrifuge built for the two-phase separation of <a href="/wastewater-centrifuge/">wastewater</a>, <a href="/crude-oil-centrifuge/">crude oil tank bottoms</a>, municipal sludge thickening, industrial sludge dewatering, paint sludge handling, and similar high-solids applications.
      </p>
      <p>
        With a 20 HP motor, the G2-40 decanter has a bowl RPM of 4,000 and can process 160 GPM of water with light sludge. The G2 generation design incorporates an optimized scroll geometry for improved solids conveyance and a high-G-force bowl generating 3,150 RCF — significantly greater centrifugal acceleration than previous generation decanters.
      </p>
    </div>
    <img
      src="/images/diagrams/Decanter-Cross-Section-nb.webp"
      alt="Decanter Cross Section"
      width="300"
      height="200"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
  </div>

  <!-- Specifications -->
  <h2 id="specifications">G2-40 Specifications</h2>

  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
      <tbody>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Model Type</td>
          <td class="px-4 py-3 font-mono text-text-light">Alfa Laval G2-40 Decanter Centrifuge</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Rated Capacity</td>
          <td class="px-4 py-3 font-mono text-text-light">160 GPM on Water Sludge Thickening</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Auger Differential Speed</td>
          <td class="px-4 py-3 font-mono text-text-light">1 ~ 140 RPM</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Drive Motor Power</td>
          <td class="px-4 py-3 font-mono text-text-light">20 HP</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">GearBox Ratio</td>
          <td class="px-4 py-3 font-mono text-text-light">1:52 (3.5 kN-M) DD Gearbox</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">AE (Area Equivalent)</td>
          <td class="px-4 py-3 font-mono text-text-light">1,565</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Bowl Speed</td>
          <td class="px-4 py-3 font-mono text-text-light">4,000 RPM</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">G-Force</td>
          <td class="px-4 py-3 font-mono text-text-light">3,150 RCF</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-semibold text-navy">Conveyor Protection</td>
          <td class="px-4 py-3 font-mono text-text-light">Carbide Tile or Tungsten Carbide Hard-Surfacing</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Key Features -->
  <h2 id="key-features">Key Features</h2>

  <ul class="space-y-3 mb-8">
    <li><strong>3,150 G-Force bowl:</strong> High centrifugal acceleration at 4,000 RPM enables effective separation of difficult-to-separate phases and finer particles that lower G-force machines cannot capture.</li>
    <li><strong>160 GPM rated capacity:</strong> Handles high-volume <a href="/wastewater-centrifuge/">wastewater</a> and sludge thickening applications with a 20 HP drive motor and energy-efficient VFD system.</li>
    <li><strong>Wide differential speed range:</strong> The 1:52 DD gearbox with 3.5 kN-M torque enables an auger differential speed range of 1–140 RPM — significantly wider than the NX-314 and NX-418 decanters' 1:159 ratio. This gives operators greater flexibility to optimize cake dryness and throughput across different feed slurries.</li>
    <li><strong>Optimized G2 scroll geometry:</strong> The second-generation scroll design improves solids conveyance efficiency, reducing scroll wear and improving cake dryness at a given <a href="/decanter-centrifuge-differential-speed/">differential speed</a>.</li>
    <li><strong>Tungsten carbide conveyor protection:</strong> Carbide tile or tungsten carbide hard-surfacing on the scroll flights extends service life in abrasive applications.</li>
    <li><strong>Area Equivalent (AE) of 1,565:</strong> A high AE value indicates a large effective settling area within the bowl, enabling finer separation and higher capacity on difficult slurries.</li>
  </ul>

  <!-- Dolphin Service -->
  <h2 id="dolphin-service">Dolphin Centrifuge G2-40 Service</h2>
  <p>
    Dolphin Centrifuge supplies both new and factory-rebuilt G2-40 decanter centrifuges. Rebuilt units are fully disassembled, inspected, worn components replaced, and reassembled to original specifications with a Dolphin warranty. Our Warren, Michigan facility maintains inventory of G2-40 rotating assemblies, gearboxes, and wear components for fast turnaround.
  </p>
  <p>
    We also provide full <a href="/industrial-disc-centrifuge-repair/">centrifuge repair and rebuilding services</a> for existing G2-40 installations — including conveyor re-surfacing, bearing replacement, gearbox rebuild, and vibration analysis. <a href="/industrial-centrifuge-sample-testing/">Sample testing</a> is available to verify separation performance on your specific feed material before purchase.
  </p>

  <!-- Applications -->
  <h2 id="applications">Applications</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <p>The Alfa Laval G2-40 decanter is used for the following applications:</p>
      <div class="grid md:grid-cols-2 gap-x-8 gap-y-2">
        <ul class="space-y-2">
          <li><a href="/waste-oil-centrifuge/">Waste oil de-sludging</a></li>
          <li><a href="/crude-oil-centrifuge/">Crude oil tank bottom sludge</a></li>
          <li><a href="/wastewater-centrifuge/">Municipal wastewater</a></li>
          <li><a href="/liquid-humus-centrifuge/">Liquid humus fertilizer</a></li>
        </ul>
        <ul class="space-y-2">
          <li><a href="/ethanol-extraction-centrifuges-technical-comparison/">Ethanol extraction</a></li>
          <li>Pyrolysis sludge separation</li>
          <li><a href="/dewatering-centrifuge/">Sludge thickening and dewatering</a></li>
          <li>Paint sludge handling</li>
        </ul>
      </div>
    </div>
    <img
      src="/images/alfa-laval-g2-40-decanter/Alfa-Laval-Decanter-Rotating-Assembly-600.webp"
      alt="Alfa Laval Decanter Rotating Assembly"
      width="300"
      height="200"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
  </div>

  <!-- Mid-page CTA -->
  <div class="not-prose bg-gold/10 border border-gold rounded-xl p-6 my-8 text-center">
    <p class="text-lg font-bold text-navy mb-2">Get a Quote for the Alfa Laval G2-40 Decanter</p>
    <p class="text-sm text-text-light mb-4">Dolphin Centrifuge supplies new and reconditioned G2-40 decanter centrifuges with full warranty. Contact our engineering team for application review and pricing.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold/80 text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Get a Quote</a>
      <a href="tel:+12485222573" class="inline-flex items-center gap-2 border border-navy/20 hover:border-gold text-navy font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
    </div>
  </div>

  <!-- FAQ Section -->
  <h2 id="faq">Frequently Asked Questions</h2>

  <div class="space-y-4 not-prose">
    {faqItems.map(item => (
      <details class="border-l-4 border-gold/40 rounded-xl p-5">
        <summary class="font-semibold text-navy cursor-pointer">{item.question}</summary>
        <p class="text-text-light mt-3 text-sm">{item.answer}</p>
      </details>
    ))}
  </div>

  <!-- Bottom CTA bar -->
  <div class="not-prose bg-navy rounded-xl p-8 text-center mt-12">
    <h2 class="text-2xl font-bold text-white mb-3">Alfa Laval G2-40 Decanter — High-Capacity Industrial Separation</h2>
    <p class="text-gray-300 mb-6 max-w-lg mx-auto">Dolphin Centrifuge supplies and services the G2-40 decanter for wastewater, oil, and sludge applications. <a href="/industrial-centrifuge-sample-testing/" class="text-gold hover:text-gold/80 underline">Sample testing</a> available.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold/80 text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Quote</a>
      <a href="/decanter-centrifuge/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">Decanter Centrifuge Guide</a>
    </div>
  </div>

</ApplicationLayout>
