  "name": "Alfa Laval G2-40 Decanter Centrifuge",
  "description": "Alfa Laval G2-40 decanter centrifuge finds multiple uses for sludge thickening and wastewater applications. It is ideal for high sludge mining applications.",
  "brand": { "@type": "Brand", "name": "Alfa Laval" },
  "model": "G2-40",
  "image": "https://dolphincentrifuge.com/images/alfa-laval-g2-40-decanter/alfa-laval-g2-40-decanter-2000.webp",
  "url": "https://dolphincentrifuge.com/alfa-laval-g2-40-decanter/",
  "additionalProperty": [
    { "@type": "PropertyValue", "name": "Rated Capacity", "value": "160 GPM on Water Sludge Thickening" },
    { "@type": "PropertyValue", "name": "Bowl Speed", "value": "4,000 RPM" },
    { "@type": "PropertyValue", "name": "G-Force", "value": "3,150 RCF" },
    { "@type": "PropertyValue", "name": "GearBox Ratio", "value": "1: 52 (3.5 kN-M) DD Gearbox" },
    { "@type": "PropertyValue", "name": "Auger Differential Speed", "value": "1 ~ 140 RPM" }
  ],
  "offers": {
    "@type": "Offer",
    "seller": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge",
      "telephone": "(248) 522-2573",
      "email": "sales@dolphincentrifuge.com",
      "url": "https://dolphincentrifuge.com"
    }
