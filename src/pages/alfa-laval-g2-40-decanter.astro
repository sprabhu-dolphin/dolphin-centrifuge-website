---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqItems = [
  {
    question: "What separations can the G2-40 decanter centrifuge handle?",
    answer: "The G2-40 is a high-performance horizontal scroll decanter designed for demanding two-phase (solid-liquid) and three-phase (oil-water-solid) separations. It is suited for high-solids applications including oily sludge dewatering, industrial wastewater treatment, food processing (starch, gluten, animal rendering), chemical slurries, and municipal biosolids."
  },
  {
    question: "How does the G2-40 compare to the NX-314 and NX-418 decanters?",
    answer: "The G2-40 is Alfa Laval's larger and higher-throughput decanter platform compared to the NX-314 and NX-418. The G2-40 offers greater bowl volume and higher G-force capability for high-volume or high-solids applications. The NX-314 and NX-418 are well-suited for moderate-volume applications (10–80 GPM typical). Contact Dolphin Centrifuge to match the right model to your specific throughput and solids loading requirements."
  },
  {
    question: "Does Dolphin Centrifuge sell new or remanufactured G2-40 decanters?",
    answer: "Dolphin Centrifuge supplies both new and factory-rebuilt G2-40 decanter centrifuges. Rebuilt units are fully disassembled, inspected, worn components replaced, and reassembled to original specifications with a Dolphin warranty. Contact us for current availability and pricing."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval G2-40 Decanter Centrifuge",
  "description": "Alfa Laval G2-40 high-performance decanter centrifuge for industrial liquid-solid and 3-phase separation.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "telephone": "(248) 522-2573",
    "email": "sales@dolphincentrifuge.com",
    "url": "https://dolphincentrifuge.com"
  },
  "model": "G2-40",
  "url": "https://dolphincentrifuge.com/alfa-laval-g2-40-decanter/",
  "offers": {
    "@type": "Offer",
    "seller": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const jsonLd = [productJsonLd, faqJsonLd];

const toc = [
  { id: 'operation', label: 'Operation' },
  { id: 'specifications', label: 'G2-40 Specifications' },
  { id: 'key-features', label: 'Key Features' },
  { id: 'applications', label: 'Applications' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedApplications = [
  { label: 'Decanter Centrifuge Applications', href: '/decanter-centrifuge-applications/' },
  { label: 'Three-Phase Decanter', href: '/three-phase-decanter/' },
  { label: 'Decanter vs Disc Stack', href: '/difference-between-decanter-centrifuge-disc-centrifuge/' },
];

const relatedProducts = [
  { label: 'Alfa Laval CHNX 418 Decanter', href: '/alfa-laval-chnx-418-decanter/', description: 'Nitrogen-purged hazardous duty decanter' },
  { label: 'Alfa Laval NX-314 Decanter', href: '/alfa-laval-nx-314-decanter-centrifuge/', description: '314 mm compact decanter' },
  { label: 'Alfa Laval NX 418 Decanter', href: '/alfa-laval-nx-418-decanter-centrifuge/', description: '418 mm industrial decanter' },
];
---

<ApplicationLayout
  title="Alfa Laval G2-40 Decanter Centrifuge"
  description="Alfa Laval G2-40 decanter centrifuge for solid-liquid and three-phase separation — sludge dewatering, wastewater, food, and chemical processing. Dolphin Centrifuge."
  heroImage="/images/alfa-laval-g2-40-decanter/Decanter-Cross-Section-600.webp"
  heroImageAlt="Decanter Cross Section"
  category="products"
  categoryLabel="Products"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-g2-40-decanter/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <!-- AI Summary — 30-50 words -->
  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">The Alfa Laval G2-40 is a second-generation high-performance horizontal decanter centrifuge for demanding industrial separation — dewatering sludges, slurries, and high-solids process streams. Available in two-phase and three-phase configurations. Dolphin Centrifuge supplies and services the G2-40 from Warren, Michigan.</p>
  </div>

  <!-- Operation -->
  <h2 id="operation">Operation</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <p>
        The Alfa Laval G2-40 is a high-performance horizontal <a href="/decanter-centrifuge/">decanter centrifuge</a> designed for the most demanding industrial separation tasks. The G2 generation design incorporates an optimized scroll geometry for improved solids conveyance, a high-G-force bowl capable of generating greater centrifugal acceleration than previous generation decanters, and an energy-efficient variable frequency drive system that reduces operating costs in high-throughput applications.
      </p>
      <p>
        The G2-40 is available in both two-phase (liquid-solid) and <a href="/three-phase-decanter/">three-phase (liquid-liquid-solid)</a> configurations, making it suitable for a wide range of process industries. The three-phase version adds a second liquid discharge and adjustable pond depth control to enable simultaneous separation of two immiscible liquids and a solid phase — essential for applications such as olive oil extraction, fish processing, and produced water treatment.
      </p>
    </div>
    <img
      src="/images/alfa-laval-g2-40-decanter/Decanter-Cross-Section-600.webp"
      alt="Decanter Cross Section"
      width="300"
      height="200"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
  </div>

  <!-- Specifications -->
  <h2 id="specifications">G2-40 Specifications</h2>

  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
      <tbody>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Centrifuge Model</td>
          <td class="px-4 py-3 font-mono text-text-light">Alfa Laval G2-40</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Centrifuge Type</td>
          <td class="px-4 py-3 font-mono text-text-light">High-Performance Horizontal Decanter</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Separation Configuration</td>
          <td class="px-4 py-3 font-mono text-text-light">Two-Phase or Three-Phase (model dependent)</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Drive System</td>
          <td class="px-4 py-3 font-mono text-text-light">Energy-Efficient VFD (Variable Frequency Drive)</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Scroll Design</td>
          <td class="px-4 py-3 font-mono text-text-light">Optimized G2 Generation Geometry</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">G-Force</td>
          <td class="px-4 py-3 font-mono text-text-light">High G-Force Bowl</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Typical Applications</td>
          <td class="px-4 py-3 font-mono text-text-light">Food, Fish, Olive Oil, Industrial Slurries, Produced Water</td>
        </tr>
        <tr class="bg-gray-50">
          <td class="px-4 py-3 font-semibold text-navy">Polymer Feed</td>
          <td class="px-4 py-3 font-mono text-text-light">Compatible</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Key Features -->
  <h2 id="key-features">Key Features</h2>

  <ul class="space-y-3 mb-8">
    <li><strong>High G-force bowl:</strong> Greater centrifugal acceleration enables effective separation of difficult-to-separate phases and finer particles that lower G-force machines cannot capture.</li>
    <li><strong>Energy-efficient VFD drive:</strong> Variable frequency drive on both the main motor and back drive reduces energy consumption compared to mechanical back drive systems, particularly at partial load.</li>
    <li><strong>Optimized scroll geometry:</strong> The G2 generation scroll design improves solids conveyance efficiency, reducing scroll wear and improving cake dryness at a given differential speed.</li>
    <li><strong>Two- and three-phase configurations:</strong> Available as a two-phase dewatering decanter or a three-phase unit for simultaneous oil-water-solids separation.</li>
  </ul>

  <!-- Applications -->
  <h2 id="applications">Applications</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <div class="grid md:grid-cols-2 gap-x-8 gap-y-2">
        <ul class="space-y-2">
          <li>Olive oil extraction (two-phase and three-phase)</li>
          <li>Fish meal and fish oil processing</li>
          <li><a href="/three-phase-decanter/">Three-phase liquid-liquid-solid separation</a></li>
          <li>Industrial slurry dewatering</li>
        </ul>
        <ul class="space-y-2">
          <li>Produced water treatment</li>
          <li>Starch and gluten processing</li>
          <li>Chemical and polymer slurries</li>
          <li><a href="/decanter-centrifuge/">Municipal and industrial sludge</a></li>
        </ul>
      </div>
    </div>
    <img
      src="/images/alfa-laval-g2-40-decanter/Alfa-Laval-Decanter-Rotating-Assembly-600.webp"
      alt="Alfa Laval Decanter Rotating Assembly"
      width="300"
      height="200"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
  </div>

  <!-- FAQ Section -->
  <h2 id="faq">Frequently Asked Questions</h2>

  <div class="space-y-4 not-prose">
    {faqItems.map(item => (
      <details class="bg-gray-50 rounded-xl border border-gray-200 p-5">
        <summary class="font-semibold text-navy cursor-pointer">{item.question}</summary>
        <p class="text-text-light mt-3 text-sm">{item.answer}</p>
      </details>
    ))}
  </div>

</ApplicationLayout>
