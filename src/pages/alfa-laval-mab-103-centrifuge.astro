---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval MAB 103 Centrifuge",
  "description": "Alfa Laval MAB 103 solid-retaining manual-clean disc-stack centrifuge. 1 HP, 8,600 RPM, 3 GPM on diesel fuel. Specs, dimensions, applications, modifications, and operation.",
  "brand": {
    "@type": "Brand",
    "name": "Alfa Laval"
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "telephone": "(248) 522-2573",
    "email": "sales@dolphincentrifuge.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "24248 Gibson Dr",
      "addressLocality": "Warren",
      "addressRegion": "MI",
      "postalCode": "48089"
    }
  },
  "model": "MAB 103 B 24-60",
  "url": "https://dolphincentrifuge.com/alfa-laval-mab-103-centrifuge/",
  "offers": {
    "@type": "Offer",
    "seller": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the capacity of the Alfa Laval MAB 103 centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Alfa Laval MAB 103 centrifuge can process 3 GPM of diesel fuel (13 cSt), 2.5 GPM of turbine lube oil, or 2 GPM of hydraulic oil. It operates at 8,600 RPM with a 1 HP motor."
      }
    },
    {
      "@type": "Question",
      "name": "Can the MAB 103 be configured for explosion-proof applications?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The MAB 103 can be configured for hazardous area installation with an explosion-proof motor, direct-drive transmission (replacing the friction clutch), classified field sensors, NEMA 7 electrical enclosure, and appropriate cables, conduits, and glands. This configuration is similar to the Alfa Laval OCM-103-Ex with ATEX Zone II rating for offshore applications."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between the MAB 103 and the WSB 203?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Alfa Laval WSB 203 is a concentrator version of the MAB 103, specifically designed for water-based industrial fluids such as machining coolant, washer fluid, and water-soluble cutting oils. While the MAB 103 is a purifier for mineral oil and fuels, the WSB 203 concentrates oil from water-based fluids. Both share the same 1 HP motor and 8,600 RPM bowl speed."
      }
    },
    {
      "@type": "Question",
      "name": "What materials are used in the MAB 103 centrifuge bowl?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The MAB 103 bowl body and bowl hood are made of 316L Duplex Stainless Steel, as is the disc stack. The distributor and top disc are Marine Grade Bronze (or 316 Stainless Steel by special order). The top covers are Silium (Aluminum Alloy) and the frame is Nodular Cast Iron."
      }
    },
    {
      "@type": "Question",
      "name": "What modifications are available for the MAB 103 centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Common modifications include direct drive for explosion-proof configuration, pump reconfiguration for different fluid viscosities, Viton or EPDM seal elastomers for biodiesel or corrosive chemicals, gear pump replacement for water-based fluids, operating frequency conversion (50 or 60 Hz), single-phase motor adaptation, bowl parts material upgrade to stainless steel, and purifier-to-clarifier conversion."
      }
    }
  ]
};
---

<BaseLayout
  title="Alfa Laval MAB 103 Centrifuge"
  description="Alfa Laval MAB 103 disc centrifuge — specs, parts, and service. Dolphin Centrifuge: MAB 103 bowl rebuilds, seal kits, and replacement units. Call (248) 522-2573."
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-mab-103-centrifuge/"
  breadcrumbs={[{label: 'Products', href: '/centrifuges/'}, {label: 'Alfa Laval MAB-103'}]}
  jsonLd={jsonLd}
>

  <!-- FAQPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Hero -->
  <section class="bg-[#1B3A5C] text-white py-14 md:py-20">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <nav class="text-sm text-blue-200 mb-4">
            <a href="/" class="hover:text-white">Home</a>
            <span class="mx-2">/</span>
            <a href="/centrifuges/" class="hover:text-white">Products</a>
            <span class="mx-2">/</span>
            <span class="text-white">Alfa Laval MAB 103</span>
          </nav>
          <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-4" style="font-family: 'Plus Jakarta Sans', sans-serif;">
            Alfa Laval MAB 103 Centrifuge
          </h1>
          <p class="text-lg text-blue-100 mb-4">Specs, Uses, Capacity &amp; Operation</p>
          <p class="text-blue-100 mb-6">Dolphin Centrifuge provides expert service, genuine parts, and fully reconditioned units for this model. The Alfa Laval MAB 103 is a solid-retaining (manual-clean) <a href="/disc-stack-centrifuge/" class="text-[#E8A317] hover:underline">disc-stack centrifuge</a> ideal for continuous, three-phase separation of fuels such as <a href="/diesel-centrifuge/" class="text-[#E8A317] hover:underline">diesel</a>, <a href="/biodiesel-centrifuge/" class="text-[#E8A317] hover:underline">biodiesel</a>, and turbine lube oil. With a 1 HP motor and 8,600 RPM bowl speed, it processes 3 GPM of diesel fuel or 1 GPM of turbine lube oil.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/contact/" class="bg-[#E8A317] text-white font-semibold px-6 py-3 rounded-lg hover:bg-yellow-600 text-center transition-colors">Get a Quote</a>
            <a href="tel:+12485222573" class="border border-white text-white px-6 py-3 rounded-lg hover:bg-white hover:text-[#1B3A5C] text-center transition-colors">(248) 522-2573</a>
          </div>
        </div>
        <div class="flex justify-center">
          <img
            src="/images/alfa-laval-mab-103-centrifuge/Alfa-Laval-MAB103-Class1Div2-300.jpg"
            alt="Alfa Laval MAB 103 Explosion Proof Skid for Compressor Lube Oil in Olefin Plant"
            width="300" height="400"
            loading="eager"
            class="rounded-xl shadow-lg object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Table of Contents -->
  <section class="bg-[#F5F5F0] py-8">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6">
        <h2 class="text-lg font-bold text-[#1B3A5C] mb-4" style="font-family: 'Plus Jakarta Sans', sans-serif;">Table of Contents</h2>
        <div class="grid sm:grid-cols-2 gap-1 text-sm">
          <a href="#overview" class="text-[#1B3A5C] hover:text-[#E8A317] py-1">→ Overview</a>
          <a href="#dimensions" class="text-[#1B3A5C] hover:text-[#E8A317] py-1">→ Dimensions</a>
          <a href="#specifications" class="text-[#1B3A5C] hover:text-[#E8A317] py-1">→ Specifications</a>
          <a href="#material-of-construction" class="text-[#1B3A5C] hover:text-[#E8A317] py-1">→ Material of Construction</a>
          <a href="#applications" class="text-[#1B3A5C] hover:text-[#E8A317] py-1">→ Applications</a>
          <a href="#explosion-proof" class="text-[#1B3A5C] hover:text-[#E8A317] py-1">→ Explosion Proof Configuration</a>
          <a href="#modifications" class="text-[#1B3A5C] hover:text-[#E8A317] py-1">→ Modifications</a>
          <a href="#operation" class="text-[#1B3A5C] hover:text-[#E8A317] py-1">→ Operation</a>
          <a href="#wsb-203" class="text-[#1B3A5C] hover:text-[#E8A317] py-1">→ Alfa Laval WSB 203 Concentrator</a>
          <a href="#wsb-203-specs" class="text-[#1B3A5C] hover:text-[#E8A317] py-1">→ WSB 203 Specifications</a>
          <a href="#wsb-203-applications" class="text-[#1B3A5C] hover:text-[#E8A317] py-1">→ WSB 203 Applications</a>
          <a href="#wsb-203-operation" class="text-[#1B3A5C] hover:text-[#E8A317] py-1">→ WSB 203 Operation</a>
          <a href="#gallery" class="text-[#1B3A5C] hover:text-[#E8A317] py-1">→ MAB 103 Modules Gallery</a>
          <a href="#higher-capacity" class="text-[#1B3A5C] hover:text-[#E8A317] py-1">→ Higher Capacity Centrifuges</a>
          <a href="#faq" class="text-[#1B3A5C] hover:text-[#E8A317] py-1">→ Frequently Asked Questions</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="bg-[#F5F5F0] pb-16">
    <div class="container mx-auto px-4 max-w-4xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
        <p class="text-sm text-text-light leading-relaxed italic">The Alfa Laval MAB 103 centrifuge is a manual-clean solid-bowl disc stack centrifuge rated at 6 GPM (4 GPM on diesel). Dolphin Centrifuge supplies the MAB 103 as the DMB-004 complete centrifuge module — a fully integrated system with controls, piping, and optional heater. Operating at 8,600 RPM with a 1 HP motor, the MAB 103 / DMB-004 handles diesel, biodiesel, and lube oil purification in small-scale applications. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in MAB-series centrifuge systems.</p>
      </div>

      <!-- Overview -->
      <div id="overview" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4" style="font-family: 'Plus Jakarta Sans', sans-serif;">Overview</h2>
        <p class="text-[#2D2D2D] mb-4">
          The Alfa Laval MAB 103 Centrifuge is a solid-retaining (aka solid bowl; manual-clean), <a href="/disc-stack-centrifuge/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">disc-stack centrifuge</a> ideal for the continuous, three-phase separation of fuels, such as <a href="/diesel-centrifuge/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">diesel</a>, <a href="/biodiesel-centrifuge/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">biodiesel</a>, and turbine lube oil.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          With a 1 HP Motor, the MAB 103 centrifuge has a bowl RPM of 8,600 and can process 3 GPM of Diesel Fuel or 1 GPM of Turbine Lube Oil.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          Dolphin Centrifuge supplies purpose-modified and re-manufactured Alfa Laval MAB 103 centrifuges for a wide range of industrial oil purification applications. With over 40 years of experience in centrifugal separation, Dolphin Centrifuge configures each MAB 103 system to match the specific requirements of the application, whether it is diesel fuel polishing on an offshore platform, turbine lube oil purification in a power plant, or hydraulic oil cleaning in a manufacturing facility.
        </p>
        <div class="flex justify-center mt-4">
          <figure class="text-center">
            <img
              src="/images/alfa-laval-mab-103-centrifuge/Alfa-Laval-MAB103-Class1Div2-300.jpg"
              alt="Alfa Laval MAB 103 Explosion Proof Skid for Compressor Lube Oil in Olefin plant"
              width="300" height="400"
              loading="lazy"
              class="rounded-lg shadow mx-auto"
            />
            <figcaption class="text-sm text-gray-500 mt-2">Alfa Laval MAB 103 Explosion Proof Skid for Compressor Lube Oil in Olefin Plant</figcaption>
          </figure>
        </div>
      </div>

      <!-- Dimensions -->
      <div id="dimensions" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4" style="font-family: 'Plus Jakarta Sans', sans-serif;">Dimensions</h2>
        <p class="text-[#2D2D2D] mb-4">
          The Alfa Laval MAB 103 centrifuge has a compact footprint, making it suitable for installation in tight spaces aboard vessels, in plant rooms, and on mobile carts. The bare centrifuge measures 24" x 30" x 26" and weighs 250 lbs. The following drawing shows the dimensional details of the MAB 103 centrifuge.
        </p>
        <div class="flex justify-center">
          <figure class="text-center w-full">
            <img
              src="/images/alfa-laval-mab-103-centrifuge/Alfa-Laval-MAB-103-Dimensions-600.jpg"
              alt="Alfa Laval MAB 103 Centrifuge Dimensions drawing — 24 x 30 x 26 inches"
              width="600" height="330"
              loading="lazy"
              class="rounded-lg shadow mx-auto w-full max-w-xl"
            />
            <figcaption class="text-sm text-gray-500 mt-2">Alfa Laval MAB 103 Dimensions</figcaption>
          </figure>
        </div>
      </div>

      <!-- Specifications -->
      <div id="specifications" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4" style="font-family: 'Plus Jakarta Sans', sans-serif;">Specifications</h2>
        <p class="text-[#2D2D2D] mb-4">
          The following table summarizes the key technical specifications of the Alfa Laval MAB 103 B 24-60 disc-stack centrifuge, including its processing capacity for different fluid types, bowl speed, physical dimensions, motor power, and available voltage configurations.
        </p>
        <div class="overflow-x-auto mb-8">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-[#1B3A5C] text-white">
                <th class="border border-gray-300 px-4 py-2 text-left">Parameter</th>
                <th class="border border-gray-300 px-4 py-2 text-left">Alfa Laval MAB 103 B 24-60</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-gray-50">
                <td class="border border-gray-200 px-4 py-2 font-medium">Centrifuge Model</td>
                <td class="border border-gray-200 px-4 py-2 font-mono">Alfa Laval MAB 103 B 24-60</td>
              </tr>
              <tr>
                <td class="border border-gray-200 px-4 py-2 font-medium">Capacity — Diesel</td>
                <td class="border border-gray-200 px-4 py-2 font-mono">3 GPM on 13 cSt Diesel Fuel</td>
              </tr>
              <tr class="bg-gray-50">
                <td class="border border-gray-200 px-4 py-2 font-medium">Capacity — Turbine Lube Oil</td>
                <td class="border border-gray-200 px-4 py-2 font-mono">2.5 GPM</td>
              </tr>
              <tr>
                <td class="border border-gray-200 px-4 py-2 font-medium">Capacity — Hydraulic Oil</td>
                <td class="border border-gray-200 px-4 py-2 font-mono">2 GPM</td>
              </tr>
              <tr class="bg-gray-50">
                <td class="border border-gray-200 px-4 py-2 font-medium">Sludge Space</td>
                <td class="border border-gray-200 px-4 py-2 font-mono">0.14 Gallons</td>
              </tr>
              <tr>
                <td class="border border-gray-200 px-4 py-2 font-medium">Bowl Speed</td>
                <td class="border border-gray-200 px-4 py-2 font-mono">8,600 RPM</td>
              </tr>
              <tr class="bg-gray-50">
                <td class="border border-gray-200 px-4 py-2 font-medium">Net Weight</td>
                <td class="border border-gray-200 px-4 py-2 font-mono">250 Lbs.</td>
              </tr>
              <tr>
                <td class="border border-gray-200 px-4 py-2 font-medium">Dimensions</td>
                <td class="border border-gray-200 px-4 py-2 font-mono">24" x 30" x 26" (Bare Centrifuge)</td>
              </tr>
              <tr class="bg-gray-50">
                <td class="border border-gray-200 px-4 py-2 font-medium">Motor Power</td>
                <td class="border border-gray-200 px-4 py-2 font-mono">1 HP</td>
              </tr>
              <tr>
                <td class="border border-gray-200 px-4 py-2 font-medium">Voltages</td>
                <td class="border border-gray-200 px-4 py-2 font-mono">230 / 460 V or 110 V Single Phase</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Material of Construction -->
        <div id="material-of-construction">
          <h3 class="text-xl font-bold text-[#1B3A5C] mb-3" style="font-family: 'Plus Jakarta Sans', sans-serif;">Material of Construction</h3>
          <p class="text-[#2D2D2D] mb-4">
            The Alfa Laval MAB 103 is designed for mineral oil and fuel separation applications. Therefore, the material used in its construction is well suited for such uses. The following table lists the various components of the centrifuge and the material it is made of.
          </p>
          <div class="overflow-x-auto">
            <table class="w-full text-sm border-collapse">
              <thead>
                <tr class="bg-[#1B3A5C] text-white">
                  <th class="border border-gray-300 px-4 py-2 text-left">Component</th>
                  <th class="border border-gray-300 px-4 py-2 text-left">Material</th>
                </tr>
              </thead>
              <tbody>
                <tr class="bg-gray-50">
                  <td class="border border-gray-200 px-4 py-2">Bowl Body &amp; Bowl Hood</td>
                  <td class="border border-gray-200 px-4 py-2 font-mono">316L Duplex Stainless Steel</td>
                </tr>
                <tr>
                  <td class="border border-gray-200 px-4 py-2">Disc Stack</td>
                  <td class="border border-gray-200 px-4 py-2 font-mono">316L Duplex Stainless Steel</td>
                </tr>
                <tr class="bg-gray-50">
                  <td class="border border-gray-200 px-4 py-2">Distributor or Disc Carrier</td>
                  <td class="border border-gray-200 px-4 py-2 font-mono">Marine Grade Bronze or 316 Stainless Steel (Special Order)</td>
                </tr>
                <tr>
                  <td class="border border-gray-200 px-4 py-2">Top Disc</td>
                  <td class="border border-gray-200 px-4 py-2 font-mono">Marine Grade Bronze or 316 Stainless Steel (Special Order)</td>
                </tr>
                <tr class="bg-gray-50">
                  <td class="border border-gray-200 px-4 py-2">Top Covers (Collecting)</td>
                  <td class="border border-gray-200 px-4 py-2 font-mono">Silium (Aluminum Alloy)</td>
                </tr>
                <tr>
                  <td class="border border-gray-200 px-4 py-2">Frame</td>
                  <td class="border border-gray-200 px-4 py-2 font-mono">Nodular Cast Iron</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- FAQ Callout -->
      <div class="bg-[#1B3A5C] bg-opacity-5 border-l-4 border-[#E8A317] rounded-r-lg p-4 mb-8">
        <p class="text-[#2D2D2D] italic">
          If you have simple, routine questions: We have condensed our 40+ years of disc-stack centrifuge experience into <a href="/disc-stack-centrifuge-faq/" class="text-[#1B3A5C] underline font-semibold hover:text-[#E8A317]">101 Frequently Asked Questions about Disc Stack Centrifuges!</a>
        </p>
      </div>

      <!-- Applications -->
      <div id="applications" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4" style="font-family: 'Plus Jakarta Sans', sans-serif;">Applications</h2>
        <p class="text-[#2D2D2D] mb-4">
          The Alfa Laval MAB-103 is a purifier-type disc-stack centrifuge. It is designed to separate water (moisture) and fine sediment from mineral oil and lubricating oil. It is primarily used for purifying fuels such as <a href="/diesel-fuel-purifier/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">diesel</a>, kerosene, etc.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          The MAB-103 is also used for separating water and fine sediment from <a href="/lube-oil-centrifuge/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">lubricating oil</a>, <a href="/hydraulic-oil-centrifuge/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">hydraulic oil</a>, and other mineral oils.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          Typical MAB 103 applications include diesel fuel polishing on offshore platforms, compressor lube oil purification in olefin plants and refineries, turbine lube oil cleaning in power generation facilities, and hydraulic oil filtration in manufacturing environments. The compact footprint and low power consumption of the MAB 103 make it well suited for both stationary and mobile installations.
        </p>

        <!-- Explosion Proof -->
        <div id="explosion-proof" class="mt-6">
          <h3 class="text-xl font-bold text-[#1B3A5C] mb-3" style="font-family: 'Plus Jakarta Sans', sans-serif;">Explosion Proof Configuration</h3>
          <div class="flex justify-center mb-4">
            <figure class="text-center">
              <img
                src="/images/alfa-laval-mab-103-centrifuge/Alfa-Laval-MAB103-Class-1-Div-2-Compressor-Oil-250.jpg"
                alt="Explosion Proof Centrifuge Alfa Laval MAB 103 — Class 1 Div 2 Compressor Oil Application"
                width="250" height="250"
                loading="lazy"
                class="rounded-lg shadow mx-auto"
              />
              <figcaption class="text-sm text-gray-500 mt-2">Explosion Proof Centrifuge Alfa Laval MAB 103</figcaption>
            </figure>
          </div>
          <p class="text-[#2D2D2D] mb-4">
            The installation of the MAB-103 centrifuge in hazardous areas requires the centrifuge system to be specially designed and configured with an explosion-proof motor, direct-drive transmission (replace friction clutch), and classified field sensors.
          </p>
          <p class="text-[#2D2D2D] mb-4">
            The control system upgrade includes a NEMA 7 electrical enclosure, cables, conduits, and glands suitable for the specific zone of the centrifuge installation.
          </p>
          <p class="text-[#2D2D2D]">
            We configure our MAB-103 centrifuge similar to the Alfa Laval OCM-103-Ex configuration with explosion-proof ATEX Zone II for offshore applications. You can read more about our <a href="/disc-stack-centrifuge-offshore-applications/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">disc-stack centrifuges for offshore applications.</a>
          </p>
          <div class="mt-4">
            <img
              src="/images/alfa-laval-mab-103-centrifuge/Alfa-Laval-MAB103-ATEX-Zone-2-Lube-Oil-Centrifuge-250.jpg"
              alt="Alfa Laval MAB 103 ATEX Zone 2 lube oil centrifuge configured for hazardous area installation"
              width="250"
              height="250"
              loading="lazy"
              class="rounded-lg"
            />
          </div>
        </div>
      </div>

      <!-- Modifications -->
      <div id="modifications" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4" style="font-family: 'Plus Jakarta Sans', sans-serif;">Modifications</h2>
        <p class="text-[#2D2D2D] mb-4">
          The MAB 103 centrifuge needs modifications for specific applications such as hazardous area installation, and processing of water-based fluids, oil, or fuel. The following is a list of common modifications by Dolphin Centrifuge based on the specific application.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-[#1B3A5C] text-white">
                <th class="border border-gray-300 px-4 py-2 text-left">Centrifuge Modification</th>
                <th class="border border-gray-300 px-4 py-2 text-left">Application / Purpose</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-gray-50">
                <td class="border border-gray-200 px-4 py-2">Direct Drive (Replace Friction Clutch)</td>
                <td class="border border-gray-200 px-4 py-2">Explosion Proof Configuration</td>
              </tr>
              <tr>
                <td class="border border-gray-200 px-4 py-2">Non-Sparking Friction Blocks</td>
                <td class="border border-gray-200 px-4 py-2">Explosion Proof Configuration</td>
              </tr>
