import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "What is the capacity of the Alfa Laval MAB 103 centrifuge?",
    answer: "The Alfa Laval MAB 103 centrifuge can process 3 GPM of diesel fuel (13 cSt), 2.5 GPM of turbine lube oil, or 2 GPM of hydraulic oil. It operates at 8,600 RPM with a 1 HP motor, generating approximately 8,500 Gs of centrifugal force for separation of solids down to 0.5 microns."
  },
  {
    question: "Can the MAB 103 be configured for explosion-proof applications?",
    answer: "Yes. The MAB 103 can be configured for hazardous area installation with an explosion-proof motor, direct-drive transmission (replacing the friction clutch), classified field sensors, NEMA 7 electrical enclosure, and appropriate cables, conduits, and glands. This configuration is similar to the Alfa Laval OCM-103-Ex with ATEX Zone II rating for offshore applications."
  },
  {
    question: "What is the difference between the MAB 103 and the WSB 203?",
    answer: "The Alfa Laval WSB 203 is a concentrator version of the MAB 103, specifically designed for water-based industrial fluids such as <a href='/machine-coolant-centrifuge/'>machining coolant</a>, washer fluid, and water-soluble cutting oils. While the MAB 103 is a purifier for mineral oil and fuels, the WSB 203 concentrates oil from water-based fluids. Both share the same 1 HP motor and 8,600 RPM bowl speed, but the WSB 203 features an all-stainless-steel distributor and top disc instead of the bronze components found in the MAB 103."
  },
  {
    question: "What materials are used in the MAB 103 centrifuge bowl?",
    answer: "The MAB 103 bowl body and bowl hood are made of 316L Duplex Stainless Steel, as is the disc stack. The distributor and top disc are Marine Grade Bronze (or 316 Stainless Steel by special order). The top covers are Silium (Aluminum Alloy) and the frame is Nodular Cast Iron. For applications involving corrosive chemicals such as aqueous ammonia, the bowl parts can be upgraded to full stainless steel construction."
  },
  {
    question: "What modifications are available for the MAB 103 centrifuge?",
    answer: "Common modifications include direct drive for explosion-proof configuration, non-sparking friction blocks, pump reconfiguration for different fluid viscosities, Viton or EPDM seal elastomers for <a href='/biodiesel-centrifuge/'>biodiesel</a> or corrosive chemicals, gear pump replacement for water-based fluids, operating frequency conversion (50 or 60 Hz), single-phase motor adaptation (110 V or 220 V), bowl parts material upgrade to stainless steel, and purifier-to-clarifier conversion for 2-phase separation mode."
  }
];

