---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqItems = [
  {
    question: "What is the WHPX 513 Clarifier Module used for?",
    answer: "The WHPX 513 Clarifier Module is a complete turnkey centrifuge system for removing total suspended solids (TSS) from process liquids down to 0.5 microns at up to 60 GPM. It includes PLC controls, stainless steel feed pump, and pre-filter — pre-wired and factory tested for wastewater clarification, machine coolant recovery, and industrial fluid polishing."
  },
  {
    question: "What is included in the WHPX 513 module package?",
    answer: "The module includes the Alfa Laval WHPX 513 self-cleaning disc stack centrifuge, PLC touchscreen control panel, stainless steel feed pump, pre-filter assembly, skid frame, and all interconnecting pipework — pre-wired and factory tested. Dolphin Centrifuge custom-builds each module to the customer's application requirements."
  },
  {
    question: "How does the clarifier module handle sludge discharge?",
    answer: "The WHPX 513's self-cleaning bowl automatically discharges accumulated solids at programmable intervals using hydraulically operated discharge valves. Discharge takes only a few seconds and does not interrupt fluid flow. The sludge is collected in an integrated sludge tank within the module. No manual bowl opening or cleaning is required between service intervals."
  },
  {
    question: "What flow rate and separation performance does the WHPX 513 clarifier achieve?",
    answer: "In clarifier (2-phase) mode, the WHPX 513 processes up to 60 GPM while achieving particle separation down to 0.5 microns. The 15 HP motor drives the bowl at 4,150 RPM. In 3-phase purifier mode for light oils, rated capacity exceeds 90 GPM."
  },
  {
    question: "Can Dolphin Centrifuge supply parts or service the WHPX 513 module?",
    answer: "Yes. Dolphin Centrifuge provides parts, complete overhauls, and field service for the WHPX 513 and its ancillary module components including the feed pump, PLC panel, and pre-filter. Contact us to schedule preventive maintenance or obtain a parts quotation."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval WHPX 513 Clarifier Centrifuge Module",
  "description": "Alfa Laval WHPX 513 clarifier centrifuge module with PLC controls, stainless steel pump, and pre-filter. 60 GPM wastewater clarification, 15 HP.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/alfa-laval-whpx-513-clarifier-centrifuge-module/",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Alfa Laval WHPX 513 Clarifier Centrifuge Module with PLC Control Panel",
  "description": "Technical overview of the Alfa Laval WHPX 513 clarifier centrifuge module for wastewater, machine coolant, and industrial fluid polishing at 60 GPM.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  },
  "url": "https://dolphincentrifuge.com/alfa-laval-whpx-513-clarifier-centrifuge-module/"
};

const jsonLd = [productJsonLd, faqJsonLd, articleJsonLd];

const toc = [
  { id: 'overview', label: 'Clarifier Module Overview' },
  { id: 'specifications', label: 'Technical Specifications' },
  { id: 'module-components', label: 'Module Components' },
  { id: 'applications', label: 'Applications' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedApplications = [
  { label: 'Wastewater Centrifuge', href: '/wastewater-centrifuge/' },
  { label: 'Machine Coolant Centrifuge', href: '/machine-coolant-centrifuge/' },
  { label: 'Lube Oil Centrifuge', href: '/lube-oil-centrifuge/' },
  { label: 'Diesel Fuel Centrifuge', href: '/diesel-centrifuge/' },
];

const relatedProducts = [
  { label: 'WHPX 513 Fuel Centrifuge', href: '/alfa-laval-whpx-513/', description: '72 GPM diesel purifier configuration' },
  { label: 'DMPX-070 Self-Cleaning System', href: '/centrifuges/dmpx-070/', description: '59-72 GPM diesel, WHPX 513 bowl' },
  { label: 'DMPX-042 Self-Cleaning System', href: '/centrifuges/dmpx-042/', description: '32-47 GPM mid-range' },
];
---

<ApplicationLayout
  title="WHPX 513 Clarifier Centrifuge Module | Dolphin"
  description="Alfa Laval WHPX 513 clarifier centrifuge module with PLC controls, stainless pump, and pre-filter. Removes TSS to 0.5 microns at 60 GPM. Dolphin Centrifuge."
  category="products"
  categoryLabel="Products"
  heroImage="/images/alfa-laval-whpx-513-clarifier-centrifuge-module/Alfa-Laval-WHPX-513-Centrifuge-for-Waste-Water-Clarification.webp"
  heroImageAlt="Alfa Laval WHPX 513 clarifier centrifuge module for wastewater clarification"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-whpx-513-clarifier-centrifuge-module/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="bg-navy/5 border-l-4 border-gold/40 rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies parts, repairs, and remanufactured Alfa Laval WHPX 513 clarifier centrifuge modules for removing total suspended solids (TSS) down to 0.5 microns at up to 60 GPM. Each module includes PLC touch-screen controls, stainless steel feed pump, and pre-filter — pre-wired and factory tested. Warren, Michigan, with over 40 years of centrifuge system integration experience.</p>
  </div>

  <h2 id="overview">Clarifier Module Overview</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <p>
        The Alfa Laval WHPX 513 is a self-cleaning <a href="/disc-stack-centrifuge/">disc stack centrifuge</a> designed for three-phase separation of mixed fluids and sludge. In this configuration, it operates as a two-phase clarifier for removing total suspended solids (TSS) from liquids, achieving particle removal down to 0.5 microns.
      </p>
      <p>
        Powered by a 15 HP motor, the WHPX 513 achieves a bowl speed of 4,150 RPM and is rated at over 90 GPM on light oils. In clarifier mode for <a href="/wastewater-centrifuge/">wastewater applications</a>, it processes up to 60 GPM while separating fine metal particles and other suspended solids.
      </p>
    </div>
    <img
      src="/images/alfa-laval-whpx-513-clarifier-centrifuge-module/Alfa-Laval-WHPX-513-Centrifuge-for-Waste-Water-Clarification.webp"
      alt="Alfa Laval WHPX 513 clarifier centrifuge for wastewater clarification"
      width="300"
      height="300"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
  </div>

  <p>
    This centrifuge module ships as a complete, turnkey system with all ancillary equipment pre-installed, pre-wired, and tested. Simply connect your process piping and power, and the system is ready for operation. For <a href="/industrial-disc-centrifuge-repair/">ongoing centrifuge repair and maintenance</a>, Dolphin Centrifuge provides full field service support.
  </p>

  <div class="bg-gold/10 border-l-4 border-gold rounded-r-xl p-5 my-8 not-prose">
    <p class="text-base font-semibold text-navy mb-1">Custom-built clarifier modules available</p>
    <p class="text-sm text-text-light mb-3">Dolphin Centrifuge builds each WHPX 513 clarifier module to your application requirements — all include PLC controls, feed pump, and pre-filter, factory tested before shipment. <a href="/industrial-centrifuge-sample-testing/" class="text-navy font-semibold hover:text-gold">Sample testing</a> is available to verify performance for your fluid.</p>
    <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold hover:bg-gold/80 text-navy font-bold px-6 py-2 rounded-lg transition-colors text-sm">Request a Quote &rarr;</a>
  </div>

  <h2 id="specifications">Technical Specifications</h2>

  <table>
    <tbody>
      <tr><td><strong>Model Type</strong></td><td>Alfa Laval WHPX 513 TGD 24-60</td></tr>
      <tr><td><strong>Rated Capacity</strong></td><td>60 GPM on Wastewater Clarification</td></tr>
      <tr><td><strong>Sludge Space</strong></td><td>3.87 Gallons</td></tr>
      <tr><td><strong>Motor HP</strong></td><td>15 HP</td></tr>
      <tr><td><strong>Voltages</strong></td><td>230 / 460 V</td></tr>
    </tbody>
  </table>

  <h2 id="module-components">Module Components</h2>

  <p>This centrifuge module includes everything needed for immediate deployment:</p>

  <div class="grid md:grid-cols-2 gap-4 mb-6 not-prose">
    <div class="bg-white rounded-xl p-5 border border-gray-200">
      <h3 class="text-base font-bold text-navy mb-2">PLC Control Panel</h3>
      <p class="text-sm text-text-light">Fully programmed PLC-based control system with touchscreen interface for automated operation, discharge timing, and system monitoring.</p>
    </div>
    <div class="bg-white rounded-xl p-5 border border-gray-200">
      <h3 class="text-base font-bold text-navy mb-2">Stainless Steel Feed Pump</h3>
      <p class="text-sm text-text-light">Corrosion-resistant stainless steel pump sized for the rated flow capacity, ensuring reliable and contamination-free feed delivery.</p>
    </div>
    <div class="bg-white rounded-xl p-5 border border-gray-200">
      <h3 class="text-base font-bold text-navy mb-2">Pre-Filter System</h3>
      <p class="text-sm text-text-light">Inline pre-strainer protects the centrifuge from large debris and extends bowl cleaning intervals for maximum uptime.</p>
    </div>
    <div class="bg-white rounded-xl p-5 border border-gray-200">
      <h3 class="text-base font-bold text-navy mb-2">Integrated Skid</h3>
      <p class="text-sm text-text-light">All components mounted on a structural steel skid with pre-installed piping and wiring for plug-and-play commissioning.</p>
    </div>
  </div>

  <h2 id="applications">Applications</h2>

  <p>The WHPX 513 clarifier module is suited for a variety of industrial clarification duties:</p>

  <ul>
    <li><a href="/wastewater-centrifuge/">Wastewater TSS clarification</a></li>
    <li><a href="/diesel-centrifuge/">Diesel fuel clarification</a> (with piping modification)</li>
    <li><a href="/lube-oil-centrifuge/">Lube oil clarification</a> (with piping modification)</li>
    <li>Mining residual water clarification</li>
    <li><a href="/wvo-centrifuge-separator/">WVO separation from water and solids</a> (with piping modification)</li>
    <li><a href="/machine-coolant-centrifuge/">Machine coolant recovery and polishing</a></li>
  </ul>

  <h3>Related Resources</h3>
  <ul>
    <li><a href="/alfa-laval-whpx-513/">Alfa Laval WHPX 513 Centrifuge (Purifier Configuration)</a></li>
    <li><a href="/disc-stack-centrifuge/">All Disc Stack Centrifuges</a></li>
    <li><a href="/disc-stack-centrifuge-faq/">101 Disc Stack Centrifuge FAQs</a></li>
    <li><a href="/alfa-laval-centrifuge-parts/">Centrifuge Parts &amp; Spares</a></li>
    <li><a href="/industrial-disc-centrifuge-repair/">Disc Centrifuge Repair &amp; Rebuild</a></li>
  </ul>

  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What is the WHPX 513 Clarifier Module used for?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The WHPX 513 Clarifier Module is a complete turnkey centrifuge system for removing total suspended solids (TSS) from process liquids down to 0.5 microns at up to 60 GPM. It includes PLC controls, stainless steel feed pump, and pre-filter — pre-wired and factory tested for wastewater clarification, machine coolant recovery, and industrial fluid polishing.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What is included in the WHPX 513 module package?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The module includes the Alfa Laval WHPX 513 self-cleaning disc stack centrifuge, PLC touchscreen control panel, stainless steel feed pump, pre-filter assembly, skid frame, and all interconnecting pipework — pre-wired and factory tested. Dolphin Centrifuge custom-builds each module to the customer's application requirements.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      How does the clarifier module handle sludge discharge?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The WHPX 513's self-cleaning bowl automatically discharges accumulated solids at programmable intervals using hydraulically operated discharge valves. Discharge takes only a few seconds and does not interrupt fluid flow. The sludge is collected in an integrated sludge tank within the module. No manual bowl opening or cleaning is required between service intervals.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What flow rate and separation performance does the WHPX 513 clarifier achieve?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">In clarifier (2-phase) mode, the WHPX 513 processes up to 60 GPM while achieving particle separation down to 0.5 microns. The 15 HP motor drives the bowl at 4,150 RPM. In 3-phase purifier mode for light oils, rated capacity exceeds 90 GPM.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      Can Dolphin Centrifuge supply parts or service the WHPX 513 module?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">Yes. Dolphin Centrifuge provides parts, complete overhauls, and field service for the WHPX 513 and its ancillary module components including the feed pump, PLC panel, and pre-filter. Contact us to schedule preventive maintenance or obtain a parts quotation.</p>
  </details>

  <div class="bg-navy rounded-xl p-8 text-center mt-12 not-prose">
    <h2 class="text-2xl font-bold text-white mb-3">WHPX 513 Clarifier Module — Get a Quote</h2>
    <p class="text-gray-300 mb-6 max-w-lg mx-auto">Contact Dolphin Centrifuge for clarifier module pricing, custom configurations, and application evaluation. Sample testing available.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold/80 text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Quote</a>
      <a href="/industrial-centrifuge-sample-testing/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">Sample Testing</a>
      <a href="tel:+12485222573" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">(248) 522-2573</a>
    </div>
  </div>

</ApplicationLayout>
