      <tr><td><strong>Model Type</strong></td><td>Alfa Laval WHPX 510 TGD 24-60</td></tr>
      <tr><td><strong>Rated Capacity</strong></td><td>42 GPM on 13 cSt Diesel Fuel</td></tr>
      <tr><td><strong>Sludge Space</strong></td><td>1.62 Gallons</td></tr>
      <tr><td><strong>Motor HP</strong></td><td>10 HP</td></tr>
