        height="400"
        loading="lazy"
        class="rounded-lg w-full"
      />
      <p class="text-sm text-center text-text-light mt-2"><strong>Crude Oil Tank Bottom Dewatering Centrifuge</strong></p>
    </div>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-6 not-prose">
    <div>
      <img
        src="/images/alfa-laval-whpx-510-centrifuge/used-motor-oil-centrifuge-e1614021987386.webp"
