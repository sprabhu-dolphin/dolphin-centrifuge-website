---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqItems = [
  {
    question: "What is the Dolphin equivalent of the Alfa Laval WHPX 510?",
    answer: "The Dolphin DMPX-042 centrifuge system is built around the Alfa Laval WHPX 510 (or equivalent MOPX 209/310 / MAPX 210) centrifuge bowl. The DMPX-042 is a complete system module rated at 32–47 GPM on diesel, with full PLC controls, electric heaters, and piping."
  },
  {
    question: "What flow rate does the Alfa Laval WHPX 510 handle?",
    answer: "The Alfa Laval WHPX 510 handles approximately 42 GPM on diesel fuel (13 cSt at operating temperature) and approximately 24 GPM on lube oil at 30 cSt. For the equivalent Dolphin DMPX-042 system, rated capacity ranges from 32 to 47 GPM on diesel depending on configuration."
  },
  {
    question: "Is the WHPX 510 self-cleaning or manual clean?",
    answer: "The Alfa Laval WHPX 510 is a self-cleaning (automatic partial-discharge) disc stack centrifuge. The bowl automatically ejects accumulated sludge through timed discharge cycles without stopping the centrifuge. This allows continuous uninterrupted operation ideal for high-volume waste oil and diesel purification applications."
  },
  {
    question: "What industries use the WHPX 510 / DMPX-042 centrifuge?",
    answer: "The WHPX 510 / DMPX-042 is widely used in: waste oil recovery and re-refining, diesel fuel polishing for large fleet operations, crude oil dehydration in oilfields, biodiesel glycerin separation, marine fuel purification, and industrial lube oil reclamation. Its 42 GPM capacity on diesel makes it one of the most popular mid-range industrial centrifuges."
  },
  {
    question: "Can Dolphin Centrifuge supply parts or rebuild the WHPX 510?",
    answer: "Yes. Dolphin Centrifuge supplies genuine and compatible replacement parts for the WHPX 510, including disc stacks, seals, bearings, and discharge valve components. Complete bowl rebuilds and remanufactured WHPX 510 centrifuges are available. Each rebuilt unit is factory tested before shipment."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval WHPX 510 Waste Oil Centrifuge",
  "description": "Alfa Laval WHPX 510 self-cleaning disc stack centrifuge for waste oil, diesel, biodiesel, and crude oil. 42 GPM on diesel, 10 HP motor.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/alfa-laval-whpx-510-centrifuge/",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Alfa Laval WHPX 510 Self-Cleaning Waste Oil and Diesel Centrifuge",
  "description": "Technical overview of the Alfa Laval WHPX 510 self-cleaning disc stack centrifuge for waste oil, diesel fuel, crude oil, and biodiesel separation.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  },
  "url": "https://dolphincentrifuge.com/alfa-laval-whpx-510-centrifuge/"
};

const jsonLd = [productJsonLd, faqJsonLd, articleJsonLd];

const toc = [
  { id: 'overview', label: 'WHPX 510 Self-Cleaning Centrifuge' },
  { id: 'specifications', label: 'WHPX 510 Specifications' },
  { id: 'mopx-310', label: 'MOPX 310 Total-Discharge' },
  { id: 'applications', label: 'Applications' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedApplications = [
  { label: 'Waste Oil Centrifuge', href: '/waste-oil-centrifuge/' },
  { label: 'Diesel Fuel Centrifuge', href: '/diesel-centrifuge/' },
  { label: 'Crude Oil Centrifuge', href: '/crude-oil-centrifuge/' },
  { label: 'Biodiesel Centrifuge', href: '/biodiesel-centrifuge/' },
];

const relatedProducts = [
  { label: 'DMPX-042 Self-Cleaning System', href: '/centrifuges/dmpx-042/', description: '32–47 GPM diesel, WHPX 510 bowl' },
  { label: 'DMPX-070 Self-Cleaning System', href: '/centrifuges/dmpx-070/', description: '47–72 GPM large-scale' },
  { label: 'DMPX-014 Self-Cleaning System', href: '/centrifuges/dmpx-014/', description: '13–16 GPM compact' },
];
---

<ApplicationLayout
  title="Alfa Laval WHPX 510 Waste Oil Centrifuge | Dolphin"
  description="Alfa Laval WHPX 510 self-cleaning disc stack centrifuge for waste oil, diesel, and crude oil. 42 GPM capacity, 10 HP, 5,180 RPM. Parts, repairs, and remanufactured units from Dolphin Centrifuge."
  category="products"
  categoryLabel="Products"
  heroImage="/images/alfa-laval-whpx-510-centrifuge/alfa-laval-WHPX510-lubricating-oil-centrifuge-e1614022691140.webp"
  heroImageAlt="Alfa Laval WHPX510 self-cleaning disc stack centrifuge for waste oil and diesel"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-whpx-510-centrifuge/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="bg-navy/5 border-l-4 border-gold/40 rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies parts, repairs, and remanufactured Alfa Laval WHPX 510 self-cleaning disc stack centrifuges rated at 42 GPM on diesel (13 cSt) with a 10 HP motor at 5,180 RPM. Available as the complete DMPX-042 system module for waste oil, diesel, crude oil, and biodiesel separation.</p>
  </div>

  <h2 id="overview">WHPX 510 Self-Cleaning Centrifuge</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start not-prose mb-6">
    <div class="md:w-1/2">
      <p class="text-text-light mb-4">
        The Alfa Laval WHPX 510 is a self-cleaning <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">disc stack centrifuge</a> engineered for the continuous three-phase separation of fuels and oils. It simultaneously separates water, solids, and clean oil in a single pass, eliminating the need for multi-stage processing.
      </p>
      <p class="text-text-light mb-4">
        The WHPX 510 is one of the most versatile centrifuges in the Alfa Laval product line, handling everything from clean <a href="/diesel-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">diesel fuel</a> polishing to heavy <a href="/waste-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">waste oil</a> reclamation. Its 10 HP motor drives the bowl at 5,180 RPM, delivering the centrifugal force needed for efficient separation across a wide range of viscosities.
      </p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/alfa-laval-centrifugal-separator/disc-centrifuge-alfa-laval-whpx-510-300.webp"
        alt="Alfa Laval WHPX 510 disc stack centrifuge"
        width="300"
        height="300"
        loading="lazy"
        class="rounded-lg w-full"
      />
    </div>
  </div>

  <div class="flex flex-col md:flex-row gap-6 items-start not-prose mb-6">
    <div class="md:w-1/2">
      <p class="text-text-light mb-4">
        Available in explosion-proof configurations for hazardous area installations, the WHPX 510 is a workhorse centrifuge found in re-refineries, fuel terminals, marine vessels, and industrial waste oil processing facilities worldwide.
      </p>
      <p class="text-text-light mb-4">
        Dolphin Centrifuge also provides complete <a href="/waste-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">used oil centrifuge</a> systems and <a href="/wvo-centrifuge-separator/" class="text-navy font-semibold hover:text-gold transition-colors">WVO centrifuge separators</a> built around the WHPX 510 platform for waste vegetable oil and cooking oil purification.
      </p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/alfa-laval-whpx-510-centrifuge/Explosion-Proof-Disc-Stack-Centrifuge-for-Crude-Oil-600.webp"
        alt="Explosion proof WHPX 510 disc stack centrifuge for crude oil"
        width="600"
        height="400"
        loading="lazy"
        class="rounded-lg w-full"
      />
      <p class="text-sm text-center text-text-light mt-2"><strong>Explosion Proof WHPX-510 Disc Stack Centrifuge for Crude Oil</strong></p>
    </div>
  </div>

  <div class="bg-gold/10 border-l-4 border-gold rounded-r-xl p-5 my-8 not-prose">
    <p class="text-base font-semibold text-navy mb-1">Need parts, repairs, or a remanufactured WHPX 510?</p>
    <p class="text-sm text-text-light mb-3">Dolphin Centrifuge supplies complete modules with pre-heaters, starters, and PLC control panels — available as the DMPX-042 turnkey system or as individual centrifuge rebuild services for waste oil, diesel, crude oil, and biodiesel applications.</p>
    <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold hover:bg-gold/80 text-navy font-bold px-6 py-2 rounded-lg transition-colors text-sm">Request a Quote &rarr;</a>
  </div>

  <h2 id="specifications">WHPX 510 Specifications</h2>

  <table>
