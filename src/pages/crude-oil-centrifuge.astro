---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqItems = [
  {
    question: "What is a crude oil centrifuge?",
    answer: "A crude oil centrifuge is an industrial centrifuge designed to dewater crude oil and separate particulate matter. These centrifuges exert high centrifugal forces (over 8,000 Gs) to continuously remove all water and sludge particles from crude oil streams, producing sale oil with less than 0.1% BS&W."
  },
  {
    question: "What is BS&W in crude oil?",
    answer: "BS&W stands for Basic Sediment and Water — the total water and solids content in crude oil. Sale oil specifications typically require less than 0.5% to 1% BS&W. A crude oil centrifuge system can reliably produce oil with less than 0.1% BS&W."
  },
  {
    question: "What is a tank bottoms recovery centrifuge?",
    answer: "Tank bottoms are the residue in crude oil settling tanks — a mixture of oil, water, and sediment. A tank bottoms recovery centrifuge processes this residue to recover saleable crude oil. Dolphin's Oil Recovery System (ORS) uses a three-step process: pre-straining, decanter de-sludging, and disc stack polishing to recover oil with less than 0.1% BS&W."
  },
  {
    question: "What is refinery slop oil and how is it treated?",
    answer: "Refinery slop is waste stream from petroleum refineries consisting of wastewater, crude oil, and sludge — often with oil emulsions. Treatment uses a crude oil decanter for de-sludging, followed by a high-speed disc stack centrifuge to separate the liquid phases. Chemical demulsifiers help break difficult emulsions."
  },
  {
    question: "What is water washing of crude oil?",
    answer: "Water washing is a process to remove heavy metals (lead, iron, arsenic, nickel, etc.) from crude oil by adsorption into water. After washing, a 3-phase disc stack centrifuge recovers the crude oil from the wash water. The contaminated wash water requires proper disposal."
  },
  {
    question: "What are the advantages of centrifuges over heater treaters for crude oil?",
    answer: "Centrifuges offer high throughput (thousands of Gs vs. 1 G for gravity settling), compact size, energy efficiency (inline heating vs. heating thousands of barrels), quick deployment, lower capital expense, reduced oil losses (less than 1% BS&W), better quality oil, and reduced disposal costs due to drier sludge cake output."
  },
  {
    question: "What types of crude oil centrifuge systems does Dolphin Centrifuge offer?",
    answer: "Dolphin Centrifuge offers containerized Oil Recovery Systems (ORS) integrated into standard 40-foot containers for remote field deployment, skid-mounted systems for fixed installation in existing facilities, and standalone centrifuge modules. All systems use the proven 3-step process of pre-straining, decanter de-sludging, and disc stack centrifuge polishing."
  },
  {
    question: "What is the difference between a decanter and a disc stack centrifuge for crude oil?",
    answer: "A decanter centrifuge is used as the first line of defense for removing heavy, abrasive solids (sludge) from crude oil streams. A disc stack centrifuge operates at higher speeds (7,000+ Gs) to separate liquid phases — removing water and fine sediment from de-sludged oil to produce sale-quality crude. Most crude oil processing systems use both in sequence."
  }
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "url": "https://dolphincentrifuge.com/crude-oil-centrifuge/",
  "name": "Crude Oil Centrifuge System",
  "description": "Industrial crude oil centrifuges for tank bottom recovery, drilling mud, refinery slop oil, and water washing. 3-phase disc stack and decanter centrifuges, 25-40 GPM, 7,000 Gs.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};
