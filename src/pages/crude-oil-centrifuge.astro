---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "What is a crude oil centrifuge?",
    answer: "A crude oil centrifuge is an industrial centrifuge designed to dewater crude oil and separate particulate matter. These centrifuges exert high centrifugal forces (over 8,000 Gs) to continuously remove all water and sludge particles from crude oil streams, producing sale oil with less than 0.1% BS&W."
  },
  {
    question: "What is BS&W in crude oil?",
    answer: "BS&W stands for Basic Sediment and Water — the total water and solids content in crude oil. Sale oil specifications typically require less than 0.5% to 1% BS&W. A crude oil centrifuge system can reliably produce oil with less than 0.1% BS&W."
  },
  {
    question: "What is a tank bottoms recovery centrifuge?",
    answer: "Tank bottoms are the residue in crude oil settling tanks — a mixture of oil, water, and sediment. A tank bottoms recovery centrifuge processes this residue to recover saleable crude oil. Dolphin's Oil Recovery System (ORS) uses a three-step process: pre-straining, decanter de-sludging, and disc stack polishing to recover oil with less than 0.1% BS&W."
  },
  {
    question: "What are the advantages of centrifuges over heater treaters for crude oil?",
    answer: "Centrifuges offer high throughput (thousands of Gs vs. 1 G for gravity settling), compact size, energy efficiency (inline heating vs. heating thousands of barrels), quick deployment, lower capital expense, reduced oil losses (less than 1% BS&W), better quality oil, and reduced disposal costs due to drier sludge cake output."
  },
  {
    question: "What is the difference between a decanter and a disc stack centrifuge for crude oil?",
    answer: "A decanter centrifuge is used as the first line of defense for removing heavy, abrasive solids (sludge) from crude oil streams. A disc stack centrifuge operates at higher speeds (7,000+ Gs) to separate liquid phases — removing water and fine sediment from de-sludged oil to produce sale-quality crude. Most crude oil processing systems use both in sequence."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "url": "https://dolphincentrifuge.com/crude-oil-centrifuge/",
  "name": "Crude Oil Centrifuge System",
  "description": "Industrial crude oil centrifuges for tank bottom recovery, drilling mud, refinery slop oil, and water washing. 3-phase disc stack and decanter centrifuges, 25-40 GPM, 7,000 Gs.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const articleJsonLd = {
  "@type": "Article",
  "headline": "Crude Oil Centrifuge",
  "description": "Disc centrifuges for crude oil dewatering and desalting. Remove BS&W to pipeline spec. Dolphin Centrifuge supplies WHPX-series purifiers — call (248) 522-2573.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  }
};

const jsonLd = [articleJsonLd, productJsonLd, faqJsonLd];

const toc = [
  { id: 'design-operation', label: 'Design and Operation' },
  { id: 'applications', label: 'Applications in Oil & Gas' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'advantages', label: 'Advantages' },
  { id: 'modules', label: 'Centrifuge Modules' },
  { id: 'faq', label: 'FAQ' },
];

const relatedApplications = [
  { label: 'Oil Centrifuge', href: '/oil-centrifuge/' },
  { label: 'Waste Oil Centrifuge', href: '/waste-oil-centrifuge/' },
  { label: 'Wastewater Centrifuge', href: '/wastewater-centrifuge/' },
  { label: 'Disc Stack Centrifuge Applications', href: '/disc-stack-centrifuge-applications/' },
];

const relatedProducts = [
  { label: 'Alfa Laval WHPX-510', href: '/alfa-laval-whpx-510-centrifuge/', description: '25 GPM on Light Crude Oil' },
  { label: 'Alfa Laval WHPX-513', href: '/alfa-laval-whpx-513/', description: '40 GPM on Light Crude Oil' },
  { label: 'Alfa Laval NX-418 Decanter', href: '/alfa-laval-nx-418-decanter-centrifuge/', description: 'Tank Bottom De-Sludging' },
];
---

<ApplicationLayout
  title="Crude Oil Centrifuge | Dolphin Centrifuge"
  description="Disc centrifuges for crude oil dewatering and desalting. Remove BS&W to pipeline spec. Dolphin Centrifuge supplies WHPX-series purifiers. Call for pricing."
  category="applications"
  categoryLabel="Oil &amp; Gas Application"
  overlay="frost"
  heroImage="/images/crude-oil-centrifuge/crude-oil-centrifuge-hero-nb.webp"
  heroImageAlt="Alfa Laval 3-Phase Centrifuge Class 1 Div 2 Crude Oil Hawaii"
  canonicalUrl="https://dolphincentrifuge.com/crude-oil-centrifuge/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="not-prose bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
    <p class="text-sm text-text leading-relaxed italic">Dolphin Centrifuge supplies three-phase disc stack and decanter centrifuge systems for crude oil dewatering, tank bottom recovery, and refinery slop oil treatment. Operating at 7,000+ Gs with 25-40 GPM throughput, these systems continuously reduce BS&W below 0.1%. Based in Warren, Michigan, with over 40 years of petroleum centrifugation experience.</p>
  </div>

  <!-- Design and Operation -->
  <h2 id="design-operation">Design and Operation</h2>

  <div class="not-prose flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <p class="text-text mb-4 leading-relaxed">
        An <a href="/industrial-centrifuge/" class="text-navy font-medium underline decoration-gold underline-offset-3 hover:text-gold-dark">industrial centrifuge</a> designed to dewater crude oil and separate particulate matter is called a crude oil centrifuge. These centrifuges exert high centrifugal forces (over 8,000 Gs) to continuously remove all water and sludge particles. Sale oil with less than 0.1% BS&amp;W can be reliably reclaimed.
      </p>
      <p class="text-text mb-4 leading-relaxed">
        Crude oil centrifuges are mechanical separating machines used in O&amp;G production applications. They perform a variety of separating functions in petroleum production. From drilling mud recovery to oil washing, centrifuges are versatile tools in the petroleum industry.
      </p>
      <p class="text-text leading-relaxed">
        Heavy sludge is the primary contaminant in all types of crude oil-related streams. It must be removed to protect downstream equipment such as pumps, separators, wellheads, etc.
      </p>
    </div>
    <div class="shrink-0 w-full md:w-[280px]">
      <img
        src="/images/crude-oil-centrifuge/DMPX-042-Self-Cleaning-Disc-Stack-Centrifuge-for-Crude-Oil-Slop.webp"
        alt="DMPX-042 Self-Cleaning Disc Stack Centrifuge for Crude Oil Slop"
        width="800" height="981"
        loading="lazy"
        class="rounded-xl w-full shadow-sm"
      />
      <p class="text-xs text-text-muted mt-2 text-center">DMPX-042 Self-Cleaning Disc Stack Centrifuge for Crude Oil Slop</p>
    </div>
  </div>

  <p>
    A decanter centrifuge is the first line of defense for these heavy, abrasive solids. Alfa Laval <a href="/three-phase-decanter/">three-phase decanters</a> efficiently remove sludge and produce sludge-free oil. De-sludged oil is much easier to handle and treat for recovery of sale oil.
  </p>
  <p>
    In general, these oilfield centrifuges are subject to considerable wear and abrasion. Therefore, these oil centrifuges need to have robust construction and wear protection.
  </p>
  <p>
    Dolphin Centrifuge has considerable experience in all applications using centrifuges for crude oil. Following is a summary of the functions for which we have supplied centrifuges.
  </p>

  <!-- Applications in Oil and Gas Production -->
  <h2 id="applications">Applications in Oil and Gas Production</h2>

  <h3 id="drilling-mud">Drilling Mud Recovery</h3>
  <p>
    Solids control centrifuges are also known as drilling mud centrifuges or decanters. Oil well drilling requires lubrication for efficient operation. This lubricant is a mix of water and barite, which is a mineral.
  </p>
  <p>
    Barite allows the drilling lubricant to work under high pressure in deep wells. The drilling mud carries crushed rocks when it flows back to the surface. Centrifuges separate drill fluids from the crushed solids as the drilling mud returns to the surface.
  </p>
  <p>
    Drilling mud solids are heavy and abrasive. They need heavy-duty gearboxes, wear protection, tiled conveyors, and precision speed control. Wear protection ensures the highest efficiency and durability.
  </p>
  <p>Dolphin Centrifuge has Alfa Laval solids control decanters for sale. Our drilling mud decanter modules include:</p>
  <ul>
    <li>Transfer pumps.</li>
    <li>Clean fluid tanks and return pumps.</li>
    <li>Sludge transfer conveyor.</li>
    <li>Automated VFD control systems.</li>
  </ul>

  <h3 id="obm">Oil-Based Drilling Mud Recovery</h3>
  <p>
    Oil-based drilling mud (OBM) often uses diesel as the lubricant. The oil enhances the lubricity and better temperature resistance without breaking down.
  </p>
  <p>
    Recovery of diesel from OBM is desirable due to the cost of oil. The diesel in used OBM carries colloidal solids, and separating these suspended solids is essential before reusing the oil.
  </p>
  <p>
    Decanters do not exert centrifugal force high enough to extract these suspended solids. A high-speed <a href="/disc-stack-centrifuge/">disc stack centrifuge</a> generates enough force to separate these small particles.
  </p>
  <p>
    Dolphin Centrifuge's oil cleaning system is suitable for recovering diesel from de-sludged OBM. Our solution uses a self-cleaning disc stack centrifuge to extract the colloidal solids. It can also break emulsified oil depending on the type of emulsion.
  </p>

  <h3 id="tank-bottoms">Tank Bottoms Recovery</h3>

  <div class="not-prose flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <p class="text-text mb-4 leading-relaxed">
        Crude oil extracted from wells carries saltwater and sand or other sediments. Producers use settling tanks to skim sale oil from the top of settling tanks. The residue left in the settling tanks is known as tank bottoms.
      </p>
      <p class="text-text mb-4 leading-relaxed">
        Tank bottoms contain Basic Sediment &amp; Water (BS&amp;W). Skimming of sale oil leaves plenty of good oil in tank bottoms. This oil can be recoverable using our centrifuge system for extra revenue.
      </p>
      <p class="text-text leading-relaxed">
        An oilfield centrifuge is a cost-effective solution for <a href="/crude-oil-tank-bottom-recovery-centrifuge/" class="text-navy font-medium underline decoration-gold underline-offset-3 hover:text-gold-dark">tank bottom processing</a> to recover sale oil. The centrifuge also reduces tank bottom sludge, thus significantly reducing tank cleaning costs.
      </p>
    </div>
    <div class="shrink-0 w-full md:w-[280px]">
      <img
        src="/images/crude-oil-centrifuge/Crude-Oil-Tank-Bottom-Recovery-System.webp"
        alt="Crude Oil Tank Bottom Recovery System"
        width="600" height="241"
        loading="lazy"
        class="rounded-xl w-full shadow-sm"
      />
      <p class="text-xs text-text-muted mt-2 text-center">Crude Oil Container &mdash; Virtual 3D Tour of Containerized ORS Module</p>
    </div>
  </div>

  <p>
    Salt Water Disposals (SWDs) use Alfa Laval three-phase centrifuges for dewatering crude oil from produced water.
  </p>

  <div class="not-prose border-l-4 border-gold bg-gold/5 pl-4 py-3 rounded-r-lg mb-4">
    <p class="text-sm text-text italic">
      If you have simple, routine questions: We have condensed our 40+ years of disc-stack centrifuge experience into <a href="/disc-stack-centrifuge-faq/" class="text-navy font-medium underline decoration-gold underline-offset-3 hover:text-gold-dark">101 Frequently Asked Questions about Disc Stack Centrifuges!</a>
    </p>
  </div>

  <p>
    Dolphin Centrifuge has been working with owners and operators to recover tank bottom oil. We have engineered robust solutions for efficient, low-cost oil recovery using specially designed produced water centrifuges.
  </p>
  <p>
    Dolphin-designed &amp; manufactured <strong>Oil Recovery System (ORS)</strong> is an ingenious solution for oil recovery. Our ORS incorporates the 3-step process listed below for crude oil de-watering:
  </p>
  <ul>
    <li>Heating and <strong>pre-straining remove large impurities,</strong> i.e., rocks, organics, etc.</li>
    <li>De-sludging through a <strong>decanter centrifuge</strong> to remove heavy sludge.</li>
    <li>Polishing the de-sludged oil through a <strong>disc stack centrifuge</strong> to separate all free water and remaining fine sediment.</li>
  </ul>

  <h3 id="containerized">Containerized Tank Bottom Recovery System</h3>
  <h4>Containerized Crude Oil Recovery Module &mdash; Three-Phase Alfa Laval Centrifuge</h4>
  <p>
    We have integrated a pre-strainer, decanter &amp; crude oil centrifuge into a standard 40&prime; container. This system includes accessories such as pumps, heaters, sludge augers, buffer tanks, etc.
  </p>
  <p>
    The design of the container is for ease of deployment and use in remote field locations. These modules have interior lighting, service crane(s), interconnecting pipes, automatic PLC control systems, etc.
  </p>
  <p>
    Our <a href="/containerized-industrial-centrifuge/">containerized Oil Recovery System (ORS)</a> is a &lsquo;self-contained&rsquo; module. We designed it to process tank bottoms and recover sale oil with <strong>less than 0.1% BS&amp;W.</strong>
  </p>

  <div class="not-prose flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <img
        src="/images/crude-oil-centrifuge/Alfa-Laval-NX418-1.webp"
        alt="Alfa Laval NX-418 Decanter Centrifuge in Crude Oil Recovery System"
        width="400" height="400"
        loading="lazy"
        class="rounded-xl w-full shadow-sm"
      />
      <p class="text-xs text-text-muted mt-2 text-center">Alfa Laval NX-418 Decanter in ORS Module</p>
    </div>
    <div class="flex-1">
      <img
        src="/images/crude-oil-centrifuge/algae-centrifuge-alfa-laval-40GPM-2.webp"
        alt="Alfa Laval MOPX 207 Self-Cleaning Disc Centrifuge for Frac-Water"
        width="300" height="300"
        loading="lazy"
        class="rounded-xl w-full shadow-sm"
      />
      <p class="text-xs text-text-muted mt-2 text-center">Alfa Laval MOPX 207 Self-Cleaning Disc Centrifuge</p>
    </div>
  </div>

  <h3 id="skid">Skid Mounted Crude Oil Recovery System</h3>

  <div class="not-prose flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <p class="text-text mb-4 leading-relaxed">
        The ORS is also available in a &lsquo;Skid Mounted&rsquo; design, which is suitable for fixed installation in existing facilities. We supply each of the 3-step components as an individual skid-mounted system.
      </p>
      <p class="text-text leading-relaxed">
        The customer has the flexibility to configure the ORS around pre-installed tanks or other assets. Also, the skid-mounted configuration offers lower costs and shorter lead times.
      </p>
    </div>
    <div class="shrink-0 w-full md:w-[280px]">
      <img
        src="/images/crude-oil-centrifuge/algae-centrifuge-alfa-laval-15GPM-2.webp"
        alt="Alfa Laval WHPX 405 Self-Cleaning Disc Centrifuge for Crude Oil"
        width="551" height="600"
        loading="lazy"
        class="rounded-xl w-full shadow-sm"
      />
      <p class="text-xs text-text-muted mt-2 text-center">Alfa Laval WHPX 405 Self-Cleaning Disc Centrifuge</p>
    </div>
  </div>

  <h3 id="slop-oil">Refinery Slop Oil</h3>
  <p>
    Oil refinery waste streams are also known as refinery slop. This waste stream consists of wastewater, crude oil, and sludge. It often contains varying amounts of oil emulsions as well.
  </p>
  <p>
    A refinery slop treatment system includes a crude oil decanter for de-sludging. A high-speed disc stack centrifuge separates the liquid phases in the de-sludged oil. Using chemicals helps the centrifuge break the oily-water mix if the emulsion is present.
  </p>
  <p>
    Therefore, both the <a href="/decanter-centrifuge/">decanter</a> and disc stack centrifuge are well suited for refinery slop oil treatment.
  </p>

  <h3 id="water-washing">Water Washing</h3>
  <p>
    Heavy metals, such as lead, iron, arsenic, nickel, etc., are present in crude oil. Though their presence in trace levels is not an issue, higher levels of metals can cause a problem for the producer.
  </p>
  <p>
    Oil companies do not want to buy crude oil with heavy metals beyond their specified level.
  </p>
  <p>
    Certain types of crude oil are washable with water to remove heavy metals by adsorption. Water absorbs the metals and needs to be separated. A 3-phase disc stack centrifuge recovers the crude oil from the wash water.
  </p>
  <p>
    Of course, this process creates a stream of water with adsorbed heavy metals. This contaminated water stream needs disposal through proper means.
  </p>
  <p>
    <a href="/contact-for-alfa-laval-centrifuges/">Contact Dolphin Centrifuge</a> for further information regarding the use of crude oil centrifuges. Let us use our expertise to your benefit!
  </p>

  <!-- Specifications -->
  <h2 id="specifications">Specifications</h2>
  <p>
    The following are the specifications for a typical Alfa Laval three-phase centrifuge processing <strong>API 40 Light Crude Oil.</strong>
  </p>

  <div class="not-prose overflow-x-auto mb-6">
