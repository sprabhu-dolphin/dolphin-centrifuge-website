  "headline": "Explosion Proof Stainless Steel Centrifuge | Alfa Laval Disc Stack Type",
  "description": "An explosion proof stainless steel centrifuge is an Alfa Laval disc-stack separator designed for the continuous separation of solids from flammable liquids.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
