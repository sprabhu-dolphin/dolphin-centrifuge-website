          <td class="py-3 px-4 font-mono">316 L Stainless Steel (Duplex)</td>
        </tr>
        <tr class="border-b border-gray-200 bg-light-bg">
          <td class="py-3 px-4 font-semibold text-navy">Frame Material</td>
          <td class="py-3 px-4">Nodular Cast Iron</td>
        </tr>
        <tr class="border-b border-gray-200">
          <td class="py-3 px-4 font-semibold text-navy">Bowl Speed</td>
          <td class="py-3 px-4 font-mono">4,400 RPM</td>
        </tr>
        <tr class="border-b border-gray-200 bg-light-bg">
          <td class="py-3 px-4 font-semibold text-navy"><a href="/centrifuge-rcf-rpm-difference-calculation/">RCF</a> (Relative Centrifugal Force)</td>
          <td class="py-3 px-4 font-mono font-bold">6,800 Gs</td>
        </tr>
        <tr class="border-b border-gray-200">
          <td class="py-3 px-4 font-semibold text-navy">Explosion Proof Classification</td>
          <td class="py-3 px-4 font-mono">UL Class 1 Div 2 Groups C&amp;D<br />IEC Zone 2 IIB T4</td>
        </tr>
        <tr>
          <td class="py-3 px-4 font-semibold text-navy">Rated Capacity</td>
          <td class="py-3 px-4 font-mono font-bold">100 Gallons-Per-Minute</td>
        </tr>
      </tbody>
    </table>
  </div>

</ApplicationLayout>
