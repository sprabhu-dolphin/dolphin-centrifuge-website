        <figcaption class="text-lg font-bold text-navy mb-2">Small Lock Ring</figcaption>
      </figure>
      <p class="text-sm text-text-light flex-1">Small lock rings secure internal bowl components. Available for all Alfa Laval separator models.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm flex flex-col">
      <figure class="m-0">
        <div class="h-44 flex items-center justify-center mb-3">
          <img
            src="/images/alfa-laval-centrifuge-parts/disc-centrifuge-paring-disc-250.webp"
            alt="Disc centrifuge paring disc pump"
            width="250"
            height="336"
            loading="lazy"
            style="max-width: 250px; width: 100%;"
            class="h-auto max-h-44 object-contain rounded-xl shadow-sm border border-gray-100"
            data-no-lightbox
          />
        </div>
        <figcaption class="text-lg font-bold text-navy mb-2">Paring Disc Pump</figcaption>
      </figure>
      <p class="text-sm text-text-light flex-1">Stationary paring discs and centripetal pump components for pressurized phase discharge.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm flex flex-col">
      <figure class="m-0">
        <div class="h-44 flex items-center justify-center mb-3">
          <img
            src="/images/alfa-laval-centrifuge-parts/disc-centrifuge-gravity-disc-250.webp"
            alt="Disc centrifuge gravity disc"
            width="250"
            height="238"
            loading="lazy"
            style="max-width: 250px; width: 100%;"
            class="h-auto max-h-44 object-contain rounded-xl shadow-sm border border-gray-100"
            data-no-lightbox
          />
        </div>
        <figcaption class="text-lg font-bold text-navy mb-2">Gravity Disc</figcaption>
      </figure>
