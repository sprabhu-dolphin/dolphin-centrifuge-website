  { id: 'gea-mitsubishi',     label: 'GEA Westfalia and Mitsubishi Separator Parts' },
  { id: 'custom-parts',       label: 'Custom-made industrial centrifuge parts' },
  { id: 'disc-stack-parts',   label: 'Disc-Stack Centrifuges Parts for Sale' },
