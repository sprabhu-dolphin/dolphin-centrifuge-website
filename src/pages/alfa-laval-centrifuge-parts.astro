---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval Centrifuge Parts",
  "description": "Alfa Laval centrifuge parts and spares: disc stacks, bearings, seals, gaskets, bowl components. OEM and aftermarket options with fast shipping from Warren, MI.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  "category": "Industrial Centrifuge Parts",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};
---

<BaseLayout
  title="Alfa Laval Centrifuge Parts"
  description="Alfa Laval centrifuge parts and spares: disc stacks, bearings, seals, gaskets, bowl components. OEM and aftermarket options with fast shipping from Warren, MI."
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-centrifuge-parts/"
  breadcrumbs={[{label: 'Centrifuges', href: '/alfa-laval-centrifuges/'}, {label: 'Centrifuge Parts'}]}
  jsonLd={jsonLd}
>
  <!-- Hero — split layout: navy text left, parts image right -->
  <section class="bg-navy text-white overflow-hidden">
    <div class="container-dolphin">
      <div class="grid lg:grid-cols-2 gap-0 items-center min-h-[420px]">

        <!-- Left: Text -->
        <div class="py-14 lg:py-16 pr-0 lg:pr-10">
          <span class="text-gold text-xs font-bold tracking-wider uppercase">Parts &amp; Spares</span>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4 leading-tight">
            Alfa Laval<br class="hidden sm:block" /> Centrifuge Parts
          </h1>
          <p class="text-gray-300 text-base lg:text-lg max-w-xl mb-6 leading-relaxed">
            OEM and precision aftermarket parts for disc stack and decanter centrifuges. Disc stacks, bearings, seals, bowl components — stocked and shipped fast from our Warren, MI facility.
          </p>
          <!-- Trust chips -->
          <div class="flex flex-wrap gap-2 mb-7">
            <span class="bg-white/10 text-white/80 text-xs font-semibold px-3 py-1.5 rounded-full">✓ 40+ Years Experience</span>
            <span class="bg-white/10 text-white/80 text-xs font-semibold px-3 py-1.5 rounded-full">✓ OEM &amp; Aftermarket</span>
            <span class="bg-white/10 text-white/80 text-xs font-semibold px-3 py-1.5 rounded-full">✓ Fast Nationwide Shipping</span>
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-yellow-400 text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">
              Request Parts Quote
            </a>
            <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">
              (248) 522-2573
            </a>
          </div>
        </div>

        <!-- Right: Parts render image -->
        <div class="hidden lg:flex items-end justify-center h-full pt-6">
          <picture>
            <source srcset="/images/alfa-laval-centrifuge-parts/parts-hero.webp" type="image/webp" />
            <img
              src="/images/alfa-laval-centrifuge-parts/parts-hero.webp"
              alt="Dolphin Centrifuge Major Service Kit — bearings, gears, seals, and centrifuge shaft components"
              class="w-full max-w-[580px] object-contain drop-shadow-2xl"
              loading="eager"
              decoding="async"
              width="580"
              height="323"
            />
          </picture>
        </div>

      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-5xl">

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Centrifuge Parts We Stock</h2>
      <p class="text-text-light mb-4">
        With 40+ years specializing in Alfa Laval centrifuge equipment, Dolphin Centrifuge stocks a comprehensive inventory of replacement parts for both current and legacy models. We carry OEM (original equipment manufacturer) components as well as precision-manufactured aftermarket alternatives that meet or exceed OEM specifications at reduced cost.
      </p>
      <p class="text-text-light mb-8">
        Whether you need a single O-ring for a scheduled service or a complete disc stack for a bowl rebuild, our parts team can identify the correct component by machine model and serial number. Call us at <a href="tel:2485222573" class="text-navy font-semibold hover:text-gold transition-colors">(248) 522-2573</a> or email <a href="mailto:sales@dolphincentrifuge.com" class="text-navy font-semibold hover:text-gold transition-colors">sales@dolphincentrifuge.com</a> with your requirements.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Parts Categories</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-lg font-bold text-navy mb-2">Disc Stacks</h3>
          <p class="text-sm text-text-light">Complete disc stack sets in carbon steel or stainless steel (304, 316L). Available for all Alfa Laval separator models. Individual discs also available.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-lg font-bold text-navy mb-2">Bearings</h3>
          <p class="text-sm text-text-light">Main spindle bearings, top bearings, and thrust bearings. OEM-spec precision bearings matched to machine model for proper fit and balance.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-lg font-bold text-navy mb-2">Seals &amp; O-Rings</h3>
          <p class="text-sm text-text-light">Mechanical shaft seals, paring disc seals, bowl hood seals, operating water seals, and all O-ring kits. Viton, Buna-N, EPDM, and PTFE materials.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-lg font-bold text-navy mb-2">Gaskets</h3>
          <p class="text-sm text-text-light">Bowl body gaskets, hood gaskets, sight glass gaskets, and piping gaskets. Full gasket kits for major overhauls.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-lg font-bold text-navy mb-2">Bowl Components</h3>
          <p class="text-sm text-text-light">Bowl bodies, bowl hoods, sliding bowl bottoms, piston rings, discharge slides, distributor assemblies, and lock rings.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-lg font-bold text-navy mb-2">Drive Components</h3>
          <p class="text-sm text-text-light">Spindles, worm gears, worm wheels, friction clutch pads, brake linings, and coupling components.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-lg font-bold text-navy mb-2">Paring Discs &amp; Pumps</h3>
          <p class="text-sm text-text-light">Stationary paring discs for light and heavy phase outlets. Built-in centripetal pump components for pressurized discharge.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-lg font-bold text-navy mb-2">Frame &amp; Housing</h3>
          <p class="text-sm text-text-light">Frame tops, frame bottoms, bowl hoods, sight glasses, inlet/outlet connections, and cyclone assemblies.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-lg font-bold text-navy mb-2">Decanter Parts</h3>
          <p class="text-sm text-text-light">Scroll assemblies, scroll tiles, weir plates, bearings, seals, gearbox components, and feed tubes for Alfa Laval decanter centrifuges.</p>
        </div>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">OEM vs. Aftermarket Parts</h2>
      <div class="grid md:grid-cols-2 gap-6 mb-10">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">OEM Parts</h3>
          <p class="text-sm text-text-light mb-3">
            Genuine Alfa Laval replacement parts manufactured to the original factory specifications. Required by some customers for warranty compliance or quality programs. Dolphin Centrifuge is an authorized source for OEM Alfa Laval parts.
          </p>
          <ul class="text-sm space-y-1 text-text-muted">
            <li>&#8226; Factory-original specifications</li>
            <li>&#8226; Full material traceability</li>
            <li>&#8226; Warranty compliance</li>
          </ul>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Aftermarket Parts</h3>
          <p class="text-sm text-text-light mb-3">
            Precision-manufactured replacement components built to meet or exceed OEM specifications. Aftermarket parts offer significant cost savings (typically 30-50% less) without compromising performance or reliability.
          </p>
          <ul class="text-sm space-y-1 text-text-muted">
            <li>&#8226; Meets or exceeds OEM specs</li>
            <li>&#8226; 30-50% cost savings</li>
            <li>&#8226; Same materials and tolerances</li>
          </ul>
        </div>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Supported Models</h2>
      <p class="text-text-light mb-4">
        We stock parts for all current and legacy Alfa Laval disc stack separator and decanter centrifuge models. If you have a model number, serial number, or part number, our team can identify and quote the correct replacement component. Common model families include:
      </p>
      <div class="grid md:grid-cols-2 gap-x-8 gap-y-2 mb-8">
        <ul class="text-text-light space-y-2">
          <li>&#8226; MOPX, MAPX, MRPX, MFPX series separators</li>
          <li>&#8226; WHPX, WSPX, WOPX series separators</li>
          <li>&#8226; BRPX, BTPX, BRGX series separators</li>
          <li>&#8226; MMB, MAB, MAB-T clarifiers</li>
        </ul>
        <ul class="text-text-light space-y-2">
          <li>&#8226; NX, CHNX decanter series</li>
          <li>&#8226; G2 decanter series</li>
          <li>&#8226; VNPX, VOPX, AFPX series separators</li>
          <li>&#8226; Legacy and discontinued models</li>
        </ul>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Fast Shipping from Warren, MI</h2>
      <p class="text-text-light mb-4">
        Dolphin Centrifuge maintains a substantial parts inventory at our 24248 Gibson Dr, Warren, MI 48089 facility. In-stock parts typically ship the same day or next business day. For critical breakdowns, we offer expedited shipping options to minimize your downtime.
      </p>
      <p class="text-text-light mb-8">
        For parts identification or pricing, contact our parts team at <a href="tel:2485222573" class="text-navy font-semibold hover:text-gold transition-colors">(248) 522-2573</a> or email <a href="mailto:sales@dolphincentrifuge.com" class="text-navy font-semibold hover:text-gold transition-colors">sales@dolphincentrifuge.com</a>. Please have the machine model, serial number, and part description ready for fastest service.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Related Services &amp; Resources</h2>
      <ul class="text-text-light space-y-2 mb-8">
        <li>&#8226; <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Disc Stack Centrifuge Overview</a></li>
        <li>&#8226; <a href="/decanter-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Decanter Centrifuge Overview</a></li>
        <li>&#8226; <a href="/industrial-centrifuge-controls/" class="text-navy font-semibold hover:text-gold transition-colors">Centrifuge Control Systems</a></li>
        <li>&#8226; <a href="/disc-stack-centrifuge-applications/" class="text-navy font-semibold hover:text-gold transition-colors">Application Directory</a></li>
      </ul>

    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-navy">
    <div class="container-dolphin py-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Need Centrifuge Parts?</h2>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">Provide your machine model, serial number, and the parts you need. We will identify the correct components and ship from our Warren, MI inventory.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3.5 rounded-lg transition-colors">Contact Us</a>
        <a href="/industrial-centrifuge-sample-testing/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3.5 rounded-lg transition-colors">Sample Testing</a>
      </div>
    </div>
  </section>
</BaseLayout>
