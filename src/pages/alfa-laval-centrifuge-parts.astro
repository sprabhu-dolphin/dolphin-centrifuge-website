---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "url": "https://dolphincentrifuge.com/alfa-laval-centrifuge-parts/",
  "name": "Alfa Laval Centrifuge Parts",
  "description": "Alfa Laval centrifuge parts and spares: disc stacks, bearings, seals, gaskets, bowl components. OEM and aftermarket options with fast shipping from Warren, MI.",
  "brand": { "@type": "Brand", "name": "Alfa Laval" },
  "manufacturer": { "@type": "Organization", "name": "Alfa Laval" },
  "category": "Industrial Centrifuge Parts",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge",
      "url": "https://dolphincentrifuge.com",
      "telephone": "(248) 522-2573",
      "email": "sales@dolphincentrifuge.com"
    }
  }
};

const jsonLd = [productJsonLd];

const toc = [
  { id: 'aftermarket-parts',  label: 'Alfa Laval Aftermarket Parts' },
  { id: 'Parts-Gallery',      label: 'Alfa Laval Centrifuge Parts Photo-Gallery' },
  { id: 'gea-mitsubishi',     label: 'GEA Westfalia and Mitsubishi Separator Parts' },
  { id: 'custom-parts',       label: 'Custom-made industrial centrifuge parts' },
  { id: 'disc-stack-parts',   label: 'Disc-Stack Centrifuges Parts for Sale' },
];

const relatedApplications = [
  { label: 'Disc Stack Centrifuge Overview', href: '/disc-stack-centrifuge/' },
  { label: 'Decanter Centrifuge Overview', href: '/decanter-centrifuge/' },
  { label: 'Application Directory', href: '/disc-stack-centrifuge-applications/' },
  { label: 'Disc Centrifuge Parts Glossary', href: '/disc-centrifuge-parts-glossary/' },
  { label: 'Disc Stack Centrifuge FAQ', href: '/disc-stack-centrifuge-faq/' },
];

const relatedProducts = [
  { label: 'Centrifuge Control Systems', href: '/industrial-centrifuge-controls/', description: 'PLC-based control panels for disc & decanter centrifuges' },
  { label: 'Centrifuge Accessories', href: '/alfa-laval-disc-centrifuge-accessories/', description: 'Heaters, strainers, pumps & ancillary equipment' },
];
---

<ApplicationLayout
  title="Alfa Laval Centrifuge Parts"
  pageTitle="Alfa Laval Centrifuge Parts | OEM and Aftermarket"
  description="Alfa Laval centrifuge parts are in stock at Dolphin Centrifuge. With 1000s of parts in inventory, contact us for OEM & Aftermarket Alfa Laval parts."
  category="products"
  categoryLabel="Parts & Spares"
  categoryHref="/disc-centrifuge-parts-glossary/"
  heroImage="/images/alfa-laval-centrifuge-parts/alfa-laval-centrifuge-parts-hero-1400.webp"
  heroImageAlt="Alfa Laval Centrifuge Parts"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-centrifuge-parts/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <p>
    <strong>Alfa Laval centrifuge parts are components for the repair and maintenance of industrial centrifuges. Centrifuges manufactured by Alfa Laval require parts for trouble-free operation. Centrifuge operators need parts for scheduled maintenance.</strong>
  </p>
  <p>
    <a href="/alfa-laval-centrifuge/">Alfa Laval centrifuge</a> parts are always in stock at Dolphin Centrifuge. We carry the complete range of Genuine OEM parts and Aftermarket (generic) parts for Alfa Laval centrifuges.
  </p>
  <p>
    Our <strong>100% compatible, aftermarket</strong> centrifuge parts <strong>save</strong> you <strong>50%</strong> over OEM parts.
  </p>
  <p>
    We have an in-house inventory of over 2000+ Alfa Laval separator parts and bowl assemblies. This large stock allows us to ship most centrifuge parts from stock on the same day. Alfa Laval decanter parts, including bearing service kits and decanter gearbox assemblies, are in stock.
  </p>
  <p>
    If your centrifuge is old and needs a major overhaul or repairs, see the <a href="/dolphin-centrifuge-products-gallery/">complete Alfa Laval centrifuge systems</a> we can supply using reconditioned centrifuges.
  </p>

  <h2 id="aftermarket-parts">Alfa Laval Aftermarket Parts</h2>

  <p>
    <strong>Alfa Laval aftermarket parts are perfectly compatible parts for Alfa Laval centrifuges. High-quality manufacturers produce generic parts for Alfa Laval separators. They save money and time while providing the reliability of genuine parts.</strong>
  </p>
  <p>
    Call us for Reconditioned Bowl Assemblies &amp; Bowl Parts for popular Alfa Laval models. We can even rebuild certain Bowl Parts worn out by long-term use. Visit our <a href="/disc-centrifuge-glossary/">centrifuge parts glossary</a> to get familiar with the unique terminology of disc centrifuges.
  </p>

  <hr />

  <blockquote class="border-l-4 border-gold bg-navy/5 p-4 rounded-r-lg my-6">
    <p class="font-semibold italic">Industrial centrifuges use special high-speed rated Bearings specially made for centrifuges. Do NOT replace centrifuge bearings with aftermarket, 'off-the-shelf,' cheap bearings.</p>
  </blockquote>

  <hr />

  <p>
    These bearings are not suitable for the high operating speeds of industrial centrifuges. Generic bearings can lead to <a href="/disc-stack-centrifuge-vibration/">centrifuge vibrations</a> and possibly catastrophic failures.
  </p>

