    <a href="/picking-the-right-industrial-centrifuge/">Picking the Right Industrial Centrifuge</a> |
    <a href="/beer-wine-centrifuge/">Beer &amp; Wine Centrifuge</a> |
    <a href="/oil-centrifuge/">Oil Centrifuge</a>
  </p>

  <FAQ items={faqItems} />

</ApplicationLayout>
