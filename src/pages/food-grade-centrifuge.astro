---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const title = "Food Grade Centrifuge | Mint Oil Purification | Dolphin Centrifuge";
const description = "Food grade stainless steel centrifuge for beverage clarification and food processing. Continuous separation with up to 10,000 Gs and 1.0 micron efficiency.";

const faqItems = [
  {
    question: "What makes a centrifuge food grade?",
    answer: "A food grade centrifuge has all fluid-contact surfaces constructed from <strong>316L stainless steel</strong>, with polished interior surfaces to minimize product adhesion and facilitate cleaning. Food-grade seals and gaskets are used throughout. These materials meet food safety standards and resist the organic acids found in fruit juices, wine, dairy, and other food products."
  },
  {
    question: "What food processing applications use a centrifuge?",
    answer: "Food grade centrifuges are used for juice clarification (apple, citrus, fruit), wine and beer clarification, edible oil purification, clarified butter (ghee) production, fish oil polishing, essential oil separation (mint, botanical), horseradish processing, potato starch recovery, and flavor extraction. <a href='/contact-for-alfa-laval-centrifuges/'>Contact us</a> with your application for a recommendation."
  },
  {
    question: "How fine can a food grade centrifuge separate?",
    answer: "Dolphin Centrifuge food grade disc stack separators are highly efficient and can separate particles as small as 0.1 microns at up to 10,000 Gs of centrifugal force. A comparable filter to separate such small particles is not feasible for large fluid volumes."
  },
  {
    question: "Can I test my product in a food grade centrifuge before purchasing?",
    answer: "Yes. Dolphin Centrifuge offers pilot testing at our facility or at your production site. We process your actual product through a food grade disc stack centrifuge under controlled conditions and provide a detailed report with results and system recommendations. <a href='/industrial-centrifuge-sample-testing/'>Learn more about our sample testing program</a>."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "url": "https://dolphincentrifuge.com/food-grade-centrifuge/",
  "name": "Food Grade Centrifuge System",
  "description": description,
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const jsonLd = [productJsonLd, faqJsonLd];

const toc = [
  { id: "overview", label: "Operation" },
  { id: "applications", label: "Applications" },
  { id: "benefits", label: "Benefits" },
  { id: "specifications", label: "Specifications" },
  { id: "materials", label: "Material of Construction (MOC)" },
  { id: "application-case-study", label: "Application Case Study" },
];

const relatedApplications = [
  { label: "Beer & Wine Centrifuge", href: "/beer-wine-centrifuge/" },
  { label: "Fish Processing Centrifuge", href: "/fish-processing-centrifuge/" },
  { label: "Algae Centrifuge", href: "/algae-centrifuge/" },
  { label: "Oil Centrifuge", href: "/oil-centrifuge/" },
];

const relatedProducts = [
  { label: "Food Grade Disc-Stack System", href: "/contact-for-alfa-laval-centrifuges/", description: "25 GPM capacity, 316L SS wetted parts" },
  { label: "High-Capacity Food Grade System", href: "/contact-for-alfa-laval-centrifuges/", description: "50+ GPM for large-scale production" },
  { label: "Compact Food Grade Separator", href: "/contact-for-alfa-laval-centrifuges/", description: "Pilot & small-batch processing" },
];
---

<ApplicationLayout
  title={title}
  description={description}
  canonicalUrl="https://dolphincentrifuge.com/food-grade-centrifuge/"
  jsonLd={jsonLd}
  heroImage="/images/food-grade-centrifuge/Alfa-Laval-Food-Grade-Stainless-Steel-3-Phase-Disc-Centrifuge-400.webp"
  heroImageAlt="Alfa Laval Food Grade Stainless Steel 3 Phase Disc Centrifuge"
  category="applications"
  categoryLabel="Applications"
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies food-grade 316L stainless steel disc stack centrifuge systems for beverage clarification, edible oil purification, and food ingredient separation. Operating at up to 10,000 Gs with 1.0-micron separation efficiency, these continuous-flow systems are built in Warren, Michigan.</p>
  </div>

  <!-- Overview -->
  <h2 id="overview">Operation</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-[40%] shrink-0">
      <img
        src="/images/food-grade-centrifuge/Alfa-Laval-Stainless-Steel-Centrifuge-600.webp"
        alt="Alfa Laval Stainless Steel Centrifuge"
        width="600"
        height="450"
        loading="lazy"
        class="rounded-lg shadow-sm w-full h-auto object-contain"
      />
    </div>
    <div>
      <p>
        A food-grade centrifuge is a specifically designed <a href="/industrial-centrifuge/">industrial centrifuge</a> for beverage clarification. With a flow-through design, stainless steel food-grade centrifuges offer continuous processing. High centrifugal force (up to <strong>10,000 Gs</strong>) separates beverages from fine impurities (<strong>1.0 micron</strong>).
      </p>
    </div>
  </div>


  <!-- Applications -->
  <h2 id="applications">Applications</h2>
  <p>
    Food and beverage industry applications for food-grade centrifuges include:
  </p>

  <ul>
    <li><a href="/disc-stack-centrifuge-applications/#Apple-Juice">Apple Juice and Other Fruit Juices</a></li>
    <li><a href="/beer-wine-centrifuge/">Red and White Wine Clarification</a></li>
    <li><a href="/beer-wine-centrifuge/">Beer Clarification</a></li>
    <li><a href="/disc-stack-centrifuge-applications/#Food-Flavoring">Flavor Extraction</a></li>
    <li><a href="/disc-stack-centrifuge-applications/#Horseradish-Extract">Horseradish Juice Clarification</a></li>
    <li><a href="/disc-stack-centrifuge-applications/#Potato-Juice">Potato Juice Clarifier</a></li>
    <li>Clarified Butter Separator</li>
    <li><a href="/fish-processing-centrifuge/">Fish Oil Separation</a></li>
  </ul>

  <!-- Mid-Page CTA -->
  <div class="bg-gradient-to-r from-[#1B3A5C] to-[#2a4f7a] rounded-xl p-6 md:p-8 text-white mb-8 not-prose">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <h3 class="text-xl font-bold mb-2">Need a Food Grade Centrifuge for Your Process?</h3>
        <p class="text-blue-100">Our engineers will evaluate your application and recommend the optimal food grade centrifuge system.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] hover:bg-yellow-500 text-white font-semibold px-6 py-3 rounded-lg transition whitespace-nowrap">Get a Quote</a>
        <a href="tel:+12485222573" class="border border-white text-white hover:bg-white hover:text-[#1B3A5C] font-semibold px-6 py-3 rounded-lg transition whitespace-nowrap">(248) 522-2573</a>
      </div>
    </div>
  </div>

  <!-- Benefits -->
  <h2 id="benefits">Benefits</h2>
  <p>
    A food-grade disc-stack centrifuge offers several benefits over conventional filtration or other gravity-based separation technologies. The following is a list of the main advantages.
  </p>
  <ul>
    <li><strong>Centrifuge Efficiency:</strong> Disc-stack centrifuges are highly efficient and can separate particles as small as 0.1 microns. A comparable filter to separate such small particles is not feasible for large fluid volumes.</li>
    <li><strong>All Stainless Steel Fluid Contact:</strong> Food-grade centrifuge has all stainless-steel wetted parts, making them ideal for processing beverages and other fluids for human consumption.</li>
    <li><strong>Processing Capacity:</strong> With a continuous, flow-through design, food-grade disc-stack centrifuges process large volumes without requiring filtration-related stoppage.</li>
    <li><strong>Automatic Operation:</strong> Fully automated controls and the ability to discharge the separated solids automatically, disc-stack centrifuges offer labor-related cost efficiency as an additional benefit.</li>
    <li><strong>Consistent Flow:</strong> Unlike filters which gradually reduce the flow as the particles block the filter media, disc centrifuges operate with a constant flow rate.</li>
    <li><strong>Large Capacity to Size Ratio:</strong> A food-grade disc centrifuge has a much smaller footprint for similar processing capacity than a filter or settling tank. This feature is an advantage for facilities with limited space.</li>
  </ul>

  <!-- Specifications -->
  <h2 id="specifications">Specifications</h2>
  <p>
    Food-grade centrifuges are available in different configurations. These specifications are for the centrifuge described in the following case study.
  </p>
  <table>
    <thead>
      <tr>
        <th>Specification</th>
        <th>Value</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Type</td>
        <td>3-Phase, Manual Clean, Disc-Stack</td>
      </tr>
      <tr>
        <td>Capacity</td>
        <td>25 GPM on Mint Oil &amp; Water Separation</td>
      </tr>
      <tr>
        <td>Sludge Space</td>
        <td>1 gallon</td>
      </tr>
      <tr>
        <td>Bowl Speed</td>
        <td>8,500 RPM</td>
      </tr>
      <tr>
        <td>G-Force</td>
        <td>8,000 Gs</td>
      </tr>
      <tr>
        <td>Motor</td>
        <td>7.5 HP</td>
      </tr>
      <tr>
        <td>Weight</td>
        <td>1,500 Lbs (Bare Centrifuge)</td>
      </tr>
      <tr>
        <td>Size (Dimensions)</td>
        <td>3' x 4' x 4' (H) (Bare Centrifuge)</td>
      </tr>
    </tbody>
  </table>
  <p>
    Capacities vary by application and product viscosity. <a href="/contact-for-alfa-laval-centrifuges/">Contact our engineers</a> for sizing recommendations specific to your process.
  </p>

  <!-- Materials of Construction -->
  <h2 id="materials">Material of Construction (MOC)</h2>

  <p>
    Most food-grade centrifuges have stainless steel as the primary material of construction. Some special applications with highly corrosive fluids may require exotic materials such as Hastelloy as the MOC.
  </p>
  <p>
    The following table lists the construction material for the most common food-grade centrifuges.
  </p>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-[40%] shrink-0">
      <img
        src="/images/food-grade-centrifuge/Alfa-Laval-Stainless-Steel-Disc-Stack-Centrifuge-600.webp"
        alt="Alfa Laval Stainless Steel Disc Stack Centrifuge"
        width="600"
        height="450"
        loading="lazy"
        class="rounded-lg shadow-sm w-full h-auto object-contain"
      />
    </div>
    <div>
      <table>
        <thead>
          <tr>
            <th>Centrifuge Part</th>
            <th>Material</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Bowl Body</td>
            <td>316 L Stainless Steel</td>
          </tr>
          <tr>
            <td>Bowl Hood</td>
            <td>316 L Stainless Steel</td>
          </tr>
          <tr>
            <td>Inlet / Outlet Assemblies</td>
            <td>316 L Stainless Steel</td>
          </tr>
          <tr>
            <td>Centrifuge Hood (Top Cover)</td>
            <td>Silumin or 316 L Stainless Steel</td>
          </tr>
          <tr>
            <td>Centrifuge Frame</td>
            <td>Cast Iron</td>
          </tr>
          <tr>
            <td>Sludge Discharge Chute</td>
            <td>Cast Iron or Stainless Steel (rare)</td>
          </tr>
          <tr>
            <td>Separated Water Discharge</td>
            <td>316L Stainless Steel or Cast Iron</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Mint Oil Case Study -->
  <h2 id="application-case-study">Application Case Study</h2>

  <p>
    The following is a case study illustrating using a food-grade centrifuge for spearmint oil purification.
  </p>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-[40%] shrink-0">
      <img
        src="/images/food-grade-centrifuge/Alfa-Laval-Disc-Stack-Centrifuge-Stainless-Steel-Explosion-Proof.webp"
        alt="Alfa Laval Disc Stack Centrifuge Stainless Steel Explosion Proof"
        width="600"
        height="450"
        loading="lazy"
        class="rounded-lg shadow-sm w-full h-auto object-contain"
      />
    </div>
    <div>
      <h3>Mint Oil as a Flavoring Agent</h3>
      <p>
        Mint oil is a widely used food flavoring agent. Many consumable products, such as toothpaste, chewing gum, soap, etc., use mint oil.
      </p>

      <h3>Moisture in Crude Mint Oil</h3>
      <p>
        Crude mint oil contains moisture. This moisture removal is necessary before distillation to make the oil dry. Large amounts of water in the oil can cause an unacceptable load on the distillation system. Trace amounts of moisture left in the oil lead to quality &amp; shelf-life issues. An industrial-scale <a href="/stainless-steel-centrifuge/">stainless steel centrifuge</a> is the solution!
      </p>
    </div>
  </div>

  <h3>Pilot Scale Feasibility Testing</h3>
  <p>
    One of the largest peppermint oil producers contacted Dolphin Centrifuge to perform a feasibility study on their oil. The producer wanted to explore centrifuges as a remedy for their moisture problem.
  </p>
  <p>
    Dolphin Centrifuge proposed a pilot-scale test of their mint oil as a proof of concept. Our bench-top, pilot-scale disc centrifuge is ideal for such testing.
  </p>
  <p>
    Disc stack centrifuges show high liquid/liquid separation efficiency. We processed a 20-gallon customer sample through our test centrifuge.
  </p>

  <h3>Testing Results</h3>
  <p>
    The customer technician used a 'freeze test' to verify the dryness of the separated oil (pure mint oil). He would freeze a small volume of the oil in a refrigerator.
  </p>
  <p>
    Clear oil indicated the absence of moisture in the processed oil. All samples taken from our testing centrifuge were clear post-freezing. The customer acknowledged the test to be a success!
  </p>

  <h3>Production Validation</h3>
  <p>
    Based on the pilot-scale test, the customer purchased a <a href="/stainless-steel-centrifuge/">stainless steel centrifuge</a> from Dolphin Centrifuge. Crude mint oil has no particle contamination. So Dolphin supplied a solid bowl-type disc-stack centrifuge for their production. It was a stainless steel, food-grade centrifuge.
  </p>
  <p>
    After the <a href="/oil-centrifuge/">oil centrifuge</a> installation and initial production, the customer returned to Dolphin. The realized production volume from the first unit was as expected. The quality of oil produced was beyond expectations.
  </p>
  <p>
    Based on these facts, the customer ordered multiple food-grade centrifuge units for their entire production volume.
  </p>

  <blockquote>
    Need help selecting a food grade centrifuge for your application? <a href="/contact-for-alfa-laval-centrifuges/">Contact our engineers</a> for a consultation and process evaluation.
  </blockquote>

  <hr />

  <p>
    <strong>Related resources:</strong>
