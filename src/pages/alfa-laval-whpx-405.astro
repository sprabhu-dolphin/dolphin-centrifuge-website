---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqItems = [
  {
    question: "What is the Dolphin equivalent of the Alfa Laval WHPX 405?",
    answer: "The Dolphin DMPX-014 centrifuge system is built around the Alfa Laval WHPX 405 (or equivalent MOPX 205) centrifuge bowl. The DMPX-014 is a complete system module including frame, PLC controls, feed pump, heaters, and piping, rated at 13–16 GPM on diesel fuel."
  },
  {
    question: "What is the difference between the WHPX 405 and MOPX 205?",
    answer: "The Alfa Laval WHPX 405 and MOPX 205 are equivalent centrifuge bowls of the same size class (0.32–0.34 gallon bowl capacity). The WHPX designation indicates a partial-discharge bowl design. Both use the same Dolphin DMPX-014 system module and have similar capacity ratings of 13–16 GPM on diesel at 13 cSt."
  },
  {
    question: "What applications is the WHPX 405 / DMPX-014 best suited for?",
    answer: "The WHPX 405 / DMPX-014 is suited for small to medium throughput applications including diesel fuel polishing (10–15 GPM), pyrolysis oil dewatering, waste oil recovery, lube oil purification, and hydraulic oil cleaning. Its compact size makes it ideal for space-constrained installations."
  },
  {
    question: "What G-force does the Alfa Laval WHPX 405 generate?",
    answer: "The Alfa Laval WHPX 405 operates at approximately 7,200 Gs of centrifugal force at rated bowl speed of 7,600 RPM. This high G-force enables separation of particles down to 0.5 microns and effective water removal from oil and fuel products."
  },
  {
    question: "Can Dolphin Centrifuge repair or supply parts for the WHPX 405?",
    answer: "Yes. Dolphin Centrifuge supplies genuine and compatible replacement parts, complete bowl rebuilds, and remanufactured WHPX 405 and MOPX 205 centrifuges. Each rebuilt unit is tested to factory specifications before shipment. Contact us for parts availability and pricing."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval WHPX 405 Disc Centrifuge",
  "description": "Alfa Laval WHPX 405 partial-discharge disc stack centrifuge for diesel fuel, waste oil, and pyrolysis oil. 15 GPM capacity, 7,200 G-force, 5 HP.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/alfa-laval-whpx-405/",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Alfa Laval WHPX 405 Partial-Discharge Disc Stack Centrifuge",
  "description": "Technical overview of the Alfa Laval WHPX 405 partial-discharge disc stack centrifuge for diesel fuel, waste oil, and pyrolysis oil purification.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  },
  "url": "https://dolphincentrifuge.com/alfa-laval-whpx-405/"
};

const jsonLd = [productJsonLd, faqJsonLd, articleJsonLd];

const toc = [
  { id: 'overview', label: 'WHPX 405 Partial-Discharge Centrifuge' },
  { id: 'specifications', label: 'WHPX 405 Specifications' },
  { id: 'mopx-205', label: 'MOPX 205 Total-Discharge' },
  { id: 'applications', label: 'Applications' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedApplications = [
  { label: 'Diesel Fuel Centrifuge', href: '/diesel-centrifuge/' },
  { label: 'Pyrolysis Oil Centrifuge', href: '/pyrolysis-oil-centrifuge/' },
  { label: 'Waste Oil Centrifuge', href: '/waste-oil-centrifuge/' },
  { label: 'Quench Oil Centrifuge', href: '/quench-oil-centrifuge/' },
];

const relatedProducts = [
  { label: 'DMPX-014 Self-Cleaning System', href: '/dmpx-014-self-cleaning-3-phase-disc-stack-centrifuge/', description: '13–16 GPM diesel, WHPX 405 bowl' },
  { label: 'DMPX-042 Self-Cleaning System', href: '/centrifuges/dmpx-042/', description: '32–47 GPM mid-to-large' },
  { label: 'DMPX-070 Self-Cleaning System', href: '/centrifuges/dmpx-070/', description: '47–72 GPM large-scale' },
];
---

<ApplicationLayout
  title="Alfa Laval WHPX 405 Self-Cleaning Diesel Fuel Centrifuge"
  description="Alfa Laval WHPX 405 partial-discharge disc centrifuge rated at 15 GPM for diesel, pyrolysis oil, and waste oil. 7,200 Gs, 5 HP. Parts and rebuilds available."
  category="products"
  categoryLabel="Products"
  heroImage="/images/alfa-laval-whpx-405/Alfa-Laval-WHPX405-Centrifuge-300-e1615139982322.webp"
  heroImageAlt="Alfa Laval WHPX405 partial-discharge disc stack centrifuge for diesel and waste oil"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-whpx-405/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="bg-navy/5 border-l-4 border-gold/40 rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies parts, repairs, and remanufactured Alfa Laval WHPX 405 partial-discharge disc stack centrifuges rated at 15 GPM on light crude oil with over 7,200 G-force. Available as the DMPX-014 turnkey module for diesel, pyrolysis oil, and waste oil purification. Warren, Michigan — over 40 years of experience.</p>
  </div>

  <h2 id="overview">WHPX 405 Partial-Discharge Centrifuge</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <p>
        The Alfa Laval WHPX 405 is a partial-ejection <a href="/disc-stack-centrifuge/">disc stack centrifuge</a> designed to remove water and solid particles from light oil and light fuel. The partial-discharge mechanism allows the centrifuge to purge only accumulated sludge while retaining process fluid in the bowl, minimizing product losses during each discharge cycle.
      </p>
      <p>
        With an operating speed of 7,600 RPM generating over 7,200 G-force, the WHPX 405 achieves exceptional separation efficiency on light oils and fuels. <a href="/pyrolysis-oil-centrifuge/">Pyrolysis oil</a> and <a href="/waste-oil-centrifuge/">waste oil separation</a> are particularly well-suited applications for this centrifuge.
      </p>
    </div>
    <img
      src="/images/alfa-laval-whpx-405/Alfa-Laval-WHPX405-Centrifuge-300-e1615139982322.webp"
      alt="Alfa Laval WHPX405 partial-discharge disc stack centrifuge"
      width="300"
      height="300"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
  </div>

  <p>
    The WHPX 405 is available in ATEX Zone 2 hazardous area configurations, making it suitable for installations in refineries, offshore platforms, and other environments where flammable vapors may be present.
  </p>

  <h2 id="specifications">WHPX 405 Specifications</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <table>
        <tbody>
          <tr><td><strong>Model Type</strong></td><td>Alfa Laval WHPX 405 TGD 24-60</td></tr>
          <tr><td><strong>Rated Capacity</strong></td><td>15 GPM on 180 cSt Light Crude Oil</td></tr>
          <tr><td><strong>Sludge Space</strong></td><td>0.36 Gallons</td></tr>
          <tr><td><strong>Motor HP</strong></td><td>5 HP</td></tr>
          <tr><td><strong>Voltages</strong></td><td>230 / 460 V</td></tr>
        </tbody>
      </table>
    </div>
    <img
      src="/images/alfa-laval-whpx-405/Alfa-Laval-WHPX405-ATEX-Hazardous-Area-System-300.webp"
      alt="Alfa Laval WHPX405 ATEX hazardous area centrifuge system"
      width="300"
      height="300"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
  </div>

  <div class="bg-gold/10 border-l-4 border-gold rounded-r-xl p-5 my-8 not-prose">
    <p class="text-base font-semibold text-navy mb-1">Need parts, repairs, or a remanufactured WHPX 405?</p>
    <p class="text-sm text-text-light mb-3">Dolphin Centrifuge supplies complete modules with pre-heaters, starters, and PLC control panels — available as the DMPX-014 turnkey system or as individual centrifuge rebuild services.</p>
    <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold hover:bg-gold/80 text-navy font-bold px-6 py-2 rounded-lg transition-colors text-sm">Request a Quote &rarr;</a>
  </div>

  <h2 id="mopx-205">Also Available: MOPX 205 Total-Discharge</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <img
      src="/images/alfa-laval-whpx-405/Alfa-Laval-MOPX205-Diesel-Purifier.webp"
      alt="Alfa Laval MOPX 205 centrifuge for diesel fuel purification"
      width="348"
      height="466"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
    <img
      src="/images/alfa-laval-whpx-405/Alfa-Laval-MOPX205-Diesel-Centrifuge-Occidental-e1614261576568.webp"
      alt="Alfa Laval MOPX205 diesel centrifuge installation"
      width="300"
      height="300"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
    <div class="flex-1">
      <p>
        The Alfa Laval MOPX 205 is a total-discharge disc stack centrifuge in the same size class, designed for three-phase separation of mineral oils and fuels. At 7,600 RPM with over 7,500 G-force, the MOPX 205 is well-suited for <a href="/diesel-centrifuge/">diesel fuel purification</a>, transformer oil, <a href="/quench-oil-centrifuge/">quench oil</a>, and <a href="/black-diesel-centrifuge/">black diesel</a> processing.
      </p>
      <table>
        <tbody>
          <tr><td><strong>Model Type</strong></td><td>Alfa Laval MOPX 205 TGT 20-60</td></tr>
          <tr><td><strong>Rated Capacity</strong></td><td>15 GPM on 13 cSt Diesel Fuel</td></tr>
          <tr><td><strong>Sludge Space</strong></td><td>0.38 Gallons</td></tr>
          <tr><td><strong>Motor HP</strong></td><td>4 HP</td></tr>
          <tr><td><strong>Voltages</strong></td><td>230 / 460 V</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <h3>MOPX 205 for Pyrolysis Oil and Explosion-Proof Installations</h3>
      <p>
        Dolphin Centrifuge supplies the MOPX 205 in explosion-proof configurations for <a href="/explosion-proof-centrifuge/">hazardous area installations</a>. The MOPX 205 is particularly effective for <a href="/pyrolysis-oil-centrifuge/">tire oil and pyrolysis oil</a> dewatering, where its total-discharge design handles heavy sludge loads efficiently.
      </p>
    </div>
    <img
      src="/images/alfa-laval-whpx-405/Alfa-Laval-MOPX205-Tire-Oil-Pyrolysis-Centrifuge-e1614259359680.webp"
      alt="Alfa Laval MOPX205 tire oil pyrolysis centrifuge"
      width="300"
      height="300"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
  </div>

  <h2 id="applications">WHPX 405 / MOPX 205 Centrifuge Applications</h2>

  <p>
    The WHPX 405 and MOPX 205 are versatile centrifuges used across a range of oil and fuel purification applications. The gallery below shows systems manufactured by Dolphin Centrifuge for specific customer applications.
  </p>

  <div class="not-prose grid sm:grid-cols-2 md:grid-cols-3 gap-4 my-6">
    <a href="/fuel-oil-centrifuge/" class="group block rounded-lg overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
      <img src="/images/alfa-laval-whpx-405/Alfa-Laval-MOPX205-Fuel-Oil-Purifier-e1614259048728.webp" alt="Alfa Laval MOPX205 Fuel Oil Purifier" width="300" height="300" loading="lazy" class="w-full h-auto" />
      <p class="text-sm font-semibold text-navy p-3 group-hover:text-gold-dark transition-colors">Fuel Oil</p>
    </a>
    <a href="/diesel-centrifuge/" class="group block rounded-lg overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
      <img src="/images/alfa-laval-whpx-405/Alfa-Laval-MOPX205-Diesel-Centrifuge-Occidental-e1614261576568.webp" alt="Alfa Laval MOPX205 Diesel Centrifuge" width="300" height="300" loading="lazy" class="w-full h-auto" />
      <p class="text-sm font-semibold text-navy p-3 group-hover:text-gold-dark transition-colors">Offshore Diesel</p>
    </a>
    <a href="/pyrolysis-oil-centrifuge/" class="group block rounded-lg overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
      <img src="/images/alfa-laval-whpx-405/Alfa-Laval-MOPX205-Tire-Oil-Pyrolysis-Centrifuge-e1614259359680.webp" alt="Alfa Laval MOPX205 Tire Oil Pyrolysis Centrifuge" width="300" height="300" loading="lazy" class="w-full h-auto" />
      <p class="text-sm font-semibold text-navy p-3 group-hover:text-gold-dark transition-colors">Tire Oil / Pyrolysis Oil</p>
    </a>
    <a href="/machine-coolant-centrifuge/" class="group block rounded-lg overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
      <img src="/images/alfa-laval-whpx-405/Alfa-Laval-WHPX405-Centrifuge-300-e1615139982322.webp" alt="Alfa Laval WHPX405 Centrifuge" width="300" height="300" loading="lazy" class="w-full h-auto" />
      <p class="text-sm font-semibold text-navy p-3 group-hover:text-gold-dark transition-colors">Machine Coolant</p>
    </a>
    <a href="/quench-oil-centrifuge/" class="group block rounded-lg overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
      <img src="/images/alfa-laval-whpx-405/Alfa-Laval-WHPX405-Centrifuge-Quench-Oil-250.webp" alt="Alfa Laval WHPX405 centrifuge for quench oil purification" width="250" height="250" loading="lazy" class="w-full h-auto" />
      <p class="text-sm font-semibold text-navy p-3 group-hover:text-gold-dark transition-colors">Quench Oil</p>
    </a>
    <a href="/explosion-proof-centrifuge/" class="group block rounded-lg overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
      <img src="/images/alfa-laval-whpx-405/MOPX205-Explosion-Proof-Centrifugal-Separator-e1614261752989.webp" alt="MOPX205 Explosion Proof Centrifugal Separator" width="300" height="300" loading="lazy" class="w-full h-auto" />
      <p class="text-sm font-semibold text-navy p-3 group-hover:text-gold-dark transition-colors">Explosion-Proof (Gasoline)</p>
    </a>
  </div>

  <p>
    The WHPX 405 and MOPX 205 are also used for <a href="/lube-oil-centrifuge/">lube oil clarification</a> on turbines and industrial engines, where continuous moisture and particle removal extends equipment life.
  </p>
  <p>
    Also see our <strong><a href="/alfa-laval-centrifuge-selection-guide/">Alfa Laval Centrifuge Selection Guide</a></strong> for help choosing the right centrifuge for your application.
  </p>
  <p>
    <a href="/disc-stack-centrifuge/">Looking for a complete turnkey system? See our disc stack centrifuge systems &rarr;</a>
  </p>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <h3>Parts, Repairs, and Remanufactured Units</h3>
      <p>
        Dolphin Centrifuge supplies fully reconditioned <a href="/alfa-laval-centrifuge-parts/">MOPX 205 and WHPX 405 centrifuges</a> with explosion-proof motor and control panel options. Each unit is rebuilt with new seals, bearings, and wear components, and tested to factory specifications before shipment. Contact our team for <a href="/industrial-centrifuge-sample-testing/">sample testing</a> to confirm suitability for your application. For ongoing maintenance, see our <a href="/industrial-disc-centrifuge-repair/">disc centrifuge repair services</a>.
      </p>
    </div>
    <img
      src="/images/alfa-laval-whpx-405/MOPX205-Explosion-Proof-Centrifugal-Separator-e1614261752989.webp"
      alt="MOPX205 explosion proof centrifugal separator"
      width="300"
      height="300"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
  </div>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <img
      src="/images/alfa-laval-whpx-405/Alfa-Laval-MOPX205-Fuel-Oil-Purifier-e1614259048728.webp"
      alt="Alfa Laval MOPX205 fuel oil purifier centrifuge"
      width="300"
      height="300"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
    <div class="flex-1">
      <h3>Related Resources</h3>
      <ul>
        <li><a href="/alfa-laval-centrifuge-selection-guide/">Alfa Laval Centrifuge Selection Guide</a></li>
        <li><a href="/disc-stack-centrifuge/">Disc Stack Centrifuge Overview</a></li>
        <li><a href="/alfa-laval-centrifuge-parts/">Centrifuge Parts &amp; Spares</a></li>
        <li><a href="/industrial-disc-centrifuge-repair/">Disc Centrifuge Repair &amp; Rebuild</a></li>
      </ul>
    </div>
  </div>

  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What is the Dolphin equivalent of the Alfa Laval WHPX 405?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The Dolphin DMPX-014 centrifuge system is built around the Alfa Laval WHPX 405 (or equivalent MOPX 205) centrifuge bowl. The DMPX-014 is a complete system module including frame, PLC controls, feed pump, heaters, and piping, rated at 13–16 GPM on diesel fuel.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What is the difference between the WHPX 405 and MOPX 205?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The Alfa Laval WHPX 405 and MOPX 205 are equivalent centrifuge bowls of the same size class (0.32–0.34 gallon bowl capacity). The WHPX designation indicates a partial-discharge bowl design. Both use the same Dolphin DMPX-014 system module and have similar capacity ratings of 13–16 GPM on diesel at 13 cSt.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What applications is the WHPX 405 / DMPX-014 best suited for?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The WHPX 405 / DMPX-014 is suited for small to medium throughput applications including diesel fuel polishing (10–15 GPM), pyrolysis oil dewatering, waste oil recovery, lube oil purification, and hydraulic oil cleaning. Its compact size makes it ideal for space-constrained installations.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What G-force does the Alfa Laval WHPX 405 generate?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The Alfa Laval WHPX 405 operates at approximately 7,200 Gs of centrifugal force at rated bowl speed of 7,600 RPM. This high G-force enables separation of particles down to 0.5 microns and effective water removal from oil and fuel products.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      Can Dolphin Centrifuge repair or supply parts for the WHPX 405?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">Yes. Dolphin Centrifuge supplies genuine and compatible replacement parts, complete bowl rebuilds, and remanufactured WHPX 405 and MOPX 205 centrifuges. Each rebuilt unit is tested to factory specifications before shipment. Contact us for parts availability and pricing.</p>
  </details>

  <div class="bg-navy rounded-xl p-8 text-center mt-12 not-prose">
    <h2 class="text-2xl font-bold text-white mb-3">Parts, Repairs &amp; Remanufactured WHPX 405</h2>
    <p class="text-gray-300 mb-6 max-w-lg mx-auto">Contact Dolphin Centrifuge for pricing, availability, and application support. Sample testing available for qualifying applications.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold/80 text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Quote</a>
      <a href="/industrial-centrifuge-sample-testing/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">Sample Testing</a>
      <a href="tel:+12485222573" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">(248) 522-2573</a>
    </div>
  </div>

</ApplicationLayout>
