---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Decanter Centrifuge Rental",
  "description": "Rent industrial decanter centrifuges for sludge dewatering, wastewater, and oil recovery. NX-314, NX-418, and G2-40 models available short or long term.",
  "provider": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "address": { "@type": "PostalAddress", "streetAddress": "24248 Gibson Dr.", "addressLocality": "Warren", "addressRegion": "MI", "postalCode": "48089", "addressCountry": "US" },
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "url": "https://dolphincentrifuge.com/decanter-centrifuge-rental/",
};
---

<BaseLayout
  title="Decanter Centrifuge Rental"
  description="Rent industrial decanter centrifuges for sludge dewatering, wastewater, and oil recovery. NX-314, NX-418, and G2-40 models available short or long term."
  canonicalUrl="https://dolphincentrifuge.com/decanter-centrifuge-rental/"
  breadcrumbs={[
    { label: 'Services', href: '/industrial-centrifuge-design/' },
    { label: 'Decanter Centrifuge Rental' },
  ]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">Services</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">Decanter Centrifuge Rental</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">
        Dolphin Centrifuge offers industrial decanter centrifuges for short-term and long-term rental. Our fleet includes NX-314, NX-418, and G2-40 decanters suited for sludge dewatering, wastewater treatment, crude oil recovery, and solids-heavy separation applications.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Get a Free Quote</a>
        <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-4xl">

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Industrial Decanter Centrifuge Rental Program</h2>
      <p class="text-text-muted mb-4">
        Decanter centrifuges are the workhorse of solids-liquid separation. Unlike disc stack separators that handle fine particles and liquid-liquid separation, decanters are designed for high-solids feeds&mdash;slurries, sludges, and suspensions where the solid phase can represent 5% to 60% or more of the total volume.
      </p>
      <p class="text-text-muted mb-8">
        Renting a decanter centrifuge from Dolphin Centrifuge gives you access to fully rebuilt, production-ready equipment without the capital expenditure. Every rental decanter is rebuilt in our <a href="/industrial-disc-centrifuge-repair/" class="text-navy font-semibold hover:text-gold transition-colors">Warren, Michigan service facility</a> with new bearings, seals, and hard-facing as needed.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Available Decanter Models</h2>

      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm text-left border border-gray-200 rounded-lg overflow-hidden">
          <thead class="bg-navy text-white">
            <tr>
              <th class="px-4 py-3 font-semibold">Model</th>
              <th class="px-4 py-3 font-semibold">Bowl Diameter</th>
              <th class="px-4 py-3 font-semibold">Throughput</th>
              <th class="px-4 py-3 font-semibold">Typical Applications</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200 text-text-muted">
            <tr>
              <td class="px-4 py-3 font-mono font-semibold">NX-314</td>
              <td class="px-4 py-3">14 inches</td>
              <td class="px-4 py-3">Up to 30 GPM</td>
              <td class="px-4 py-3">Wastewater sludge, oily water, drilling mud</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-mono font-semibold">NX-418</td>
              <td class="px-4 py-3">18 inches</td>
              <td class="px-4 py-3">Up to 80 GPM</td>
              <td class="px-4 py-3">Municipal sludge, industrial wastewater, oil sludge</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-mono font-semibold">G2-40</td>
              <td class="px-4 py-3">16 inches</td>
              <td class="px-4 py-3">Up to 60 GPM</td>
              <td class="px-4 py-3">High-G dewatering, fine solids, chemical sludge</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-mono font-semibold">CHNX-418</td>
              <td class="px-4 py-3">18 inches</td>
              <td class="px-4 py-3">Up to 80 GPM</td>
              <td class="px-4 py-3">Food-grade, chemical, pharmaceutical</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Decanter Rental Applications</h2>
      <p class="text-text-muted mb-4">
        Our rental decanters serve a wide range of industries and use cases:
      </p>
      <ul class="list-disc list-inside space-y-2 text-text-muted mb-8 ml-4">
        <li><strong>Wastewater Sludge Dewatering:</strong> Reduce sludge volume by 70&ndash;90% before disposal, cutting hauling and landfill costs</li>
        <li><strong>Oily Water Treatment:</strong> Separate free oil from produced water, bilge water, or wash water for compliant discharge</li>
        <li><strong>Crude Oil Recovery:</strong> Recover oil from tank bottoms, pit cleanouts, and drilling waste</li>
        <li><strong>Industrial Process:</strong> Clarify process liquids, recover valuable solids, or dewater slurries</li>
        <li><strong>Emergency Response:</strong> Rapid deployment for spill cleanup, lagoon closure, or regulatory compliance deadlines</li>
        <li><strong>Pilot Testing:</strong> Run your actual feed material through a full-scale decanter to generate reliable design data before purchasing</li>
      </ul>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">What's Included</h2>
      <p class="text-text-muted mb-4">
        Dolphin Centrifuge rental decanters are delivered as complete, ready-to-operate systems:
      </p>
      <ul class="list-disc list-inside space-y-2 text-text-muted mb-8 ml-4">
        <li>Fully rebuilt decanter centrifuge with new bearings, seals, and wear components</li>
        <li>Drive motor, VFD (variable frequency drive), and control panel</li>
        <li>Feed pump and polymer dosing system (if applicable)</li>
        <li>Interconnecting piping and process connections</li>
        <li>Operating manual with recommended parameters for your application</li>
        <li>Remote or on-site startup and commissioning support</li>
        <li>Technical support throughout the rental period</li>
      </ul>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Rental Terms &amp; Pricing</h2>
      <p class="text-text-muted mb-4">
        We structure rental agreements to fit your project requirements:
      </p>
      <ul class="list-disc list-inside space-y-2 text-text-muted mb-8 ml-4">
        <li><strong>Short-Term (1&ndash;3 months):</strong> Ideal for project work, pilot testing, or emergency needs</li>
        <li><strong>Long-Term (6&ndash;12+ months):</strong> Reduced monthly rates for extended commitments</li>
        <li><strong>Rent-to-Own:</strong> Apply a portion of rental payments toward eventual purchase</li>
        <li><strong>Mobilization:</strong> We coordinate trucking and delivery nationwide</li>
        <li><strong>Insurance:</strong> Rental includes standard equipment coverage</li>
      </ul>
      <p class="text-text-muted mb-8">
        Rental pricing depends on the model, duration, and application. Contact us at <a href="mailto:sales@dolphincentrifuge.com" class="text-navy font-semibold hover:text-gold transition-colors">sales@dolphincentrifuge.com</a> or <a href="tel:2485222573" class="text-navy font-semibold hover:text-gold transition-colors">(248) 522-2573</a> for a detailed quote.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Need a Disc Stack Separator Instead?</h2>
      <p class="text-text-muted mb-4">
        If your application involves liquid-liquid separation, fine solids removal, or oil purification, a disc stack centrifuge may be a better fit. See our <a href="/disc-stack-centrifuge-rental/" class="text-navy font-semibold hover:text-gold transition-colors">disc stack centrifuge rental program</a> for DMPX-series self-cleaning separators.
      </p>
      <p class="text-text-muted mb-4">
        Not sure which type you need? Our <a href="/industrial-centrifuge-sample-testing/" class="text-navy font-semibold hover:text-gold transition-colors">sample testing service</a> can determine the optimal centrifuge type and size for your specific material.
      </p>

    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-navy">
    <div class="container-dolphin py-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Ready to Rent a Decanter?</h2>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">Tell us about your application, volume, and timeline. We will match you with the right decanter and provide a rental quote within 24 hours.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3.5 rounded-lg transition-colors">Contact Us Today</a>
        <a href="/industrial-centrifuge-sample-testing/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3.5 rounded-lg transition-colors">Sample Testing</a>
      </div>
    </div>
  </section>
</BaseLayout>
