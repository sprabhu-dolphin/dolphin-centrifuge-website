    <div class="md:w-1/2">
      <img loading="lazy" src="/images/decanter-centrifuge-rental/Alfa-Laval-NX418-Decanter-C1D2-for-Hemp-Ethanol-Processing-1000.webp" alt="Alfa Laval NX418 Decanter C1D2 for Hemp Ethanol Processing" width="1000" height="701" class="rounded-xl" />
