---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "What decanter centrifuge models does Dolphin Centrifuge have available for rental?",
    answer: "Dolphin Centrifuge offers rental of Alfa Laval NX-314 and NX-418 decanter centrifuges — horizontal scroll decanters suitable for sludge dewatering, oily water separation, industrial wastewater, and oil-based drilling mud recovery. Availability varies; contact us for current rental inventory."
  },
  {
    question: "How long is the minimum rental period for a decanter centrifuge?",
    answer: "Rental terms are flexible based on your project timeline. Minimum rental periods typically start at 1 month for short-term pilot projects or emergency capacity situations. Long-term rentals (3–12 months or longer) are available for extended projects or while capital equipment is on order."
  },
  {
    question: "Does the rental include delivery, setup, and support?",
    answer: "Yes. Dolphin Centrifuge rental packages include delivery to your site, on-site commissioning assistance, and phone/remote technical support during the rental period. We can also provide operator training for your team. Contact us to discuss the level of support needed for your application."
  },
  {
    question: "What is the difference between renting a decanter and a disc stack centrifuge?",
    answer: "Decanter centrifuges are designed for high-solids feeds — slurries, sludges, and suspensions with 5% to 60%+ solids. Disc stack centrifuges handle fine particles, liquid-liquid separation, and oil purification with typically less than 5% solids. If your application involves wastewater sludge dewatering or slurry processing, a decanter is usually the right choice. For oil clarification or oily water polishing, a disc stack separator is more appropriate."
  },
  {
    question: "Can a rented decanter centrifuge be converted to a purchase?",
    answer: "Yes. Dolphin Centrifuge offers rent-to-own arrangements where a portion of rental payments can be applied toward the purchase price of the unit. This allows you to validate the equipment's performance in your facility before committing to a capital purchase. Contact us to discuss rent-to-own terms for your specific application."
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Decanter Centrifuge Rental",
  "description": "Rent industrial decanter centrifuges for sludge dewatering, wastewater treatment, and oil recovery. NX-314, NX-418, and G2-40 models available for short or long-term rental from Dolphin Centrifuge.",
  "provider": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "address": { "@type": "PostalAddress", "streetAddress": "24248 Gibson Dr.", "addressLocality": "Warren", "addressRegion": "MI", "postalCode": "48089", "addressCountry": "US" },
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "url": "https://dolphincentrifuge.com/decanter-centrifuge-rental/",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Decanter Centrifuge Rental Program",
  "description": "Rent industrial decanter centrifuges from Dolphin Centrifuge. NX-314 and NX-418 models for sludge dewatering, wastewater treatment, and oil recovery. Short- and long-term rental from Warren, Michigan.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/decanter-centrifuge-rental/",
  "mainEntityOfPage": "https://dolphincentrifuge.com/decanter-centrifuge-rental/"
};

const toc = [
  { id: 'overview', label: 'Rental Fleet Overview' },
  { id: 'nx314', label: 'NX-314 Rental Decanter' },
  { id: 'nx418', label: 'NX-418 Rental Decanter' },
  { id: 'program', label: 'Rental Program Details' },
  { id: 'applications', label: 'Rental Applications' },
  { id: 'included', label: "What's Included" },
  { id: 'terms', label: 'Rental Terms & Pricing' },
  { id: 'modules', label: 'Decanter Modules' },
  { id: 'faq', label: 'FAQ' },
];

const relatedApplications = [
  { label: 'Disc Stack Centrifuge Rental', href: '/disc-stack-centrifuge-rental/' },
  { label: 'Decanter Centrifuge Applications', href: '/decanter-centrifuge-applications/' },
  { label: 'Sample Testing Service', href: '/industrial-centrifuge-sample-testing/' },
];

const relatedProducts = [
  { label: 'NX-314 Decanter', href: '/alfa-laval-nx-314-decanter-centrifuge/', description: '40 GPM, wastewater & sludge' },
  { label: 'NX-418 Decanter', href: '/alfa-laval-nx-418-decanter-centrifuge/', description: '80 GPM, industrial wastewater' },
  { label: 'Centrifuge Buyback', href: '/industrial-centrifuge-buyback/', description: 'Sell or trade your centrifuge' },
];
