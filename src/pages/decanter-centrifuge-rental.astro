---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Decanter Centrifuge Rental",
  "description": "Dolphin Centrifuge reviews decanter centrifuge rental requests on a case-by-case basis. Availability is limited. Rental units are Alfa Laval NX-314 and NX-418 decanters based in Warren, Michigan.",
  "provider": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "24248 Gibson Dr.",
      "addressLocality": "Warren",
      "addressRegion": "MI",
      "postalCode": "48089",
      "addressCountry": "US"
    }
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "url": "https://dolphincentrifuge.com/decanter-centrifuge-rental/"
};

const toc = [
  { id: 'overview', label: 'Rental Overview' },
  {
    id: 'nx314',
    label: 'NX-314 Decanter',
    subItems: [
      { id: 'nx314-applications', label: 'Typical Applications' },
      { id: 'nx314-specs', label: 'Specifications' },
    ],
  },
  {
    id: 'nx418',
    label: 'NX-418 Decanter',
    subItems: [
      { id: 'nx418-applications', label: 'Typical Applications' },
      { id: 'nx418-specs', label: 'Specifications' },
    ],
  },
  { id: 'contact', label: 'Contact for Availability' },
];

const relatedApplications = [
  { label: 'Disc Stack Centrifuge Rental', href: '/disc-stack-centrifuge-rental/' },
  { label: 'Decanter Centrifuge Applications', href: '/decanter-centrifuge-applications/' },
  { label: 'Sample Testing Service', href: '/industrial-centrifuge-sample-testing/' },
];

const relatedProducts = [
  { label: 'NX-314 Decanter', href: '/alfa-laval-nx-314-decanter-centrifuge/', description: '40 GPM, wastewater & sludge' },
  { label: 'NX-418 Decanter', href: '/alfa-laval-nx-418-decanter-centrifuge/', description: '80 GPM, industrial wastewater' },
  { label: 'Centrifuge Buyback', href: '/industrial-centrifuge-buyback/', description: 'Sell or trade your centrifuge' },
];
---

<ApplicationLayout
  title="Decanter Centrifuge Rental"
  pageTitle="Decanter Centrifuge Rental | Alfa Laval Decanter Leasing"
  description="Decanter Centrifuge Rental from Dolphin Centrifuge. Complete Alfa Laval skid-mounted decanter centrifuge modules with automatic controls for rent."
  disableTitleSuffix={true}
  hideBottomCTA={true}
  category="services"
  categoryLabel="Services"
  heroImage="/images/decanter-centrifuge-rental/Alfa-Laval-NX418.webp"
  heroImageAlt="Alfa Laval NX-418 Decanter Centrifuge"
  canonicalUrl="https://dolphincentrifuge.com/decanter-centrifuge-rental/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <!-- Rental Overview -->
  <h2 id="overview">Rental Overview</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-1/2">
      <p>Dolphin Centrifuge maintains a limited fleet of Alfa Laval <a href="/decanter-centrifuge/">decanter centrifuges</a> that may be available for rent. Rental requests are reviewed case-by-case based on application, duration, and equipment condition requirements.</p>
      <p>Decanters in abrasive or high-solids service can experience significant wear. For that reason, rental units are not offered as a general catalogue item; each request is assessed individually before any commitment is made.</p>
      <p>Rental situations we can consider include:</p>
      <ul>
        <li>Process evaluation for a specific application</li>
        <li>Short-term capacity cover while a unit is in service</li>
        <li>Pilot-scale runs before a capital purchase decision</li>
      </ul>
      <p><strong>A rental requires a minimum rental period commitment, deposit, execution of a formal rental contract, and other standard conditions.</strong></p>
    </div>
    <div class="md:w-1/2">
      <figure>
        <img
          loading="lazy"
          src="/images/decanter-centrifuge-rental/biomass-centrifuge-Alfa-Laval-NX314.webp"
          alt="Alfa Laval NX-314 decanter centrifuge on skid"
          width="600"
          height="600"
          class="img-cap-600"
        />
        <figcaption>Alfa Laval NX-314 Decanter Centrifuge</figcaption>
      </figure>
    </div>
  </div>

  <!-- NX-314 -->
  <h2 id="nx314">NX-314 Rental Decanter</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-1/2">
      <h3 id="nx314-applications">Typical Applications</h3>
      <ul>
        <li><a href="/wastewater-centrifuge/">Wastewater Sludge Thickening</a></li>
        <li><a href="/crude-oil-tank-bottom-recovery-centrifuge/">Crude Oil Tank Bottoms</a></li>
        <li><a href="/manure-centrifuge-separator/">Manure Dewatering</a></li>
        <li>Paint Manufacturing Wastewater</li>
        <li>Other 2-phase separation with &lt;35% solids (v/v)</li>
      </ul>
    </div>
    <div class="md:w-1/2">
      <figure>
        <img
          loading="lazy"
          src="/images/decanter-centrifuge-rental/biomass-centrifuge-Alfa-Laval-NX314-e1614264203157.webp"
          alt="Alfa Laval NX-314 decanter centrifuge"
          width="250"
          height="250"
          class="img-cap-300"
        />
        <figcaption>Alfa Laval NX-314 Decanter Centrifuge</figcaption>
      </figure>
    </div>
  </div>

  <h3 id="nx314-specs">NX-314 Specifications</h3>
  <table>
    <thead>
      <tr><th>Spec</th><th>Value</th></tr>
    </thead>
    <tbody>
      <tr><td>Rated Capacity</td><td>40 GPM</td></tr>
      <tr><td>Motor</td><td>460V / 3Ph - 15 HP Motor</td></tr>
      <tr><td>Skid Size</td><td>3' x 7' x 6' (H)</td></tr>
      <tr><td>Weight</td><td>~ 2,500 Lbs</td></tr>
      <tr><td>Power</td><td>460 VAC Power</td></tr>
      <tr><td>Bowl Speed</td><td>4,000 RPM</td></tr>
      <tr><td>RCF (<a href="/centrifuge-rcf-rpm-difference-calculation/">Relative Centrifugal Force</a>)</td><td>3,150 Gs</td></tr>
      <tr><td>Included options</td><td>Remote Mounted VFD Control Panel W/ Over-Torque Alarms</td></tr>
    </tbody>
  </table>

  <!-- NX-418 -->
  <h2 id="nx418">NX-418 Rental Decanter</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-1/2">
      <h3 id="nx418-applications">Typical Applications</h3>
      <ul>
        <li><a href="/wastewater-centrifuge/">Industrial Wastewater</a></li>
        <li><a href="/decanter-centrifuge/">Drilling Mud</a></li>
        <li><a href="/wvo-centrifuge-separator/">WVO, UCO, Grease Trap/Yellow Grease</a></li>
        <li><a href="/wastewater-centrifuge/">Paper Mill Wastewater</a></li>
        <li>Other 2-phase or 3-phase separation with &lt;35% solids (v/v)</li>
      </ul>
    </div>
    <div class="md:w-1/2">
      <figure>
        <img
          loading="lazy"
          src="/images/decanter-centrifuge-rental/Alfa-Laval-NX418-Decanter-C1D2-for-Hemp-Ethanol-Processing-1000.webp"
          alt="Alfa Laval NX-418 Decanter C1D2 for Hemp Ethanol Processing"
          width="1000"
          height="701"
          class="img-cap-600"
        />
        <figcaption>Alfa Laval NX-418 Decanter Module</figcaption>
      </figure>
    </div>
  </div>

  <h3 id="nx418-specs">NX-418 Specifications</h3>
  <table>
    <thead>
      <tr><th>Spec</th><th>Value</th></tr>
    </thead>
    <tbody>
      <tr><td>Rated Capacity</td><td>80 GPM</td></tr>
      <tr><td>Motor</td><td>460V / 3Ph - 25 HP Motor</td></tr>
      <tr><td>Skid Size</td><td>3' x 7' x 6' (H)</td></tr>
      <tr><td>Weight</td><td>~ 4,000 Lbs</td></tr>
      <tr><td>Power</td><td>460 VAC Power</td></tr>
      <tr><td>Bowl Speed</td><td>4,000 RPM</td></tr>
      <tr><td>RCF (<a href="/centrifuge-rcf-rpm-difference-calculation/">Relative Centrifugal Force</a>)</td><td>3,150 Gs</td></tr>
      <tr><td>Included options</td><td>Remote Mounted VFD Control Panel W/ Vibration and Over-Torque Alarms</td></tr>
    </tbody>
  </table>

  <!-- Contact CTA -->
  <h2 id="contact">Contact for Availability</h2>
  <p>Rental availability is limited and depends on current fleet status, your application, and the projected rental duration. Contact Dolphin Centrifuge to discuss whether your application qualifies and whether a unit is available.</p>
  <p>If your application involves <a href="/disc-stack-centrifuge-rental/">liquid-liquid separation or fine solids removal</a>, a disc stack centrifuge rental may be more appropriate than a decanter.</p>
  <p>Not sure which type you need? Our <a href="/industrial-centrifuge-sample-testing/">sample testing service</a> can determine the right centrifuge type and size for your material before you commit to a rental or purchase.</p>
  <p><strong>Call <a href="tel:+12485222573">(248) 522-2573</a> or email <a href="mailto:sales@dolphincentrifuge.com">sales@dolphincentrifuge.com</a> to discuss availability.</strong></p>

</ApplicationLayout>
