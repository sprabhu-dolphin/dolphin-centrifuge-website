---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Industrial Disc Centrifuge Repair & Rebuild",
  "description": "Complete industrial disc centrifuge repair services — minor bowl re-gasketing, major service, transmission rebuild, full centrifuge rebuild, testing, and control system upgrades. 50+ years collective experience.",
  "provider": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "(248) 522-2573",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "24248 Gibson Dr",
      "addressLocality": "Warren",
      "addressRegion": "MI",
      "postalCode": "48089"
    }
  },
  "serviceType": "Centrifuge Repair and Rebuild",
  "areaServed": "United States"
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How often should an industrial disc centrifuge be serviced?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Minor bowl service intervals range from 2-3 weeks (for aggressive chemicals or abrasive solids) to 3-6 months (for benign fluids like lubricating oil). Industrial centrifuge manufacturers recommend a major overhaul of the disc centrifuge every 2-3 years, based on the expected lifespan of transmission components and bowl wear."
      }
    },
    {
      "@type": "Question",
      "name": "How much does it cost to repair an industrial centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Repair costs vary by centrifuge type and service level. Minor service starts at $800+ for small manual-clean disc centrifuges and $2,500+ for medium self-cleaning models. Major service ranges from $2,000+ to $13,000+. Complete rebuilds cost $5,000+ for small disc centrifuges up to $18,000+ for medium decanter centrifuges."
      }
    },
    {
      "@type": "Question",
      "name": "How long does a centrifuge rebuild take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rebuild turnaround time depends on centrifuge size and repair scope. A small disc centrifuge can be rebuilt in about three days, whereas a large capacity self-cleaning disc centrifuge can take four weeks or more for a complete overhaul."
      }
    },
    {
      "@type": "Question",
      "name": "What is included in a complete centrifuge rebuild?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A complete centrifuge rebuild includes stripping down to bare metal, cleaning all bowl and transmission parts, sandblasting and painting the frame with durable epoxy topcoat, inspecting and testing all critical parts for dimensional tolerance, replacing worn parts with new or rebuilt components, replacing all bearings with OEM-recommended high-speed bearings, replacing all consumable parts (O-Rings, Gaskets, Friction Material, Belts), rebuilding to original specifications, and full mechanical and operational testing."
      }
    },
    {
      "@type": "Question",
      "name": "What service kits should centrifuge operators keep in stock?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Centrifuge operators should keep bowl service kits (O-rings, seals, gaskets) in stock at all times. These kits are inexpensive and easy to store. Additional recommended stock includes bowl outlet gaskets, centrifuge-specific seal lubricant, operating water nozzles, friction pads (for friction clutch models), and drive belts (for belt-drive models). Stocking these kits reduces service downtime and prevents unplanned production losses."
      }
    }
  ]
};
---

<BaseLayout
  title="Industrial Disc Centrifuge Repair"
  description="Complete disc centrifuge repair and rebuild service. Bowl overhaul, spindle replacement, seal kits. Fast turnaround — call Dolphin Centrifuge (248) 522-2573."
  canonicalUrl="https://dolphincentrifuge.com/industrial-disc-centrifuge-repair/"
  breadcrumbs={[{label: 'Services', href: '/centrifuge-repair-service/'}, {label: 'Disc Centrifuge Repair'}]}
  jsonLd={jsonLd}
>

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Hero -->
  <section class="bg-[#1B3A5C] text-white py-14 md:py-20">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <nav class="text-sm text-blue-200 mb-4" aria-label="Breadcrumb">
            <a href="/industrial-disc-centrifuge-repair/" class="hover:text-white transition-colors">Services</a>
            <span class="mx-2">›</span>
            <span class="text-white">Disc Centrifuge Repair</span>
          </nav>
          <h1 class="text-3xl md:text-4xl font-bold font-['Plus_Jakarta_Sans'] mb-4 leading-tight">
            Industrial Centrifuge Repair
          </h1>
          <p class="text-lg text-blue-100 mb-4 font-['Source_Sans_3']">
            Disc Centrifuge Rebuild & Testing
          </p>
          <p class="text-blue-100 mb-4 font-['Source_Sans_3']">
            Industrial disc centrifuge repair covers a range of services, from minor bowl re-gasketing to a complete overhaul of the centrifuge. This section describes the range of disc centrifuge repair and rebuild options available to customers.
          </p>
          <p class="text-blue-100 mb-4 font-['Source_Sans_3']">
            Dolphin Centrifuge has the expertise and knowledge to service and repair <a href="https://www.alfalaval.us/service-and-support/local/service-and-support-in-the-usa/high-speed-separator-service/" class="text-white underline hover:text-[#E8A317]" target="_blank" rel="noopener">Alfa Laval</a> disc centrifuges. We have more than <strong>50+ years of collective centrifuge rebuild experience.</strong>
          </p>
          <p class="text-blue-100 mb-4 font-['Source_Sans_3']">
            Dolphin Centrifuge's remanufacturing process brings new life to your old industrial centrifuge. We use an industry-leading centrifuge rebuild process based on OEM specifications.
          </p>
          <p class="text-blue-100 mb-8 font-['Source_Sans_3']">
            Dolphin also carries 200+ industrial centrifuges in our inventory. These are ready for remanufacture and sale.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] hover:bg-yellow-500 text-black font-bold py-3 px-6 rounded-lg transition-colors text-center">
              Request Service Quote
            </a>
            <a href="tel:+12485222573" class="border border-white text-white hover:bg-white hover:text-[#1B3A5C] font-semibold py-3 px-6 rounded-lg transition-colors text-center">
              (248) 522-2573
            </a>
          </div>
        </div>
        <div class="flex justify-center">
          <img
            src="/images/industrial-disc-centrifuge-repair/disc-stack-centrifuge-repair-600.webp"
            alt="Disc centrifuge repair and rebuild service at Dolphin Centrifuge facility in Warren Michigan"
            width="600"
            height="274"
            loading="eager"
            class="rounded-xl shadow-2xl w-full max-w-md object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Banner -->
  <div class="bg-[#E8A317] py-4">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="flex flex-wrap justify-center gap-6 text-black font-semibold font-['Source_Sans_3'] text-sm">
        <span>50+ Years Collective Experience</span>
        <span>OEM-Spec Rebuild Process</span>
        <span>200+ Units in Inventory</span>
        <span>All Major Brands Serviced</span>
        <span>Full Testing Before Delivery</span>
      </div>
    </div>
  </div>

  <!-- AI Citation Summary -->
  <section class="bg-[#F5F5F0] py-6">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="bg-navy/5 border-l-4 border-[#E8A317] rounded-r-lg p-4">
        <p class="text-sm text-[#555] leading-relaxed italic">Dolphin Centrifuge provides complete industrial disc centrifuge repair and rebuild services — from minor bowl re-gasketing ($800+) to complete machine rebuilds ($18,000+). With 50+ years of collective rebuild experience on Alfa Laval, Westfalia, and Sharples centrifuges, Dolphin services all major brands at our Warren, Michigan facility with a full parts inventory of 200+ units.</p>
      </div>
    </div>
  </section>

  <!-- Table of Contents -->
  <section class="bg-white border-b border-gray-200">
    <div class="container mx-auto px-4 max-w-4xl py-6">
      <details class="group">
        <summary class="cursor-pointer font-semibold text-[#1B3A5C] font-['Plus_Jakarta_Sans'] text-lg flex items-center gap-2">
          <span>Table of Contents</span>
          <span class="group-open:rotate-180 transition-transform">&#9660;</span>
        </summary>
        <nav class="mt-4 grid sm:grid-cols-2 gap-1 text-sm font-['Source_Sans_3']">
          <a href="#minor-service" class="text-[#1B3A5C] hover:underline py-1">Minor Service and Maintenance</a>
          <a href="#minor-bowl-interval" class="text-[#1B3A5C] hover:underline py-1">Minor Bowl Service Interval</a>
          <a href="#bowl-service" class="text-[#1B3A5C] hover:underline py-1">Centrifuge Bowl Service (Re-Gasketting)</a>
          <a href="#bowl-maintenance" class="text-[#1B3A5C] hover:underline py-1">Centrifuge Bowl Maintenance</a>
          <a href="#major-service" class="text-[#1B3A5C] hover:underline py-1">Major Service</a>
          <a href="#major-interval" class="text-[#1B3A5C] hover:underline py-1">Major Service Interval</a>
          <a href="#bowl-cleaning" class="text-[#1B3A5C] hover:underline py-1">Bowl Cleaning</a>
          <a href="#transmission-rebuild" class="text-[#1B3A5C] hover:underline py-1">Transmission Rebuild</a>
          <a href="#centrifuge-rebuild" class="text-[#1B3A5C] hover:underline py-1">Centrifuge Rebuild</a>
          <a href="#rebuilt-testing" class="text-[#1B3A5C] hover:underline py-1">Rebuilt Centrifuge Testing</a>
          <a href="#repair-cost" class="text-[#1B3A5C] hover:underline py-1">Repair Cost and Time</a>
          <a href="#parts-repair" class="text-[#1B3A5C] hover:underline py-1">Parts Repair for Wear Damage</a>
          <a href="#system-upgrade" class="text-[#1B3A5C] hover:underline py-1">Centrifuge System Upgrade</a>
          <a href="#service-kits" class="text-[#1B3A5C] hover:underline py-1">Recommended Service Kits to Stock</a>
          <a href="#faq" class="text-[#1B3A5C] hover:underline py-1">Frequently Asked Questions</a>
        </nav>
      </details>
    </div>
  </section>

  <!-- Related Article Banner -->
  <div class="bg-blue-50 border-b border-blue-200 py-3">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <a href="/industrial-centrifuge/" class="text-[#1B3A5C] font-['Source_Sans_3'] text-sm hover:underline">
        Read our detailed article: Industrial Centrifuges — Types, Applications, Cost, and More &rarr;
      </a>
    </div>
  </div>

  <!-- Main Content -->
  <section class="bg-[#F5F5F0]">
    <div class="container mx-auto px-4 max-w-4xl py-12 md:py-16">

      <!-- Minor Service -->
      <div id="minor-service" class="bg-white rounded-xl border border-gray-200 shadow-sm p-8 mb-8">
        <h2 class="text-2xl font-bold font-['Plus_Jakarta_Sans'] text-[#1B3A5C] mb-4">Minor Service and Maintenance</h2>
        <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-6">
          Periodic maintenance of the centrifuge bowl goes a long way toward the reliability and optimum performance of the centrifuge. This servicing is further divided into bowl service and centrifuge maintenance. Regular minor service is the most cost-effective way to extend the operating life of any disc centrifuge, regardless of manufacturer or model. Dolphin Centrifuge recommends establishing a documented maintenance schedule tailored to your specific application and process conditions.
        </p>

        <!-- Minor Bowl Service Interval -->
        <div id="minor-bowl-interval" class="mb-6 pb-6 border-b border-gray-100">
          <h3 class="text-xl font-bold font-['Plus_Jakarta_Sans'] text-[#1B3A5C] mb-3">Minor Bowl Service Interval</h3>
          <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-3">
            The specific centrifuge application defines the service interval of this minor bowl service. In other words, processing benign fluids such as lubricating oil could have a period of 3-6 months between minor bowl service.
          </p>
          <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-3">
            The processing of aggressive chemicals or fluids with abrasive solids requires the bowl service to be performed every 2-3 weeks or sooner.
          </p>
          <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed">
            We recommend the centrifuge user frequently inspect the centrifuge during the initial startup phase to determine the condition of the bowl seals. The user can decide the period between bowl servicing based on the bowl condition during these inspections.
          </p>

          <div class="mt-4 bg-blue-50 rounded-lg p-4 border border-blue-100">
            <h4 class="font-bold font-['Plus_Jakarta_Sans'] text-[#1B3A5C] mb-2 text-sm">Minor Bowl Service Interval by Application Type</h4>
            <div class="overflow-x-auto">
              <table class="w-full text-sm font-['Source_Sans_3']">
                <thead>
                  <tr class="text-[#1B3A5C] font-bold">
                    <th class="text-left p-2">Application Type</th>
                    <th class="text-left p-2">Recommended Minor Service Interval</th>
                  </tr>
                </thead>
                <tbody>
                  <tr class="border-t border-blue-200">
                    <td class="p-2">Benign fluids (lube oil, clean water)</td>
                    <td class="p-2 font-['JetBrains_Mono']">3 - 6 months</td>
                  </tr>
                  <tr class="border-t border-blue-200">
                    <td class="p-2">Moderately aggressive fluids</td>
                    <td class="p-2 font-['JetBrains_Mono']">6 - 12 weeks</td>
                  </tr>
                  <tr class="border-t border-blue-200">
                    <td class="p-2">Aggressive chemicals / abrasive solids</td>
                    <td class="p-2 font-['JetBrains_Mono']">2 - 3 weeks or sooner</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Bowl Service (Re-Gasketting) -->
        <div id="bowl-service" class="mb-6 pb-6 border-b border-gray-100">
          <h3 class="text-xl font-bold font-['Plus_Jakarta_Sans'] text-[#1B3A5C] mb-3">Centrifuge Bowl Service (Re-Gasketting)</h3>
          <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-3">
            During the regular operation of the centrifuge, the seals and gaskets in the bowl are exposed to varying temperatures, process fluid, and sludge deposits. Over time this exposure deteriorates the seals and affects centrifuge performance.
          </p>
          <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-3">
            A periodic bowl service that includes replacing all seals and gaskets is essential to maintain centrifuge performance.
          </p>
          <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed">
            A bowl service involves changing the o-rings, oil seals, gaskets, and other consumable parts. The gaskets are lubricated with an exceptionally long-lasting lubricant specific for centrifuge seals. The operator must thoroughly clean the seal grooves and other crevices to remove accumulated sludge and other debris.
          </p>
        </div>

        <!-- Bowl Maintenance -->
        <div id="bowl-maintenance">
          <h3 class="text-xl font-bold font-['Plus_Jakarta_Sans'] text-[#1B3A5C] mb-3">Centrifuge Bowl Maintenance</h3>
          <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-3">
            Cleaning the <a href="/disc-stack-centrifuge-operating-water/" class="text-[#1B3A5C] hover:underline font-semibold">operating water system</a> under the bowl is essential to this periodic minor service. The primary purpose of cleaning this part of the system is to clean out sediment and mineral deposits that can prevent the operation of the sludge ejection mechanism.
          </p>
          <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-3">
            A simple cleaning with vinegar or any mineral cleaning solvent is sufficient. Replacing o-rings with the proper lubrication is also essential to the cleaning process.
          </p>
          <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed">
            Any nozzles in the operating water system must be thoroughly cleaned and blown out with compressed air.
          </p>
        </div>
      </div>

      <!-- Mid-Page CTA -->
      <div class="bg-[#1B3A5C] rounded-xl p-6 mb-8 text-center text-white">
        <p class="font-['Source_Sans_3'] text-blue-100 mb-3">
          Need a minor bowl service or major centrifuge repair? Dolphin Centrifuge services all major disc centrifuge brands.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] hover:bg-yellow-500 text-black font-bold py-2 px-6 rounded-lg transition-colors text-sm">
            Get a Service Quote
          </a>
          <a href="tel:+12485222573" class="border border-white text-white hover:bg-white hover:text-[#1B3A5C] font-semibold py-2 px-6 rounded-lg transition-colors text-sm">
            (248) 522-2573
          </a>
        </div>
      </div>

      <!-- Major Service -->
      <div id="major-service" class="bg-white rounded-xl border border-gray-200 shadow-sm p-8 mb-8">
        <h2 class="text-2xl font-bold font-['Plus_Jakarta_Sans'] text-[#1B3A5C] mb-4">Major Service</h2>
        <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-6">
          A primary service of the centrifuge involves all the aspects of the minor service above. In addition to the consumable parts, this service includes replacing mechanical parts of the centrifuge transmission, including bearings, friction pads, springs, etc.
        </p>

        <!-- Service Interval -->
        <div id="major-interval" class="mb-6 pb-6 border-b border-gray-100">
          <h3 class="text-xl font-bold font-['Plus_Jakarta_Sans'] text-[#1B3A5C] mb-3">Service Interval of Major Centrifuge Service</h3>
          <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-4">
            <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed">
              Industrial centrifuge manufacturers recommend a <strong>major overhaul of the disc centrifuge every 2-3 years.</strong> This period between the service is based on the expected lifespan of the components. The expected wear of specific components in the bowl also defines this period.
            </p>
          </div>
          <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed">
            An unexpected failure of a transmission component could require a major centrifuge rebuild. For example, a sudden bearing failure could make the centrifuge inoperable. A major service is unavoidable under such circumstances.
          </p>
        </div>

        <!-- Bowl Cleaning -->
        <div id="bowl-cleaning" class="mb-6 pb-6 border-b border-gray-100">
          <h3 class="text-xl font-bold font-['Plus_Jakarta_Sans'] text-[#1B3A5C] mb-3">Bowl Cleaning</h3>
          <div class="grid md:grid-cols-2 gap-6 items-start">
            <div>
              <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-3">
                A thorough cleaning of the stack bowl as part of the major service process involves cleaning the disc stack and other components of the liquid passage. The distributor, cone, and the upper chamber of the top disc are all areas that can accumulate sludge during operation.
              </p>
              <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-3">
                The sediment can scratch the individual disc surface that the sludge particles stick to.
              </p>
              <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-3">
                An industrial parts washer or other mechanical cleaning equipment is well suited for cleaning these components. Soaking the bowl discs in a mild detergent or special disc cleaner liquid removes the sludge buildup. Subsequent rinsing of the disc stack follows the soaking process.
              </p>
              <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed">
                As an added step, a worn disc stack may be electropolished to smoothen the disc surface and resist the possibility of sludge particles sticking to the discs.
              </p>
            </div>
            <div>
              <img
                src="/images/industrial-disc-centrifuge-repair/Electropolished-Bowl-Discs-400.webp"
                alt="Electropolished bowl disc stack showing smooth polished surface ready for reassembly in disc centrifuge rebuild"
                width="400"
                height="491"
                loading="lazy"
                class="rounded-lg w-full max-w-xs"
              />
              <p class="text-xs text-gray-500 mt-2 text-center font-['Source_Sans_3']">Electropolished Stack Discs</p>
            </div>
          </div>
        </div>

        <!-- Transmission Rebuild -->
        <div id="transmission-rebuild">
          <h3 class="text-xl font-bold font-['Plus_Jakarta_Sans'] text-[#1B3A5C] mb-3">Transmission Rebuild</h3>
          <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-3">
            A major service of the disc centrifuge includes a transmission rebuild and the bowl cleaning mentioned above. This part of the service involves the replacement of all bearings and related parts. In a centrifuge with a friction clutch, replacing friction pads is also a part of the service. These parts replacements reduce the possibility of unexpected centrifuge breakdown during operations.
          </p>
          <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-4">
            The inspection of the gears in the gear train is a crucial part of this service. Uneven wear of the gear teeth may require the gears to be changed. Changing the transmission gears as a complete set, not as individual gears, is essential. The image below shows a typical disc-centrifuge gear set.
          </p>

          <div class="grid md:grid-cols-2 gap-6 items-start mb-4">
            <div>
              <img
                src="/images/industrial-disc-centrifuge-repair/Centrifuge-Gear-600-1.webp"
                alt="Disc centrifuge gear set showing complete transmission gear train used during centrifuge rebuild service"
                width="600"
                height="300"
                loading="lazy"
                class="rounded-lg w-full"
              />
              <p class="text-xs text-gray-500 mt-2 text-center font-['Source_Sans_3']">Disc Centrifuge Gear Set</p>
            </div>
            <div>
              <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 h-full">
                <h4 class="font-bold font-['Plus_Jakarta_Sans'] text-[#1B3A5C] mb-3 text-sm">Transmission Rebuild Checklist</h4>
                <ul class="text-sm font-['Source_Sans_3'] text-[#2D2D2D] space-y-2">
                  <li class="flex gap-2"><span class="text-[#E8A317]">&#10003;</span> Replace all bearings (high-speed rated)</li>
                  <li class="flex gap-2"><span class="text-[#E8A317]">&#10003;</span> Replace friction pads (friction clutch models)</li>
                  <li class="flex gap-2"><span class="text-[#E8A317]">&#10003;</span> Inspect and replace gear set if worn</li>
                  <li class="flex gap-2"><span class="text-[#E8A317]">&#10003;</span> Replace vibration-dampening springs if needed</li>
                  <li class="flex gap-2"><span class="text-[#E8A317]">&#10003;</span> Drain and inspect gearbox oil for metal shavings</li>
                  <li class="flex gap-2"><span class="text-[#E8A317]">&#10003;</span> Thoroughly clean gearbox before reassembly</li>
                  <li class="flex gap-2"><span class="text-[#E8A317]">&#10003;</span> Refill with OEM specified lubricant</li>
                </ul>
              </div>
            </div>
          </div>

          <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-3">
            If the centrifuge was experiencing high vibration levels before service, it requires replacing the vibration-dampening spring in the spring casing.
          </p>
          <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed">
            While draining the gearbox oil, the operator should look for metal shavings in the oil. The presence of brass or steel metal particles in the oil implies excessive wear of the gear set. These metal particles damage the bearings through the splash lubrication. Therefore, replacing all bearings and thoroughly cleaning the gearbox is essential.
          </p>
        </div>
      </div>

      <!-- Centrifuge Rebuild -->
      <div id="centrifuge-rebuild" class="bg-white rounded-xl border border-gray-200 shadow-sm p-8 mb-8">
        <h2 class="text-2xl font-bold font-['Plus_Jakarta_Sans'] text-[#1B3A5C] mb-4">Centrifuge Rebuild</h2>
        <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-4">
          An old disc centrifuge that has been out of service for a prolonged period requires a complete overhaul or rebuild. Often the centrifuge is of unknown origin without any information regarding its previous use.
        </p>
        <p class="text-[#2D2D2D] font-['Source_Sans_3'] leading-relaxed mb-6">
          In such cases, the centrifuge's complete and thorough rebuild is crucial for safe future operation. Our centrifuge rebuild process is detailed and involves the following steps.
        </p>

        <h3 class="text-lg font-bold font-['Plus_Jakarta_Sans'] text-[#1B3A5C] mb-4">Our Centrifuge Rebuild Process</h3>
