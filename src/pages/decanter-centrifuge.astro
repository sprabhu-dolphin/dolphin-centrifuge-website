  "offers": {
    "@type": "AggregateOffer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "lowPrice": "20000",
    "highPrice": "600000",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a decanter centrifuge used for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A decanter centrifuge is used for continuously separating solids from liquids in industrial processes. Common applications include crude oil tank bottom recovery, oilfield drilling mud processing, waste oil de-sludging, industrial and municipal wastewater treatment, fish meal stick-water processing, WVO (waste vegetable oil) de-sludging, rendering plant sludge thickening, and food industry waste streams."
      }
    },
    {
      "@type": "Question",
      "name": "How does a decanter centrifuge work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A decanter centrifuge works by exerting high centrifugal force (upwards of 3,000 g) on a slurry of solids and liquids. The slurry enters through an axial feed tube and is accelerated into the rotating bowl, forming a pond. Heavier solids settle against the bowl wall and are conveyed out by a scroll (auger) rotating at a differential speed. The clarified liquid flows over weir plates and exits from the opposite end."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between a 2-phase and 3-phase decanter centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A 2-phase decanter separates solids from a single liquid phase — it produces one solid output and one liquid output. A 3-phase decanter (also called a tricanter) separates solids from two immiscible liquids simultaneously — for example, separating crude oil from water and sludge in a single pass."
      }
    },
    {
      "@type": "Question",
      "name": "How much does a decanter centrifuge cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A new decanter centrifuge from a quality, established manufacturer starts from around $50,000 for a small capacity unit to over $1 million for a large capacity machine. Remanufactured models typically cost 40% to 60% of comparable new models. Additional accessories such as explosion-proof upgrades, control systems, and pumps add to the cost."
      }
    },
    {
      "@type": "Question",
      "name": "What factors affect decanter centrifuge performance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Key factors affecting decanter centrifuge performance include bowl speed (RPM/centrifugal force), auger or conveyor differential speed, pond depth (controlled by weir plates), beach angle of the conical bowl section, and conveyor pitch. Each of these parameters can be adjusted to optimize separation for specific applications."
      }
    },
    {
      "@type": "Question",
      "name": "What should I consider when buying a remanufactured decanter centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Important considerations include the manufacturer of the original centrifuge, credentials and experience of the re-manufacturer, the machine's previous use, wear status of the bowl and conveyor, quality of parts used in the rebuild (especially bearings), balancing of major rotating components, and vibration check and complete testing per OEM specifications."
      }
    }
  ]
};
