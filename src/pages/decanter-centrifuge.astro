const faqItems = [
  {
    question: "What is a decanter centrifuge used for?",
    answer: "A decanter centrifuge is used for continuously separating solids from liquids in industrial processes. Common applications include <a href='/crude-oil-tank-bottom-recovery-centrifuge/' class='text-navy font-semibold hover:text-gold transition-colors'>crude oil tank bottom recovery</a>, oilfield drilling mud processing, <a href='/waste-oil-centrifuge/' class='text-navy font-semibold hover:text-gold transition-colors'>waste oil de-sludging</a>, industrial and municipal <a href='/wastewater-centrifuge/' class='text-navy font-semibold hover:text-gold transition-colors'>wastewater treatment</a>, fish meal stick-water processing, WVO (waste vegetable oil) de-sludging, rendering plant sludge thickening, and food industry waste streams."
  },
  {
    question: "How does a decanter centrifuge work?",
    answer: "A decanter centrifuge works by exerting high centrifugal force (upwards of 3,000 g) on a slurry of solids and liquids. The slurry enters through an axial feed tube and is accelerated into the rotating bowl, forming a pond. Heavier solids settle against the bowl wall and are conveyed out by a scroll (auger) rotating at a <a href='/decanter-centrifuge-differential-speed/' class='text-navy font-semibold hover:text-gold transition-colors'>differential speed</a>. The clarified liquid flows over weir plates and exits from the opposite end."
  },
  {
    question: "What is the difference between a 2-phase and 3-phase decanter centrifuge?",
    answer: "A 2-phase decanter separates solids from a single liquid phase &mdash; it produces one solid output and one liquid output. A <a href='/three-phase-decanter/' class='text-navy font-semibold hover:text-gold transition-colors'>3-phase decanter</a> (also called a tricanter) separates solids from two immiscible liquids simultaneously &mdash; for example, separating crude oil from water and sludge in a single pass."
  },
