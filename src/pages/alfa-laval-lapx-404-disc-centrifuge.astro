---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What applications is the Alfa Laval LAPX-404 used for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Alfa Laval LAPX-404 is used for organic fish oil separation, food flavor extraction, animal fat and water separation, coolant tramp oil separation, two-phase immiscible chemical separation, and clarified butter (ghee) separation. It handles suspended solids with particle sizes from 0.5 to 500 microns."
      }
    },
    {
      "@type": "Question",
      "name": "What is the capacity of the Alfa Laval LAPX-404?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Alfa Laval LAPX-404 has a maximum process capacity of 5 gallons per minute (GPM). Its rated capacity is 5 GPM on chicken broth / chicken fat separation. The bowl speed is 8,200 RPM generating 8,000 Gs of centrifugal force."
      }
    },
    {
      "@type": "Question",
      "name": "Does the LAPX-404 have automatic solids ejection?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The LAPX-404 features a partial solids ejection mechanism that purges only the solids, reducing fluid losses during sludge ejection. The sludge ejection cycle can be timer triggered or based on the volume of fluid processed."
      }
    },
    {
      "@type": "Question",
      "name": "Can the LAPX-404 be configured as a clarifier or concentrator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The LAPX-404 can be configured as a clarifier (solid-liquid separator) or as a concentrator to separate large volumes of water-based fluid from a small volume of oil. The solids content in the process fluid can be up to 10% by volume."
      }
    }
  ]
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Alfa Laval LAPX-404 Disc Centrifuge",
    "description": "Alfa Laval LAPX-404 laboratory-scale self-cleaning disc stack centrifuge. 8,000 Gs, 5 GPM capacity, partial solids ejection. Rebuilt by Dolphin Centrifuge.",
    "brand": { "@type": "Brand", "name": "Alfa Laval" },
    "manufacturer": { "@type": "Organization", "name": "Alfa Laval" },
    "category": "Disc Stack Centrifuges",
    "url": "https://dolphincentrifuge.com/alfa-laval-lapx-404-disc-centrifuge/",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
      "seller": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
    },
  },
  faqJsonLd,
];

const toc = [
  { id: 'overview', label: 'LAPX-404 Overview' },
  { id: 'technical-specifications', label: 'Technical Specifications' },
  { id: 'applications', label: 'Applications' },
  { id: 'operation', label: 'How It Works' },
  { id: 'supply-and-service', label: 'Supply & Service' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedProducts = [
  { label: 'Disc Stack Centrifuge Overview', href: '/disc-stack-centrifuge/', description: 'Complete disc stack centrifuge systems' },
  { label: 'Stainless Steel Centrifuges', href: '/stainless-steel-centrifuge/', description: 'Hygienic stainless steel models' },
  { label: 'Alfa Laval Clara 20', href: '/alfa-laval-clara-20-food-grade-centrifuge/', description: 'Food grade centrifuge' },
];

const relatedApplications = [
  { label: 'Disc Stack Centrifuge Options', href: '/disc-stack-centrifuge-options/' },
  { label: 'Food Grade Centrifuge Systems', href: '/food-grade-centrifuge/' },
  { label: 'Centrifuge Parts & Spares', href: '/alfa-laval-centrifuge-parts/' },
  { label: 'Pilot Sample Testing', href: '/industrial-centrifuge-sample-testing/' },
];
---

<ApplicationLayout
  title="Alfa Laval LAPX-404 Disc Centrifuge | Dolphin Centrifuge"
  description="Alfa Laval LAPX-404 laboratory-scale self-cleaning disc stack centrifuge. 8,000 Gs, 5 GPM, partial solids ejection. Rebuilt by Dolphin Centrifuge in Warren, MI."
  heroImage="/images/stainless-steel-centrifuge/Alfa-Laval-Food-Grade-Stainless-Steel-3-Phase-Disc-Centrifuge-400.webp"
  heroImageAlt="Alfa Laval Food Grade Stainless Steel 3 Phase Disc Centrifuge"
  category="products"
  categoryLabel="Disc Stack Centrifuges"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-lapx-404-disc-centrifuge/"
  jsonLd={jsonLd}
  toc={toc}
  relatedProducts={relatedProducts}
  relatedApplications={relatedApplications}
>

  <!-- AI Summary — 30-50 words -->
  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">The Alfa Laval LAPX-404 is a laboratory-scale self-cleaning disc stack centrifuge generating 8,000 Gs at 8,200 RPM with 5 GPM capacity and partial solids ejection. Dolphin Centrifuge supplies reconditioned LAPX-404 systems from Warren, Michigan.</p>
  </div>

  <!-- Overview -->
  <h2 id="overview">LAPX-404 Overview</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-1/2">
      <p>
        The Alfa Laval LAPX-404 is a <a href="/disc-stack-centrifuge-options/">self-cleaning centrifuge</a> of the disc-stack type. Its design allows it to separate liquid from liquid and solids (purifier) or liquid from solids (clarifier).
      </p>
      <p>
        The LAPX-404 features a &ldquo;partial solids&rdquo; ejection feature that allows the centrifuge to purge only the solids. This feature reduces fluid losses associated with sludge ejection. The sludge ejection cycle can be timer triggered or based on the volume processed.
      </p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/stainless-steel-centrifuge/Alfa-Laval-Stainless-Steel-Disc-Stack-Centrifuge-600.webp"
        alt="Alfa Laval Stainless Steel Disc Stack Centrifuge"
        loading="lazy"
        width="600"
        height="450"
        class="rounded-xl shadow-md w-full"
      />
    </div>
  </div>

  <p>
    This centrifuge model is configured as a clarifier (solid-liquid) separator or concentrator to separate large volumes of water-based fluid from a small volume of oil. The solids content in the process fluid can be up to 10% by volume and vary.
  </p>

  <!-- Technical Specifications -->
  <h2 id="technical-specifications">Technical Specifications</h2>
  <div class="overflow-x-auto mb-8 not-prose">
    <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
      <tbody>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Model Type</td>
          <td class="px-4 py-3 font-mono text-text-light">Alfa Laval LAPX-404</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Rated Capacity</td>
          <td class="px-4 py-3 font-mono text-text-light">5 GPM on Chicken Broth / Chicken Fat Separation</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Sludge Space</td>
          <td class="px-4 py-3 font-mono text-text-light">0.25 Gallons</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Bowl RPM</td>
          <td class="px-4 py-3 font-mono text-text-light">8,200</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">G-Force</td>
          <td class="px-4 py-3 font-mono text-text-light">8,000 Gs</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Motor HP</td>
          <td class="px-4 py-3 font-mono text-text-light">5 HP</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-semibold text-navy">Voltages</td>
          <td class="px-4 py-3 font-mono text-text-light">230 / 460 V</td>
        </tr>
      </tbody>
    </table>
  </div>
  <p class="text-sm text-text-muted italic">Note: Capacity figures are indicative. Actual throughput depends on feed viscosity, density difference, solids loading, and required separation sharpness. Contact Dolphin Centrifuge for application-specific sizing.</p>

  <!-- Applications -->
  <h2 id="applications">Applications</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-1/2">
      <p>
        The LAPX-404 is applicable for removing suspended solids with a particle size of 0.5 to 500 &micro;m. The liquid medium is lighter than the solids. The solids content is usually in the range of 0.1 to 10% by volume. The maximum process capacity of the machine is 5 Gallons/Minute.
      </p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/stainless-steel-centrifuge/Alfa-Laval-Stainless-Steel-Centrifuge-600.webp"
        alt="Alfa Laval Stainless Steel Centrifuge"
        loading="lazy"
        width="600"
        height="450"
        class="rounded-xl shadow-md w-full"
      />
    </div>
  </div>

  <p>The following are some of the popular applications of the Alfa Laval LAPX-404:</p>

  <div class="grid md:grid-cols-2 gap-6 mb-8 not-prose">
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2">Biotechnology</h3>
      <ul class="text-sm text-text-light space-y-1 list-disc list-inside">
        <li>Organic Fish Oil Separation</li>
        <li>Food Flavor Extraction</li>
        <li>Animal Fat Water Separation</li>
      </ul>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2">Industrial</h3>
      <ul class="text-sm text-text-light space-y-1 list-disc list-inside">
        <li>Coolant Tramp Oil Separation</li>
        <li>Two-Phase (Immiscible) Chemical Separation</li>
        <li>Clarified Butter (Ghee) Separation</li>
      </ul>
    </div>
  </div>

  <!-- Operation -->
  <h2 id="operation">How the LAPX-404 Works</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-1/2">
      <p>
        The fluid enters the rotating bowl of the <a href="/disc-stack-centrifuge/">Alfa Laval LAPX-404 centrifuge</a>. The bowl exerts a high g-force (8,000 Gs) on the process fluid. The centrifugal force causes rapid sedimentation of the solid particles. These separated solids are auto-ejected from the centrifuge. The liquid phase (broth) moves towards the center and exits the bowl through a separate outlet.
      </p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/alfa-laval-lapx-404-disc-centrifuge/BTPX-205-Bowl-Cross-Section-300.webp"
        alt="BTPX 205 Bowl Cross Section"
        loading="lazy"
        width="300"
        height="341"
        class="rounded-xl shadow-md w-full"
      />
      <p class="text-sm text-text-muted italic mt-2 text-center">LAPX-404 Bowl Cross Section</p>
    </div>
  </div>

  <p>The process fluid enters the rotating bowl of the centrifuge through a stationary inlet pipe. The distributor accelerates the fluid before it enters the disc stack. The separation of the solids from the liquid happens in the inter-disc space.</p>
  <p>The clear liquid moves toward the center of the bowl. A paring disc pumps out the clear centrate. The denser solids move towards the bowl periphery, where their ejection happens through the centrifuge cyclone.</p>
  <p>A hydraulic mechanism located under the bowl separation space causes the sludge ejection. This mechanism forces the sliding piston downward, opening the solids ejection ports at the bowl periphery. The cyclone reduces the high ejection velocity of the solids.</p>

  <!-- Supply & Service -->
  <h2 id="supply-and-service">Dolphin Centrifuge Supply &amp; Service</h2>
  <p>
    Dolphin Centrifuge has an Alfa Laval LAPX-404 disc stack concentrator centrifuge system in stock for sale. Each unit is fully disassembled, inspected, and rebuilt to original specifications at our Warren, Michigan facility. We also offer <a href="/industrial-centrifuge-sample-testing/">pilot sample testing</a> with your actual process fluid before purchase and maintain inventory of common <a href="/alfa-laval-centrifuge-parts/">wear parts</a> for rapid delivery.
  </p>
  <p>
    For applications requiring <a href="/stainless-steel-centrifuge/">stainless steel construction</a> or <a href="/food-grade-centrifuge/">food-grade centrifuge</a> systems, contact us to discuss the best configuration for your process needs.
  </p>

  <!-- Mid-page CTA -->
  <div class="bg-navy/5 border border-navy/10 rounded-xl p-6 my-8 text-center not-prose">
    <p class="text-lg font-bold text-navy mb-2">Need a quote for the LAPX-404?</p>
    <p class="text-sm text-text-light mb-4">Tell us your application, required throughput, and processing conditions.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Get a Free Quote</a>
      <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-navy/20 hover:border-gold text-navy font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
    </div>
  </div>

  <!-- FAQ Section -->
  <h2 id="faq">Frequently Asked Questions</h2>
  <div class="space-y-4 not-prose">
    <details class="bg-gray-50 rounded-xl border border-gray-200 p-5">
      <summary class="font-semibold text-navy cursor-pointer">What applications is the Alfa Laval LAPX-404 used for?</summary>
      <p class="text-text-light mt-3 text-sm">The Alfa Laval LAPX-404 is used for organic fish oil separation, food flavor extraction, animal fat and water separation, coolant tramp oil separation, two-phase immiscible chemical separation, and clarified butter (ghee) separation. It handles suspended solids with particle sizes from 0.5 to 500 microns.</p>
    </details>
    <details class="bg-gray-50 rounded-xl border border-gray-200 p-5">
      <summary class="font-semibold text-navy cursor-pointer">What is the capacity of the Alfa Laval LAPX-404?</summary>
      <p class="text-text-light mt-3 text-sm">The Alfa Laval LAPX-404 has a maximum process capacity of 5 gallons per minute (GPM). Its rated capacity is 5 GPM on chicken broth / chicken fat separation. The bowl speed is 8,200 RPM generating 8,000 Gs of centrifugal force.</p>
    </details>
    <details class="bg-gray-50 rounded-xl border border-gray-200 p-5">
      <summary class="font-semibold text-navy cursor-pointer">Does the LAPX-404 have automatic solids ejection?</summary>
      <p class="text-text-light mt-3 text-sm">Yes. The LAPX-404 features a partial solids ejection mechanism that purges only the solids, reducing fluid losses during sludge ejection. The sludge ejection cycle can be timer triggered or based on the volume of fluid processed.</p>
    </details>
    <details class="bg-gray-50 rounded-xl border border-gray-200 p-5">
      <summary class="font-semibold text-navy cursor-pointer">Can the LAPX-404 be configured as a clarifier or concentrator?</summary>
      <p class="text-text-light mt-3 text-sm">Yes. The LAPX-404 can be configured as a clarifier (solid-liquid separator) or as a concentrator to separate large volumes of water-based fluid from a small volume of oil. The solids content in the process fluid can be up to 10% by volume.</p>
    </details>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

</ApplicationLayout>
