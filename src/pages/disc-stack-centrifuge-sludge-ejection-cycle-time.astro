                <th class="px-4 py-3 font-semibold text-center">0.3%</th>
                <th class="px-4 py-3 font-semibold text-center">0.4%</th>
                <th class="px-4 py-3 font-semibold text-center">0.5%</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr><td class="px-4 py-2 font-medium text-navy">2 GPM</td><td class="px-4 py-2 text-center text-text">387</td><td class="px-4 py-2 text-center text-text">194</td><td class="px-4 py-2 text-center text-text">130</td><td class="px-4 py-2 text-center text-text">97</td><td class="px-4 py-2 text-center text-text">77</td></tr>
              <tr><td class="px-4 py-2 font-medium text-navy">4 GPM</td><td class="px-4 py-2 text-center text-text">194</td><td class="px-4 py-2 text-center text-text">97</td><td class="px-4 py-2 text-center text-text">65</td><td class="px-4 py-2 text-center text-text">48</td><td class="px-4 py-2 text-center text-text">39</td></tr>
              <tr><td class="px-4 py-2 font-medium text-navy">6 GPM</td><td class="px-4 py-2 text-center text-text">129</td><td class="px-4 py-2 text-center text-text">65</td><td class="px-4 py-2 text-center text-text">43</td><td class="px-4 py-2 text-center text-text">32</td><td class="px-4 py-2 text-center text-text">26</td></tr>
              <tr><td class="px-4 py-2 font-medium text-navy">8 GPM</td><td class="px-4 py-2 text-center text-text">97</td><td class="px-4 py-2 text-center text-text">48</td><td class="px-4 py-2 text-center text-text">32</td><td class="px-4 py-2 text-center text-text">24</td><td class="px-4 py-2 text-center text-text">19</td></tr>
              <tr><td class="px-4 py-2 font-medium text-navy">10 GPM</td><td class="px-4 py-2 text-center text-text">77</td><td class="px-4 py-2 text-center text-text">39</td><td class="px-4 py-2 text-center text-text">26</td><td class="px-4 py-2 text-center text-text">19</td><td class="px-4 py-2 text-center text-text">16</td></tr>
              <tr><td class="px-4 py-2 font-medium text-navy">12 GPM</td><td class="px-4 py-2 text-center text-text">65</td><td class="px-4 py-2 text-center text-text">32</td><td class="px-4 py-2 text-center text-text">22</td><td class="px-4 py-2 text-center text-text">16</td><td class="px-4 py-2 text-center text-text">13</td></tr>
              <tr><td class="px-4 py-2 font-medium text-navy">14 GPM</td><td class="px-4 py-2 text-center text-text">55</td><td class="px-4 py-2 text-center text-text">28</td><td class="px-4 py-2 text-center text-text">18</td><td class="px-4 py-2 text-center text-text">14</td><td class="px-4 py-2 text-center text-text">11</td></tr>
            </tbody>
