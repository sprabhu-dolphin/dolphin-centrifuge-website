---
import BaseLayout from '../../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "DMPX-010 Self-Cleaning Disc Stack Centrifuge",
  "description": "Dolphin DMPX-010 self-cleaning three-phase disc stack centrifuge. Compact 7 GPM separator for diesel, waste oil, and light industrial fluids.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  "category": "Disc Stack Centrifuges",
  "model": "DMPX-010",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the throughput of the DMPX-010 centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Dolphin DMPX-010 self-cleaning disc stack centrifuge processes approximately 7 GPM of diesel fuel (13 cSt) at operating temperature. Throughput varies with fluid viscosity: lube oil (R&O) runs at ~4 GPM; steam turbine oil at ~8 GPM. Higher viscosity fluids and heavier solids loading reduce effective capacity. Contact Dolphin Centrifuge for application-specific sizing."
      }
    },
    {
      "@type": "Question",
      "name": "How does the DMPX-010 compare to the DMPX-014?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The DMPX-010 is Dolphin's smallest self-cleaning separator, suited for throughput requirements below 10 GPM. The DMPX-014 handles roughly twice the diesel throughput (~13 GPM) with a larger 0.32–0.34 gallon bowl. If your application requires consistent flow above 8–10 GPM, the DMPX-014 is the recommended step up. Both use the same self-cleaning (automatic discharge) operating principle."
      }
    },
    {
      "@type": "Question",
      "name": "What applications is the DMPX-010 best suited for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The DMPX-010 is best suited for small-volume waste oil processing, diesel fuel polishing, turbine lube oil purification, hydraulic oil maintenance, and compact laboratory or pilot-scale separation where 5–10 GPM throughput is adequate. Its small footprint makes it the preferred choice when floor space or skid size is constrained."
      }
    },
    {
      "@type": "Question",
      "name": "Is the DMPX-010 available in stainless steel or explosion-proof configurations?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The DMPX-010 is available with 316L stainless steel bowl construction for food-grade or corrosive fluid applications, and with explosion-proof (Class I Division 1 or Division 2) motor and electrical components for hazardous location installations. Contact Dolphin Centrifuge to specify your requirements."
      }
    }
  ]
};
---

<BaseLayout
  title="DMPX-010 Self-Cleaning Disc Stack Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMPX-010 self-cleaning disc stack centrifuge. ~7 GPM diesel, 7,000+ Gs, 0.16 gal bowl. Compact 3-phase separator for space-limited industrial installations."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmpx-010/"
  breadcrumbs={[{label: 'Products', href: '/disc-stack-centrifuge/'}, {label: 'DMPX-010 Centrifuge'}]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">DMPX Series &mdash; Dolphin Centrifuge</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">DMPX-010 Self-Cleaning Three-Phase Disc Stack Centrifuge</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">The Dolphin DMPX-010 is our most compact self-cleaning disc stack separator, processing approximately 7 GPM of diesel-viscosity fluid with automatic solids ejection. Ideal for small-volume waste oil reclamation, diesel polishing, turbine lube oil purification, and any three-phase separation task where space is at a premium.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Request a Quote</a>
        <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-5xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies the DMPX-010 — a self-cleaning three-phase disc stack centrifuge system for continuous oil-water-solids separation at compact scale. Operating at 7,000+ Gs with a 0.16 gallon bowl, the DMPX-010 processes approximately 7 GPM of diesel-viscosity fluids with automatic solids ejection. Applications include small-volume waste oil recovery, diesel fuel polishing, turbine lube oil purification, and hydraulic oil maintenance. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in disc stack centrifuge systems.</p>
      </div>

      <!-- Specs Table -->
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">DMPX-010 Specifications</h2>
      <div class="overflow-x-auto mb-4">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Parameter</th>
              <th class="text-left px-4 py-3 font-semibold">Value</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Separation type</td>
              <td class="px-4 py-3 text-text-light">Three-phase (light liquid / heavy liquid / solids)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Diesel throughput</td>
              <td class="px-4 py-3 text-text-light">~7 GPM (13 cSt at operating temperature)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Rated throughput (water)</td>
              <td class="px-4 py-3 text-text-light">~12 GPM</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Bowl capacity</td>
              <td class="px-4 py-3 text-text-light">0.16 gallon (Dolphin&rsquo;s smallest self-cleaning bowl)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">G-force</td>
              <td class="px-4 py-3 text-text-light">7,000+ Gs</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Solids ejection</td>
              <td class="px-4 py-3 text-text-light">Hydraulic self-cleaning; PLC-controlled intervals</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Bowl construction</td>
              <td class="px-4 py-3 text-text-light">Carbon steel standard; 316L stainless steel available</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Power supply</td>
              <td class="px-4 py-3 text-text-light">460V / 3-phase / 60 Hz standard (other voltages available)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Control system</td>
              <td class="px-4 py-3 text-text-light">PLC with programmable discharge intervals and alarms</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Explosion-proof option</td>
              <td class="px-4 py-3 text-text-light">Class I Division 1 &amp; 2 configurations available</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-sm text-text-muted mb-8 italic">Throughput figures are for typical fluids at listed conditions. Actual capacity varies with feed viscosity, temperature, density difference, and solids loading.</p>

      <!-- Capacity by Application -->
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">DMPX-010 Capacity by Application (GPM)</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Application</th>
              <th class="text-left px-4 py-3 font-semibold">Throughput (GPM)</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Diesel fuel (13 cSt)</td><td class="px-4 py-3 text-text-light">~7 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">HFO 30 cSt</td><td class="px-4 py-3 text-text-light">~7 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">HFO 60 cSt</td><td class="px-4 py-3 text-text-light">~6 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">HFO 100 cSt</td><td class="px-4 py-3 text-text-light">~5 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">HFO 180 cSt</td><td class="px-4 py-3 text-text-light">~4 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Lube oil (R&amp;O)</td><td class="px-4 py-3 text-text-light">~4 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Steam turbine oil</td><td class="px-4 py-3 text-text-light">~8 GPM</td></tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Where the DMPX-010 Excels</h2>
      <p class="text-text-light mb-4">
        The DMPX-010 fills a specific niche: facilities that need continuous three-phase separation with automatic solids ejection but operate at volumes that make larger machines inefficient or physically impractical. At 7 GPM diesel throughput, it handles roughly 10,000 gallons per day — enough for single-machine waste oil operations, fuel polishing on smaller tank farms, and turbine lube oil purification on equipment up to several thousand horsepower.
      </p>
      <p class="text-text-light mb-8">
        Unlike manual-clean clarifiers in the same flow range, the DMPX-010 ejects accumulated solids automatically. This means continuous 24/7 unattended operation — no scheduled shutdowns for bowl cleaning, no labor cost for manual disassembly, and no processing gaps. For feeds with moderate to significant solids content, self-cleaning operation delivers major operational advantages over batch-clean alternatives.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Key Applications</h2>
      <div class="grid md:grid-cols-2 gap-6 mb-10">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Small-Volume Waste Oil Processing</h3>
          <p class="text-sm text-text-light">Shops generating 50&ndash;200 gallons per day of used motor oil, hydraulic fluid, or compressor oil. The DMPX-010 separates water, soot, and wear metal solids continuously, producing reclaimed oil suitable for re-use or consolidation for off-site re-refining.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Diesel Fuel Polishing</h3>
          <p class="text-sm text-text-light">Generator sets, standby power systems, and emergency fuel tanks accumulate water and microbial contamination over time. The DMPX-010 polishes diesel continuously at ~7 GPM, removing free water and particulates while operating within the footprint of a standard equipment cabinet.</p>
          <a href="/diesel-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Diesel Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Turbine &amp; Hydraulic Lube Oil</h3>
          <p class="text-sm text-text-light">Small turbine generators, CNC hydraulic systems, and industrial presses require clean, dry oil for reliable operation. The DMPX-010 removes water ingress and particulates from lube circuits in continuous bypass or full-flow configuration at 4&ndash;8 GPM depending on viscosity.</p>
          <a href="/hydraulic-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Hydraulic Oil Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Pilot Scale &amp; Lab Separation</h3>
          <p class="text-sm text-text-light">Research facilities, process development labs, and food oil processors at pilot scale use the DMPX-010 when representative three-phase separation data is needed before scaling up. The machine delivers industrial-grade separation accuracy at compact bench or skid scale.</p>
        </div>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Skid-Mounted System</h2>
      <p class="text-text-light mb-4">
        The DMPX-010 is available as a complete, pre-engineered, skid-mounted system from Dolphin Centrifuge. The standard skid includes the centrifuge with drive motor, feed pump with variable speed control, electric pre-heater, stainless or carbon steel skid frame, pre-wired PLC control panel, all process piping and instrumentation, and a solids collection pan. The skid arrives ready to connect to feed, product outlets, utilities, and drains.
      </p>
      <p class="text-text-light mb-8">
        Because the DMPX-010 is the smallest unit in the DMPX self-cleaning family, the skid footprint is particularly compact — making it the right choice where floor space is constrained. Explosion-proof skid configurations are available for Class I Division 1 and Division 2 hazardous area installations.
      </p>

      <!-- FAQ -->
      <div id="faq" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What is the throughput of the DMPX-010 centrifuge?</h3>
            <p class="text-text-light text-sm">The DMPX-010 processes approximately 7 GPM of diesel-viscosity fluid (13 cSt). Throughput varies with viscosity: ~4 GPM on lube oil, ~8 GPM on steam turbine oil. Contact Dolphin Centrifuge for application-specific sizing.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">How does the DMPX-010 compare to the DMPX-014?</h3>
            <p class="text-text-light text-sm">The DMPX-010 is Dolphin&rsquo;s smallest self-cleaning separator with a 0.16 gal bowl (~7 GPM diesel). The DMPX-014 is the next step up with a 0.32&ndash;0.34 gal bowl (~13 GPM diesel). If your throughput requirement is consistently above 8&ndash;10 GPM, the DMPX-014 is recommended.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What applications is the DMPX-010 best suited for?</h3>
            <p class="text-text-light text-sm">Small-volume waste oil processing, diesel fuel polishing, turbine lube oil purification, hydraulic oil maintenance, and pilot-scale separation where 5&ndash;10 GPM throughput is adequate. Its compact footprint makes it ideal when floor space is limited.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">Is the DMPX-010 available in stainless steel or explosion-proof?</h3>
            <p class="text-text-light text-sm">Yes — 316L stainless steel bowl construction is available for food-grade or corrosive fluid applications. Explosion-proof (Class I Division 1 or 2) electrical configurations are also available for hazardous location installations.</p>
          </div>
        </div>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Related Resources</h2>
      <ul class="text-text-light space-y-2 mb-8">
        <li>&#8226; <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Disc Stack Centrifuge Overview (all DMPX models)</a></li>
        <li>&#8226; <a href="/centrifuges/dmpx-014/" class="text-navy font-semibold hover:text-gold transition-colors">DMPX-014 Self-Cleaning Centrifuge (~13 GPM)</a></li>
        <li>&#8226; <a href="/waste-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Waste Oil Centrifuge Applications</a></li>
        <li>&#8226; <a href="/diesel-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Diesel Fuel Polishing Centrifuge</a></li>
        <li>&#8226; <a href="/contact-for-alfa-laval-centrifuges/" class="text-navy font-semibold hover:text-gold transition-colors">Contact Us for DMPX-010 Pricing</a></li>
      </ul>

    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Bottom CTA -->
  <section class="bg-navy">
    <div class="container-dolphin py-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Get Pricing on the DMPX-010</h2>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">Tell us your fluid type, daily volume, site conditions, and any special requirements. We will provide a detailed quote for the DMPX-010 centrifuge or complete skid system.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3.5 rounded-lg transition-colors">Contact Us</a>
        <a href="/industrial-centrifuge-sample-testing/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3.5 rounded-lg transition-colors">Sample Testing</a>
      </div>
    </div>
  </section>
</BaseLayout>
