---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "DMPX-010 Self-Cleaning 3-Phase Disc Stack Centrifuge",
    "description": "The DMPX-010 is Dolphin Centrifuge's most compact self-cleaning three-phase disc stack centrifuge, processing ~7 GPM of diesel fuel and ideal for small-scale marine, remote-site, and portable oil-separation systems.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "category": "Disc Stack Centrifuges",
    "model": "DMPX-010",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
      "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the throughput of the DMPX-010 centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMPX-010 processes approximately 7 GPM of diesel fuel at rated conditions and up to ~12 GPM under ideal, low-viscosity conditions. Lube oil throughput is ~4 GPM and steam turbine oil throughput is ~8 GPM."
        }
      },
      {
        "@type": "Question",
        "name": "What applications is the DMPX-010 best suited for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMPX-010 is purpose-built for compact and portable installations including small marine vessel diesel polishing, remote-site waste oil reclamation, compact hydraulic oil maintenance, and portable lube oil purification where space and weight are at a premium."
        }
      },
      {
        "@type": "Question",
        "name": "How does the DMPX-010 compare to larger Dolphin DMPX models?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMPX-010 is the smallest model in the DMPX series with a 0.16-gallon sludge bowl and ~3.5–5 HP motor. The DMPX-014 roughly doubles the throughput (~13 GPM diesel), while the DMPX-028 (~20–26 GPM) and DMPX-042 (~32–47 GPM) serve progressively larger industrial applications."
        }
      }
    ]
  }
];
---

<ApplicationLayout
  title="DMPX-010 Compact Self-Cleaning Disc Stack Centrifuge | Dolphin Centrifuge"
  description="DMPX-010 compact self-cleaning disc centrifuge: ~7 GPM diesel. Smallest Dolphin DMPX model for marine, remote sites, and small-scale oil separation. Quote today."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmpx-010/"
  heroImage="/images/dmpx-014-self-cleaning-3-phase-disc-stack-centrifuge/DMPX-014-Self-Cleaning-Centrifuge-modified-Alfa-Laval-Disc-Stack-Centrifuge-Hydraulic-Oil-600.webp"
  heroImageAlt="Dolphin Centrifuge DMPX-010 self-cleaning three-phase disc stack centrifuge"
  category="products"
  categoryLabel="Dolphin Disc Centrifuges"
  toc={[
    { id: "technical-specifications", label: "Technical Specifications" },
    { id: "capacity-by-fluid-type", label: "Capacity by Fluid Type" },
    { id: "key-applications", label: "Key Applications" },
    { id: "dmpx-series-comparison", label: "DMPX Series Comparison" },
    { id: "frequently-asked-questions", label: "Frequently Asked Questions" },
  ]}
  relatedApplications={[
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
    { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
    { label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/" },
  ]}
  relatedProducts={[
    { label: "DMPX-028 (~20–26 GPM)", href: "/centrifuges/dmpx-028/" },
    { label: "DMPX-042 (~32–47 GPM)", href: "/centrifuges/dmpx-042/" },
    { label: "DMPX-070 (~59–72 GPM)", href: "/centrifuges/dmpx-070/" },
    { label: "DMB-013 Purifier", href: "/centrifuges/dmb-013/" },
  ]}
  jsonLd={jsonLd}
>

  <article class="prose-dolphin max-w-none">

    <!-- AI Summary -->
    <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-6 not-prose mb-8">
      <p class="text-base italic text-gray-700 leading-relaxed">
        <strong>AI Summary:</strong> The Dolphin Centrifuge DMPX-010 is the most compact self-cleaning three-phase disc stack centrifuge in the DMPX series, rated at ~7 GPM for diesel fuel polishing at 7,200+ RPM. Ideal for portable skids, small marine vessels, and remote-site oil separation.
      </p>
    </div>

    <!-- Product Image -->
    <figure class="text-center my-8">
      <img
        src="/images/dmpx-014-self-cleaning-3-phase-disc-stack-centrifuge/DMPX-014-Self-Cleaning-Centrifuge-modified-Alfa-Laval-Disc-Stack-Centrifuge-Hydraulic-Oil-600.webp"
        alt="Dolphin Centrifuge DMPX-010 self-cleaning three-phase disc stack centrifuge"
        width="600"
        height="600"
        loading="eager"
        class="rounded-lg shadow-lg max-w-full mx-auto"
      />
      <figcaption class="text-sm text-gray-500 mt-2">
        DMPX-010 — Compact Self-Cleaning 3-Phase Disc Stack Centrifuge
      </figcaption>
    </figure>

    <!-- Technical Specifications -->
    <h2 id="technical-specifications">Technical Specifications</h2>
    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Parameter</th>
            <th>DMPX-010 Value</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Diesel Throughput (Actual)</td><td>~7 GPM</td></tr>
          <tr><td>Diesel Throughput (Rated)</td><td>~12 GPM</td></tr>
          <tr><td>Bowl Sludge Capacity</td><td>0.16 gallon</td></tr>
          <tr><td>Motor Power</td><td>~3.5–5 HP</td></tr>
          <tr><td>Separation Type</td><td>Three-phase (oil / water / solids)</td></tr>
          <tr><td>Desludging</td><td>Automatic self-cleaning (hydraulic ejection)</td></tr>
          <tr><td>Process</td><td>Continuous, unattended operation</td></tr>
          <tr><td>Lube Oil (R&amp;O) Throughput</td><td>~4 GPM</td></tr>
          <tr><td>Steam Turbine Oil Throughput</td><td>~8 GPM</td></tr>
          <tr><td>DMPX Series Position</td><td>Smallest / Entry (10 bowl equiv.)</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Capacity by Fluid Type -->
    <h2 id="capacity-by-fluid-type">Capacity by Fluid Type</h2>
    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Fluid Type</th>
            <th>Approx. Throughput (GPM)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Diesel / Light Fuel Oil</td><td>~7</td></tr>
          <tr><td>HFO 30 cSt</td><td>~7</td></tr>
          <tr><td>HFO 60 cSt</td><td>~6</td></tr>
          <tr><td>HFO 100 cSt</td><td>~5</td></tr>
          <tr><td>HFO 180 cSt</td><td>~4</td></tr>
          <tr><td>HFO 380 cSt</td><td>Not rated for this model</td></tr>
          <tr><td>Lube Oil (R&amp;O) / Steam Turbine</td><td>~4 / ~8 GPM</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-xs text-gray-500">
      * Throughput values are at typical process temperature (194&deg;F / 90&deg;C). Actual flow rates vary with temperature, contamination level, and desired separation efficiency.
    </p>

    <!-- Key Applications -->
    <h2 id="key-applications">Key Applications</h2>

    <h3>Marine Diesel Polishing</h3>
    <p>
      The DMPX-010's compact size fits tight engine room spaces on small vessels, yachts, and workboats. It continuously removes water, microbial contamination, and particulates from <a href="/diesel-centrifuge/">diesel</a> day tanks without manual intervention.
    </p>

    <h3>Remote-Site Waste Oil Reclamation</h3>
    <p>
      For remote generators, mobile equipment fleets, or off-grid facilities, the DMPX-010 reclaims used lube oil and diesel on-site, eliminating costly waste oil disposal and reducing re-supply frequency. See our <a href="/waste-oil-centrifuge/">waste oil centrifuge</a> page for more.
    </p>

    <h3>Compact Hydraulic &amp; Lube Oil Maintenance</h3>
    <p>
      Small machine shops, mobile hydraulic systems, and light industrial operations use the DMPX-010 to continuously clean hydraulic and R&amp;O <a href="/lube-oil-centrifuge/">lube oils</a>, extending fluid and component life at ~4 GPM throughput.
    </p>

    <h3>Portable Skid &amp; Trailer Applications</h3>
    <p>
      The smallest DMPX bowl and motor make it the natural choice for portable oil-cleaning skids and trailers serving multiple machines or tanks at different sites. Pairs well with a small feed pump and <a href="/centrifuge-feed-heater/">process heater</a> in a self-contained unit.
    </p>

    <!-- DMPX Series Comparison -->
    <h2 id="dmpx-series-comparison">How the DMPX-010 Fits the DMPX Series</h2>
    <p>
      The DMPX series spans a wide range of throughputs to match every application scale. The <strong>DMPX-010</strong> (this page) is the entry-level model at ~7 GPM diesel, ideal when space and flow requirements are modest. Moving up, the
      <a href="/dmpx-014-self-cleaning-3-phase-disc-stack-centrifuge/">DMPX-014</a>
      roughly doubles throughput to ~13 GPM, while the
      <a href="/centrifuges/dmpx-028/">DMPX-028</a>
      (~20–26 GPM) handles medium industrial volumes. The
      <a href="/centrifuges/dmpx-042/">DMPX-042</a>
      (~32–47 GPM) and
      <a href="/centrifuges/dmpx-070/">DMPX-070</a>
      (~59–72 GPM) serve large-scale industrial and power-generation applications.
      All DMPX models share the same automatic self-cleaning bowl technology and continuous three-phase separation capability. Visit our
      <a href="/disc-stack-centrifuge/">Disc Stack Centrifuge overview</a>
      to compare models side by side.
    </p>

    <!-- FAQ -->
    <h2 id="frequently-asked-questions">Frequently Asked Questions</h2>

    <h3>What is the throughput of the DMPX-010 centrifuge?</h3>
    <p>
      The DMPX-010 processes approximately 7 GPM of diesel fuel at rated conditions and up to ~12 GPM under ideal, low-viscosity conditions. Lube oil (R&amp;O) throughput is ~4 GPM and steam turbine oil is ~8 GPM. HFO can be processed at 4–7 GPM depending on viscosity grade.
    </p>

    <h3>What applications is the DMPX-010 best suited for?</h3>
    <p>
      The DMPX-010 is purpose-built for compact and portable installations: small marine vessel <a href="/diesel-centrifuge/">diesel polishing</a>, remote-site waste oil reclamation, compact hydraulic oil maintenance, and portable lube oil purification where space and weight are at a premium.
    </p>

    <h3>How does the DMPX-010 compare to larger Dolphin DMPX models?</h3>
    <p>
      The DMPX-010 is the smallest model in the DMPX series with a 0.16-gallon sludge bowl and ~3.5–5 HP motor. The <a href="/dmpx-014-self-cleaning-3-phase-disc-stack-centrifuge/">DMPX-014</a> roughly doubles diesel throughput (~13 GPM), while the <a href="/centrifuges/dmpx-028/">DMPX-028</a> (~20–26 GPM) and <a href="/centrifuges/dmpx-042/">DMPX-042</a> (~32–47 GPM) serve progressively larger industrial applications.
    </p>

  </article>

</ApplicationLayout>
