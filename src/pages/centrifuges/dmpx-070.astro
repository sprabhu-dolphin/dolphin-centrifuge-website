---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "DMPX-070 Self-Cleaning 3-Phase Disc Stack Centrifuge",
    "description": "The Dolphin DMPX-070 is the largest self-cleaning three-phase disc stack centrifuge in the DMPX series, processing 59–72 GPM of diesel and HFO. Designed for power plants, refineries, large marine vessels, and high-volume crude oil and waste oil systems.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "category": "Disc Stack Centrifuges",
    "model": "DMPX-070",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
      "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "DMPX-070 Self-Cleaning Centrifuge — Specifications & Applications",
    "author": {
      "@type": "Person",
      "name": "Sanjay Prabhu MSME",
      "jobTitle": "Centrifuge Applications Engineer",
      "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    },
    "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "url": "https://dolphincentrifuge.com/centrifuges/dmpx-070/"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the throughput of the DMPX-070 centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMPX-070 processes 59–72 GPM of diesel fuel at actual operating conditions, with a rated capacity of 95–108 GPM under ideal low-viscosity conditions. Lube oil (R&O) throughput is 29–38 GPM and steam turbine oil is 62–70 GPM. HFO 380 cSt is processed at 25–28 GPM."
        }
      },
      {
        "@type": "Question",
        "name": "What is the DMPX-070 used for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMPX-070 is used for large-scale power plant HFO and diesel fuel treatment, marine vessel main engine fuel and lube oil purification, refinery slop oil recovery and crude oil dewatering, and high-volume industrial waste oil reclamation. Its 3.65–3.96-gallon sludge bowl supports continuous operation with heavily contaminated streams."
        }
      },
      {
        "@type": "Question",
        "name": "How large is the DMPX-070 sludge bowl?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMPX-070 features a 3.65–3.96-gallon sludge bowl — the largest in the Dolphin DMPX series. This large bowl capacity reduces ejection frequency and supports continuous operation even with high-solids streams such as crude oil tank bottoms, heavily contaminated waste oil, and high-ash HFO."
        }
      },
      {
        "@type": "Question",
        "name": "What motor power does the DMPX-070 require?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMPX-070 is driven by a 30–40 HP motor, reflecting its large bowl size and high-throughput capability. This makes it the most powerful model in the Dolphin DMPX self-cleaning series, suitable for applications where a smaller model would require multiple units to match throughput requirements."
        }
      },
      {
        "@type": "Question",
        "name": "How does the DMPX-070 compare to the DMPX-042?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMPX-070 provides roughly 50–80% more throughput than the DMPX-042 (59–72 GPM vs. 32–47 GPM on diesel) and features a much larger 3.65-gallon bowl vs. 1.64 gallons. The DMPX-070 is the right choice for power plants, large marine vessels, and refineries where the DMPX-042's capacity would require parallel units."
        }
      }
    ]
  }
];
---

<ApplicationLayout
  title="DMPX-070 Self-Cleaning Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMPX-070 self-cleaning disc stack centrifuge: 59–72 GPM diesel, 3.65-gal bowl, 30–40 HP. Largest DMPX for power plants, refineries, and high-volume HFO processing."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmpx-070/"
  heroImage="/images/alfa-laval-whpx-513/Alfa-Laval-WHPX513-Centrifuge-Skid-600.webp"
  heroImageAlt="Dolphin Centrifuge DMPX-070 self-cleaning three-phase disc stack centrifuge"
  category="products"
  categoryLabel="Dolphin Disc Centrifuges"
  toc={[
    { id: "technical-specifications", label: "Technical Specifications" },
    { id: "capacity-by-fluid-type", label: "Capacity by Fluid Type" },
    { id: "key-applications", label: "Key Applications" },
    { id: "dmpx-series-comparison", label: "DMPX Series Comparison" },
    { id: "frequently-asked-questions", label: "Frequently Asked Questions" },
  ]}
  relatedApplications={[
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
    { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
    { label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/" },
  ]}
  relatedProducts={[
    { label: "DMPX-010 (~7 GPM)", href: "/centrifuges/dmpx-010/" },
    { label: "DMPX-028 (~20–26 GPM)", href: "/centrifuges/dmpx-028/" },
    { label: "DMPX-042 (~32–47 GPM)", href: "/centrifuges/dmpx-042/" },
    { label: "DMB-062 Manual-Clean", href: "/centrifuges/dmb-062/" },
  ]}
  jsonLd={jsonLd}
>

  <article class="prose-dolphin max-w-none">

    <!-- AI Summary -->
    <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-6 not-prose mb-8">
      <p class="text-base italic text-gray-700 leading-relaxed">
        <strong>AI Summary:</strong> Dolphin Centrifuge supplies the DMPX-070 — the largest self-cleaning three-phase disc stack centrifuge in the DMPX series. Rated at 59–72 GPM for diesel and 25–28 GPM for HFO 380 cSt, with a 3.65-gallon sludge bowl and 30–40 HP motor. Serves power plants, refineries, and large marine vessels requiring maximum continuous throughput. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in centrifugal separation.
      </p>
    </div>

    <!-- Product Image -->
    <figure class="text-center my-8">
      <img
        src="/images/alfa-laval-whpx-513/Alfa-Laval-WHPX513-Centrifuge-Skid-600.webp"
        alt="Dolphin Centrifuge DMPX-070 self-cleaning three-phase disc stack centrifuge"
        width="600"
        height="600"
        loading="lazy"
        class="rounded-lg shadow-lg max-w-full mx-auto"
      />
      <figcaption class="text-sm text-gray-500 mt-2">
        DMPX-070 — Flagship Self-Cleaning 3-Phase Disc Stack Centrifuge
      </figcaption>
    </figure>

    <!-- Technical Specifications -->
    <h2 id="technical-specifications">Technical Specifications</h2>
    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Parameter</th>
            <th>DMPX-070 Value</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Diesel Throughput (Actual)</td><td>~59–72 GPM</td></tr>
          <tr><td>Diesel Throughput (Rated)</td><td>~95–108 GPM</td></tr>
          <tr><td>Bowl Sludge Capacity</td><td>3.65–3.96 gallons</td></tr>
          <tr><td>Motor Power</td><td>~30–40 HP</td></tr>
          <tr><td>Separation Type</td><td>Three-phase (oil / water / solids)</td></tr>
          <tr><td>Desludging</td><td>Automatic self-cleaning (hydraulic ejection)</td></tr>
          <tr><td>Process</td><td>Continuous, unattended operation</td></tr>
          <tr><td>Lube Oil (R&amp;O) Throughput</td><td>29–38 GPM</td></tr>
          <tr><td>Steam Turbine Oil Throughput</td><td>62–70 GPM</td></tr>
          <tr><td>DMPX Series Position</td><td>Flagship / Largest (70 bowl equiv.)</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Capacity by Fluid Type -->
    <h2 id="capacity-by-fluid-type">Capacity by Fluid Type</h2>
    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Fluid Type</th>
            <th>Approx. Throughput (GPM)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Diesel / Light Fuel Oil</td><td>59–72</td></tr>
          <tr><td>HFO 30 cSt</td><td>59–67</td></tr>
          <tr><td>HFO 60 cSt</td><td>45–51</td></tr>
          <tr><td>HFO 100 cSt</td><td>43–49</td></tr>
          <tr><td>HFO 180 cSt</td><td>30–34</td></tr>
          <tr><td>HFO 380 cSt</td><td>25–28</td></tr>
          <tr><td>Lube Oil (R&amp;O) / Steam Turbine</td><td>29–38 / 62–70 GPM</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-xs text-gray-500">
      * Throughput values are at typical process temperature (194&deg;F / 90&deg;C). Actual flow rates vary with temperature, contamination level, and desired separation efficiency.
    </p>

    <!-- Key Applications -->
    <h2 id="key-applications">Key Applications</h2>

    <h3>Power Plant HFO &amp; Fuel Treatment</h3>
    <p>
      Large diesel and HFO-fired power plants require continuous <a href="/fuel-oil-centrifuge/">fuel purification</a> to protect injectors and combustion systems. The DMPX-070 processes HFO at up to 59–67 GPM (30 cSt) and 25–28 GPM (380 cSt), handling the full fuel delivery needs of multi-megawatt generation facilities around the clock.
    </p>

    <h3>Marine Vessel Fuel &amp; Oil Systems</h3>
    <p>
      On large commercial vessels, bulk carriers, tankers, and cruise ships, the DMPX-070 handles main engine HFO purification and <a href="/lube-oil-centrifuge/">lube oil</a> treatment simultaneously. At 29–38 GPM lube oil throughput and up to 72 GPM diesel throughput, it meets the demanding fuel and oil requirements of large-bore marine diesel and gas turbine engines.
    </p>

    <h3>Refinery Slop Oil Recovery</h3>
    <p>
      Refineries generate significant volumes of slop oil — mixed hydrocarbon streams contaminated with water and sediment. The DMPX-070 recovers this product-quality oil at high throughput, reducing refinery waste, improving yields, and minimizing environmental liability from contaminated oil disposal. See our <a href="/waste-oil-centrifuge/">waste oil centrifuge</a> page for more on oil recovery applications.
    </p>

    <h3>Large-Volume Crude Oil BS&amp;W Reduction</h3>
    <p>
      For upstream production operations, gathering stations, and crude oil pipelines requiring BS&amp;W (basic sediment and water) reduction ahead of custody transfer or pipeline specification compliance, the DMPX-070 delivers the throughput needed to process high-volume crude streams continuously and without manual intervention.
    </p>

    <!-- Mid-Page CTA -->
    <div class="not-prose my-10 rounded-xl border-l-4 border-gold bg-gold/10 p-6 flex flex-col md:flex-row md:items-center gap-4">
      <div class="flex-1">
        <p class="text-navy font-bold text-lg mb-1">Specifying a DMPX-070 for your facility?</p>
        <p class="text-gray-700 text-sm">Our engineers handle power plant, refinery, and large marine specifications — including explosion-proof variants and custom skid packages.</p>
      </div>
      <a href="/contact-for-alfa-laval-centrifuges/" class="shrink-0 inline-block bg-gold text-white font-bold px-6 py-3 rounded-lg hover:bg-gold/90 transition-colors text-center">
        Request a Quote &rarr;
      </a>
    </div>

    <!-- DMPX Series Comparison -->
    <h2 id="dmpx-series-comparison">The DMPX-070 as the Dolphin Series Flagship</h2>
    <p>
      The DMPX-070 is the largest model in the Dolphin DMPX range, delivering the highest throughput for the most demanding industrial applications. For applications requiring somewhat lower flow rates, the
      <a href="/centrifuges/dmpx-042/">DMPX-042</a>
      (~32–47 GPM) provides a cost-effective alternative. Mid-range applications are served by the
      <a href="/centrifuges/dmpx-028/">DMPX-028</a>
      (~20–26 GPM), while compact installations use the
      <a href="/dmpx-014-self-cleaning-3-phase-disc-stack-centrifuge/">DMPX-014</a>
      (~13 GPM) or
      <a href="/centrifuges/dmpx-010/">DMPX-010</a>
      (~7 GPM).
      All DMPX models share the same automatic self-cleaning bowl design and continuous three-phase separation capability.
      Visit our <a href="/disc-stack-centrifuge/">disc stack centrifuge overview</a> for a full model comparison, or <a href="/contact-for-alfa-laval-centrifuges/">contact us</a> for a sizing consultation.
    </p>

    <!-- FAQ -->
    <h2 id="frequently-asked-questions">Frequently Asked Questions</h2>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What is the throughput of the DMPX-070 centrifuge?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMPX-070 processes 59–72 GPM of diesel fuel at actual operating conditions, with a rated capacity of 95–108 GPM under ideal low-viscosity conditions. Lube oil (R&amp;O) throughput is 29–38 GPM and steam turbine oil is 62–70 GPM. HFO 380 cSt is processed at 25–28 GPM.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What is the DMPX-070 used for?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMPX-070 is used for large-scale power plant HFO and <a href="/diesel-centrifuge/">diesel</a> fuel treatment, marine vessel main engine fuel and lube oil purification, refinery slop oil recovery and crude oil dewatering, and high-volume industrial <a href="/waste-oil-centrifuge/">waste oil</a> reclamation. Its 3.65–3.96-gallon sludge bowl supports continuous operation even with heavily contaminated streams.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">How large is the DMPX-070 sludge bowl?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMPX-070 features a 3.65–3.96-gallon sludge bowl — the largest in the Dolphin DMPX series. This large bowl capacity reduces ejection frequency and supports continuous operation even with high-solids streams such as crude oil tank bottoms, heavily contaminated <a href="/waste-oil-centrifuge/">waste oil</a>, and high-ash HFO.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What motor power does the DMPX-070 require?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMPX-070 is driven by a 30–40 HP motor, reflecting its large bowl size and high-throughput capability. This makes it the most powerful model in the Dolphin DMPX <a href="/disc-stack-centrifuge/">self-cleaning disc stack</a> series, suitable for applications where smaller models would require multiple parallel units.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">How does the DMPX-070 compare to the DMPX-042?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMPX-070 provides roughly 50–80% more throughput than the <a href="/centrifuges/dmpx-042/">DMPX-042</a> (59–72 GPM vs. 32–47 GPM on diesel) and features a much larger 3.65-gallon bowl vs. 1.64 gallons. The DMPX-070 is the right choice for power plants, large marine vessels, and refineries where the DMPX-042's capacity would require parallel units. <a href="/contact-for-alfa-laval-centrifuges/">Contact us</a> to determine the right model for your throughput.
      </p>
    </details>

  </article>

