---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "DMB-028 Manual-Clean Disc Stack Centrifuge",
    "description": "Dolphin DMB-028 manual-clean disc stack centrifuge clarifier. 28 GPM diesel, 7.5 HP, 8,700 RPM. High-capacity manual clarifier for large turbine lube oil systems and industrial fluid purification.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "category": "Disc Stack Centrifuges",
    "model": "DMB-028",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
      "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the throughput of the DMB-028 centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Dolphin DMB-028 processes approximately 28 GPM of diesel fuel (13 cSt), 37 GPM of gas oil at 40°C, 15 GPM of lube oil (R&O), and 27 GPM of steam turbine oil. It is rated at 42 GPM on water-viscosity fluid. Operating at approximately 8,700 RPM with a 7.5 HP motor."
        }
      },
      {
        "@type": "Question",
        "name": "What turbine or industrial application is the DMB-028 sized for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "At 15 GPM on lube oil (R&O) throughput, the DMB-028 is suited for large turbine generators in the 10,000–25,000 HP range, large industrial gearboxes, or multiple smaller turbines sharing a centralized lube oil purification system. It is also commonly used for large diesel fuel polishing systems and high-throughput gas oil clarification."
        }
      },
      {
        "@type": "Question",
        "name": "When should I choose the DMB-028 over the DMPX-028 self-cleaning model?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Both deliver approximately 28 GPM on diesel-viscosity fluid. The DMB-028 (manual-clean) is the better choice for clean turbine lube oil and diesel polishing where solids content is low and planned cleaning shutdowns are manageable. The DMPX-028 (self-cleaning) is better for feeds with significant solids, continuous 24/7 unattended operation, or when manual cleaning labor costs are high."
        }
      }
    ]
  }
];
---

<ApplicationLayout
  title="DMB-028 Manual-Clean Disc Stack Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMB-028 manual-clean disc stack centrifuge: 28 GPM diesel, 7.5 HP, 42 GPM rated. High-capacity clarifier for turbine lube oil and industrial applications."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmb-028/"
  category="products"
  categoryLabel="Dolphin Basket Centrifuges"
  toc={[{id: "specs", label: "Specifications"}, {id: "capacity", label: "Capacity by Application"}, {id: "applications", label: "Key Applications"}, {id: "faq", label: "FAQ"}, {id: "resources", label: "Related Resources"}]}
  relatedApplications={[{label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/"}, {label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/"}, {label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/"}]}
  relatedProducts={[{label: "DMB-019 Manual-Clean Centrifuge", href: "/centrifuges/dmb-019/"}, {label: "DMB-037 Manual-Clean Centrifuge", href: "/centrifuges/dmb-037/"}, {label: "DMPX-028 Self-Cleaning Centrifuge", href: "/centrifuges/dmpx-028/"}]}
  jsonLd={jsonLd}
  heroImage="/images/lube-oil-centrifuge/Lube-Oil-Centrifuge-System.webp"
  heroImageAlt="Lube oil centrifuge system — Dolphin DMB-028 manual-clean disc stack clarifier for turbine and industrial oil"
>
  <article class="prose-dolphin max-w-none">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies the DMB-028 — a high-capacity manual-clean disc stack centrifuge clarifier. Operating at approximately 8,700 RPM with a 7.5 HP motor, the DMB-028 processes approximately 28 GPM of diesel-viscosity fluid (42 GPM rated on water). Applications include large turbine lube oil purification for systems in the 10,000–25,000 HP range, high-volume diesel and gas oil polishing, large industrial hydraulic oil maintenance, and compressor lube oil purification. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in disc stack centrifuge systems.</p>
      </div>

      <!-- Specs Table -->
      <h2 id="specs" class="text-2xl md:text-3xl font-bold text-navy mb-4">DMB-028 Specifications</h2>
      <div class="overflow-x-auto mb-4">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Parameter</th>
              <th class="text-left px-4 py-3 font-semibold">Value</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Separation type</td>
              <td class="px-4 py-3 text-text-light">Two-phase clarifier (liquid-liquid or liquid-solid)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Diesel throughput</td>
              <td class="px-4 py-3 text-text-light">~28 GPM (13 cSt at operating temperature)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Rated throughput (water)</td>
              <td class="px-4 py-3 text-text-light">~42 GPM</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Bowl speed</td>
              <td class="px-4 py-3 text-text-light">~8,700 RPM</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Drive motor</td>
              <td class="px-4 py-3 text-text-light">7.5 HP</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Cleaning method</td>
              <td class="px-4 py-3 text-text-light">Manual (bowl disassembly required for solids removal)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Bowl construction</td>
              <td class="px-4 py-3 text-text-light">Carbon steel standard</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Power supply</td>
              <td class="px-4 py-3 text-text-light">460V / 3-phase / 60 Hz standard (other voltages available)</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-sm text-text-muted mb-8 italic">Throughput figures are for typical fluids at listed conditions. Actual capacity varies with feed viscosity, temperature, density difference, and solids loading.</p>

      <!-- Capacity by Application -->
      <h2 id="capacity" class="text-2xl md:text-3xl font-bold text-navy mb-4">DMB-028 Capacity by Application (GPM)</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Application / Fluid</th>
              <th class="text-left px-4 py-3 font-semibold">Throughput (GPM)</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Gas oil at 40&deg;C</td><td class="px-4 py-3 text-text-light">~37 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Diesel fuel (13 cSt)</td><td class="px-4 py-3 text-text-light">~28 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Lube oil (R&amp;O)</td><td class="px-4 py-3 text-text-light">~15 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Lube oil (detergent)</td><td class="px-4 py-3 text-text-light">~13 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Steam turbine oil</td><td class="px-4 py-3 text-text-light">~27 GPM</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="applications" class="text-2xl md:text-3xl font-bold text-navy mb-4">Key Applications</h2>
      <div class="grid md:grid-cols-2 gap-6 mb-10">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Large Turbine Lube Oil Purification</h3>
          <p class="text-sm text-text-light">Steam and gas turbine generators in the 10,000–25,000 HP range, and large industrial turbine-driven equipment. At 15 GPM on R&amp;O lube oil, the DMB-028 delivers high-throughput bypass purification that keeps large lube oil systems continuously clean between scheduled oil changes.</p>
          <a href="/lube-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Lube Oil Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">High-Volume Diesel &amp; Gas Oil Polishing</h3>
          <p class="text-sm text-text-light">Large fuel storage depots, refinery off-spec handling, and large generator installations with high daily fuel throughput. The DMB-028 polishes diesel at 28 GPM and gas oil at 37 GPM — handling large-scale fuel quality maintenance economically.</p>
          <a href="/diesel-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Diesel Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Industrial Compressor Lube Oil</h3>
          <p class="text-sm text-text-light">Large reciprocating compressors, centrifugal compressors, and compressor stations in gas processing and petrochemical facilities. The DMB-028 maintains lube oil cleanliness for compressors with large oil reservoir volumes where continuous high-throughput purification is needed.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Central Lube Oil Systems</h3>
          <p class="text-sm text-text-light">Centralized lube oil systems serving multiple pieces of industrial machinery from a common reservoir. The DMB-028&rsquo;s high throughput makes it effective for large central systems where individual machine purifiers would be impractical.</p>
        </div>
      </div>

      <!-- FAQ -->
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 id="faq" class="text-xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What is the throughput of the DMB-028?</h3>
            <p class="text-text-light text-sm">The DMB-028 processes ~28 GPM of diesel, ~37 GPM of gas oil at 40&deg;C, ~15 GPM of lube oil (R&amp;O), and ~27 GPM of steam turbine oil. Rated at 42 GPM on water-viscosity fluid. 7.5 HP, ~8,700 RPM.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What turbine or industrial application is the DMB-028 sized for?</h3>
            <p class="text-text-light text-sm">At 15 GPM on lube oil (R&amp;O), the DMB-028 suits large turbines in the 10,000–25,000 HP range, large industrial gearboxes, or centralized lube oil purification for multiple machines. Also effective for large diesel polishing at 28 GPM.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">When should I choose DMB-028 over the DMPX-028?</h3>
            <p class="text-text-light text-sm">Both deliver ~28 GPM diesel throughput. The DMB-028 (manual-clean) suits clean lube oil and diesel where solids are low and planned cleanings are manageable. The DMPX-028 (self-cleaning) is better for feeds with significant solids or when continuous unattended operation is required.</p>
          </div>
        </div>
      </div>

      <h2 id="resources" class="text-2xl md:text-3xl font-bold text-navy mb-4">Related Resources</h2>
      <ul class="text-text-light space-y-2 mb-8">
        <li>&#8226; <a href="/centrifuges/dmb-019/" class="text-navy font-semibold hover:text-gold transition-colors">DMB-019 Manual-Clean Centrifuge (~19 GPM)</a></li>
        <li>&#8226; <a href="/centrifuges/dmb-037/" class="text-navy font-semibold hover:text-gold transition-colors">DMB-037 Manual-Clean Centrifuge (~37 GPM)</a></li>
        <li>&#8226; <a href="/centrifuges/dmpx-028/" class="text-navy font-semibold hover:text-gold transition-colors">DMPX-028 Self-Cleaning Centrifuge (20–26 GPM)</a></li>
        <li>&#8226; <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Disc Stack Centrifuge Overview</a></li>
        <li>&#8226; <a href="/contact-for-alfa-laval-centrifuges/" class="text-navy font-semibold hover:text-gold transition-colors">Contact Us for DMB-028 Pricing</a></li>
      </ul>

  </article>
</ApplicationLayout>
