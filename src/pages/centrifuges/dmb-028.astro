---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "DMB-028 Manual-Clean Disc Stack Centrifuge",
    "description": "Dolphin DMB-028 manual-clean disc stack centrifuge clarifier. 28 GPM diesel, 7.5 HP, 8,700 RPM. High-capacity manual clarifier for large turbine lube oil systems and industrial fluid purification.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "category": "Disc Stack Centrifuges",
    "model": "DMB-028",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
      "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "DMB-028 Manual-Clean Disc Stack Centrifuge — Specifications & Applications",
    "author": {
      "@type": "Person",
      "name": "Dolphin Centrifuge Engineering",
      "jobTitle": "Centrifuge Applications Engineer",
      "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    },
    "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "url": "https://dolphincentrifuge.com/centrifuges/dmb-028/"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the throughput of the DMB-028 centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Dolphin DMB-028 processes approximately 28 GPM of diesel fuel (13 cSt), 37 GPM of gas oil at 40°C, 15 GPM of lube oil (R&O), and 27 GPM of steam turbine oil. It is rated at 42 GPM on water-viscosity fluid. Operating at approximately 8,700 RPM with a 7.5 HP motor."
        }
      },
      {
        "@type": "Question",
        "name": "What turbine or industrial application is the DMB-028 sized for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "At 15 GPM on lube oil (R&O) throughput, the DMB-028 is suited for large turbine generators in the 10,000–25,000 HP range, large industrial gearboxes, or multiple smaller turbines sharing a centralized lube oil purification system. It is also commonly used for large diesel fuel polishing systems and high-throughput gas oil clarification."
        }
      },
      {
        "@type": "Question",
        "name": "When should I choose the DMB-028 over the DMPX-028 self-cleaning model?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Both deliver approximately 28 GPM on diesel-viscosity fluid. The DMB-028 (manual-clean) is the better choice for clean turbine lube oil and diesel polishing where solids content is low and planned cleaning shutdowns are manageable. The DMPX-028 (self-cleaning) is better for feeds with significant solids, continuous 24/7 unattended operation, or when manual cleaning labor costs are high."
        }
      },
      {
        "@type": "Question",
        "name": "How does the DMB-028 compare to the DMB-019 and DMB-037?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMB-028 (28 GPM diesel) sits between the DMB-019 (19 GPM) and the DMB-037 (37 GPM). At 15 GPM on R&O lube oil, it suits turbines in the 10,000–25,000 HP range — significantly larger than the DMB-019's 5,000–15,000 HP range. The DMB-037 steps up to 19 GPM on R&O for systems above 20,000 HP."
        }
      },
      {
        "@type": "Question",
        "name": "Can the DMB-028 serve a centralized lube oil system for multiple machines?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. At 15 GPM on R&O lube oil and 28 GPM on diesel-viscosity fluid, the DMB-028 is well suited for centralized lube oil systems serving multiple industrial machines from a common reservoir. The high throughput makes it effective where individual machine purifiers would be impractical. Contact Dolphin Centrifuge to size the system for your specific configuration."
        }
      }
    ]
  }
];
---

<ApplicationLayout
  title="DMB-028 Manual-Clean Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMB-028 manual-clean disc stack centrifuge: 28 GPM diesel, 7.5 HP, 42 GPM rated. High-capacity clarifier for large turbine lube oil (10,000–25,000 HP) applications."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmb-028/"
  heroImage="/images/lube-oil-centrifuge/Lube-Oil-Centrifuge-System.webp"
  heroImageAlt="Lube oil centrifuge system — Dolphin DMB-028 manual-clean disc stack clarifier for turbine and industrial oil"
  category="products"
  categoryLabel="Dolphin Basket Centrifuges"
  toc={[
    { id: "ai-summary", label: "AI Summary" },
    { id: "specs", label: "Specifications" },
    { id: "capacity", label: "Capacity by Application" },
    { id: "applications", label: "Key Applications" },
    { id: "faq", label: "FAQ" },
  ]}
  relatedApplications={[
    { label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/" },
    { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
  ]}
  relatedProducts={[
    { label: "DMB-019 Manual-Clean Centrifuge", href: "/centrifuges/dmb-019/" },
    { label: "DMB-037 Manual-Clean Centrifuge", href: "/centrifuges/dmb-037/" },
    { label: "DMPX-028 Self-Cleaning Centrifuge", href: "/centrifuges/dmpx-028/" },
  ]}
  jsonLd={jsonLd}
>
  <article class="prose-dolphin max-w-none">

    <div id="ai-summary" class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-6 not-prose mb-8">
      <p class="text-base italic text-gray-700 leading-relaxed">
        <strong>AI Summary:</strong> Dolphin Centrifuge supplies the DMB-028 — a high-capacity manual-clean disc stack centrifuge clarifier. Operating at approximately 8,700 RPM with a 7.5 HP motor, the DMB-028 processes approximately 28 GPM of diesel-viscosity fluid (42 GPM rated on water). Suited for large turbine lube oil purification (10,000–25,000 HP), high-volume diesel and gas oil polishing, and large industrial hydraulic oil maintenance. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in centrifugal separation.
      </p>
    </div>

    <h2 id="specs">DMB-028 Specifications</h2>
    <div class="overflow-x-auto mb-4">
      <table>
        <thead>
          <tr>
            <th>Parameter</th>
            <th>Value</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Separation type</td><td>Two-phase clarifier (liquid-liquid or liquid-solid)</td></tr>
          <tr><td>Diesel throughput</td><td>~28 GPM (13 cSt at operating temperature)</td></tr>
          <tr><td>Rated throughput (water)</td><td>~42 GPM</td></tr>
          <tr><td>Bowl speed</td><td>~8,700 RPM</td></tr>
          <tr><td>Drive motor</td><td>7.5 HP</td></tr>
          <tr><td>Cleaning method</td><td>Manual (bowl disassembly required for solids removal)</td></tr>
          <tr><td>Bowl construction</td><td>Carbon steel standard</td></tr>
          <tr><td>Power supply</td><td>460V / 3-phase / 60 Hz standard (other voltages available)</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-sm text-gray-500 italic">Throughput figures are for typical fluids at listed conditions. Actual capacity varies with feed viscosity, temperature, density difference, and solids loading.</p>

    <h2 id="capacity">DMB-028 Capacity by Application (GPM)</h2>
    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Application / Fluid</th>
            <th>Throughput (GPM)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Gas oil at 40&deg;C</td><td>~37 GPM</td></tr>
          <tr><td>Diesel fuel (13 cSt)</td><td>~28 GPM</td></tr>
          <tr><td>Lube oil (R&amp;O)</td><td>~15 GPM</td></tr>
          <tr><td>Lube oil (detergent)</td><td>~13 GPM</td></tr>
          <tr><td>Steam turbine oil</td><td>~27 GPM</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Mid-Page CTA -->
    <div class="not-prose my-10 rounded-xl border-l-4 border-gold bg-gold/10 p-6 flex flex-col md:flex-row md:items-center gap-4">
      <div class="flex-1">
        <p class="text-navy font-bold text-lg mb-1">Sizing a DMB-028 for your turbine or industrial system?</p>
        <p class="text-gray-700 text-sm">Our team calculates turnover rates, cleaning intervals, and throughput from your HP rating and reservoir volume — free of charge.</p>
      </div>
      <a href="/contact-for-alfa-laval-centrifuges/" class="shrink-0 inline-block bg-gold text-white font-bold px-6 py-3 rounded-lg hover:bg-gold/90 transition-colors text-center">
        Request a Quote &rarr;
      </a>
    </div>

    <h2 id="applications">Key Applications</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-10 not-prose">
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Large Turbine Lube Oil Purification</h3>
        <p class="text-sm text-gray-600">Steam and gas turbine generators in the 10,000–25,000 HP range, and large industrial turbine-driven equipment. At 15 GPM on R&amp;O lube oil, the DMB-028 delivers high-throughput bypass purification that keeps large lube oil systems continuously clean between scheduled oil changes.</p>
        <a href="/lube-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Lube Oil Centrifuge Details &rarr;</a>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">High-Volume Diesel &amp; Gas Oil Polishing</h3>
        <p class="text-sm text-gray-600">Large fuel storage depots, refinery off-spec handling, and large generator installations with high daily fuel throughput. The DMB-028 polishes diesel at 28 GPM and gas oil at 37 GPM — handling large-scale fuel quality maintenance economically.</p>
        <a href="/diesel-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Diesel Centrifuge Details &rarr;</a>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Industrial Compressor Lube Oil</h3>
        <p class="text-sm text-gray-600">Large reciprocating compressors, centrifugal compressors, and compressor stations in gas processing and petrochemical facilities. The DMB-028 maintains lube oil cleanliness for compressors with large oil reservoir volumes where continuous high-throughput purification is needed.</p>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Central Lube Oil Systems</h3>
        <p class="text-sm text-gray-600">Centralized lube oil systems serving multiple pieces of industrial machinery from a common reservoir. The DMB-028&rsquo;s high throughput makes it effective for large central systems where individual machine purifiers would be impractical.</p>
      </div>
    </div>

    <!-- FAQ -->
    <h2 id="faq">Frequently Asked Questions</h2>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What is the throughput of the DMB-028?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMB-028 processes ~28 GPM of diesel, ~37 GPM of gas oil at 40&deg;C, ~15 GPM of lube oil (R&amp;O), and ~27 GPM of steam turbine oil. Rated at 42 GPM on water-viscosity fluid. 7.5 HP, ~8,700 RPM.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What turbine or industrial application is the DMB-028 sized for?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        At 15 GPM on lube oil (R&amp;O), the DMB-028 suits large turbines in the 10,000–25,000 HP range, large industrial gearboxes, or centralized <a href="/lube-oil-centrifuge/">lube oil</a> purification for multiple machines. Also effective for large diesel polishing at 28 GPM.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">When should I choose DMB-028 over the DMPX-028?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        Both deliver ~28 GPM diesel throughput. The DMB-028 (manual-clean) suits clean lube oil and diesel where solids are low and planned cleanings are manageable. The <a href="/centrifuges/dmpx-028/">DMPX-028</a> (self-cleaning) is better for feeds with significant solids or when continuous unattended operation is required.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">How does the DMB-028 compare to the DMB-019 and DMB-037?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMB-028 (28 GPM diesel) sits between the <a href="/centrifuges/dmb-019/">DMB-019</a> (19 GPM) and the <a href="/centrifuges/dmb-037/">DMB-037</a> (37 GPM). At 15 GPM on R&amp;O lube oil, it suits turbines in the 10,000–25,000 HP range. See all models at the <a href="/disc-stack-centrifuge/">disc stack centrifuge overview</a>.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">Can the DMB-028 serve a centralized lube oil system?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        Yes. At 15 GPM on R&amp;O lube oil, the DMB-028 is well suited for centralized systems serving multiple industrial machines from a common reservoir. <a href="/contact-for-alfa-laval-centrifuges/">Contact Dolphin Centrifuge</a> to size the system for your specific configuration and determine the optimal cleaning schedule.
      </p>
    </details>

    <h2>Related Resources</h2>
    <ul>
      <li><a href="/centrifuges/dmb-019/">DMB-019 Manual-Clean Centrifuge (~19 GPM)</a></li>
      <li><a href="/centrifuges/dmb-037/">DMB-037 Manual-Clean Centrifuge (~37 GPM)</a></li>
      <li><a href="/centrifuges/dmpx-028/">DMPX-028 Self-Cleaning Centrifuge (20–26 GPM)</a></li>
      <li><a href="/disc-stack-centrifuge/">Disc Stack Centrifuge Overview</a></li>
      <li><a href="/contact-for-alfa-laval-centrifuges/">Contact Us for DMB-028 Pricing</a></li>
    </ul>

  </article>

  <!-- Bottom CTA Bar -->
  <div class="not-prose mt-12 rounded-xl bg-navy px-8 py-8 flex flex-col md:flex-row md:items-center gap-6">
    <div class="flex-1">
      <p class="text-white font-bold text-xl mb-1">Ready to order the DMB-028?</p>
      <p class="text-white/80 text-sm">Call <a href="tel:2485222573" class="text-gold font-semibold">(248) 522-2573</a> or email <a href="mailto:sales@dolphincentrifuge.com" class="text-gold font-semibold">sales@dolphincentrifuge.com</a> — 40+ years in centrifugal separation, Warren MI.</p>
    </div>
    <div class="flex flex-col sm:flex-row gap-3 shrink-0">
      <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold text-white font-bold px-6 py-3 rounded-lg hover:bg-gold/90 transition-colors text-center">Get a Free Quote</a>
      <a href="/industrial-centrifuge-sample-testing/" class="inline-block border border-white text-white font-bold px-6 py-3 rounded-lg hover:bg-white/10 transition-colors text-center">Free Sample Testing</a>
    </div>
  </div>

</ApplicationLayout>
