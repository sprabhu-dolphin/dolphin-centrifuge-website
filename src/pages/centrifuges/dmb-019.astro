---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "DMB-019 Manual-Clean Disc Stack Centrifuge",
    "description": "Dolphin DMB-019 manual-clean disc stack centrifuge clarifier. 19 GPM diesel, 5 HP, 8,700 RPM. High-performance manual clarifier for large turbine lube oil systems and industrial fluid purification.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "category": "Disc Stack Centrifuges",
    "model": "DMB-019",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
      "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "DMB-019 Manual-Clean Disc Stack Centrifuge — Specifications & Applications",
    "author": {
      "@type": "Person",
      "name": "Sanjay Prabhu MSME",
      "jobTitle": "Centrifuge Applications Engineer",
      "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    },
    "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "url": "https://dolphincentrifuge.com/centrifuges/dmb-019/"
  }
];
---

<ApplicationLayout
  title="DMB-019 Manual-Clean Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMB-019 manual-clean disc centrifuge: 19 GPM diesel, 5 HP, 8,700 RPM. High-capacity clarifier for large turbine lube oil (5,000-15,000 HP) applications."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmb-019/"
  heroImage="/images/lube-oil-centrifuge/Alfa-Laval-MAB206-Turbine-Lube-Oil.webp"
  heroImageAlt="Dolphin DMB-019 manual-clean disc stack centrifuge for turbine lube oil purification"
  category="products"
  categoryLabel="Dolphin Basket Centrifuges"
  toc={[
    { id: "ai-summary", label: "AI Summary" },
    { id: "specs", label: "Specifications" },
    { id: "capacity", label: "Capacity by Application" },
    { id: "applications", label: "Key Applications" },
    { id: "faq", label: "FAQ" },
  ]}
  relatedApplications={[
    { label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/" },
    { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
  ]}
  relatedProducts={[
    { label: "DMB-028 Manual-Clean Centrifuge", href: "/centrifuges/dmb-028/" },
    { label: "DMB-037 Manual-Clean Centrifuge", href: "/centrifuges/dmb-037/" },
    { label: "DMPX-028 Self-Cleaning Centrifuge", href: "/centrifuges/dmpx-028/" },
  ]}
  jsonLd={jsonLd}
>
  <article class="prose-dolphin max-w-none">

    <div id="ai-summary" class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-6 not-prose mb-8">
      <p class="text-base italic text-gray-700 leading-relaxed">
        <strong>AI Summary:</strong> Dolphin Centrifuge supplies the DMB-019 — a manual-clean disc stack centrifuge clarifier rated at 19 GPM on diesel (13 cSt) and 29 GPM water-rated throughput. Operating at 8,700 RPM with a 5 HP motor, the DMB-019 is suited for large turbine lube oil purification (5,000–15,000 HP), high-volume diesel polishing, and large industrial hydraulic oil maintenance. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in centrifugal separation.
      </p>
    </div>

    <h2 id="specs">DMB-019 Specifications</h2>
    <div class="overflow-x-auto mb-4">
      <table>
        <thead>
          <tr>
            <th>Parameter</th>
            <th>Value</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Separation type</td><td>Two-phase clarifier (liquid-liquid or liquid-solid)</td></tr>
          <tr><td>Diesel throughput</td><td>~19 GPM (13 cSt at operating temperature)</td></tr>
          <tr><td>Rated throughput (water)</td><td>~29 GPM</td></tr>
          <tr><td>Bowl speed</td><td>8,700 RPM</td></tr>
          <tr><td>Drive motor</td><td>5 HP</td></tr>
          <tr><td>Cleaning method</td><td>Manual (bowl disassembly required for solids removal)</td></tr>
          <tr><td>Bowl construction</td><td>Carbon steel standard</td></tr>
          <tr><td>Power supply</td><td>460V / 3-phase / 60 Hz standard (other voltages available)</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-sm text-gray-500 italic">Throughput figures are for typical fluids at listed conditions. Actual capacity varies with feed viscosity, temperature, density difference, and solids loading.</p>

    <h2 id="capacity">DMB-019 Capacity by Application (GPM)</h2>
    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Application / Fluid</th>
            <th>Throughput (GPM)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Gas oil at 40&deg;C</td><td>~25 GPM</td></tr>
          <tr><td>Diesel fuel (13 cSt)</td><td>~19 GPM</td></tr>
          <tr><td>Lube oil (R&amp;O)</td><td>~10 GPM</td></tr>
          <tr><td>Lube oil (detergent)</td><td>~9 GPM</td></tr>
          <tr><td>Steam turbine oil</td><td>~19 GPM</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Mid-Page CTA -->
    <div class="not-prose my-10 rounded-xl border-l-4 border-gold bg-gold/10 p-6 flex flex-col md:flex-row md:items-center gap-4">
      <div class="flex-1">
        <p class="text-navy font-bold text-lg mb-1">Sizing a turbine lube oil purifier?</p>
        <p class="text-gray-700 text-sm">Our applications engineers calculate the correct DMB model from your turbine HP rating, oil reservoir volume, and target turnover rate — at no charge.</p>
      </div>
      <a href="/contact-for-alfa-laval-centrifuges/" class="shrink-0 inline-block bg-gold text-white font-bold px-6 py-3 rounded-lg hover:bg-gold/90 transition-colors text-center">
        Request a Quote &rarr;
      </a>
    </div>

    <h2 id="applications">Key Applications</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-10 not-prose">
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Large Turbine Lube Oil Systems</h3>
        <p class="text-sm text-gray-600">Turbine generators in the 5,000–15,000 HP range with large lube oil reservoirs. The DMB-019 handles bypass purification at 10–19 GPM on turbine oil, removing water ingress and particulates to maintain ISO cleanliness targets and extend oil drain intervals.</p>
        <a href="/lube-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Lube Oil Centrifuge Details &rarr;</a>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">High-Volume Diesel &amp; Gas Oil Polishing</h3>
        <p class="text-sm text-gray-600">Large standby generators, prime power installations, and diesel fuel storage facilities with large tank volumes. The DMB-019 polishes fuel at 19–25 GPM, maintaining fuel quality and removing water contamination before it reaches engine fuel systems.</p>
        <a href="/diesel-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Diesel Centrifuge Details &rarr;</a>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Large Industrial Hydraulic Systems</h3>
        <p class="text-sm text-gray-600">Heavy industrial presses, rolling mills, die casting machines, and other large hydraulic equipment requiring continuous oil purification. At 10 GPM on hydraulic oil, the DMB-019 maintains system cleanliness across large oil volumes.</p>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Process Oil &amp; Compressor Lube</h3>
        <p class="text-sm text-gray-600">Large reciprocating and screw compressors, process industry lubrication systems, and industrial gearboxes requiring continuous oil polishing at higher flow rates than smaller DMB models can provide.</p>
      </div>
    </div>

    <!-- FAQ -->
    <h2 id="faq">Frequently Asked Questions</h2>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What is the throughput of the DMB-019?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMB-019 processes ~19 GPM of diesel, ~25 GPM of gas oil at 40&deg;C, ~10 GPM of lube oil (R&amp;O), and ~19 GPM of steam turbine oil. Rated at 29 GPM on water-viscosity fluid. Operating at 8,700 RPM, 5 HP.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What turbine size is the DMB-019 suited for?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        At 10 GPM on lube oil (R&amp;O), the DMB-019 suits turbines from approximately 5,000–15,000 HP with lube oil reservoirs of 2,000–10,000 gallons. <a href="/contact-for-alfa-laval-centrifuges/">Contact Dolphin Centrifuge</a> for a sizing calculation based on your specific turbine and oil reservoir.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">When should I choose DMB-019 over the DMPX-028?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        Choose the DMB-019 when solids content is low and periodic planned cleaning is acceptable — primarily for clean turbine lube oil and diesel polishing. The <a href="/centrifuges/dmpx-028/">DMPX-028</a> is better when solids loading is moderate to high, continuous unattended operation is required, or manual cleaning labor costs outweigh the self-cleaning price premium.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">How does the DMB-019 compare to the DMB-013 and DMB-028?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMB-019 (19 GPM diesel) sits between the <a href="/centrifuges/dmb-013/">DMB-013</a> (13 GPM) and the <a href="/centrifuges/dmb-028/">DMB-028</a> (28 GPM). At 10 GPM on lube oil (R&amp;O), it bridges the gap for turbine systems in the 5,000–15,000 HP range. See the full comparison at the <a href="/disc-stack-centrifuge/">disc stack centrifuge overview</a>.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What is the motor size for the DMB-019?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMB-019 uses a 5 HP motor at 8,700 RPM, delivering the centrifugal force needed for effective separation of <a href="/lube-oil-centrifuge/">lube oil</a>, diesel, and gas oil across its full rated throughput range. <a href="/contact-for-alfa-laval-centrifuges/">Contact us</a> for full electrical specifications and available power configurations.
      </p>
    </details>

    <h2>Related Resources</h2>
    <ul>
      <li><a href="/centrifuges/dmb-013/">DMB-013 Manual-Clean Centrifuge (~13 GPM)</a></li>
      <li><a href="/centrifuges/dmb-028/">DMB-028 Manual-Clean Centrifuge (~28 GPM)</a></li>
      <li><a href="/centrifuges/dmpx-028/">DMPX-028 Self-Cleaning Centrifuge (20–26 GPM)</a></li>
      <li><a href="/disc-stack-centrifuge/">Disc Stack Centrifuge Overview</a></li>
      <li><a href="/contact-for-alfa-laval-centrifuges/">Contact Us for DMB-019 Pricing</a></li>
    </ul>

  </article>

  <!-- Bottom CTA Bar -->
  <div class="not-prose mt-12 rounded-xl bg-navy px-8 py-8 flex flex-col md:flex-row md:items-center gap-6">
    <div class="flex-1">
      <p class="text-white font-bold text-xl mb-1">Ready to order the DMB-019?</p>
      <p class="text-white/80 text-sm">Call <a href="tel:+12485222573" class="text-gold font-semibold">(248) 522-2573</a> or email <a href="mailto:sales@dolphincentrifuge.com" class="text-gold font-semibold">sales@dolphincentrifuge.com</a> — 40+ years in centrifugal separation, Warren MI.</p>
    </div>
    <div class="flex flex-col sm:flex-row gap-3 shrink-0">
      <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold text-white font-bold px-6 py-3 rounded-lg hover:bg-gold/90 transition-colors text-center">Get a Quote</a>
      <a href="/industrial-centrifuge-sample-testing/" class="inline-block border border-white text-white font-bold px-6 py-3 rounded-lg hover:bg-white/10 transition-colors text-center">Sample Testing</a>
    </div>
  </div>

</ApplicationLayout>
