---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "DMB-019 Manual-Clean Disc Stack Centrifuge",
    "description": "Dolphin DMB-019 manual-clean disc stack centrifuge clarifier. 19 GPM diesel, 5 HP, 8,700 RPM. High-performance manual clarifier for large turbine lube oil systems and industrial fluid purification.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "category": "Disc Stack Centrifuges",
    "model": "DMB-019",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
      "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the throughput of the DMB-019 centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Dolphin DMB-019 processes approximately 19 GPM of diesel fuel (13 cSt), 25 GPM of gas oil at 40°C, 10 GPM of lube oil (R&O), and 19 GPM of steam turbine oil. It is rated at 29 GPM on water-viscosity fluid. Operating at 8,700 RPM with a 5 HP motor."
        }
      },
      {
        "@type": "Question",
        "name": "What turbine size is the DMB-019 suited for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "At 10 GPM on lube oil (R&O) throughput, the DMB-019 is well suited for turbines from approximately 5,000–15,000 HP with lube oil reservoirs of 2,000–10,000 gallons. It can also serve as a bypass purifier for larger turbines when a full-flow unit is not required. Contact Dolphin Centrifuge for a sizing calculation based on your specific turbine model and oil reservoir volume."
        }
      },
      {
        "@type": "Question",
        "name": "When should I choose the DMB-019 over the DMPX-028 self-cleaning model?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMB-019 is the better choice when feed solids content is low and periodic planned cleaning is acceptable — primarily for clean turbine lube oil, diesel polishing, and gas oil purification. The DMPX-028 is the better choice when solids loading is moderate to high, continuous 24/7 unattended operation is required, or when the cost of manual cleaning shutdowns exceeds the capital cost premium for self-cleaning."
        }
      }
    ]
  }
];
---

<ApplicationLayout
  title="DMB-019 Manual-Clean Disc Stack Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMB-019 manual-clean disc stack centrifuge. 19 GPM diesel, 5 HP, 8,700 RPM. Large turbine lube oil systems and high-volume industrial fluid purification."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmb-019/"
  category="products"
  categoryLabel="Dolphin Basket Centrifuges"
  toc={[{id: "specs", label: "Specifications"}, {id: "capacity", label: "Capacity by Application"}, {id: "applications", label: "Key Applications"}, {id: "faq", label: "FAQ"}, {id: "resources", label: "Related Resources"}]}
  relatedApplications={[{label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/"}, {label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/"}, {label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/"}]}
  relatedProducts={[{label: "DMB-028 Manual-Clean Centrifuge", href: "/centrifuges/dmb-028/"}, {label: "DMB-037 Manual-Clean Centrifuge", href: "/centrifuges/dmb-037/"}, {label: "DMPX-028 Self-Cleaning Centrifuge", href: "/centrifuges/dmpx-028/"}]}
  jsonLd={jsonLd}
  heroImage="/images/lube-oil-centrifuge/Alfa-Laval-MAB206-Turbine-Lube-Oil.webp"
  heroImageAlt="Alfa Laval MAB 206 turbine lube oil centrifuge — base unit for the Dolphin DMB-019 manual-clean clarifier"
>
  <article class="prose-dolphin max-w-none">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies the DMB-019 — a manual-clean disc stack centrifuge clarifier for high-throughput oil purification where self-cleaning is not required. Operating at 8,700 RPM with a 5 HP motor, the DMB-019 processes approximately 19 GPM of diesel-viscosity fluid (29 GPM rated on water). Applications include large turbine lube oil purification (5,000–15,000 HP systems), high-volume diesel polishing, gas oil clarification, and large industrial hydraulic oil maintenance. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in disc stack centrifuge systems.</p>
      </div>

      <!-- Specs Table -->
      <h2 id="specs" class="text-2xl md:text-3xl font-bold text-navy mb-4">DMB-019 Specifications</h2>
      <div class="overflow-x-auto mb-4">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Parameter</th>
              <th class="text-left px-4 py-3 font-semibold">Value</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Separation type</td>
              <td class="px-4 py-3 text-text-light">Two-phase clarifier (liquid-liquid or liquid-solid)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Diesel throughput</td>
              <td class="px-4 py-3 text-text-light">~19 GPM (13 cSt at operating temperature)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Rated throughput (water)</td>
              <td class="px-4 py-3 text-text-light">~29 GPM</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Bowl speed</td>
              <td class="px-4 py-3 text-text-light">8,700 RPM</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Drive motor</td>
              <td class="px-4 py-3 text-text-light">5 HP</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Cleaning method</td>
              <td class="px-4 py-3 text-text-light">Manual (bowl disassembly required for solids removal)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Bowl construction</td>
              <td class="px-4 py-3 text-text-light">Carbon steel standard</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Power supply</td>
              <td class="px-4 py-3 text-text-light">460V / 3-phase / 60 Hz standard (other voltages available)</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-sm text-text-muted mb-8 italic">Throughput figures are for typical fluids at listed conditions. Actual capacity varies with feed viscosity, temperature, density difference, and solids loading.</p>

      <!-- Capacity by Application -->
      <h2 id="capacity" class="text-2xl md:text-3xl font-bold text-navy mb-4">DMB-019 Capacity by Application (GPM)</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Application / Fluid</th>
              <th class="text-left px-4 py-3 font-semibold">Throughput (GPM)</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Gas oil at 40&deg;C</td><td class="px-4 py-3 text-text-light">~25 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Diesel fuel (13 cSt)</td><td class="px-4 py-3 text-text-light">~19 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Lube oil (R&amp;O)</td><td class="px-4 py-3 text-text-light">~10 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Lube oil (detergent)</td><td class="px-4 py-3 text-text-light">~9 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Steam turbine oil</td><td class="px-4 py-3 text-text-light">~19 GPM</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="applications" class="text-2xl md:text-3xl font-bold text-navy mb-4">Key Applications</h2>
      <div class="grid md:grid-cols-2 gap-6 mb-10">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Large Turbine Lube Oil Systems</h3>
          <p class="text-sm text-text-light">Turbine generators in the 5,000–15,000 HP range with large lube oil reservoirs. The DMB-019 handles bypass purification at 10–19 GPM on turbine oil, removing water ingress and particulates to maintain ISO cleanliness targets and extend oil drain intervals.</p>
          <a href="/lube-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Lube Oil Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">High-Volume Diesel &amp; Gas Oil Polishing</h3>
          <p class="text-sm text-text-light">Large standby generators, prime power installations, and diesel fuel storage facilities with large tank volumes. The DMB-019 polishes fuel at 19–25 GPM, maintaining fuel quality and removing water contamination before it reaches engine fuel systems.</p>
          <a href="/diesel-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Diesel Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Large Industrial Hydraulic Systems</h3>
          <p class="text-sm text-text-light">Heavy industrial presses, rolling mills, die casting machines, and other large hydraulic equipment requiring continuous oil purification. At 10 GPM on hydraulic oil, the DMB-019 maintains system cleanliness across large oil volumes.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Process Oil &amp; Compressor Lube</h3>
          <p class="text-sm text-text-light">Large reciprocating and screw compressors, process industry lubrication systems, and industrial gearboxes requiring continuous oil polishing at higher flow rates than smaller DMB models can provide.</p>
        </div>
      </div>

      <!-- FAQ -->
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 id="faq" class="text-xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What is the throughput of the DMB-019?</h3>
            <p class="text-text-light text-sm">The DMB-019 processes ~19 GPM of diesel, ~25 GPM of gas oil at 40&deg;C, ~10 GPM of lube oil (R&amp;O), and ~19 GPM of steam turbine oil. Rated at 29 GPM on water-viscosity fluid. Operating at 8,700 RPM, 5 HP.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What turbine size is the DMB-019 suited for?</h3>
            <p class="text-text-light text-sm">At 10 GPM on lube oil (R&amp;O), the DMB-019 suits turbines from approximately 5,000–15,000 HP with lube oil reservoirs of 2,000–10,000 gallons. Contact Dolphin Centrifuge for a sizing calculation based on your specific turbine and oil reservoir.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">When should I choose DMB-019 over the DMPX-028?</h3>
            <p class="text-text-light text-sm">Choose the DMB-019 when solids content is low and periodic planned cleaning is acceptable — primarily for clean turbine lube oil and diesel polishing. The DMPX-028 is better when solids loading is moderate to high, continuous unattended operation is required, or manual cleaning labor costs outweigh the self-cleaning price premium.</p>
          </div>
        </div>
      </div>

      <h2 id="resources" class="text-2xl md:text-3xl font-bold text-navy mb-4">Related Resources</h2>
      <ul class="text-text-light space-y-2 mb-8">
        <li>&#8226; <a href="/centrifuges/dmb-013/" class="text-navy font-semibold hover:text-gold transition-colors">DMB-013 Manual-Clean Centrifuge (~13 GPM)</a></li>
        <li>&#8226; <a href="/centrifuges/dmb-028/" class="text-navy font-semibold hover:text-gold transition-colors">DMB-028 Manual-Clean Centrifuge (~28 GPM)</a></li>
        <li>&#8226; <a href="/centrifuges/dmpx-028/" class="text-navy font-semibold hover:text-gold transition-colors">DMPX-028 Self-Cleaning Centrifuge (20–26 GPM)</a></li>
        <li>&#8226; <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Disc Stack Centrifuge Overview</a></li>
        <li>&#8226; <a href="/contact-for-alfa-laval-centrifuges/" class="text-navy font-semibold hover:text-gold transition-colors">Contact Us for DMB-019 Pricing</a></li>
      </ul>

  </article>
</ApplicationLayout>
