---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "DMPX-028 Self-Cleaning 3-Phase Disc Stack Centrifuge",
    "description": "The Dolphin DMPX-028 is a mid-range self-cleaning three-phase disc stack centrifuge processing 20–26 GPM of diesel and handling HFO, biodiesel, waste oil, and lube oil in continuous industrial service.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "category": "Disc Stack Centrifuges",
    "model": "DMPX-028",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
      "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "DMPX-028 Self-Cleaning Centrifuge — Specifications & Applications",
    "author": {
      "@type": "Person",
      "name": "Sanjay Prabhu MSME",
      "jobTitle": "Centrifuge Applications Engineer",
      "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    },
    "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "url": "https://dolphincentrifuge.com/centrifuges/dmpx-028/"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the throughput of the DMPX-028 centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMPX-028 processes approximately 20–26 GPM of diesel fuel at actual operating conditions, with a rated capacity of 33–40 GPM under ideal low-viscosity conditions. Lube oil (R&O) throughput is 10–14 GPM and steam turbine oil is 21–26 GPM."
        }
      },
      {
        "@type": "Question",
        "name": "What applications is the DMPX-028 used for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMPX-028 is widely used for biodiesel production finishing, industrial waste oil reclamation, HFO purification on medium-sized marine vessels and power generators, hydraulic and lube oil maintenance, and light crude oil dewatering. Its 1.03-gallon sludge bowl supports continuous operation in moderately contaminated streams."
        }
      },
      {
        "@type": "Question",
        "name": "How does the DMPX-028 compare to the DMPX-014?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMPX-028 delivers roughly twice the diesel throughput of the DMPX-014 (20–26 GPM vs. 13–16 GPM) and features a significantly larger 1.03-gallon sludge bowl versus the DMPX-014's smaller bowl. This makes it better suited for industrial waste oil and HFO applications with higher solids loading, while the DMPX-014 is preferred for lighter marine and small industrial duties."
        }
      },
      {
        "@type": "Question",
        "name": "Can the DMPX-028 process HFO 380 cSt heavy fuel oil?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The DMPX-028 processes HFO 380 cSt at approximately 8–10 GPM, making it suitable for HFO purification on medium marine vessels, shore-based power generators, and industrial boiler fuel systems. For larger HFO volumes or higher viscosities, the DMPX-042 or DMPX-070 may be more appropriate."
        }
      },
      {
        "@type": "Question",
        "name": "What is the sludge bowl capacity of the DMPX-028?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMPX-028 features a 1.03-gallon sludge bowl that automatically ejects accumulated solids via hydraulic pressure without stopping the centrifuge. This allows continuous 24/7 operation even with moderately contaminated oil streams. For heavily contaminated feeds with very high solids loading, the DMPX-042 with its 1.64-gallon bowl is recommended."
        }
      }
    ]
  }
];
---

<ApplicationLayout
  title="DMPX-028 Self-Cleaning Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMPX-028 self-cleaning disc centrifuge: 20-26 GPM diesel, 1.03-gal bowl, 10-15 HP. Mid-range unit for waste oil, HFO purification, and biodiesel."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmpx-028/"
  heroImage="/images/alfa-laval-mopx-207-centrifuge/Alfa-Laval-MOPX207-Used-Oil-Centrifuge-600.webp"
  heroImageAlt="Dolphin Centrifuge DMPX-028 self-cleaning three-phase disc stack centrifuge"
  category="products"
  categoryLabel="Dolphin Disc Centrifuges"
  toc={[
    { id: "technical-specifications", label: "Technical Specifications" },
    { id: "capacity-by-fluid-type", label: "Capacity by Fluid Type" },
    { id: "key-applications", label: "Key Applications" },
    { id: "dmpx-series-comparison", label: "DMPX Series Comparison" },
    { id: "frequently-asked-questions", label: "Frequently Asked Questions" },
  ]}
  relatedApplications={[
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
    { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
    { label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/" },
  ]}
  relatedProducts={[
    { label: "DMPX-010 (~7 GPM)", href: "/centrifuges/dmpx-010/" },
    { label: "DMPX-042 (~32–47 GPM)", href: "/centrifuges/dmpx-042/" },
    { label: "DMPX-070 (~59–72 GPM)", href: "/centrifuges/dmpx-070/" },
    { label: "DMB-019 Manual-Clean", href: "/centrifuges/dmb-019/" },
  ]}
  jsonLd={jsonLd}
>

  <article class="prose-dolphin max-w-none">

    <!-- AI Summary -->
    <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-6 not-prose mb-8">
      <p class="text-base italic text-gray-700 leading-relaxed">
        <strong>AI Summary:</strong> Dolphin Centrifuge supplies the DMPX-028 — a mid-range self-cleaning three-phase disc stack centrifuge rated at 20–26 GPM for diesel fuel, with a 1.03-gallon sludge bowl and 10–15 HP motor. Purpose-built for industrial waste oil reclamation, biodiesel finishing, and HFO purification up to 380 cSt. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in centrifugal separation.
      </p>
    </div>

    <!-- Product Image -->
    <figure class="text-center my-8">
      <img
        src="/images/alfa-laval-mopx-207-centrifuge/Alfa-Laval-MOPX207-Used-Oil-Centrifuge-600.webp"
        alt="Dolphin Centrifuge DMPX-028 self-cleaning three-phase disc stack centrifuge"
        width="600"
        height="600"
        loading="lazy"
        class="rounded-lg shadow-lg max-w-full mx-auto"
      />
      <figcaption class="text-sm text-gray-500 mt-2">
        DMPX-028 — Mid-Range Self-Cleaning 3-Phase Disc Stack Centrifuge
      </figcaption>
    </figure>

    <!-- Technical Specifications -->
    <h2 id="technical-specifications">Technical Specifications</h2>
    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Parameter</th>
            <th>DMPX-028 Value</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Diesel Throughput (Actual)</td><td>~20–26 GPM</td></tr>
          <tr><td>Diesel Throughput (Rated)</td><td>~33–40 GPM</td></tr>
          <tr><td>Bowl Sludge Capacity</td><td>1.03 gallons</td></tr>
          <tr><td>Motor Power</td><td>~10–15 HP</td></tr>
          <tr><td>Separation Type</td><td>Three-phase (oil / water / solids)</td></tr>
          <tr><td>Desludging</td><td>Automatic self-cleaning (hydraulic ejection)</td></tr>
          <tr><td>Process</td><td>Continuous, unattended operation</td></tr>
          <tr><td>Lube Oil (R&amp;O) Throughput</td><td>10–14 GPM</td></tr>
          <tr><td>Steam Turbine Oil Throughput</td><td>21–26 GPM</td></tr>
          <tr><td>DMPX Series Position</td><td>Mid-range (28 bowl equiv.)</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Capacity by Fluid Type -->
    <h2 id="capacity-by-fluid-type">Capacity by Fluid Type</h2>
    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Fluid Type</th>
            <th>Approx. Throughput (GPM)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Diesel / Light Fuel Oil</td><td>20–26</td></tr>
          <tr><td>HFO 30 cSt</td><td>20–25</td></tr>
          <tr><td>HFO 60 cSt</td><td>15–18</td></tr>
          <tr><td>HFO 100 cSt</td><td>15–18</td></tr>
          <tr><td>HFO 180 cSt</td><td>10–12</td></tr>
          <tr><td>HFO 380 cSt</td><td>8–10</td></tr>
          <tr><td>Lube Oil (R&amp;O) / Steam Turbine</td><td>10–14 / 21–26 GPM</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-xs text-gray-500">
      * Throughput values are at typical process temperature (194&deg;F / 90&deg;C). Actual flow rates vary with temperature, contamination level, and desired separation efficiency.
    </p>

    <!-- Key Applications -->
    <h2 id="key-applications">Key Applications</h2>

    <h3>Waste Oil Reclamation</h3>
    <p>
      At 20–26 GPM, the DMPX-028 can continuously process industrial used oil streams — including used motor oil, hydraulic oil, and gear oil — separating water and particulate solids to produce reclaimed base oil suitable for reuse or resale. See our <a href="/waste-oil-centrifuge/">waste oil centrifuge</a> application page for details.
    </p>

    <h3>Biodiesel Production</h3>
    <p>
      The DMPX-028 is widely used in <a href="/biodiesel-centrifuge/">biodiesel</a> finishing: removing residual methanol, water, and glycerin from biodiesel after transesterification. Continuous operation at 20–26 GPM supports mid-scale biodiesel production without manual centrifuge downtime.
    </p>

    <h3>HFO Purification</h3>
    <p>
      Capable of processing HFO up to 380 cSt at 8–10 GPM, the DMPX-028 handles <a href="/fuel-oil-centrifuge/">heavy fuel oil</a> purification on medium marine vessels, shore-based power generators, and industrial boiler fuel systems. Three-phase separation removes both water and catalyst fines in a single pass.
    </p>

    <h3>Hydraulic &amp; Lube Oil Maintenance</h3>
    <p>
      The DMPX-028 processes 10–14 GPM of R&amp;O <a href="/lube-oil-centrifuge/">lube oil</a>, making it appropriate for larger industrial gearbox oil systems, compressor lube circuits, and hydraulic power units where the DMPX-010 or DMPX-014 is undersized. Continuous operation eliminates the need for batch filtering or oil changes.
    </p>

    <!-- Mid-Page CTA -->
    <div class="not-prose my-10 rounded-xl border-l-4 border-gold bg-gold/10 p-6 flex flex-col md:flex-row md:items-center gap-4">
      <div class="flex-1">
        <p class="text-navy font-bold text-lg mb-1">Ready to specify the DMPX-028?</p>
        <p class="text-gray-700 text-sm">Our applications engineers size every system to your fluid, flow rate, and contamination level — no guesswork. Get a quote or request free sample testing.</p>
      </div>
      <a href="/contact-for-alfa-laval-centrifuges/" class="shrink-0 inline-block bg-gold text-white font-bold px-6 py-3 rounded-lg hover:bg-gold/90 transition-colors text-center">
        Request a Quote &rarr;
      </a>
    </div>

    <!-- DMPX Series Comparison -->
    <h2 id="dmpx-series-comparison">Where the DMPX-028 Fits in the DMPX Series</h2>
    <p>
      The DMPX-028 sits at the middle of the Dolphin DMPX product range. For lighter-duty applications, the
      <a href="/centrifuges/dmpx-010/">DMPX-010</a>
      (~7 GPM) and
      <a href="/dmpx-014-self-cleaning-3-phase-disc-stack-centrifuge/">DMPX-014</a>
      (~13 GPM) offer more compact and lower-power alternatives. For higher-volume industrial applications, the
      <a href="/centrifuges/dmpx-042/">DMPX-042</a>
      (~32–47 GPM) and
      <a href="/centrifuges/dmpx-070/">DMPX-070</a>
      (~59–72 GPM) provide the throughput needed for large-scale crude oil, refinery, or power-plant fuel treatment. All DMPX models use the same automatic self-cleaning bowl design.
      Visit our <a href="/disc-stack-centrifuge/">disc stack centrifuge overview</a> to compare all models, or <a href="/contact-for-alfa-laval-centrifuges/">contact us</a> for application sizing.
    </p>

    <!-- FAQ -->
    <h2 id="frequently-asked-questions">Frequently Asked Questions</h2>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What is the throughput of the DMPX-028 centrifuge?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMPX-028 processes approximately 20–26 GPM of diesel fuel at actual operating conditions, with a rated capacity of 33–40 GPM under ideal low-viscosity conditions. Lube oil (R&amp;O) throughput is 10–14 GPM and steam turbine oil is 21–26 GPM.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What applications is the DMPX-028 used for?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMPX-028 is used for <a href="/biodiesel-centrifuge/">biodiesel</a> production finishing, industrial <a href="/waste-oil-centrifuge/">waste oil</a> reclamation, HFO purification on medium marine vessels and power generators, hydraulic and lube oil maintenance, and light crude oil dewatering. Its 1.03-gallon sludge bowl supports continuous operation even with moderately contaminated oil streams.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">How does the DMPX-028 compare to the DMPX-014?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMPX-028 delivers roughly twice the diesel throughput of the <a href="/dmpx-014-self-cleaning-3-phase-disc-stack-centrifuge/">DMPX-014</a> (20–26 GPM vs. 13–16 GPM) and features a significantly larger 1.03-gallon sludge bowl, making it better suited for industrial waste oil and HFO applications with higher solids loading. The DMPX-014 is preferred for lighter marine and small industrial duties.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">Can the DMPX-028 process HFO 380 cSt heavy fuel oil?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        Yes. The DMPX-028 processes HFO 380 cSt at approximately 8–10 GPM, suitable for <a href="/fuel-oil-centrifuge/">HFO purification</a> on medium marine vessels, shore-based power generators, and industrial boiler fuel systems. For larger HFO volumes, the <a href="/centrifuges/dmpx-042/">DMPX-042</a> (14–18 GPM at 380 cSt) is recommended.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What is the sludge bowl capacity of the DMPX-028?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMPX-028 features a 1.03-gallon sludge bowl that ejects accumulated solids automatically via hydraulic pressure. This enables continuous 24/7 operation without cleaning shutdowns. For extremely high solids loading, the <a href="/centrifuges/dmpx-042/">DMPX-042</a> (1.64-gallon bowl) may be more appropriate. <a href="/contact-for-alfa-laval-centrifuges/">Contact us</a> for application-specific guidance.
      </p>
    </details>

  </article>

  <!-- Bottom CTA Bar -->
  <div class="not-prose mt-12 rounded-xl bg-navy px-8 py-8 flex flex-col md:flex-row md:items-center gap-6">
    <div class="flex-1">
      <p class="text-white font-bold text-xl mb-1">Ready to specify the DMPX-028?</p>
      <p class="text-white/80 text-sm">Call <a href="tel:+12485222573" class="text-gold font-semibold">(248) 522-2573</a> or email <a href="mailto:sales@dolphincentrifuge.com" class="text-gold font-semibold">sales@dolphincentrifuge.com</a> — 40+ years in centrifugal separation, Warren MI.</p>
    </div>
    <div class="flex flex-col sm:flex-row gap-3 shrink-0">
      <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold text-white font-bold px-6 py-3 rounded-lg hover:bg-gold/90 transition-colors text-center">Get a Free Quote</a>
      <a href="/industrial-centrifuge-sample-testing/" class="inline-block border border-white text-white font-bold px-6 py-3 rounded-lg hover:bg-white/10 transition-colors text-center">Free Sample Testing</a>
