---
import BaseLayout from '../../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "DMPX-028 Self-Cleaning Disc Stack Centrifuge",
  "description": "Dolphin DMPX-028 self-cleaning three-phase disc stack centrifuge. 20–26 GPM diesel throughput, 1.03 gal bowl, 7,000–7,800 Gs. General-purpose workhorse for waste oil, biodiesel, and industrial applications.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  "category": "Disc Stack Centrifuges",
  "model": "DMPX-028",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the throughput of the DMPX-028 centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Dolphin DMPX-028 processes 20–26 GPM of diesel-viscosity fluid (13 cSt). Throughput varies by application: HFO at 30 cSt runs 20–25 GPM; lube oil (R&O) runs 10–14 GPM; steam turbine oil runs 21–26 GPM. Actual capacity depends on feed viscosity, temperature, density difference, and solids loading. Contact Dolphin Centrifuge for application-specific sizing."
      }
    },
    {
      "@type": "Question",
      "name": "What makes the DMPX-028 the general-purpose workhorse of the DMPX line?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The DMPX-028 occupies the ideal throughput range for most industrial waste oil, biodiesel, and process oil applications — large enough to handle significant daily volumes efficiently, yet compact enough for most plant footprints. Its 1.03 gallon bowl handles meaningful solids inventory between discharges, and its broad application range (diesel, HFO, lube oil, process water) makes it the most versatile single model in the DMPX family."
      }
    },
    {
      "@type": "Question",
      "name": "What applications is the DMPX-028 best suited for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The DMPX-028 is well suited for waste oil reclamation operations processing 30,000–38,000 gallons per day, mid-scale biodiesel production (glycerin-FAME separation), diesel and heavy fuel oil purification for marine and power generation applications, industrial wastewater clarification, and machining coolant recovery. Its three-phase separation capability handles oil-water-solids feeds in a single continuous pass."
      }
    },
    {
      "@type": "Question",
      "name": "How does the DMPX-028 compare to the DMPX-042?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The DMPX-028 (20–26 GPM diesel) is the right choice for operations requiring up to roughly 35,000 GPD throughput. The DMPX-042 (32–47 GPM diesel) is the step up for larger-volume operations or applications demanding higher throughput with the same self-cleaning, three-phase separation capability. Both share similar operating principles; selection depends primarily on your required daily volume."
      }
    }
  ]
};
---

<BaseLayout
  title="DMPX-028 Self-Cleaning Disc Stack Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMPX-028 self-cleaning disc stack centrifuge. 20–26 GPM diesel, 1.03 gal bowl. General-purpose workhorse for waste oil, biodiesel, and industrial separation."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmpx-028/"
  breadcrumbs={[{label: 'Products', href: '/disc-stack-centrifuge/'}, {label: 'DMPX-028 Centrifuge'}]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">DMPX Series &mdash; Dolphin Centrifuge</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">DMPX-028 Self-Cleaning Three-Phase Disc Stack Centrifuge</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">The Dolphin DMPX-028 is the general-purpose workhorse of the DMPX self-cleaning series — processing 20–26 GPM of diesel-viscosity fluid with automatic solids ejection and true three-phase (oil-water-solids) separation. The most widely deployed DMPX model across waste oil, biodiesel, marine fuel, and industrial process applications.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Request a Quote</a>
        <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-5xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies the DMPX-028 — a self-cleaning three-phase disc stack centrifuge system for continuous oil-water-solids separation at mid-to-large industrial scale. Operating at 7,000–7,800 Gs with a 1.03 gallon bowl, the DMPX-028 processes 20–26 GPM of diesel-viscosity fluids (33–40 GPM rated) with PLC-controlled automatic solids ejection. Applications include waste oil reclamation, biodiesel production, marine heavy fuel oil purification, and industrial wastewater clarification. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in disc stack centrifuge systems.</p>
      </div>

      <!-- Specs Table -->
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">DMPX-028 Specifications</h2>
      <div class="overflow-x-auto mb-4">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Parameter</th>
              <th class="text-left px-4 py-3 font-semibold">Value</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Separation type</td>
              <td class="px-4 py-3 text-text-light">Three-phase (light liquid / heavy liquid / solids)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Diesel throughput</td>
              <td class="px-4 py-3 text-text-light">20–26 GPM (13 cSt at operating temperature)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Rated throughput (water)</td>
              <td class="px-4 py-3 text-text-light">33–40 GPM</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Bowl capacity</td>
              <td class="px-4 py-3 text-text-light">1.03 gallons</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">G-force</td>
              <td class="px-4 py-3 text-text-light">7,000–7,800 Gs</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Solids ejection</td>
              <td class="px-4 py-3 text-text-light">Hydraulic self-cleaning; PLC-controlled intervals</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Bowl construction</td>
              <td class="px-4 py-3 text-text-light">Carbon steel standard; 316L stainless steel available</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Power supply</td>
              <td class="px-4 py-3 text-text-light">460V / 3-phase / 60 Hz standard (other voltages available)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Control system</td>
              <td class="px-4 py-3 text-text-light">PLC with HMI; programmable discharge intervals and alarms</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Explosion-proof option</td>
              <td class="px-4 py-3 text-text-light">Class I Division 1 &amp; 2 configurations available</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-sm text-text-muted mb-8 italic">Throughput figures are for typical fluids at listed conditions. Actual capacity varies with feed viscosity, temperature, density difference, and solids loading. Contact Dolphin Centrifuge for application-specific confirmation.</p>

      <!-- Capacity by Application -->
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">DMPX-028 Capacity by Application (GPM)</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Application / Fluid</th>
              <th class="text-left px-4 py-3 font-semibold">Throughput (GPM)</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Diesel fuel (13 cSt)</td><td class="px-4 py-3 text-text-light">20–26 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">HFO 30 cSt</td><td class="px-4 py-3 text-text-light">20–25 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">HFO 60 cSt</td><td class="px-4 py-3 text-text-light">15–18 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">HFO 100 cSt</td><td class="px-4 py-3 text-text-light">15–18 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">HFO 180 cSt</td><td class="px-4 py-3 text-text-light">10–12 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">HFO 380 cSt</td><td class="px-4 py-3 text-text-light">8–10 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Lube oil (R&amp;O)</td><td class="px-4 py-3 text-text-light">10–14 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Steam turbine oil</td><td class="px-4 py-3 text-text-light">21–26 GPM</td></tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Why the DMPX-028 Is the Most Widely Deployed DMPX Model</h2>
      <p class="text-text-light mb-4">
        The DMPX-028 consistently outsells other DMPX models because its 20–26 GPM diesel throughput matches the processing volume of the largest class of industrial waste oil operations, mid-scale biodiesel producers, and marine fuel treatment systems. At this flow rate, a single DMPX-028 processes 28,800–37,440 gallons per day — covering the daily output of most single-site industrial operations.
      </p>
      <p class="text-text-light mb-8">
        The 1.03 gallon bowl provides meaningful solids inventory capacity between discharge cycles, reducing discharge frequency on heavy-solids feeds and extending bowl life compared to smaller models. The machine operates continuously at full throughput between discharges, unlike some competitor designs that reduce throughput during the discharge cycle.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Key Applications</h2>
      <div class="grid md:grid-cols-2 gap-6 mb-10">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Waste Oil Reclamation</h3>
          <p class="text-sm text-text-light mb-3">Used motor oil, transmission fluid, and industrial waste oils with water and solids contamination. The DMPX-028 separates all three phases continuously at 20+ GPM, recovering reclaimed oil while producing clean water discharge and ejected dry solids.</p>
          <a href="/waste-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Waste Oil Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Biodiesel Production</h3>
          <p class="text-sm text-text-light mb-3">Separating biodiesel (FAME) from glycerin, methanol, soap, and catalyst residues after transesterification. The DMPX-028 replaces multiple settling tanks and wash vessels in the production sequence, handling mid-scale biodiesel production of 30,000+ GPD continuously.</p>
          <a href="/biodiesel-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Biodiesel Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Marine &amp; Industrial Fuel Treatment</h3>
          <p class="text-sm text-text-light mb-3">Purifying diesel, heavy fuel oil (HFO 30–380 cSt), and intermediate fuel oil for marine engines and industrial power generation. The DMPX-028 removes water and solids from HFO at 8–25 GPM depending on viscosity, providing fuel quality that protects injectors and reduces engine wear.</p>
          <a href="/diesel-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Diesel Fuel Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Industrial Wastewater &amp; Process Oil</h3>
          <p class="text-sm text-text-light mb-3">Machining coolant recovery, industrial oily water treatment, tank bottom slop processing, and continuous process oil clarification. The DMPX-028 handles variable-composition feeds with high water cut that would overwhelm smaller centrifuges.</p>
          <a href="/wastewater-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Wastewater Centrifuge Details &rarr;</a>
        </div>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Self-Cleaning Operation</h2>
      <p class="text-text-light mb-4">
        The DMPX-028 ejects accumulated solids automatically through hydraulically actuated discharge ports at the bowl periphery. Each discharge cycle takes less than one second, after which the machine immediately resumes full-speed separation. Discharge frequency is PLC-programmed based on your feed&rsquo;s solids loading: high-solids feeds (waste oil, tank bottoms) typically use 15&ndash;60 minute intervals; low-solids feeds (fuel polishing) may discharge every several hours.
      </p>
      <p class="text-text-light mb-8">
        Self-cleaning operation means the DMPX-028 runs unattended 24/7 without manual cleaning shutdowns. Operators transitioning from manual-clean centrifuges report significant reductions in labor cost and processing gaps, with consistent output quality regardless of solids loading variability in the feed.
      </p>

      <!-- FAQ -->
      <div id="faq" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What is the throughput of the DMPX-028?</h3>
            <p class="text-text-light text-sm">The DMPX-028 processes 20–26 GPM on diesel-viscosity fluid. Lube oil (R&amp;O) runs 10–14 GPM; HFO 180 cSt runs 10–12 GPM; steam turbine oil runs 21–26 GPM. Contact Dolphin Centrifuge for application-specific sizing.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What makes the DMPX-028 the general-purpose workhorse?</h3>
            <p class="text-text-light text-sm">Its 20–26 GPM diesel throughput matches most industrial waste oil, biodiesel, and process oil daily volumes. The 1.03 gal bowl handles significant solids inventory. Broad application range across diesel, HFO, lube oil, and process water makes it the most versatile single DMPX model.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What applications is the DMPX-028 best suited for?</h3>
            <p class="text-text-light text-sm">Waste oil reclamation, biodiesel production, marine and industrial fuel treatment, machining coolant recovery, and industrial wastewater clarification. Best fit for operations requiring 15–30 GPM continuous three-phase separation.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">How does the DMPX-028 compare to the DMPX-042?</h3>
            <p class="text-text-light text-sm">The DMPX-028 (20–26 GPM diesel) handles most mid-scale industrial operations. The DMPX-042 (32–47 GPM diesel) is the step up for larger volumes or higher-throughput requirements. Both use the same self-cleaning, three-phase operating principle.</p>
          </div>
        </div>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Related Resources</h2>
      <ul class="text-text-light space-y-2 mb-8">
        <li>&#8226; <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Disc Stack Centrifuge Overview (all DMPX models)</a></li>
        <li>&#8226; <a href="/centrifuges/dmpx-042/" class="text-navy font-semibold hover:text-gold transition-colors">DMPX-042 Self-Cleaning Centrifuge (32–47 GPM)</a></li>
        <li>&#8226; <a href="/waste-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Waste Oil Centrifuge Applications</a></li>
        <li>&#8226; <a href="/biodiesel-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Biodiesel Centrifuge</a></li>
        <li>&#8226; <a href="/explosion-proof-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Explosion Proof Centrifuge Systems</a></li>
        <li>&#8226; <a href="/contact-for-alfa-laval-centrifuges/" class="text-navy font-semibold hover:text-gold transition-colors">Contact Us for DMPX-028 Pricing</a></li>
      </ul>

    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Bottom CTA -->
  <section class="bg-navy">
    <div class="container-dolphin py-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Get Pricing on the DMPX-028</h2>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">Tell us your fluid type, daily throughput requirement, site conditions, and any special requirements. We will provide a detailed quote for the DMPX-028 or complete skid system.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3.5 rounded-lg transition-colors">Contact Us</a>
        <a href="/industrial-centrifuge-sample-testing/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3.5 rounded-lg transition-colors">Sample Testing</a>
      </div>
    </div>
  </section>
</BaseLayout>
