---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "DMB-007 Manual-Clean Disc Stack Centrifuge",
    "description": "Dolphin DMB-007 manual-clean disc stack centrifuge clarifier. 7 GPM diesel, 1–2 HP, 8,600 RPM. Cost-effective clarifier for turbine lube oil, diesel polishing, and low-volume industrial applications. Also available as DMB-007S in 316L stainless steel.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "category": "Disc Stack Centrifuges",
    "model": "DMB-007",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
      "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "DMB-007 Manual-Clean Disc Stack Centrifuge — Specifications & Applications",
    "author": {
      "@type": "Person",
      "name": "Dolphin Centrifuge Engineering",
      "jobTitle": "Centrifuge Applications Engineer",
      "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    },
    "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "url": "https://dolphincentrifuge.com/centrifuges/dmb-007/"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the throughput of the DMB-007 centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Dolphin DMB-007 processes approximately 7 GPM of diesel fuel (13 cSt), 9 GPM of gas oil at 40°C, 4 GPM of lube oil (R&O), and 6 GPM of steam turbine oil. It is rated at 10 GPM on water-viscosity fluid. Actual throughput varies with fluid viscosity, temperature, and solids loading."
        }
      },
      {
        "@type": "Question",
        "name": "What is the DMB-007S stainless steel variant?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMB-007S is the stainless steel variant of the DMB-007, featuring 316L stainless steel wetted-parts construction throughout the bowl assembly. It delivers the same throughput and operating speed as the DMB-007 and is used for food-grade oil clarification, edible oil processing, pharmaceutical applications, or any application requiring stainless steel material compatibility."
        }
      },
      {
        "@type": "Question",
        "name": "What applications is the DMB-007 best suited for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMB-007 is best suited for medium-small turbine lube oil systems (1,000–3,000 HP), diesel fuel polishing on small to mid-size generators, hydraulic oil purification, quench oil clarification, and low-volume industrial oil polishing where solids content is low and periodic cleaning is acceptable."
        }
      },
      {
        "@type": "Question",
        "name": "When should I choose the DMB-007 over the DMB-004 or DMB-013?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Choose the DMB-007 when your throughput requirement is 5–9 GPM diesel — outgrown the DMB-004 (4 GPM) but below the DMB-013 (13 GPM). For turbine lube oil, the DMB-007 at 4 GPM R&O throughput suits systems from approximately 1,000–3,000 HP. If you need food-grade construction, the DMB-007S stainless variant is available at the same throughput."
        }
      },
      {
        "@type": "Question",
        "name": "Can the DMB-007 handle food-grade oil applications?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, with the DMB-007S stainless steel variant. The DMB-007S features 316L stainless steel bowl construction suitable for edible oil clarification, food-grade lubricant purification, and pharmaceutical oil processing. The carbon steel DMB-007 is suitable for industrial petroleum applications but not food-contact applications."
        }
      }
    ]
  }
];
---

<ApplicationLayout
  title="DMB-007 Manual-Clean Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMB-007 manual-clean disc stack centrifuge: 7 GPM diesel, 1–2 HP, 8,600 RPM. Cost-effective for turbine lube oil, diesel polishing, and light industrial use."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmb-007/"
  heroImage="/images/alfa-laval-mab-103-centrifuge/Alfa-Laval-MAB103-Class1Div2-300.webp"
  heroImageAlt="Dolphin DMB-007 manual-clean disc stack centrifuge system"
  category="products"
  categoryLabel="Dolphin Basket Centrifuges"
  toc={[
    { id: "ai-summary", label: "AI Summary" },
    { id: "specifications", label: "DMB-007 Specifications" },
    { id: "capacity-by-application", label: "Capacity by Application" },
    { id: "stainless-steel-variant", label: "DMB-007S Stainless Steel" },
    { id: "key-applications", label: "Key Applications" },
    { id: "faq", label: "Frequently Asked Questions" },
  ]}
  relatedApplications={[
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
    { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
    { label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/" },
  ]}
  relatedProducts={[
    { label: "DMB-004 Manual-Clean Centrifuge", href: "/centrifuges/dmb-004/" },
    { label: "DMB-013 Manual-Clean Centrifuge", href: "/centrifuges/dmb-013/" },
    { label: "DMPX-010 Self-Cleaning Centrifuge", href: "/centrifuges/dmpx-010/" },
  ]}
  jsonLd={jsonLd}
>
  <article class="prose-dolphin max-w-none">

    <div id="ai-summary" class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-6 not-prose mb-8">
      <p class="text-base italic text-gray-700 leading-relaxed">
        <strong>AI Summary:</strong> Dolphin Centrifuge supplies the DMB-007 — a manual-clean disc stack centrifuge clarifier rated at 7 GPM on diesel (13 cSt) and 8,600 RPM with 1–2 HP drive power. Also available as the DMB-007S in 316L stainless steel for food-grade and pharmaceutical applications. Ideal for turbine lube oil systems (1,000–3,000 HP), diesel polishing, and quench oil clarification. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in centrifugal separation.
      </p>
    </div>

    <h2 id="specifications">DMB-007 Specifications</h2>
    <div class="overflow-x-auto mb-4">
      <table>
        <thead>
          <tr>
            <th>Parameter</th>
            <th>DMB-007</th>
            <th>DMB-007S (Stainless)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Separation type</td><td colspan="2">Two-phase clarifier (liquid-liquid or liquid-solid)</td></tr>
          <tr><td>Diesel throughput</td><td colspan="2">~7 GPM (13 cSt at operating temperature)</td></tr>
          <tr><td>Rated throughput (water)</td><td colspan="2">~10 GPM</td></tr>
          <tr><td>Bowl speed</td><td colspan="2">~8,600 RPM</td></tr>
          <tr><td>Drive motor</td><td colspan="2">1–2 HP</td></tr>
          <tr><td>Bowl construction</td><td>Carbon steel</td><td>316L stainless steel</td></tr>
          <tr><td>Cleaning method</td><td colspan="2">Manual (bowl disassembly required for solids removal)</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-sm text-gray-500 italic">Throughput figures are for typical fluids at listed conditions. Actual capacity varies with feed viscosity, temperature, density difference, and solids loading.</p>

    <h2 id="capacity-by-application">DMB-007 Capacity by Application (GPM)</h2>
    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Application / Fluid</th>
            <th>Throughput (GPM)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Gas oil at 40&deg;C</td><td>~9 GPM</td></tr>
          <tr><td>Diesel fuel (13 cSt)</td><td>~7 GPM</td></tr>
          <tr><td>Lube oil (R&amp;O)</td><td>~4 GPM</td></tr>
          <tr><td>Lube oil (detergent)</td><td>~3 GPM</td></tr>
          <tr><td>Steam turbine oil</td><td>~6 GPM</td></tr>
        </tbody>
      </table>
    </div>

    <h2 id="stainless-steel-variant">DMB-007S — Stainless Steel Variant</h2>
    <p>
      The DMB-007S is the stainless steel construction variant of the DMB-007, featuring 316L stainless steel wetted-part construction throughout the bowl assembly. It delivers the same throughput and operating speed as the DMB-007 in a <a href="/food-grade-centrifuge/">food-grade</a> compatible configuration. The DMB-007S is used for:
    </p>
    <ul>
      <li>Edible oil clarification (vegetable oil, olive oil, sunflower oil)</li>
      <li>Food-grade lubricant purification</li>
      <li>Pharmaceutical oil clarification</li>
      <li>Applications requiring stainless steel for chemical compatibility</li>
      <li>Wash water clarification in food processing environments</li>
    </ul>

    <!-- Mid-Page CTA -->
    <div class="not-prose my-10 rounded-xl border-l-4 border-gold bg-gold/10 p-6 flex flex-col md:flex-row md:items-center gap-4">
      <div class="flex-1">
        <p class="text-navy font-bold text-lg mb-1">DMB-007 or DMB-007S — which fits your application?</p>
        <p class="text-gray-700 text-sm">Our team can confirm material compatibility, throughput sizing, and quote lead time for both the carbon steel and stainless variants.</p>
      </div>
      <a href="/contact-for-alfa-laval-centrifuges/" class="shrink-0 inline-block bg-gold text-white font-bold px-6 py-3 rounded-lg hover:bg-gold/90 transition-colors text-center">
        Request a Quote &rarr;
      </a>
    </div>

    <h2 id="key-applications">Key Applications</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-10 not-prose">
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Turbine Lube Oil Purification</h3>
        <p class="text-sm text-gray-600">Steam and gas turbines in the 1,000–3,000 HP range with lube oil reservoirs of 500–2,000 gallons. The DMB-007 handles bypass purification at 4–6 GPM on turbine oil, removing water ingress and particulates to protect bearings and extend oil life between changes.</p>
        <a href="/lube-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Lube Oil Centrifuge Details &rarr;</a>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Diesel &amp; Gas Oil Polishing</h3>
        <p class="text-sm text-gray-600">Generator sets and standby power systems requiring continuous fuel polishing at 7–9 GPM. The DMB-007 removes free water and particulates from diesel and gas oil in a compact, economical package suited for space-constrained installations.</p>
        <a href="/diesel-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Diesel Centrifuge Details &rarr;</a>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Food-Grade Oil (DMB-007S)</h3>
        <p class="text-sm text-gray-600">Edible oil clarification, food-grade lubricant purification, and pharmaceutical oil processing. The DMB-007S stainless construction meets food-grade contact material requirements and is compatible with CIP (clean-in-place) procedures using caustic and acidic cleaning agents.</p>
        <a href="/food-grade-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Food Grade Centrifuge Details &rarr;</a>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Quench &amp; Process Oil</h3>
        <p class="text-sm text-gray-600">Heat treatment quench oil, metalworking oil, and similar industrial fluids requiring periodic clarification to remove soot, scale, and water accumulation. The DMB-007 handles these polishing applications cost-effectively at 5–7 GPM.</p>
        <a href="/quench-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Quench Oil Centrifuge Details &rarr;</a>
      </div>
    </div>

    <!-- FAQ -->
    <h2 id="faq">Frequently Asked Questions</h2>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What is the throughput of the DMB-007?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMB-007 processes ~7 GPM of diesel, ~9 GPM of gas oil at 40&deg;C, ~4 GPM of lube oil (R&amp;O), and ~6 GPM of steam turbine oil. Rated at 10 GPM on water-viscosity fluid.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What is the DMB-007S stainless steel variant?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMB-007S features 316L stainless steel bowl construction for <a href="/food-grade-centrifuge/">food-grade oil</a>, pharmaceutical, or corrosive fluid applications. Same throughput and speed as the DMB-007. Used when carbon steel is not suitable for the application.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What applications is the DMB-007 best suited for?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        Turbine <a href="/lube-oil-centrifuge/">lube oil</a> (1,000–3,000 HP systems), <a href="/diesel-centrifuge/">diesel polishing</a> on mid-size generators, hydraulic oil purification, and quench oil clarification. Ideal when solids content is low and periodic manual cleaning is acceptable.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">When should I choose the DMB-007 over the DMB-004 or DMB-013?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        Choose the DMB-007 when your throughput requirement is 5–9 GPM diesel — above the <a href="/centrifuges/dmb-004/">DMB-004</a> (4 GPM) but below the <a href="/centrifuges/dmb-013/">DMB-013</a> (13 GPM). For turbine lube oil, the DMB-007 suits 1,000–3,000 HP systems at 4 GPM R&amp;O throughput.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">Can the DMB-007 handle food-grade oil applications?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        Yes, with the DMB-007S stainless variant. The DMB-007S features 316L stainless steel bowl construction suitable for edible oil clarification, food-grade lubricant purification, and pharmaceutical oil processing. The carbon steel DMB-007 is for industrial petroleum applications. <a href="/contact-for-alfa-laval-centrifuges/">Contact us</a> to specify the right variant.
      </p>
    </details>

    <h2>Related Resources</h2>
    <ul>
      <li><a href="/centrifuges/dmb-004/">DMB-004 Manual-Clean Centrifuge (~4 GPM)</a></li>
      <li><a href="/centrifuges/dmb-013/">DMB-013 Manual-Clean Centrifuge (~13 GPM)</a></li>
      <li><a href="/centrifuges/dmpx-010/">DMPX-010 Self-Cleaning Centrifuge (~7 GPM)</a></li>
      <li><a href="/disc-stack-centrifuge/">Disc Stack Centrifuge Overview</a></li>
      <li><a href="/contact-for-alfa-laval-centrifuges/">Contact Us for DMB-007 Pricing</a></li>
    </ul>

  </article>

  <!-- Bottom CTA Bar -->
  <div class="not-prose mt-12 rounded-xl bg-navy px-8 py-8 flex flex-col md:flex-row md:items-center gap-6">
    <div class="flex-1">
      <p class="text-white font-bold text-xl mb-1">Ready to order the DMB-007?</p>
      <p class="text-white/80 text-sm">Call <a href="tel:2485222573" class="text-gold font-semibold">(248) 522-2573</a> or email <a href="mailto:sales@dolphincentrifuge.com" class="text-gold font-semibold">sales@dolphincentrifuge.com</a> — 40+ years in centrifugal separation, Warren MI.</p>
    </div>
    <div class="flex flex-col sm:flex-row gap-3 shrink-0">
      <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold text-white font-bold px-6 py-3 rounded-lg hover:bg-gold/90 transition-colors text-center">Get a Free Quote</a>
      <a href="/industrial-centrifuge-sample-testing/" class="inline-block border border-white text-white font-bold px-6 py-3 rounded-lg hover:bg-white/10 transition-colors text-center">Free Sample Testing</a>
    </div>
  </div>

</ApplicationLayout>
