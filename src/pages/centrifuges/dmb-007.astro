---
import BaseLayout from '../../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "DMB-007 Manual-Clean Disc Stack Centrifuge",
  "description": "Dolphin DMB-007 manual-clean disc stack centrifuge clarifier. 7 GPM diesel, 1–2 HP, 8,600 RPM. Cost-effective clarifier for turbine lube oil, diesel polishing, and low-volume industrial applications.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  "category": "Disc Stack Centrifuges",
  "model": "DMB-007",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the throughput of the DMB-007 centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Dolphin DMB-007 processes approximately 7 GPM of diesel fuel (13 cSt), 9 GPM of gas oil at 40°C, 4 GPM of lube oil (R&O), and 6 GPM of steam turbine oil. It is rated at 10 GPM on water-viscosity fluid. Actual throughput varies with fluid viscosity, temperature, and solids loading."
      }
    },
    {
      "@type": "Question",
      "name": "What is the DMB-007S stainless steel variant?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The DMB-007S is the stainless steel variant of the DMB-007, built around the Alfa Laval WSB 104 centrifuge bowl with 316L stainless steel wetted-parts construction. The DMB-007S is used for food-grade oil clarification, edible oil processing, pharmaceutical applications, or any application requiring stainless steel material compatibility. Throughput and operating speed are the same as the DMB-007."
      }
    },
    {
      "@type": "Question",
      "name": "What applications is the DMB-007 best suited for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The DMB-007 is best suited for medium-small turbine lube oil systems (1,000–3,000 HP), diesel fuel polishing on small to mid-size generators, hydraulic oil purification, quench oil clarification, and low-volume industrial oil polishing where solids content is low and periodic cleaning is acceptable."
      }
    }
  ]
};
---

<BaseLayout
  title="DMB-007 Manual-Clean Disc Stack Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMB-007 manual-clean disc stack centrifuge. 7 GPM diesel, 1–2 HP, 8,600 RPM. Cost-effective for turbine lube oil, diesel polishing, and low-volume industrial separation."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmb-007/"
  breadcrumbs={[{label: 'Products', href: '/disc-stack-centrifuge/'}, {label: 'DMB-007 Centrifuge'}]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">DMB Series &mdash; Dolphin Centrifuge</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">DMB-007 Manual-Clean Disc Stack Centrifuge</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">The Dolphin DMB-007 processes approximately 7 GPM of diesel-viscosity fluid at 8,600 RPM with 1&ndash;2 HP drive power. A cost-effective manual-clean clarifier for turbine lube oil purification, diesel fuel polishing, and low-to-medium volume industrial oil applications where feed solids are low and periodic cleaning is acceptable. Also available as the DMB-007S in stainless steel construction for food-grade applications.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Request a Quote</a>
        <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-5xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies the DMB-007 — a manual-clean disc stack centrifuge clarifier for low-to-medium volume oil purification. Operating at 8,600 RPM with 1–2 HP drive power, the DMB-007 processes approximately 7 GPM of diesel-viscosity fluid. The DMB-007S stainless steel variant is available for food-grade and corrosive fluid applications. Applications include turbine lube oil purification, diesel polishing, hydraulic oil maintenance, and quench oil clarification. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in disc stack centrifuge systems.</p>
      </div>

      <!-- Specs Table -->
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">DMB-007 Specifications</h2>
      <div class="overflow-x-auto mb-4">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Parameter</th>
              <th class="text-left px-4 py-3 font-semibold">DMB-007</th>
              <th class="text-left px-4 py-3 font-semibold">DMB-007S (Stainless)</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Separation type</td>
              <td class="px-4 py-3 text-text-light" colspan="2">Two-phase clarifier (liquid-liquid or liquid-solid)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Diesel throughput</td>
              <td class="px-4 py-3 text-text-light" colspan="2">~7 GPM (13 cSt at operating temperature)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Rated throughput (water)</td>
              <td class="px-4 py-3 text-text-light" colspan="2">~10 GPM</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Bowl speed</td>
              <td class="px-4 py-3 text-text-light" colspan="2">~8,600 RPM</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Drive motor</td>
              <td class="px-4 py-3 text-text-light" colspan="2">1–2 HP</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Bowl construction</td>
              <td class="px-4 py-3 text-text-light">Carbon steel</td>
              <td class="px-4 py-3 text-text-light">316L stainless steel</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Cleaning method</td>
              <td class="px-4 py-3 text-text-light" colspan="2">Manual (bowl disassembly required for solids removal)</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-sm text-text-muted mb-8 italic">Throughput figures are for typical fluids at listed conditions. Actual capacity varies with feed viscosity, temperature, density difference, and solids loading.</p>

      <!-- Capacity by Application -->
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">DMB-007 Capacity by Application (GPM)</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Application / Fluid</th>
              <th class="text-left px-4 py-3 font-semibold">Throughput (GPM)</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Gas oil at 40&deg;C</td><td class="px-4 py-3 text-text-light">~9 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Diesel fuel (13 cSt)</td><td class="px-4 py-3 text-text-light">~7 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Lube oil (R&amp;O)</td><td class="px-4 py-3 text-text-light">~4 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Lube oil (detergent)</td><td class="px-4 py-3 text-text-light">~3 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Steam turbine oil</td><td class="px-4 py-3 text-text-light">~6 GPM</td></tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">DMB-007S — Stainless Steel Variant</h2>
      <p class="text-text-light mb-4">
        The DMB-007S is the stainless steel construction variant of the DMB-007, featuring 316L stainless steel wetted-part construction throughout the bowl assembly. It delivers the same throughput and operating speed as the DMB-007 in a food-grade compatible configuration. The DMB-007S is used for:
      </p>
      <ul class="text-text-light space-y-2 mb-8">
        <li>&#8226; Edible oil clarification (vegetable oil, olive oil, sunflower oil)</li>
        <li>&#8226; Food-grade lubricant purification</li>
        <li>&#8226; Pharmaceutical oil clarification</li>
        <li>&#8226; Applications requiring stainless steel for chemical compatibility</li>
        <li>&#8226; Wash water clarification in food processing environments</li>
      </ul>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Key Applications</h2>
      <div class="grid md:grid-cols-2 gap-6 mb-10">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Turbine Lube Oil Purification</h3>
          <p class="text-sm text-text-light">Steam and gas turbines in the 1,000–3,000 HP range with lube oil reservoirs of 500–2,000 gallons. The DMB-007 handles bypass purification at 4–6 GPM on turbine oil, removing water ingress and particulates to protect bearings and extend oil life between changes.</p>
          <a href="/lube-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Lube Oil Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Diesel &amp; Gas Oil Polishing</h3>
          <p class="text-sm text-text-light">Generator sets and standby power systems requiring continuous fuel polishing at 7–9 GPM. The DMB-007 removes free water and particulates from diesel and gas oil in a compact, economical package suited for space-constrained installations.</p>
          <a href="/diesel-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Diesel Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Food-Grade Oil (DMB-007S)</h3>
          <p class="text-sm text-text-light">Edible oil clarification, food-grade lubricant purification, and pharmaceutical oil processing. The DMB-007S stainless construction meets food-grade contact material requirements and is compatible with CIP (clean-in-place) procedures using caustic and acidic cleaning agents.</p>
          <a href="/food-grade-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Food Grade Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Quench &amp; Process Oil</h3>
          <p class="text-sm text-text-light">Heat treatment quench oil, metalworking oil, and similar industrial fluids requiring periodic clarification to remove soot, scale, and water accumulation. The DMB-007 handles these polishing applications cost-effectively at 5–7 GPM.</p>
          <a href="/quench-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Quench Oil Centrifuge Details &rarr;</a>
        </div>
      </div>

      <!-- FAQ -->
      <div id="faq" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What is the throughput of the DMB-007?</h3>
            <p class="text-text-light text-sm">The DMB-007 processes ~7 GPM of diesel, ~9 GPM of gas oil at 40&deg;C, ~4 GPM of lube oil (R&amp;O), and ~6 GPM of steam turbine oil. Rated at 10 GPM on water-viscosity fluid.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What is the DMB-007S stainless steel variant?</h3>
            <p class="text-text-light text-sm">The DMB-007S features 316L stainless steel bowl construction for food-grade oil, pharmaceutical, or corrosive fluid applications. Same throughput and speed as the DMB-007. Used when carbon steel is not suitable for the application.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What applications is the DMB-007 best suited for?</h3>
            <p class="text-text-light text-sm">Turbine lube oil (1,000–3,000 HP systems), diesel polishing on mid-size generators, hydraulic oil purification, and quench oil clarification. Ideal when solids content is low and periodic manual cleaning is acceptable.</p>
          </div>
        </div>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Related Resources</h2>
      <ul class="text-text-light space-y-2 mb-8">
        <li>&#8226; <a href="/centrifuges/dmb-004/" class="text-navy font-semibold hover:text-gold transition-colors">DMB-004 Manual-Clean Centrifuge (~4 GPM)</a></li>
        <li>&#8226; <a href="/centrifuges/dmb-013/" class="text-navy font-semibold hover:text-gold transition-colors">DMB-013 Manual-Clean Centrifuge (~13 GPM)</a></li>
        <li>&#8226; <a href="/centrifuges/dmpx-010/" class="text-navy font-semibold hover:text-gold transition-colors">DMPX-010 Self-Cleaning Centrifuge (~7 GPM)</a></li>
        <li>&#8226; <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Disc Stack Centrifuge Overview</a></li>
        <li>&#8226; <a href="/contact-for-alfa-laval-centrifuges/" class="text-navy font-semibold hover:text-gold transition-colors">Contact Us for DMB-007 Pricing</a></li>
      </ul>

    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Bottom CTA -->
  <section class="bg-navy">
    <div class="container-dolphin py-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Get Pricing on the DMB-007</h2>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">Tell us your fluid type, volume, and site conditions. We will provide a quote for the DMB-007 (carbon steel) or DMB-007S (stainless steel) based on your application.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3.5 rounded-lg transition-colors">Contact Us</a>
        <a href="/industrial-centrifuge-sample-testing/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3.5 rounded-lg transition-colors">Sample Testing</a>
      </div>
    </div>
  </section>
</BaseLayout>
