---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "DMB-062 Manual-Clean Disc Stack Centrifuge",
    "description": "Dolphin DMB-062 manual-clean disc stack centrifuge clarifier. 62 GPM diesel, 92 GPM rated. Dolphin's largest manual-clean clarifier for major turbine lube oil systems and high-volume industrial purification.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "category": "Disc Stack Centrifuges",
    "model": "DMB-062",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
      "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the throughput of the DMB-062 centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Dolphin DMB-062 processes approximately 62 GPM of diesel fuel (13 cSt), 81 GPM of gas oil at 40°C, 33 GPM of lube oil (R&O), and 60 GPM of steam turbine oil. It is rated at 92 GPM on water-viscosity fluid. The DMB-062 is Dolphin's highest-capacity manual-clean disc stack centrifuge."
        }
      },
      {
        "@type": "Question",
        "name": "What turbine or system size is the DMB-062 suited for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "At 33 GPM on lube oil (R&O) throughput, the DMB-062 is suited for major power generation turbines above 30,000 HP, large marine turbine installations, multiple large turbines served by a centralized lube oil purification system, and large petrochemical compressor trains. It can handle oil reservoirs of 15,000–50,000+ gallons in continuous bypass operation."
        }
      },
      {
        "@type": "Question",
        "name": "What applications is the DMB-062 best suited for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMB-062 is Dolphin's largest manual-clean clarifier, suited for major turbine lube oil systems (30,000+ HP), bulk diesel and gas oil polishing at 62–81 GPM, large marine engine lube systems, centralized lube oil purification for large industrial complexes, and any high-volume application requiring maximum throughput without self-cleaning complexity."
        }
      }
    ]
  }
];
---

<ApplicationLayout
  title="DMB-062 Manual-Clean Disc Stack Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMB-062 manual-clean disc stack centrifuge: 62 GPM diesel, 92 GPM rated. Largest DMB for high-volume turbine lube oil and industrial clarification."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmb-062/"
  category="products"
  categoryLabel="Dolphin Basket Centrifuges"
  toc={[{id: "specs", label: "Specifications"}, {id: "capacity", label: "Capacity by Application"}, {id: "applications", label: "Key Applications"}, {id: "faq", label: "FAQ"}, {id: "resources", label: "Related Resources"}]}
  relatedApplications={[{label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/"}, {label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/"}, {label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/"}]}
  relatedProducts={[{label: "DMB-037 Manual-Clean Centrifuge", href: "/centrifuges/dmb-037/"}, {label: "DMB-019 Manual-Clean Centrifuge", href: "/centrifuges/dmb-019/"}, {label: "DMPX-070 Self-Cleaning Centrifuge", href: "/centrifuges/dmpx-070/"}]}
  jsonLd={jsonLd}
  heroImage="/images/lube-oil-centrifuge/DMPX-014-Lube-Oil-Centrifuge-1000-822x1024.webp"
  heroImageAlt="Industrial lube oil centrifuge system — Dolphin DMB-062 largest manual-clean clarifier at 62 GPM diesel"
>
  <article class="prose-dolphin max-w-none">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies the DMB-062 — Dolphin&rsquo;s highest-capacity manual-clean disc stack centrifuge clarifier. The DMB-062 processes approximately 62 GPM of diesel-viscosity fluid (92 GPM rated on water). Applications include major turbine lube oil purification (30,000+ HP systems), bulk diesel and gas oil polishing at 62–81 GPM, large marine engine lube systems, centralized lube oil purification for large industrial complexes, and offshore and power generation facilities requiring maximum throughput in a proven manual-clean design. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in disc stack centrifuge systems.</p>
      </div>

      <!-- Specs Table -->
      <h2 id="specs" class="text-2xl md:text-3xl font-bold text-navy mb-4">DMB-062 Specifications</h2>
      <div class="overflow-x-auto mb-4">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Parameter</th>
              <th class="text-left px-4 py-3 font-semibold">Value</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Separation type</td>
              <td class="px-4 py-3 text-text-light">Two-phase clarifier (liquid-liquid or liquid-solid)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Diesel throughput</td>
              <td class="px-4 py-3 text-text-light">~62 GPM (13 cSt at operating temperature)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Rated throughput (water)</td>
              <td class="px-4 py-3 text-text-light">~92 GPM</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Cleaning method</td>
              <td class="px-4 py-3 text-text-light">Manual (bowl disassembly required for solids removal)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Bowl construction</td>
              <td class="px-4 py-3 text-text-light">Carbon steel standard</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Power supply</td>
              <td class="px-4 py-3 text-text-light">460V / 3-phase / 60 Hz standard (other voltages available)</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-sm text-text-muted mb-8 italic">Throughput figures are for typical fluids at listed conditions. Actual capacity varies with feed viscosity, temperature, density difference, and solids loading. Contact Dolphin Centrifuge for application-specific confirmation.</p>

      <!-- Capacity by Application -->
      <h2 id="capacity" class="text-2xl md:text-3xl font-bold text-navy mb-4">DMB-062 Capacity by Application (GPM)</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Application / Fluid</th>
              <th class="text-left px-4 py-3 font-semibold">Throughput (GPM)</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Gas oil at 40&deg;C</td><td class="px-4 py-3 text-text-light">~81 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Diesel fuel (13 cSt)</td><td class="px-4 py-3 text-text-light">~62 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Lube oil (R&amp;O)</td><td class="px-4 py-3 text-text-light">~33 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Lube oil (detergent)</td><td class="px-4 py-3 text-text-light">~28 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Steam turbine oil</td><td class="px-4 py-3 text-text-light">~60 GPM</td></tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">The Case for High-Capacity Manual-Clean</h2>
      <p class="text-text-light mb-4">
        For applications with clean, low-solids fluid — such as turbine lube oil purification or clean diesel polishing — a manual-clean centrifuge at high throughput often provides better economics than a self-cleaning unit. The DMB-062 delivers 62 GPM diesel throughput without the complexity, control system cost, and maintenance overhead of hydraulic self-cleaning mechanisms.
      </p>
      <p class="text-text-light mb-8">
        In large turbine lube oil applications, fluid cleanliness is usually high (low particulate loading), and cleaning intervals are long — measured in weeks or months rather than days. A single DMB-062 on a planned cleaning schedule outperforms multiple smaller self-cleaning units from both cost and simplicity perspectives. Dolphin Centrifuge can help you calculate the optimal cleaning interval based on your fluid analysis.
      </p>

      <h2 id="applications" class="text-2xl md:text-3xl font-bold text-navy mb-4">Key Applications</h2>
      <div class="grid md:grid-cols-2 gap-6 mb-10">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Major Power Generation Turbines</h3>
          <p class="text-sm text-text-light">Power station steam turbines and gas turbines above 30,000 HP with large lube oil reservoirs. The DMB-062 provides continuous bypass purification at 33–60 GPM on turbine oil, maintaining ISO cleanliness targets across very large oil reservoirs that smaller units cannot service efficiently.</p>
          <a href="/lube-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Lube Oil Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Bulk Diesel &amp; Gas Oil Polishing</h3>
          <p class="text-sm text-text-light">Large fuel depots, tank farms, and bulk storage terminals requiring high-throughput diesel and gas oil polishing. The DMB-062 processes 62–81 GPM continuously, maintaining fuel quality across large storage volumes and keeping water and particulates at acceptable levels for downstream equipment.</p>
          <a href="/diesel-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Diesel Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Large Marine Lube Oil Systems</h3>
          <p class="text-sm text-text-light">Large marine vessels with multiple propulsion turbines, main engine lube systems, and auxiliary machinery lube oil requiring centralized purification. The DMB-062 handles marine application conditions including variable pitch, shock loading, and the need for robust, reliable design.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Centralized Industrial Lube Systems</h3>
          <p class="text-sm text-text-light">Large industrial complexes, refineries, and chemical plants with centralized lubrication systems serving multiple large machines from a common reservoir. The DMB-062 handles the high throughput required for centralized purification of very large shared lube oil inventories.</p>
        </div>
      </div>

      <!-- FAQ -->
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 id="faq" class="text-xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What is the throughput of the DMB-062?</h3>
            <p class="text-text-light text-sm">The DMB-062 processes ~62 GPM of diesel, ~81 GPM of gas oil at 40&deg;C, ~33 GPM of lube oil (R&amp;O), and ~60 GPM of steam turbine oil. Rated at 92 GPM on water-viscosity fluid — Dolphin&rsquo;s highest-capacity manual-clean model.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What turbine or system size is the DMB-062 suited for?</h3>
            <p class="text-text-light text-sm">At 33 GPM on lube oil (R&amp;O), the DMB-062 suits major turbines above 30,000 HP, large marine turbine installations, centralized lube oil systems for multiple large turbines, and large petrochemical compressor trains with reservoirs of 15,000–50,000+ gallons.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What applications is the DMB-062 best suited for?</h3>
            <p class="text-text-light text-sm">Major turbine lube oil (30,000+ HP), bulk diesel and gas oil polishing at 62–81 GPM, large marine lube systems, centralized lube oil purification for large industrial complexes, and offshore facilities requiring maximum throughput in a manual-clean design.</p>
          </div>
        </div>
      </div>

      <h2 id="resources" class="text-2xl md:text-3xl font-bold text-navy mb-4">Related Resources</h2>
      <ul class="text-text-light space-y-2 mb-8">
        <li>&#8226; <a href="/centrifuges/dmb-037/" class="text-navy font-semibold hover:text-gold transition-colors">DMB-037 Manual-Clean Centrifuge (~37 GPM)</a></li>
        <li>&#8226; <a href="/centrifuges/dmpx-070/" class="text-navy font-semibold hover:text-gold transition-colors">DMPX-070 Self-Cleaning Centrifuge (59–72 GPM)</a></li>
        <li>&#8226; <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Disc Stack Centrifuge Overview</a></li>
        <li>&#8226; <a href="/lube-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Lube Oil Centrifuge Applications</a></li>
        <li>&#8226; <a href="/contact-for-alfa-laval-centrifuges/" class="text-navy font-semibold hover:text-gold transition-colors">Contact Us for DMB-062 Pricing</a></li>
      </ul>

  </article>
</ApplicationLayout>
