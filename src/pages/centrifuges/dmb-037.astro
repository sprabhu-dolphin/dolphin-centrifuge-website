---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "DMB-037 Manual-Clean Disc Stack Centrifuge",
    "description": "Dolphin DMB-037 manual-clean disc stack centrifuge clarifier. 37 GPM diesel, 55 GPM rated. Extra-high-capacity manual clarifier for very large turbine lube oil systems and industrial fluid purification.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "category": "Disc Stack Centrifuges",
    "model": "DMB-037",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
      "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the throughput of the DMB-037 centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Dolphin DMB-037 processes approximately 37 GPM of diesel fuel (13 cSt), 50 GPM of gas oil at 40°C, 19 GPM of lube oil (R&O), and 36 GPM of steam turbine oil. It is rated at 55 GPM on water-viscosity fluid. Contact Dolphin Centrifuge for application-specific capacity confirmation."
        }
      },
      {
        "@type": "Question",
        "name": "What applications is the DMB-037 best suited for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMB-037 is suited for very large turbine lube oil systems above 20,000 HP, large diesel and gas oil polishing at 37–50 GPM, large industrial compressor lube oil purification, and centralized lube oil purification systems serving multiple large machines. It is the second-largest model in the DMB manual-clean series, just below the DMB-062."
        }
      },
      {
        "@type": "Question",
        "name": "When should I choose the DMB-037 versus the DMB-062?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMB-037 (37 GPM diesel, 55 GPM rated) is the right choice when your throughput requirement is 30–40 GPM diesel or 15–20 GPM on lube oil. The DMB-062 (62 GPM diesel, 92 GPM rated) handles the largest volumes. For applications between these two, the DMB-037 often provides the better fit without oversizing the equipment."
        }
      }
    ]
  }
];
---

<ApplicationLayout
  title="DMB-037 Manual-Clean Disc Stack Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMB-037 manual-clean disc stack centrifuge: 37 GPM diesel, 55 GPM rated. High-capacity clarifier for turbine lube oil and large industrial applications."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmb-037/"
  category="products"
  categoryLabel="Dolphin Basket Centrifuges"
  toc={[{id: "specs", label: "Specifications"}, {id: "capacity", label: "Capacity by Application"}, {id: "applications", label: "Key Applications"}, {id: "faq", label: "FAQ"}, {id: "resources", label: "Related Resources"}]}
  relatedApplications={[{label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/"}, {label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/"}, {label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/"}]}
  relatedProducts={[{label: "DMB-028 Manual-Clean Centrifuge", href: "/centrifuges/dmb-028/"}, {label: "DMB-062 Manual-Clean Centrifuge", href: "/centrifuges/dmb-062/"}, {label: "DMPX-042 Self-Cleaning Centrifuge", href: "/centrifuges/dmpx-042/"}]}
  jsonLd={jsonLd}
>
  <article class="prose-dolphin max-w-none">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies the DMB-037 — an extra-high-capacity manual-clean disc stack centrifuge clarifier for large-volume oil purification. The DMB-037 processes approximately 37 GPM of diesel-viscosity fluid (55 GPM rated on water). Applications include very large turbine lube oil purification (20,000+ HP systems), high-volume diesel and gas oil polishing, large industrial compressor lube oil maintenance, and centralized purification systems for multiple large machines. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in disc stack centrifuge systems.</p>
      </div>

      <!-- Specs Table -->
      <h2 id="specs" class="text-2xl md:text-3xl font-bold text-navy mb-4">DMB-037 Specifications</h2>
      <div class="overflow-x-auto mb-4">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Parameter</th>
              <th class="text-left px-4 py-3 font-semibold">Value</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Separation type</td>
              <td class="px-4 py-3 text-text-light">Two-phase clarifier (liquid-liquid or liquid-solid)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Diesel throughput</td>
              <td class="px-4 py-3 text-text-light">~37 GPM (13 cSt at operating temperature)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Rated throughput (water)</td>
              <td class="px-4 py-3 text-text-light">~55 GPM</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Cleaning method</td>
              <td class="px-4 py-3 text-text-light">Manual (bowl disassembly required for solids removal)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Bowl construction</td>
              <td class="px-4 py-3 text-text-light">Carbon steel standard</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Power supply</td>
              <td class="px-4 py-3 text-text-light">460V / 3-phase / 60 Hz standard (other voltages available)</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-sm text-text-muted mb-8 italic">Throughput figures are for typical fluids at listed conditions. Actual capacity varies with feed viscosity, temperature, density difference, and solids loading. Contact Dolphin Centrifuge for application-specific confirmation.</p>

      <!-- Capacity by Application -->
      <h2 id="capacity" class="text-2xl md:text-3xl font-bold text-navy mb-4">DMB-037 Capacity by Application (GPM)</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Application / Fluid</th>
              <th class="text-left px-4 py-3 font-semibold">Throughput (GPM)</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Gas oil at 40&deg;C</td><td class="px-4 py-3 text-text-light">~50 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Diesel fuel (13 cSt)</td><td class="px-4 py-3 text-text-light">~37 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Lube oil (R&amp;O)</td><td class="px-4 py-3 text-text-light">~19 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Lube oil (detergent)</td><td class="px-4 py-3 text-text-light">~17 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Steam turbine oil</td><td class="px-4 py-3 text-text-light">~36 GPM</td></tr>
          </tbody>
        </table>
      </div>

      <h2 id="applications" class="text-2xl md:text-3xl font-bold text-navy mb-4">Key Applications</h2>
      <div class="grid md:grid-cols-2 gap-6 mb-10">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Very Large Turbine Lube Oil</h3>
          <p class="text-sm text-text-light">Large steam turbine generators above 20,000 HP, gas turbine generators, and large turbine-driven compressor trains in petrochemical, power generation, and marine applications. At 19 GPM on R&amp;O lube oil, the DMB-037 provides effective bypass purification for the largest turbine lube oil systems.</p>
          <a href="/lube-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Lube Oil Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">High-Volume Gas Oil Polishing</h3>
          <p class="text-sm text-text-light">Large fuel depots, refineries, and bulk storage facilities requiring gas oil and diesel polishing at 37–50 GPM. The DMB-037&rsquo;s high rated throughput makes it effective for large-scale fuel quality maintenance applications where smaller clarifiers would require multiple units.</p>
          <a href="/diesel-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Diesel Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Large Compressor Lube Oil</h3>
          <p class="text-sm text-text-light">Gas compression stations, refinery compressor trains, and large industrial compressors with high lube oil volumes. The DMB-037 provides continuous bypass purification at 17–19 GPM on compressor lube oil, maintaining viscosity stability and cleanliness across large oil reservoirs.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Centralized Industrial Lube Systems</h3>
          <p class="text-sm text-text-light">Centralized lube oil systems serving multiple large industrial machines, rolling mills, or large gear trains from a common reservoir. The DMB-037&rsquo;s high throughput handles centralized purification efficiently without the complexity of self-cleaning controls.</p>
        </div>
      </div>

      <!-- FAQ -->
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 id="faq" class="text-xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What is the throughput of the DMB-037?</h3>
            <p class="text-text-light text-sm">The DMB-037 processes ~37 GPM of diesel, ~50 GPM of gas oil at 40&deg;C, ~19 GPM of lube oil (R&amp;O), and ~36 GPM of steam turbine oil. Rated at 55 GPM on water-viscosity fluid.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What applications is the DMB-037 best suited for?</h3>
            <p class="text-text-light text-sm">Very large turbine lube oil (20,000+ HP systems), high-volume diesel and gas oil polishing at 37–50 GPM, large compressor lube oil, and centralized purification systems for multiple large machines where self-cleaning is not required.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">When should I choose DMB-037 versus DMB-062?</h3>
            <p class="text-text-light text-sm">The DMB-037 (37 GPM diesel, 55 GPM rated) suits 30–40 GPM diesel or 15–20 GPM lube oil applications. The DMB-062 (62 GPM diesel, 92 GPM rated) handles the largest volumes. For between-size requirements, the DMB-037 avoids oversizing.</p>
          </div>
        </div>
      </div>

      <h2 id="resources" class="text-2xl md:text-3xl font-bold text-navy mb-4">Related Resources</h2>
      <ul class="text-text-light space-y-2 mb-8">
        <li>&#8226; <a href="/centrifuges/dmb-028/" class="text-navy font-semibold hover:text-gold transition-colors">DMB-028 Manual-Clean Centrifuge (~28 GPM)</a></li>
        <li>&#8226; <a href="/centrifuges/dmb-062/" class="text-navy font-semibold hover:text-gold transition-colors">DMB-062 Manual-Clean Centrifuge (~62 GPM)</a></li>
        <li>&#8226; <a href="/centrifuges/dmpx-042/" class="text-navy font-semibold hover:text-gold transition-colors">DMPX-042 Self-Cleaning Centrifuge (32–47 GPM)</a></li>
        <li>&#8226; <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Disc Stack Centrifuge Overview</a></li>
        <li>&#8226; <a href="/contact-for-alfa-laval-centrifuges/" class="text-navy font-semibold hover:text-gold transition-colors">Contact Us for DMB-037 Pricing</a></li>
      </ul>

  </article>
</ApplicationLayout>
