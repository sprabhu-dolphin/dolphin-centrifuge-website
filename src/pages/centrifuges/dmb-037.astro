---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "DMB-037 Manual-Clean Disc Stack Centrifuge",
    "description": "Dolphin DMB-037 manual-clean disc stack centrifuge clarifier. 37 GPM diesel, 55 GPM rated. Extra-high-capacity manual clarifier for very large turbine lube oil systems and industrial fluid purification.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "category": "Disc Stack Centrifuges",
    "model": "DMB-037",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
      "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "DMB-037 Manual-Clean Disc Stack Centrifuge — Specifications & Applications",
    "author": {
      "@type": "Person",
      "name": "Sanjay Prabhu MSME",
      "jobTitle": "Centrifuge Applications Engineer",
      "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    },
    "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "url": "https://dolphincentrifuge.com/centrifuges/dmb-037/"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the throughput of the DMB-037 centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Dolphin DMB-037 processes approximately 37 GPM of diesel fuel (13 cSt), 50 GPM of gas oil at 40°C, 19 GPM of lube oil (R&O), and 36 GPM of steam turbine oil. It is rated at 55 GPM on water-viscosity fluid. Contact Dolphin Centrifuge for application-specific capacity confirmation."
        }
      },
      {
        "@type": "Question",
        "name": "What applications is the DMB-037 best suited for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMB-037 is suited for very large turbine lube oil systems above 20,000 HP, large diesel and gas oil polishing at 37–50 GPM, large industrial compressor lube oil purification, and centralized lube oil purification systems serving multiple large machines. It is the second-largest model in the DMB manual-clean series, just below the DMB-062."
        }
      },
      {
        "@type": "Question",
        "name": "When should I choose the DMB-037 versus the DMB-062?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMB-037 (37 GPM diesel, 55 GPM rated) is the right choice when your throughput requirement is 30–40 GPM diesel or 15–20 GPM on lube oil. The DMB-062 (62 GPM diesel, 92 GPM rated) handles the largest volumes. For applications between these two, the DMB-037 often provides the better fit without oversizing the equipment."
        }
      },
      {
        "@type": "Question",
        "name": "How does the DMB-037 compare to the DMPX-042 self-cleaning model?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMB-037 (37 GPM diesel, manual-clean) and DMPX-042 (32–47 GPM diesel, self-cleaning) have similar diesel throughput. The DMB-037 is lower cost and better for clean turbine lube oil and diesel polishing with low solids content. The DMPX-042 is better when solids loading is significant or when continuous 24/7 unattended operation is required."
        }
      },
      {
        "@type": "Question",
        "name": "What turbine size is the DMB-037 suited for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "At 19 GPM on R&O lube oil throughput, the DMB-037 is suited for large turbines above 20,000 HP, gas turbine-driven compressor trains, and large centralized lube oil systems serving multiple machines. For the largest power generation turbines above 30,000 HP, the DMB-062 with 33 GPM on R&O is typically required."
        }
      }
    ]
  }
];
---

<ApplicationLayout
  title="DMB-037 Manual-Clean Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMB-037 manual-clean disc centrifuge: 37 GPM diesel, 55 GPM rated. High-capacity clarifier for large turbine lube oil (20,000+ HP) and industrial use."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmb-037/"
  heroImage="/images/lube-oil-centrifuge/explosion-proof-compressor-oil-centrifuge.webp"
  heroImageAlt="Explosion-proof compressor oil centrifuge — Dolphin DMB-037 high-capacity manual-clean clarifier"
  category="products"
  categoryLabel="Dolphin Basket Centrifuges"
  toc={[
    { id: "ai-summary", label: "AI Summary" },
    { id: "specs", label: "Specifications" },
    { id: "capacity", label: "Capacity by Application" },
    { id: "applications", label: "Key Applications" },
    { id: "faq", label: "FAQ" },
  ]}
  relatedApplications={[
    { label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/" },
    { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
  ]}
  relatedProducts={[
    { label: "DMB-028 Manual-Clean Centrifuge", href: "/centrifuges/dmb-028/" },
    { label: "DMB-062 Manual-Clean Centrifuge", href: "/centrifuges/dmb-062/" },
    { label: "DMPX-042 Self-Cleaning Centrifuge", href: "/centrifuges/dmpx-042/" },
  ]}
  jsonLd={jsonLd}
>
  <article class="prose-dolphin max-w-none">

    <div id="ai-summary" class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-6 not-prose mb-8">
      <p class="text-base italic text-gray-700 leading-relaxed">
        <strong>AI Summary:</strong> Dolphin Centrifuge supplies the DMB-037 — an extra-high-capacity manual-clean disc stack centrifuge clarifier processing approximately 37 GPM of diesel-viscosity fluid (55 GPM rated on water). Ideal for very large turbine lube oil purification (20,000+ HP systems), high-volume diesel and gas oil polishing, and large industrial compressor lube oil maintenance. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in centrifugal separation.
      </p>
    </div>

    <h2 id="specs">DMB-037 Specifications</h2>
    <div class="overflow-x-auto mb-4">
      <table>
        <thead>
          <tr>
            <th>Parameter</th>
            <th>Value</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Separation type</td><td>Two-phase clarifier (liquid-liquid or liquid-solid)</td></tr>
          <tr><td>Diesel throughput</td><td>~37 GPM (13 cSt at operating temperature)</td></tr>
          <tr><td>Rated throughput (water)</td><td>~55 GPM</td></tr>
          <tr><td>Cleaning method</td><td>Manual (bowl disassembly required for solids removal)</td></tr>
          <tr><td>Bowl construction</td><td>Carbon steel standard</td></tr>
          <tr><td>Power supply</td><td>460V / 3-phase / 60 Hz standard (other voltages available)</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-sm text-gray-500 italic">Throughput figures are for typical fluids at listed conditions. Actual capacity varies with feed viscosity, temperature, density difference, and solids loading. Contact Dolphin Centrifuge for application-specific confirmation.</p>

    <h2 id="capacity">DMB-037 Capacity by Application (GPM)</h2>
    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Application / Fluid</th>
            <th>Throughput (GPM)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Gas oil at 40&deg;C</td><td>~50 GPM</td></tr>
          <tr><td>Diesel fuel (13 cSt)</td><td>~37 GPM</td></tr>
          <tr><td>Lube oil (R&amp;O)</td><td>~19 GPM</td></tr>
          <tr><td>Lube oil (detergent)</td><td>~17 GPM</td></tr>
          <tr><td>Steam turbine oil</td><td>~36 GPM</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Mid-Page CTA -->
    <div class="not-prose my-10 rounded-xl border-l-4 border-gold bg-gold/10 p-6 flex flex-col md:flex-row md:items-center gap-4">
      <div class="flex-1">
        <p class="text-navy font-bold text-lg mb-1">DMB-037 or DMB-062 — which fits your application?</p>
        <p class="text-gray-700 text-sm">Our applications engineers will size the right DMB model from your turbine HP, reservoir volume, and throughput requirements — at no charge.</p>
      </div>
      <a href="/contact-for-alfa-laval-centrifuges/" class="shrink-0 inline-block bg-gold text-white font-bold px-6 py-3 rounded-lg hover:bg-gold/90 transition-colors text-center">
        Request a Quote &rarr;
      </a>
    </div>

    <h2 id="applications">Key Applications</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-10 not-prose">
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Very Large Turbine Lube Oil</h3>
        <p class="text-sm text-gray-600">Large steam turbine generators above 20,000 HP, gas turbine generators, and large turbine-driven compressor trains in petrochemical, power generation, and marine applications. At 19 GPM on R&amp;O lube oil, the DMB-037 provides effective bypass purification for the largest turbine lube oil systems.</p>
        <a href="/lube-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Lube Oil Centrifuge Details &rarr;</a>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">High-Volume Gas Oil Polishing</h3>
        <p class="text-sm text-gray-600">Large fuel depots, refineries, and bulk storage facilities requiring gas oil and diesel polishing at 37–50 GPM. The DMB-037&rsquo;s high rated throughput makes it effective for large-scale fuel quality maintenance where smaller clarifiers would require multiple units.</p>
        <a href="/diesel-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Diesel Centrifuge Details &rarr;</a>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Large Compressor Lube Oil</h3>
        <p class="text-sm text-gray-600">Gas compression stations, refinery compressor trains, and large industrial compressors with high lube oil volumes. The DMB-037 provides continuous bypass purification at 17–19 GPM on compressor lube oil, maintaining viscosity stability and cleanliness across large oil reservoirs.</p>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Centralized Industrial Lube Systems</h3>
        <p class="text-sm text-gray-600">Centralized lube oil systems serving multiple large industrial machines, rolling mills, or large gear trains from a common reservoir. The DMB-037&rsquo;s high throughput handles centralized purification efficiently without the complexity of self-cleaning controls.</p>
      </div>
    </div>

    <!-- FAQ -->
    <h2 id="faq">Frequently Asked Questions</h2>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What is the throughput of the DMB-037?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMB-037 processes ~37 GPM of diesel, ~50 GPM of gas oil at 40&deg;C, ~19 GPM of lube oil (R&amp;O), and ~36 GPM of steam turbine oil. Rated at 55 GPM on water-viscosity fluid.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What applications is the DMB-037 best suited for?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        Very large turbine lube oil (20,000+ HP systems), high-volume diesel and gas oil polishing at 37–50 GPM, large compressor <a href="/lube-oil-centrifuge/">lube oil</a>, and centralized purification systems for multiple large machines where self-cleaning is not required.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">When should I choose DMB-037 versus DMB-062?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMB-037 (37 GPM diesel, 55 GPM rated) suits 30–40 GPM diesel or 15–20 GPM lube oil applications. The <a href="/centrifuges/dmb-062/">DMB-062</a> (62 GPM diesel, 92 GPM rated) handles the largest volumes. For between-size requirements, the DMB-037 avoids oversizing.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">How does the DMB-037 compare to the DMPX-042 self-cleaning model?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        Both have similar diesel throughput (~37 GPM vs. 32–47 GPM). The DMB-037 (manual-clean) is lower cost and better for clean <a href="/lube-oil-centrifuge/">turbine lube oil</a> and diesel polishing with low solids. The <a href="/centrifuges/dmpx-042/">DMPX-042</a> (self-cleaning) is better when solids loading is significant or continuous unattended operation is required. <a href="/contact-for-alfa-laval-centrifuges/">Contact us</a> for application guidance.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What turbine size is the DMB-037 suited for?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        At 19 GPM on R&amp;O lube oil, the DMB-037 suits large turbines above 20,000 HP, gas turbine-driven compressor trains, and large centralized lube oil systems. For the largest power generation turbines above 30,000 HP, the <a href="/centrifuges/dmb-062/">DMB-062</a> with 33 GPM on R&amp;O is typically required.
      </p>
    </details>

    <h2>Related Resources</h2>
    <ul>
      <li><a href="/centrifuges/dmb-028/">DMB-028 Manual-Clean Centrifuge (~28 GPM)</a></li>
      <li><a href="/centrifuges/dmb-062/">DMB-062 Manual-Clean Centrifuge (~62 GPM)</a></li>
      <li><a href="/centrifuges/dmpx-042/">DMPX-042 Self-Cleaning Centrifuge (32–47 GPM)</a></li>
      <li><a href="/disc-stack-centrifuge/">Disc Stack Centrifuge Overview</a></li>
      <li><a href="/contact-for-alfa-laval-centrifuges/">Contact Us for DMB-037 Pricing</a></li>
    </ul>

  </article>

  <!-- Bottom CTA Bar -->
  <div class="not-prose mt-12 rounded-xl bg-navy px-8 py-8 flex flex-col md:flex-row md:items-center gap-6">
    <div class="flex-1">
      <p class="text-white font-bold text-xl mb-1">Ready to order the DMB-037?</p>
      <p class="text-white/80 text-sm">Call <a href="tel:+12485222573" class="text-gold font-semibold">(248) 522-2573</a> or email <a href="mailto:sales@dolphincentrifuge.com" class="text-gold font-semibold">sales@dolphincentrifuge.com</a> — 40+ years in centrifugal separation, Warren MI.</p>
    </div>
    <div class="flex flex-col sm:flex-row gap-3 shrink-0">
      <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold text-white font-bold px-6 py-3 rounded-lg hover:bg-gold/90 transition-colors text-center">Get a Free Quote</a>
      <a href="/industrial-centrifuge-sample-testing/" class="inline-block border border-white text-white font-bold px-6 py-3 rounded-lg hover:bg-white/10 transition-colors text-center">Free Sample Testing</a>
    </div>
  </div>

</ApplicationLayout>
