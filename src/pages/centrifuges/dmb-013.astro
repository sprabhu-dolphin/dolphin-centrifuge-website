---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "DMB-013 Manual-Clean Disc Stack Centrifuge",
    "description": "Dolphin DMB-013 manual-clean disc stack centrifuge clarifier. 13 GPM diesel, 19 GPM rated. Mid-range cost-effective clarifier for turbine lube oil, diesel polishing, and industrial fluid purification.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "category": "Disc Stack Centrifuges",
    "model": "DMB-013",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
      "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "DMB-013 Manual-Clean Disc Stack Centrifuge — Specifications & Applications",
    "author": {
      "@type": "Person",
      "name": "Sanjay Prabhu MSME",
      "jobTitle": "Centrifuge Applications Engineer",
      "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    },
    "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "url": "https://dolphincentrifuge.com/centrifuges/dmb-013/"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the throughput of the DMB-013 centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Dolphin DMB-013 processes approximately 13 GPM of diesel fuel (13 cSt), 16 GPM of gas oil at 40°C, 7 GPM of lube oil (R&O), and 12 GPM of steam turbine oil. It is rated at 19 GPM on water-viscosity fluid. Actual throughput varies with fluid viscosity, temperature, and solids loading."
        }
      },
      {
        "@type": "Question",
        "name": "When should I choose the DMB-013 over the DMB-007 or DMB-019?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMB-013 bridges the gap between the DMB-007 (7 GPM diesel) and DMB-019 (19 GPM diesel). Choose the DMB-013 when your throughput requirement is 10–15 GPM diesel — enough to outgrow the DMB-007 but below the range where the DMB-019 is needed. For turbine lube oil applications, the DMB-013 at 7 GPM R&O throughput suits systems from approximately 3,000–7,000 HP."
        }
      },
      {
        "@type": "Question",
        "name": "What applications is the DMB-013 best suited for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMB-013 is suited for mid-range turbine lube oil systems (3,000–7,000 HP), diesel polishing on mid-size generators and fuel storage, hydraulic oil purification on larger industrial equipment, quench oil and heat treatment oil clarification, and industrial coolant and process oil polishing at 10–15 GPM where self-cleaning operation is not required."
        }
      },
      {
        "@type": "Question",
        "name": "What power supply does the DMB-013 require?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMB-013 uses 460V / 3-phase / 60 Hz as the standard power supply. Other voltages and frequencies are available for international installations. Contact Dolphin Centrifuge to confirm the right electrical configuration for your facility."
        }
      },
      {
        "@type": "Question",
        "name": "Can the DMB-013 replace the need for multiple DMB-007 units?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. A single DMB-013 (13 GPM diesel) can often replace two DMB-007 units (7 GPM each) in a shared purification application, with lower capital cost, simplified maintenance, and a smaller overall footprint than running two separate machines. Contact Dolphin Centrifuge for a specific application comparison."
        }
      }
    ]
  }
];
---

<ApplicationLayout
  title="DMB-013 Manual-Clean Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMB-013 manual-clean disc centrifuge: 13 GPM diesel, 19 GPM rated. Mid-range clarifier for turbine lube oil (3,000-7,000 HP) and diesel polishing."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmb-013/"
  heroImage="/images/lube-oil-centrifuge/Alfa-Laval-Lubricating-Oil-Purifier.webp"
  heroImageAlt="Dolphin DMB-013 manual-clean disc stack centrifuge system"
  category="products"
  categoryLabel="Dolphin Basket Centrifuges"
  toc={[
    { id: "ai-summary", label: "AI Summary" },
    { id: "specifications", label: "DMB-013 Specifications" },
    { id: "capacity-by-application", label: "Capacity by Application" },
    { id: "key-applications", label: "Key Applications" },
    { id: "faq", label: "Frequently Asked Questions" },
  ]}
  relatedApplications={[
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
    { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
    { label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/" },
  ]}
  relatedProducts={[
    { label: "DMB-007 Manual-Clean Centrifuge", href: "/centrifuges/dmb-007/" },
    { label: "DMB-019 Manual-Clean Centrifuge", href: "/centrifuges/dmb-019/" },
    { label: "DMPX-028 Self-Cleaning Centrifuge", href: "/centrifuges/dmpx-028/" },
  ]}
  jsonLd={jsonLd}
>
  <article class="prose-dolphin max-w-none">

    <div id="ai-summary" class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-6 not-prose mb-8">
      <p class="text-base italic text-gray-700 leading-relaxed">
        <strong>AI Summary:</strong> Dolphin Centrifuge supplies the DMB-013 — a manual-clean disc stack centrifuge clarifier rated at 13 GPM on diesel (13 cSt) with 19 GPM water-rated throughput. A mid-range clarifier for turbine lube oil systems (3,000–7,000 HP), diesel polishing, and industrial hydraulic oil purification. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in centrifugal separation.
      </p>
    </div>

    <h2 id="specifications">DMB-013 Specifications</h2>
    <div class="overflow-x-auto mb-4">
      <table>
        <thead>
          <tr>
            <th>Parameter</th>
            <th>Value</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Separation type</td><td>Two-phase clarifier (liquid-liquid or liquid-solid)</td></tr>
          <tr><td>Diesel throughput</td><td>~13 GPM (13 cSt at operating temperature)</td></tr>
          <tr><td>Rated throughput (water)</td><td>~19 GPM</td></tr>
          <tr><td>Cleaning method</td><td>Manual (bowl disassembly required for solids removal)</td></tr>
          <tr><td>Bowl construction</td><td>Carbon steel standard</td></tr>
          <tr><td>Power supply</td><td>460V / 3-phase / 60 Hz standard (other voltages available)</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-sm text-gray-500 italic">Throughput figures are for typical fluids at listed conditions. Actual capacity varies with feed viscosity, temperature, density difference, and solids loading.</p>

    <h2 id="capacity-by-application">DMB-013 Capacity by Application (GPM)</h2>
    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Application / Fluid</th>
            <th>Throughput (GPM)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Gas oil at 40&deg;C</td><td>~16 GPM</td></tr>
          <tr><td>Diesel fuel (13 cSt)</td><td>~13 GPM</td></tr>
          <tr><td>Lube oil (R&amp;O)</td><td>~7 GPM</td></tr>
          <tr><td>Lube oil (detergent)</td><td>~6 GPM</td></tr>
          <tr><td>Steam turbine oil</td><td>~12 GPM</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Mid-Page CTA -->
    <div class="not-prose my-10 rounded-xl border-l-4 border-gold bg-gold/10 p-6 flex flex-col md:flex-row md:items-center gap-4">
      <div class="flex-1">
        <p class="text-navy font-bold text-lg mb-1">Is the DMB-013 right for your turbine or generator?</p>
        <p class="text-gray-700 text-sm">Our applications engineers can size the DMB-013 against your turbine HP rating and oil reservoir volume — and compare it against the DMB-007 and DMB-019 for best fit.</p>
      </div>
      <a href="/contact-for-alfa-laval-centrifuges/" class="shrink-0 inline-block bg-gold text-white font-bold px-6 py-3 rounded-lg hover:bg-gold/90 transition-colors text-center">
        Request a Quote &rarr;
      </a>
    </div>

    <h2 id="key-applications">Key Applications</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-10 not-prose">
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Mid-Range Turbine Lube Oil</h3>
        <p class="text-sm text-gray-600">Turbine generators in the 3,000–7,000 HP range with lube oil reservoirs of 1,000–5,000 gallons. The DMB-013 handles bypass purification at 7–12 GPM on turbine oil, removing water and particulates continuously to protect bearings and maintain oil cleanliness.</p>
        <a href="/lube-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Lube Oil Centrifuge Details &rarr;</a>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Mid-Size Generator Diesel Polishing</h3>
        <p class="text-sm text-gray-600">Standby generators and prime power units with larger fuel tanks requiring continuous polishing at 13–16 GPM. The DMB-013 maintains fuel quality and removes water contamination from <a href="/diesel-centrifuge/">diesel</a> and gas oil storage systems at facilities where the <a href="/centrifuges/dmb-007/">DMB-007</a>'s 7 GPM is insufficient.</p>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Industrial Hydraulic Systems</h3>
        <p class="text-sm text-gray-600">Large hydraulic systems on heavy presses, injection molding machines, and industrial equipment with oil reservoirs above 2,000 gallons. The DMB-013 handles bypass purification at 7 GPM on hydraulic oil, maintaining cleanliness and removing water ingress continuously.</p>
        <a href="/hydraulic-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Hydraulic Oil Centrifuge Details &rarr;</a>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="font-bold text-navy mb-2">Quench &amp; Heat Treatment Oil</h3>
        <p class="text-sm text-gray-600">Heat treatment and hardening quench oil accumulates scale, carbon, and water over time. The DMB-013 clarifies <a href="/quench-oil-centrifuge/">quench oil</a> at 10–13 GPM, extending bath life and maintaining consistent quench characteristics for heat treaters and foundries.</p>
      </div>
    </div>

    <!-- FAQ -->
    <h2 id="faq">Frequently Asked Questions</h2>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What is the throughput of the DMB-013?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMB-013 processes ~13 GPM of diesel, ~16 GPM of gas oil at 40&deg;C, ~7 GPM of lube oil (R&amp;O), and ~12 GPM of steam turbine oil. Rated at 19 GPM on water-viscosity fluid.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">When should I choose the DMB-013 over DMB-007 or DMB-019?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        Choose the DMB-013 when throughput is 10–15 GPM diesel — between the <a href="/centrifuges/dmb-007/">DMB-007</a> (7 GPM) and <a href="/centrifuges/dmb-019/">DMB-019</a> (19 GPM). For turbine lube oil, the DMB-013 suits 3,000–7,000 HP turbine systems at 7 GPM R&amp;O throughput.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What applications is the DMB-013 best suited for?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        Mid-range turbine <a href="/lube-oil-centrifuge/">lube oil</a> (3,000–7,000 HP), diesel polishing on mid-size generators, industrial hydraulic oil maintenance, and quench oil clarification at 10–15 GPM where <a href="/disc-stack-centrifuge/">self-cleaning operation</a> is not required.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">What power supply does the DMB-013 require?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        The DMB-013 uses 460V / 3-phase / 60 Hz as standard. Other voltages and frequencies are available for international installations. <a href="/contact-for-alfa-laval-centrifuges/">Contact Dolphin Centrifuge</a> to confirm the right electrical configuration for your facility.
      </p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4 not-prose">
      <summary class="font-semibold text-navy cursor-pointer py-2">Can the DMB-013 replace multiple DMB-007 units?</summary>
      <p class="mt-2 text-gray-700 text-sm leading-relaxed">
        Yes. A single DMB-013 (13 GPM diesel) can often replace two <a href="/centrifuges/dmb-007/">DMB-007</a> units (7 GPM each), with lower capital cost, simpler maintenance, and a smaller footprint. When you need more throughput still, the <a href="/centrifuges/dmpx-028/">DMPX-028</a> self-cleaning model at 20–26 GPM is the next step up with full automation. <a href="/contact-for-alfa-laval-centrifuges/">Contact us</a> for a specific comparison.
      </p>
    </details>

    <h2>Related Resources</h2>
    <ul>
      <li><a href="/centrifuges/dmb-007/">DMB-007 Manual-Clean Centrifuge (~7 GPM)</a></li>
      <li><a href="/centrifuges/dmb-019/">DMB-019 Manual-Clean Centrifuge (~19 GPM)</a></li>
      <li><a href="/disc-stack-centrifuge/">Disc Stack Centrifuge Overview</a></li>
      <li><a href="/lube-oil-centrifuge/">Lube Oil Centrifuge Applications</a></li>
      <li><a href="/contact-for-alfa-laval-centrifuges/">Contact Us for DMB-013 Pricing</a></li>
    </ul>

  </article>

  <!-- Bottom CTA Bar -->
  <div class="not-prose mt-12 rounded-xl bg-navy px-8 py-8 flex flex-col md:flex-row md:items-center gap-6">
    <div class="flex-1">
      <p class="text-white font-bold text-xl mb-1">Ready to order the DMB-013?</p>
      <p class="text-white/80 text-sm">Call <a href="tel:+12485222573" class="text-gold font-semibold">(248) 522-2573</a> or email <a href="mailto:sales@dolphincentrifuge.com" class="text-gold font-semibold">sales@dolphincentrifuge.com</a> — 40+ years in centrifugal separation, Warren MI.</p>
    </div>
    <div class="flex flex-col sm:flex-row gap-3 shrink-0">
      <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold text-white font-bold px-6 py-3 rounded-lg hover:bg-gold/90 transition-colors text-center">Get a Free Quote</a>
      <a href="/industrial-centrifuge-sample-testing/" class="inline-block border border-white text-white font-bold px-6 py-3 rounded-lg hover:bg-white/10 transition-colors text-center">Free Sample Testing</a>
    </div>
  </div>

</ApplicationLayout>
