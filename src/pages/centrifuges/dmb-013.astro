---
import BaseLayout from '../../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "DMB-013 Manual-Clean Disc Stack Centrifuge",
  "description": "Dolphin DMB-013 manual-clean disc stack centrifuge clarifier. 13 GPM diesel, 19 GPM rated. Mid-range cost-effective clarifier for turbine lube oil, diesel polishing, and industrial fluid purification.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  "category": "Disc Stack Centrifuges",
  "model": "DMB-013",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the throughput of the DMB-013 centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Dolphin DMB-013 processes approximately 13 GPM of diesel fuel (13 cSt), 16 GPM of gas oil at 40°C, 7 GPM of lube oil (R&O), and 12 GPM of steam turbine oil. It is rated at 19 GPM on water-viscosity fluid. Actual throughput varies with fluid viscosity, temperature, and solids loading."
      }
    },
    {
      "@type": "Question",
      "name": "When should I choose the DMB-013 over the DMB-007 or DMB-019?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The DMB-013 bridges the gap between the DMB-007 (7 GPM diesel) and DMB-019 (19 GPM diesel). Choose the DMB-013 when your throughput requirement is 10–15 GPM diesel — enough to outgrow the DMB-007 but below the range where the DMB-019 is needed. For turbine lube oil applications, the DMB-013 at 7 GPM R&O throughput suits systems from approximately 3,000–7,000 HP."
      }
    },
    {
      "@type": "Question",
      "name": "What applications is the DMB-013 best suited for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The DMB-013 is suited for mid-range turbine lube oil systems (3,000–7,000 HP), diesel polishing on mid-size generators and fuel storage, hydraulic oil purification on larger industrial equipment, quench oil and heat treatment oil clarification, and industrial coolant and process oil polishing at 10–15 GPM where self-cleaning operation is not required."
      }
    }
  ]
};
---

<BaseLayout
  title="DMB-013 Manual-Clean Disc Stack Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMB-013 manual-clean disc stack centrifuge: 13 GPM diesel, 19 GPM rated. Mid-range clarifier for turbine lube oil, diesel polishing, and fluid purification."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmb-013/"
  breadcrumbs={[{label: 'Products', href: '/disc-stack-centrifuge/'}, {label: 'DMB-013 Centrifuge'}]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">DMB Series &mdash; Dolphin Centrifuge</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">DMB-013 Manual-Clean Disc Stack Centrifuge</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">The Dolphin DMB-013 processes approximately 13 GPM of diesel-viscosity fluid — the mid-range entry in the DMB manual-clean series. An economical clarifier for turbine lube oil systems in the 3,000&ndash;7,000 HP range, mid-size diesel polishing, industrial hydraulic oil purification, and process oil clarification where self-cleaning operation is not required.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Request a Quote</a>
        <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-5xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies the DMB-013 — a manual-clean disc stack centrifuge clarifier for mid-range oil purification. The DMB-013 processes approximately 13 GPM of diesel-viscosity fluid (19 GPM rated on water). Applications include mid-range turbine lube oil purification (3,000–7,000 HP systems), diesel and gas oil polishing, hydraulic oil maintenance on larger industrial equipment, and quench oil clarification. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in disc stack centrifuge systems.</p>
      </div>

      <!-- Specs Table -->
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">DMB-013 Specifications</h2>
      <div class="overflow-x-auto mb-4">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Parameter</th>
              <th class="text-left px-4 py-3 font-semibold">Value</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Separation type</td>
              <td class="px-4 py-3 text-text-light">Two-phase clarifier (liquid-liquid or liquid-solid)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Diesel throughput</td>
              <td class="px-4 py-3 text-text-light">~13 GPM (13 cSt at operating temperature)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Rated throughput (water)</td>
              <td class="px-4 py-3 text-text-light">~19 GPM</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Cleaning method</td>
              <td class="px-4 py-3 text-text-light">Manual (bowl disassembly required for solids removal)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Bowl construction</td>
              <td class="px-4 py-3 text-text-light">Carbon steel standard</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Power supply</td>
              <td class="px-4 py-3 text-text-light">460V / 3-phase / 60 Hz standard (other voltages available)</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-sm text-text-muted mb-8 italic">Throughput figures are for typical fluids at listed conditions. Actual capacity varies with feed viscosity, temperature, density difference, and solids loading.</p>

      <!-- Capacity by Application -->
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">DMB-013 Capacity by Application (GPM)</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Application / Fluid</th>
              <th class="text-left px-4 py-3 font-semibold">Throughput (GPM)</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Gas oil at 40&deg;C</td><td class="px-4 py-3 text-text-light">~16 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Diesel fuel (13 cSt)</td><td class="px-4 py-3 text-text-light">~13 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Lube oil (R&amp;O)</td><td class="px-4 py-3 text-text-light">~7 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Lube oil (detergent)</td><td class="px-4 py-3 text-text-light">~6 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Steam turbine oil</td><td class="px-4 py-3 text-text-light">~12 GPM</td></tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Key Applications</h2>
      <div class="grid md:grid-cols-2 gap-6 mb-10">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Mid-Range Turbine Lube Oil</h3>
          <p class="text-sm text-text-light">Turbine generators in the 3,000–7,000 HP range with lube oil reservoirs of 1,000–5,000 gallons. The DMB-013 handles bypass purification at 7–12 GPM on turbine oil, removing water and particulates continuously to protect bearings and maintain oil cleanliness.</p>
          <a href="/lube-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Lube Oil Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Mid-Size Generator Diesel Polishing</h3>
          <p class="text-sm text-text-light">Standby generators and prime power units with larger fuel tanks requiring continuous polishing at 13–16 GPM. The DMB-013 maintains fuel quality and removes water contamination from diesel and gas oil storage systems at facilities where the DMB-007&rsquo;s 7 GPM is insufficient.</p>
          <a href="/diesel-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Diesel Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Industrial Hydraulic Systems</h3>
          <p class="text-sm text-text-light">Large hydraulic systems on heavy presses, injection molding machines, and industrial equipment with oil reservoirs above 2,000 gallons. The DMB-013 handles bypass purification at 7 GPM on hydraulic oil, maintaining cleanliness and removing water ingress continuously.</p>
          <a href="/hydraulic-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Hydraulic Oil Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Quench &amp; Heat Treatment Oil</h3>
          <p class="text-sm text-text-light">Heat treatment and hardening quench oil accumulates scale, carbon, and water over time. The DMB-013 clarifies quench oil at 10–13 GPM, extending bath life and maintaining consistent quench characteristics for heat treaters and foundries.</p>
          <a href="/quench-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Quench Oil Centrifuge Details &rarr;</a>
        </div>
      </div>

      <!-- FAQ -->
      <div id="faq" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What is the throughput of the DMB-013?</h3>
            <p class="text-text-light text-sm">The DMB-013 processes ~13 GPM of diesel, ~16 GPM of gas oil at 40&deg;C, ~7 GPM of lube oil (R&amp;O), and ~12 GPM of steam turbine oil. Rated at 19 GPM on water-viscosity fluid.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">When should I choose the DMB-013 over DMB-007 or DMB-019?</h3>
            <p class="text-text-light text-sm">Choose the DMB-013 when throughput is 10–15 GPM diesel — between the DMB-007 (7 GPM) and DMB-019 (19 GPM). For turbine lube oil, the DMB-013 suits 3,000–7,000 HP turbine systems at 7 GPM R&amp;O throughput.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What applications is the DMB-013 best suited for?</h3>
            <p class="text-text-light text-sm">Mid-range turbine lube oil (3,000–7,000 HP), diesel polishing on mid-size generators, industrial hydraulic oil maintenance, and quench oil clarification at 10–15 GPM where self-cleaning operation is not required.</p>
          </div>
        </div>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Related Resources</h2>
      <ul class="text-text-light space-y-2 mb-8">
        <li>&#8226; <a href="/centrifuges/dmb-007/" class="text-navy font-semibold hover:text-gold transition-colors">DMB-007 Manual-Clean Centrifuge (~7 GPM)</a></li>
        <li>&#8226; <a href="/centrifuges/dmb-019/" class="text-navy font-semibold hover:text-gold transition-colors">DMB-019 Manual-Clean Centrifuge (~19 GPM)</a></li>
        <li>&#8226; <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Disc Stack Centrifuge Overview</a></li>
        <li>&#8226; <a href="/lube-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Lube Oil Centrifuge Applications</a></li>
        <li>&#8226; <a href="/contact-for-alfa-laval-centrifuges/" class="text-navy font-semibold hover:text-gold transition-colors">Contact Us for DMB-013 Pricing</a></li>
      </ul>

    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Bottom CTA -->
  <section class="bg-navy">
    <div class="container-dolphin py-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Get Pricing on the DMB-013</h2>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">Tell us your fluid type, daily volume, and site conditions. We will provide a quote for the DMB-013 or recommend the right model for your application.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3.5 rounded-lg transition-colors">Contact Us</a>
        <a href="/industrial-centrifuge-sample-testing/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3.5 rounded-lg transition-colors">Sample Testing</a>
      </div>
    </div>
  </section>
</BaseLayout>
