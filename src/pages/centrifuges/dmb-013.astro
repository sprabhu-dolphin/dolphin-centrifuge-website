---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "DMB-013 Manual-Clean Disc Stack Centrifuge",
    "description": "Dolphin DMB-013 manual-clean disc stack centrifuge clarifier. 13 GPM diesel, 19 GPM rated. Mid-range cost-effective clarifier for turbine lube oil, diesel polishing, and industrial fluid purification.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "category": "Disc Stack Centrifuges",
    "model": "DMB-013",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
      "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the throughput of the DMB-013 centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Dolphin DMB-013 processes approximately 13 GPM of diesel fuel (13 cSt), 16 GPM of gas oil at 40°C, 7 GPM of lube oil (R&O), and 12 GPM of steam turbine oil. It is rated at 19 GPM on water-viscosity fluid. Actual throughput varies with fluid viscosity, temperature, and solids loading."
        }
      },
      {
        "@type": "Question",
        "name": "When should I choose the DMB-013 over the DMB-007 or DMB-019?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMB-013 bridges the gap between the DMB-007 (7 GPM diesel) and DMB-019 (19 GPM diesel). Choose the DMB-013 when your throughput requirement is 10–15 GPM diesel — enough to outgrow the DMB-007 but below the range where the DMB-019 is needed. For turbine lube oil applications, the DMB-013 at 7 GPM R&O throughput suits systems from approximately 3,000–7,000 HP."
        }
      },
      {
        "@type": "Question",
        "name": "What applications is the DMB-013 best suited for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMB-013 is suited for mid-range turbine lube oil systems (3,000–7,000 HP), diesel polishing on mid-size generators and fuel storage, hydraulic oil purification on larger industrial equipment, quench oil and heat treatment oil clarification, and industrial coolant and process oil polishing at 10–15 GPM where self-cleaning operation is not required."
        }
      }
    ]
  }
];
---

<ApplicationLayout
  title="DMB-013 Manual-Clean Disc Stack Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMB-013 manual-clean disc stack centrifuge: 13 GPM diesel, 19 GPM rated. Mid-range clarifier for turbine lube oil, diesel polishing, and fluid purification."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmb-013/"
  heroImage="/images/centrifuges/dmb-013-manual-clean-centrifuge.jpg"
  heroImageAlt="Dolphin DMB-013 manual-clean disc stack centrifuge system"
  category="products"
  categoryLabel="Dolphin Basket Centrifuges"
  toc={[
    { id: "ai-summary", label: "AI Summary" },
    { id: "specifications", label: "DMB-013 Specifications" },
    { id: "capacity-by-application", label: "Capacity by Application" },
    { id: "key-applications", label: "Key Applications" },
    { id: "faq", label: "Frequently Asked Questions" },
    { id: "related-resources", label: "Related Resources" },
  ]}
  relatedApplications={[
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
    { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
    { label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/" },
  ]}
  relatedProducts={[
    { label: "DMB-007 Manual-Clean Centrifuge", href: "/centrifuges/dmb-007/" },
    { label: "DMB-019 Manual-Clean Centrifuge", href: "/centrifuges/dmb-019/" },
    { label: "DMPX-020 Self-Cleaning Centrifuge", href: "/centrifuges/dmpx-020/" },
  ]}
  jsonLd={jsonLd}
>
  <article class="prose-dolphin max-w-none">

    <div id="ai-summary" class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8">
      <p class="text-sm text-text-light leading-relaxed italic"><strong>AI Summary:</strong> The Dolphin Centrifuge DMB-013 is a manual-clean disc stack centrifuge clarifier rated at 13 GPM on diesel (13 cSt) with 19 GPM water-rated throughput. A mid-range clarifier for turbine lube oil systems (3,000–7,000 HP), diesel polishing, and industrial hydraulic oil purification.</p>
    </div>

    <h2 id="specifications">DMB-013 Specifications</h2>
    <div class="overflow-x-auto mb-4">
      <table>
        <thead>
          <tr>
            <th>Parameter</th>
            <th>Value</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Separation type</td><td>Two-phase clarifier (liquid-liquid or liquid-solid)</td></tr>
          <tr><td>Diesel throughput</td><td>~13 GPM (13 cSt at operating temperature)</td></tr>
          <tr><td>Rated throughput (water)</td><td>~19 GPM</td></tr>
          <tr><td>Cleaning method</td><td>Manual (bowl disassembly required for solids removal)</td></tr>
          <tr><td>Bowl construction</td><td>Carbon steel standard</td></tr>
          <tr><td>Power supply</td><td>460V / 3-phase / 60 Hz standard (other voltages available)</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-sm text-text-muted italic">Throughput figures are for typical fluids at listed conditions. Actual capacity varies with feed viscosity, temperature, density difference, and solids loading.</p>

    <h2 id="capacity-by-application">DMB-013 Capacity by Application (GPM)</h2>
    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Application / Fluid</th>
            <th>Throughput (GPM)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Gas oil at 40&deg;C</td><td>~16 GPM</td></tr>
          <tr><td>Diesel fuel (13 cSt)</td><td>~13 GPM</td></tr>
          <tr><td>Lube oil (R&amp;O)</td><td>~7 GPM</td></tr>
          <tr><td>Lube oil (detergent)</td><td>~6 GPM</td></tr>
          <tr><td>Steam turbine oil</td><td>~12 GPM</td></tr>
        </tbody>
      </table>
    </div>

    <h2 id="key-applications">Key Applications</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-10">
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3>Mid-Range Turbine Lube Oil</h3>
        <p class="text-sm text-text-light">Turbine generators in the 3,000–7,000 HP range with lube oil reservoirs of 1,000–5,000 gallons. The DMB-013 handles bypass purification at 7–12 GPM on turbine oil, removing water and particulates continuously to protect bearings and maintain oil cleanliness.</p>
        <a href="/lube-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Lube Oil Centrifuge Details &rarr;</a>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3>Mid-Size Generator Diesel Polishing</h3>
        <p class="text-sm text-text-light">Standby generators and prime power units with larger fuel tanks requiring continuous polishing at 13–16 GPM. The DMB-013 maintains fuel quality and removes water contamination from <a href="/diesel-centrifuge/">diesel</a> and gas oil storage systems at facilities where the <a href="/centrifuges/dmb-007/">DMB-007</a>'s 7 GPM is insufficient.</p>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3>Industrial Hydraulic Systems</h3>
        <p class="text-sm text-text-light">Large hydraulic systems on heavy presses, injection molding machines, and industrial equipment with oil reservoirs above 2,000 gallons. The DMB-013 handles bypass purification at 7 GPM on hydraulic oil, maintaining cleanliness and removing water ingress continuously.</p>
        <a href="/hydraulic-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Hydraulic Oil Centrifuge Details &rarr;</a>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3>Quench &amp; Heat Treatment Oil</h3>
        <p class="text-sm text-text-light">Heat treatment and hardening quench oil accumulates scale, carbon, and water over time. The DMB-013 clarifies <a href="/quench-oil-centrifuge/">quench oil</a> at 10–13 GPM, extending bath life and maintaining consistent quench characteristics for heat treaters and foundries.</p>
      </div>
    </div>

    <div id="faq" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8">
      <h2>Frequently Asked Questions</h2>
      <div class="space-y-6">
        <div>
          <h3>What is the throughput of the DMB-013?</h3>
          <p class="text-sm text-text-light">The DMB-013 processes ~13 GPM of diesel, ~16 GPM of gas oil at 40&deg;C, ~7 GPM of lube oil (R&amp;O), and ~12 GPM of steam turbine oil. Rated at 19 GPM on water-viscosity fluid.</p>
        </div>
        <div>
          <h3>When should I choose the DMB-013 over DMB-007 or DMB-019?</h3>
          <p class="text-sm text-text-light">Choose the DMB-013 when throughput is 10–15 GPM diesel — between the <a href="/centrifuges/dmb-007/">DMB-007</a> (7 GPM) and <a href="/centrifuges/dmb-019/">DMB-019</a> (19 GPM). For turbine lube oil, the DMB-013 suits 3,000–7,000 HP turbine systems at 7 GPM R&amp;O throughput.</p>
        </div>
        <div>
          <h3>What applications is the DMB-013 best suited for?</h3>
          <p class="text-sm text-text-light">Mid-range turbine <a href="/lube-oil-centrifuge/">lube oil</a> (3,000–7,000 HP), diesel polishing on mid-size generators, industrial hydraulic oil maintenance, and quench oil clarification at 10–15 GPM where <a href="/self-cleaning-centrifuge/">self-cleaning operation</a> is not required.</p>
        </div>
      </div>
    </div>

    <h2 id="related-resources">Related Resources</h2>
    <ul>
      <li><a href="/centrifuges/dmb-007/">DMB-007 Manual-Clean Centrifuge (~7 GPM)</a></li>
      <li><a href="/centrifuges/dmb-019/">DMB-019 Manual-Clean Centrifuge (~19 GPM)</a></li>
      <li><a href="/disc-stack-centrifuge/">Disc Stack Centrifuge Overview</a></li>
      <li><a href="/lube-oil-centrifuge/">Lube Oil Centrifuge Applications</a></li>
      <li><a href="/contact-for-alfa-laval-centrifuges/">Contact Us for DMB-013 Pricing</a></li>
    </ul>

  </article>
</ApplicationLayout>
