---
import BaseLayout from '../../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "DMPX-042 Self-Cleaning Disc Stack Centrifuge",
  "description": "Dolphin DMPX-042 self-cleaning three-phase disc stack centrifuge. 32–47 GPM diesel throughput, 1.64–1.66 gal bowl, 7,000–8,000 Gs. High-capacity 3-phase separator for large industrial applications.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  "category": "Disc Stack Centrifuges",
  "model": "DMPX-042",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the throughput of the DMPX-042 centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Dolphin DMPX-042 processes 32–47 GPM of diesel-viscosity fluid (13 cSt) at operating temperature. Throughput varies by application: HFO 30 cSt runs 32–44 GPM; HFO 60 cSt runs 24–33 GPM; HFO 100 cSt runs 23–32 GPM; lube oil (R&O) runs 15–24 GPM; steam turbine oil runs 34–46 GPM. The wide range reflects the multiple Alfa Laval base machine configurations available in this model class."
      }
    },
    {
      "@type": "Question",
      "name": "Why does the DMPX-042 have multiple Alfa Laval base machine options?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The DMPX-042 class includes several Alfa Laval base centrifuge machines (MOPX 209, MOPX 210/310, WHPX 409/410/510, MAPX 210) that fall within its rated capacity range. Dolphin selects the appropriate base machine based on your specific application, fluid properties, required throughput, and any material or construction requirements. All configurations are sold and supported as the Dolphin DMPX-042 system."
      }
    },
    {
      "@type": "Question",
      "name": "What applications is the DMPX-042 best suited for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The DMPX-042 excels in large-volume waste oil reclamation, commercial-scale biodiesel production, yellow grease and WVO purification, crude oil tank bottom recovery, large machining coolant systems, and marine or industrial HFO/MFO purification. It is Dolphin's standard recommendation for operations requiring 30–50 GPM continuous three-phase separation."
      }
    },
    {
      "@type": "Question",
      "name": "When should I choose the DMPX-042 over the DMPX-028 or DMPX-070?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Choose the DMPX-042 when your required diesel throughput is 30–47 GPM, or your daily processing volume is 45,000–68,000 gallons. The DMPX-028 is appropriate for volumes up to roughly 35,000 GPD; the DMPX-070 is for the largest operations above 85,000 GPD. When two DMPX-028 units are being considered, a single DMPX-042 often provides better economics and simpler operation."
      }
    }
  ]
};
---

<BaseLayout
  title="DMPX-042 Self-Cleaning Disc Stack Centrifuge | Dolphin Centrifuge"
  description="Dolphin DMPX-042 self-cleaning disc stack centrifuge. 32–47 GPM diesel, 1.64 gal bowl. High-capacity 3-phase separator for large industrial applications."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmpx-042/"
  breadcrumbs={[{label: 'Products', href: '/disc-stack-centrifuge/'}, {label: 'DMPX-042 Centrifuge'}]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">DMPX Series &mdash; Dolphin Centrifuge</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">DMPX-042 Self-Cleaning Three-Phase Disc Stack Centrifuge</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">The Dolphin DMPX-042 is our high-capacity self-cleaning disc stack separator, processing 32–47 GPM of diesel-viscosity fluid with automatic solids ejection and true three-phase separation. Built for large-volume industrial waste oil operations, commercial biodiesel production, yellow grease purification, and continuous process oil clarification at scale.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Request a Quote</a>
        <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-5xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies the DMPX-042 — a self-cleaning three-phase disc stack centrifuge system for continuous high-volume oil-water-solids separation. Operating at 7,000–8,000 Gs with a 1.64–1.66 gallon bowl, the DMPX-042 processes 32–47 GPM of diesel-viscosity fluids (52–70 GPM rated) with PLC-controlled automatic solids ejection. Applications include large-volume waste oil reclamation, commercial biodiesel production, yellow grease and WVO purification, crude oil tank bottom recovery, and heavy industrial wastewater treatment. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in disc stack centrifuge systems.</p>
      </div>

      <!-- Specs Table -->
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">DMPX-042 Specifications</h2>
      <div class="overflow-x-auto mb-4">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Parameter</th>
              <th class="text-left px-4 py-3 font-semibold">Value</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Separation type</td>
              <td class="px-4 py-3 text-text-light">Three-phase (light liquid / heavy liquid / solids)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Diesel throughput</td>
              <td class="px-4 py-3 text-text-light">32–47 GPM (13 cSt at operating temperature)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Rated throughput (water)</td>
              <td class="px-4 py-3 text-text-light">52–70 GPM</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Bowl capacity</td>
              <td class="px-4 py-3 text-text-light">1.64–1.66 gallons (varies by base machine configuration)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">G-force</td>
              <td class="px-4 py-3 text-text-light">7,000–8,000 Gs</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Solids ejection</td>
              <td class="px-4 py-3 text-text-light">Hydraulic self-cleaning; PLC-controlled intervals</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Bowl construction</td>
              <td class="px-4 py-3 text-text-light">Carbon steel standard; 316L stainless steel available</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Power supply</td>
              <td class="px-4 py-3 text-text-light">460V / 3-phase / 60 Hz standard (other voltages available)</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Control system</td>
              <td class="px-4 py-3 text-text-light">PLC with HMI; programmable discharge intervals and alarms</td>
            </tr>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 font-medium text-navy">Explosion-proof option</td>
              <td class="px-4 py-3 text-text-light">Class I Division 1 &amp; 2 configurations available</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-sm text-text-muted mb-8 italic">The DMPX-042 class includes multiple Alfa Laval base centrifuge configurations. Dolphin selects the appropriate base machine for your specific application. Contact us for a configuration-specific quote.</p>

      <!-- Capacity by Application -->
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">DMPX-042 Capacity by Application (GPM)</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left px-4 py-3 font-semibold">Application / Fluid</th>
              <th class="text-left px-4 py-3 font-semibold">Throughput (GPM)</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Diesel fuel (13 cSt)</td><td class="px-4 py-3 text-text-light">32–47 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">HFO 30 cSt</td><td class="px-4 py-3 text-text-light">32–44 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">HFO 60 cSt</td><td class="px-4 py-3 text-text-light">24–33 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">HFO 100 cSt</td><td class="px-4 py-3 text-text-light">23–32 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">HFO 180 cSt</td><td class="px-4 py-3 text-text-light">16–22 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">HFO 380 cSt</td><td class="px-4 py-3 text-text-light">14–18 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Lube oil (R&amp;O)</td><td class="px-4 py-3 text-text-light">15–24 GPM</td></tr>
            <tr class="border-t border-gray-100"><td class="px-4 py-3 font-medium text-navy">Steam turbine oil</td><td class="px-4 py-3 text-text-light">34–46 GPM</td></tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Key Applications</h2>
      <div class="grid md:grid-cols-2 gap-6 mb-10">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Large-Volume Waste Oil Reclamation</h3>
          <p class="text-sm text-text-light mb-3">Operations processing 45,000–68,000 gallons per day of used oil, industrial waste oil, or oily water. The DMPX-042 handles high-solids feeds at 32+ GPM continuously, recovering reclaimed oil while separating water and ejecting sludge automatically.</p>
          <a href="/waste-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Waste Oil Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Commercial Biodiesel &amp; Yellow Grease</h3>
          <p class="text-sm text-text-light mb-3">Commercial-scale biodiesel production requires high-throughput three-phase separation to efficiently separate FAME, glycerin, and catalyst residues. Yellow grease and WVO purification at large rendering or waste grease operations benefit from the DMPX-042&rsquo;s 40+ GPM capacity on vegetable oil viscosities.</p>
          <a href="/yellow-grease-purification-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Yellow Grease Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Crude Oil &amp; Tank Bottom Recovery</h3>
          <p class="text-sm text-text-light mb-3">Tank bottom slop, crude oil dewatering, and oilfield waste with high water cut require high-capacity three-phase centrifugation. The DMPX-042 processes crude oil and oily slop at 30+ GPM, recovering crude from tank bottoms and separating produced water in a single continuous pass.</p>
          <a href="/crude-oil-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Crude Oil Centrifuge Details &rarr;</a>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">Large Machining Coolant Systems</h3>
          <p class="text-sm text-text-light mb-3">Central coolant systems for large machining facilities, automotive manufacturers, and aerospace manufacturers require high-throughput coolant recovery to maintain fluid quality across hundreds of machines. The DMPX-042 handles these large-scale coolant recovery and tramp oil removal tasks continuously.</p>
          <a href="/machining-coolant-recovery-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Machining Coolant Recovery Details &rarr;</a>
        </div>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Multiple Base Machine Configurations</h2>
      <p class="text-text-light mb-4">
        The DMPX-042 class encompasses several Alfa Laval base centrifuge machines that fall within the 32–47 GPM diesel throughput range. Different base machines offer variations in bowl construction (carbon steel vs. stainless steel), G-force (7,000 to 8,000 Gs), and rated throughput. Dolphin Centrifuge selects the appropriate base machine configuration based on your specific application requirements, fluid properties, throughput targets, and any special requirements such as food-grade construction or hazardous area certification.
      </p>
      <p class="text-text-light mb-8">
        All DMPX-042 configurations are sold and supported as complete Dolphin Centrifuge system modules — with Dolphin-supplied controls, piping, heating, pumping, and skid integration. The Dolphin model number (DMPX-042) is the identifier for your system; the specific base machine configuration is selected and managed by Dolphin to meet your application requirements.
      </p>

      <!-- FAQ -->
      <div id="faq" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What is the throughput of the DMPX-042?</h3>
            <p class="text-text-light text-sm">The DMPX-042 processes 32–47 GPM on diesel-viscosity fluid. Throughput varies by configuration and fluid: lube oil (R&amp;O) runs 15–24 GPM; HFO 180 cSt runs 16–22 GPM; steam turbine oil runs 34–46 GPM. Contact Dolphin Centrifuge for configuration-specific sizing.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">Why does the DMPX-042 have multiple base machine options?</h3>
            <p class="text-text-light text-sm">Multiple Alfa Laval base machines fall in this capacity class, offering variations in bowl construction, G-force, and throughput. Dolphin selects the appropriate configuration for your application and sells it as the complete DMPX-042 system.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What applications is the DMPX-042 best suited for?</h3>
            <p class="text-text-light text-sm">Large-volume waste oil reclamation, commercial biodiesel production, yellow grease and WVO purification, crude oil tank bottom recovery, and large machining coolant systems. Best for operations requiring 30–50 GPM continuous three-phase separation.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">When should I choose the DMPX-042 over the DMPX-028 or DMPX-070?</h3>
            <p class="text-text-light text-sm">Choose the DMPX-042 when diesel throughput is 30–47 GPM or daily volume is 45,000–68,000 gallons. The DMPX-028 handles up to ~35,000 GPD; the DMPX-070 handles operations above ~85,000 GPD. A single DMPX-042 often replaces two DMPX-028 units with better economics.</p>
          </div>
        </div>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Related Resources</h2>
      <ul class="text-text-light space-y-2 mb-8">
        <li>&#8226; <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Disc Stack Centrifuge Overview (all DMPX models)</a></li>
        <li>&#8226; <a href="/centrifuges/dmpx-028/" class="text-navy font-semibold hover:text-gold transition-colors">DMPX-028 Self-Cleaning Centrifuge (20–26 GPM)</a></li>
        <li>&#8226; <a href="/centrifuges/dmpx-070/" class="text-navy font-semibold hover:text-gold transition-colors">DMPX-070 Self-Cleaning Centrifuge (59–72 GPM)</a></li>
        <li>&#8226; <a href="/waste-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Waste Oil Centrifuge Applications</a></li>
        <li>&#8226; <a href="/crude-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Crude Oil Centrifuge</a></li>
        <li>&#8226; <a href="/contact-for-alfa-laval-centrifuges/" class="text-navy font-semibold hover:text-gold transition-colors">Contact Us for DMPX-042 Pricing</a></li>
      </ul>

    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Bottom CTA -->
  <section class="bg-navy">
    <div class="container-dolphin py-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Get Pricing on the DMPX-042</h2>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">Tell us your fluid type, daily throughput requirement, site conditions, and any special requirements. We will select the right DMPX-042 configuration and provide a detailed quote.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3.5 rounded-lg transition-colors">Contact Us</a>
        <a href="/industrial-centrifuge-sample-testing/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3.5 rounded-lg transition-colors">Sample Testing</a>
      </div>
    </div>
  </section>
</BaseLayout>
