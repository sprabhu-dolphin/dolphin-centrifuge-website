---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "DMPX-042 Self-Cleaning 3-Phase Disc Stack Centrifuge",
    "description": "The DMPX-042 is a large self-cleaning three-phase disc stack centrifuge processing 32–47 GPM of diesel, designed for high-volume crude oil dewatering, large-scale HFO purification, industrial waste oil, and transformer oil applications.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "category": "Disc Stack Centrifuges",
    "model": "DMPX-042",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "priceCurrency": "USD",
      "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the throughput of the DMPX-042 centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMPX-042 processes 32–47 GPM of diesel fuel at actual operating conditions, with a rated capacity of 52–70 GPM. Lube oil (R&O) throughput is 15–24 GPM, steam turbine oil is 34–46 GPM, and HFO 380 cSt is processed at 14–18 GPM."
        }
      },
      {
        "@type": "Question",
        "name": "What industries use the DMPX-042?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The DMPX-042 is used in oil field operations for crude oil tank-bottom dewatering, large-scale biodiesel production, HFO purification at power plants and industrial boiler facilities, transformer oil purification, and high-volume industrial waste oil reclamation at manufacturing plants and fleet operations."
        }
      },
      {
        "@type": "Question",
        "name": "Is the DMPX-042 available in explosion-proof configuration?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The DMPX-042 is available in Class I Division 1 and Class I Division 2 explosion-proof configurations for use in hazardous locations including oil fields, refineries, chemical plants, and offshore platforms. Visit our explosion-proof centrifuge page for details."
        }
      }
    ]
  }
];
---

<ApplicationLayout
  title="DMPX-042 Self-Cleaning 3-Phase Disc Centrifuge | Dolphin Centrifuge"
  description="DMPX-042 self-cleaning disc centrifuge: 32–47 GPM diesel. Large industrial unit for crude oil, HFO, waste oil, and lube oil separation. Request a quote."
  canonicalUrl="https://dolphincentrifuge.com/centrifuges/dmpx-042/"
  heroImage="/images/alfa-laval-mopx-209-centrifuge/Alfa-Laval-MOPX209-Cutting-Oil-Centrifuge-300.webp"
  heroImageAlt="Dolphin Centrifuge DMPX-042 self-cleaning three-phase disc stack centrifuge"
  category="products"
  categoryLabel="Dolphin Disc Centrifuges"
  toc={[
    { id: "technical-specifications", label: "Technical Specifications" },
    { id: "capacity-by-fluid-type", label: "Capacity by Fluid Type" },
    { id: "key-applications", label: "Key Applications" },
    { id: "dmpx-series-comparison", label: "DMPX Series Comparison" },
    { id: "frequently-asked-questions", label: "Frequently Asked Questions" },
  ]}
  relatedApplications={[
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
    { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
    { label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/" },
  ]}
  relatedProducts={[
    { label: "DMPX-010 (~7 GPM)", href: "/centrifuges/dmpx-010/" },
    { label: "DMPX-028 (~20–26 GPM)", href: "/centrifuges/dmpx-028/" },
    { label: "DMPX-070 (~59–72 GPM)", href: "/centrifuges/dmpx-070/" },
    { label: "DMB-037 Purifier", href: "/centrifuges/dmb-037/" },
  ]}
  jsonLd={jsonLd}
>

  <article class="prose-dolphin max-w-none">

    <!-- AI Summary -->
    <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-6 not-prose mb-8">
      <p class="text-base italic text-gray-700 leading-relaxed">
        <strong>AI Summary:</strong> The Dolphin Centrifuge DMPX-042 is a large self-cleaning three-phase disc stack centrifuge rated at 32–47 GPM for diesel fuel, with a 1.64-gallon sludge bowl and 20–25 HP motor. Built for crude oil dewatering, HFO 380 cSt purification at 14–18 GPM, and transformer oil restoration.
      </p>
    </div>

    <!-- Product Image -->
    <figure class="text-center my-8">
      <img
        src="/images/alfa-laval-mopx-209-centrifuge/Alfa-Laval-MOPX209-Cutting-Oil-Centrifuge-300.webp"
        alt="Dolphin Centrifuge DMPX-042 self-cleaning three-phase disc stack centrifuge"
        width="300"
        height="300"
        loading="eager"
        class="rounded-lg shadow-lg max-w-full mx-auto"
      />
      <figcaption class="text-sm text-gray-500 mt-2">
        DMPX-042 — Large Self-Cleaning 3-Phase Disc Stack Centrifuge
      </figcaption>
    </figure>

    <!-- Technical Specifications -->
    <h2 id="technical-specifications">Technical Specifications</h2>
    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Parameter</th>
            <th>DMPX-042 Value</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Diesel Throughput (Actual)</td><td>~32–47 GPM</td></tr>
          <tr><td>Diesel Throughput (Rated)</td><td>~52–70 GPM</td></tr>
          <tr><td>Bowl Sludge Capacity</td><td>1.64–1.66 gallons</td></tr>
          <tr><td>Motor Power</td><td>~20–25 HP</td></tr>
          <tr><td>Separation Type</td><td>Three-phase (oil / water / solids)</td></tr>
          <tr><td>Desludging</td><td>Automatic self-cleaning (hydraulic ejection)</td></tr>
          <tr><td>Process</td><td>Continuous, unattended operation</td></tr>
          <tr><td>Lube Oil (R&amp;O) Throughput</td><td>15–24 GPM</td></tr>
          <tr><td>Steam Turbine Oil Throughput</td><td>34–46 GPM</td></tr>
          <tr><td>DMPX Series Position</td><td>Large industrial (42 bowl equiv.)</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Capacity by Fluid Type -->
    <h2 id="capacity-by-fluid-type">Capacity by Fluid Type</h2>
    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Fluid Type</th>
            <th>Approx. Throughput (GPM)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Diesel / Light Fuel Oil</td><td>32–47</td></tr>
          <tr><td>HFO 30 cSt</td><td>32–44</td></tr>
          <tr><td>HFO 60 cSt</td><td>24–33</td></tr>
          <tr><td>HFO 100 cSt</td><td>23–32</td></tr>
          <tr><td>HFO 180 cSt</td><td>16–22</td></tr>
          <tr><td>HFO 380 cSt</td><td>14–18</td></tr>
          <tr><td>Lube Oil (R&amp;O) / Steam Turbine</td><td>15–24 / 34–46 GPM</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-xs text-gray-500">
      * Throughput values are at typical process temperature (194&deg;F / 90&deg;C). Actual flow rates vary with temperature, contamination level, and desired separation efficiency.
    </p>

    <!-- Key Applications -->
    <h2 id="key-applications">Key Applications</h2>

    <h3>Crude Oil / Tank-Bottoms Dewatering</h3>
    <p>
      The DMPX-042 handles high-volume crude oil dewatering and tank-bottom BS&amp;W (basic sediment and water) reduction at 32–47 GPM, making it suitable for oil-field gathering stations, tank farm operations, and upstream production facilities. Three-phase separation removes water and solids simultaneously in a single pass.
    </p>

    <h3>Large-Scale HFO Purification</h3>
    <p>
      For large marine vessels, shore-power plants, and industrial boiler systems burning <a href="/fuel-oil-centrifuge/">heavy fuel oil</a>, the DMPX-042 processes HFO 380 cSt at 14–18 GPM continuously — removing water and catalyst fines that cause injector wear, fouling, and combustion inefficiency.
    </p>

    <h3>Industrial Waste Oil Processing</h3>
    <p>
      At 32–47 GPM diesel-equivalent throughput, the DMPX-042 services large <a href="/waste-oil-centrifuge/">waste oil</a> reclamation operations: fleet maintenance facilities, large industrial plants, and centralized waste oil collection centers processing thousands of gallons per day. <a href="/explosion-proof-centrifuge/">Explosion-proof</a> options available for hazardous locations.
    </p>

    <h3>Transformer Oil Purification</h3>
    <p>
      The DMPX-042 is used by utilities and industrial facilities to purify transformer oil in service, removing particulate contamination, free water, and degradation products to restore dielectric strength and extend transformer service life. Continuous processing at 15–24 GPM <a href="/lube-oil-centrifuge/">lube oil</a> throughput supports large transformer maintenance programs.
    </p>

    <!-- DMPX Series Comparison -->
    <h2 id="dmpx-series-comparison">Where the DMPX-042 Fits in the DMPX Series</h2>
    <p>
      The DMPX-042 is the second-largest model in the Dolphin DMPX range. For medium industrial applications, the
      <a href="/centrifuges/dmpx-028/">DMPX-028</a>
      (~20–26 GPM) is the step below. For compact or portable use, the
      <a href="/dmpx-014-self-cleaning-3-phase-disc-stack-centrifuge/">DMPX-014</a>
      (~13 GPM) and
      <a href="/centrifuges/dmpx-010/">DMPX-010</a>
      (~7 GPM) serve smaller-scale needs. For the highest-volume industrial and power-generation applications, the
      <a href="/centrifuges/dmpx-070/">DMPX-070</a>
      (~59–72 GPM) is the flagship model.
      All DMPX models share the same automatic self-cleaning bowl technology.
      See the full comparison at our <a href="/disc-stack-centrifuge/">Disc Stack Centrifuge overview</a>.
    </p>

    <!-- FAQ -->
    <h2 id="frequently-asked-questions">Frequently Asked Questions</h2>

    <h3>What is the throughput of the DMPX-042 centrifuge?</h3>
    <p>
      The DMPX-042 processes 32–47 GPM of diesel fuel at actual operating conditions, with a rated capacity of 52–70 GPM. Lube oil (R&amp;O) throughput is 15–24 GPM, steam turbine oil is 34–46 GPM, and HFO 380 cSt is processed at 14–18 GPM.
    </p>

    <h3>What industries use the DMPX-042?</h3>
    <p>
      The DMPX-042 is used in oil field operations for crude oil tank-bottom dewatering, large-scale <a href="/biodiesel-centrifuge/">biodiesel</a> production, HFO purification at power plants and industrial boiler facilities, transformer oil purification, and high-volume industrial <a href="/waste-oil-centrifuge/">waste oil</a> reclamation at manufacturing plants and fleet operations.
    </p>

    <h3>Is the DMPX-042 available in explosion-proof configuration?</h3>
    <p>
      Yes. The DMPX-042 is available in Class I Division 1 and Class I Division 2 <a href="/explosion-proof-centrifuge/">explosion-proof</a> configurations for use in hazardous locations including oil fields, refineries, chemical plants, and offshore platforms. <a href="/contact-for-alfa-laval-centrifuges/">Contact us</a> to discuss hazardous-area requirements.
    </p>

  </article>

</ApplicationLayout>
