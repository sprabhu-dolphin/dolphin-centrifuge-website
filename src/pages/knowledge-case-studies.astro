---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const title = "Centrifuge Case Studies & FAQ — Real-World Results & Answers";
const description = "Real-world centrifuge case studies and FAQ covering waste oil recovery, wastewater treatment, and more. Documented results from Dolphin Centrifuge.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Centrifuge Case Studies & FAQ",
  "description": description,
  "url": "https://dolphincentrifuge.com/knowledge-case-studies/",
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "email": "sales@dolphincentrifuge.com",
  },
};

const toc = [
  { id: "case-studies", label: "Case Studies" },
  { id: "faq-resources", label: "FAQ Resources" },
  { id: "explore-knowledge", label: "Explore Other Knowledge Categories" },
];

const caseStudies = [
  {
    title: "Marine & Industrial Waste Oil Recovery — Case Study",
    href: "/waste-oil-centrifuge-case-study-marine-and-industrial-waste-oil-recovery/",
    description: "Real-world case study of a waste oil recovery operation processing marine and industrial waste oil with disc stack centrifuges — throughput, oil quality results, and ROI data.",
    tag: "Case Study",
  },
  {
    title: "6 MGY Used Oil Processing Plant",
    href: "/used-oil-centrifuge-plant/",
    description: "Detailed look at a 6 million gallon per year used oil processing facility using disc stack centrifuges — plant layout, processing stages, and output quality specifications.",
    tag: "Case Study",
  },
  {
    title: "Silicon Wafer Wastewater Treatment",
    href: "/industrial-wastewater-centrifuge-silicon-wafer-facility/",
    description: "How a silicon wafer manufacturing facility uses centrifuge systems to treat process wastewater — removing silicon fines and recovering clean water for reuse.",
    tag: "Case Study",
  },
  {
    title: "Pyrolysis Oil from Tire Recycling",
    href: "/pyrolysis-oil-centrifuge/",
    description: "Processing pyrolysis oil from waste tire recycling with disc stack centrifuges — removing carbon black, metals, and water to produce sale-ready fuel oil.",
    tag: "Case Study",
  },
];

const faqArticles = [
  {
    title: "Decanter Centrifuge Applications A-Z",
    href: "/decanter-centrifuge-applications/",
    description: "Comprehensive alphabetical listing of decanter centrifuge applications across industries — from animal rendering to wastewater sludge dewatering.",
  },
  {
    title: "Disc Stack Centrifuge FAQ",
    href: "/disc-stack-centrifuge-faq/",
    description: "Answers to the most frequently asked questions about disc stack centrifuges — how they work, maintenance requirements, costs, and application suitability.",
    tag: "FAQ",
  },
  {
    title: "Industrial Centrifuge FAQ",
    href: "/industrial-centrifuges-faq/",
    description: "General FAQ covering all types of industrial centrifuges — selection criteria, operating principles, maintenance schedules, and cost considerations.",
    tag: "FAQ",
  },
];
---

<ApplicationLayout
  title={title}
  description={description}
  canonicalUrl="https://dolphincentrifuge.com/knowledge-case-studies/"
  category="knowledge"
  categoryLabel="Case Studies"
  toc={toc}
  relatedApplications={[
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
    { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
  ]}
  relatedProducts={[
    { label: "DMPX-042 Disc Centrifuge", href: "/centrifuges/dmpx-042/" },
    { label: "DMPX-028 Disc Centrifuge", href: "/centrifuges/dmpx-028/" },
  ]}
  jsonLd={jsonLd}
>
  <div class="prose-dolphin max-w-none">
    <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8">
      <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge publishes industrial centrifuge case studies documenting real-world separation performance, ROI, and system design decisions. Case studies cover diesel fuel recovery, waste oil processing, coolant reclamation, marine fuel treatment, and more — with documented savings figures and installation details. Based in Warren, Michigan, with over 40 years of centrifuge case study documentation.</p>
    </div>

    <h2 id="case-studies">Case Studies</h2>
    <p>Each case study below documents a real centrifuge installation with measured results — throughput rates, output quality, and return on investment. These projects use <a href="/disc-stack-centrifuge/">disc stack centrifuges</a> and <a href="/decanter-centrifuge/">decanter centrifuges</a> supplied by Dolphin Centrifuge.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 not-prose my-6">
      {caseStudies.map((article) => (
        <a href={article.href} class="group bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg hover:border-purple-300/40 transition-all duration-300 overflow-hidden flex flex-col">
          <div class="relative h-32 bg-gradient-to-br from-purple-500/10 to-purple-600/5 flex items-center justify-center">
            <svg class="w-12 h-12 text-purple-400/30 group-hover:text-purple-400/50 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
            </svg>
            {article.tag && (
              <span class="absolute top-3 left-3 bg-gold text-navy text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">{article.tag}</span>
            )}
          </div>
          <div class="p-5 flex-1 flex flex-col">
            <h3 class="text-lg font-bold font-heading text-navy group-hover:text-purple-600 transition-colors mb-2">{article.title}</h3>
            <p class="text-sm text-text-light leading-relaxed flex-1">{article.description}</p>
            <div class="mt-4 flex items-center gap-1 text-gold font-semibold text-sm">
              Read More
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <h2 id="faq-resources">FAQ Resources</h2>
    <p>Browse frequently asked questions about <a href="/disc-stack-centrifuge-applications/">disc stack centrifuge applications</a> and industrial centrifuge systems. For hands-on testing before purchase, see our <a href="/industrial-centrifuge-sample-testing/">sample testing service</a>.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 not-prose my-6">
      {faqArticles.map((article) => (
        <a href={article.href} class="group bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg hover:border-purple-300/40 transition-all duration-300 overflow-hidden flex flex-col">
          <div class="relative h-32 bg-gradient-to-br from-purple-500/10 to-purple-600/5 flex items-center justify-center">
            <svg class="w-12 h-12 text-purple-400/30 group-hover:text-purple-400/50 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
            </svg>
            {article.tag && (
              <span class="absolute top-3 left-3 bg-gold text-navy text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">{article.tag}</span>
            )}
          </div>
          <div class="p-5 flex-1 flex flex-col">
            <h3 class="text-lg font-bold font-heading text-navy group-hover:text-purple-600 transition-colors mb-2">{article.title}</h3>
            <p class="text-sm text-text-light leading-relaxed flex-1">{article.description}</p>
            <div class="mt-4 flex items-center gap-1 text-gold font-semibold text-sm">
              Read More
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <h2 id="explore-knowledge">Explore Other Knowledge Categories</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 not-prose my-6">
      <a href="/knowledge-troubleshooting/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-red-300/40 hover:shadow-md transition-all">
        <div class="w-10 h-10 rounded-lg bg-red-50 text-red-500 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" /></svg>
        </div>
        <span class="text-sm font-bold text-navy group-hover:text-red-600 transition-colors">Troubleshooting</span>
      </a>
      <a href="/knowledge-guides/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-blue-300/40 hover:shadow-md transition-all">
        <div class="w-10 h-10 rounded-lg bg-blue-50 text-blue-500 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
        </div>
        <span class="text-sm font-bold text-navy group-hover:text-blue-600 transition-colors">Guides & How-To</span>
      </a>
      <a href="/knowledge-comparisons/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-emerald-300/40 hover:shadow-md transition-all">
        <div class="w-10 h-10 rounded-lg bg-emerald-50 text-emerald-500 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z" /></svg>
        </div>
        <span class="text-sm font-bold text-navy group-hover:text-emerald-600 transition-colors">Comparisons</span>
      </a>
      <a href="/knowledge-product-brand/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-amber-300/40 hover:shadow-md transition-all">
        <div class="w-10 h-10 rounded-lg bg-amber-50 text-amber-500 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.991l1.004.827c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        </div>
        <span class="text-sm font-bold text-navy group-hover:text-amber-600 transition-colors">Product & Brand</span>
      </a>
    </div>
  </div>
</ApplicationLayout>
