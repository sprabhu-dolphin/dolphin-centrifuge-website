<ApplicationLayout
  title="Disc Stack Centrifuge Disadvantages | Dolphin Centrifuge"
  description="The real limitations of disc stack centrifuges: solids handling capacity, capital cost, maintenance complexity, and when a decanter makes more sense."
  canonicalUrl="https://dolphincentrifuge.com/disadvantages-disc-stack-centrifuge/"
  heroImage="/images/disadvantages-disc-stack-centrifuge/disc-stack-centrifuge-bowl-moving-parts-1050.webp"
