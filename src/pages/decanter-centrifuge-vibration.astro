const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "6 Causes of Decanter Centrifuge Vibration and How to Fix Them",
  "description": "Expert guide to the 6 causes of decanter centrifuge vibration — from gradual bearing wear to sudden part breakage — with practical fixes and vibration reference levels.",
  "author": { "@type": "Person", "name": "Sanjay Prabhu MSME", "jobTitle": "Engineering Manager", "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" } },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
