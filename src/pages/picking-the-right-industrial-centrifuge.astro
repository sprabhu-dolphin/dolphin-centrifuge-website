---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the first step in selecting an industrial centrifuge?",
      "acceptedAnswer": { "@type": "Answer", "text": "The first step is fluid analysis — characterizing the mixture to be separated: phase compositions, particle size distribution, density difference, viscosity, temperature, and required flow rate. Without accurate fluid data, centrifuge sizing and type selection cannot be done reliably." }
    },
    {
      "@type": "Question",
      "name": "How do I choose between a disc stack centrifuge and a decanter centrifuge?",
      "acceptedAnswer": { "@type": "Answer", "text": "Use a disc stack centrifuge for separating fine particles from liquid-continuous feeds at low solids concentrations (typically under 3% by volume). Use a decanter centrifuge for dewatering high-solids sludges (3–40% solids) where continuous solids discharge is required. Fluid testing can confirm which technology achieves the required separation quality." }
    },
    {
      "@type": "Question",
      "name": "Is a remanufactured centrifuge a good alternative to a new one?",
      "acceptedAnswer": { "@type": "Answer", "text": "A remanufactured centrifuge can deliver 80–90% of new machine performance at 40–60% of the cost, provided it is fully rebuilt with new bearings, seals, and wear components and properly balanced. Dolphin Centrifuge offers fully refurbished disc stack and decanter centrifuges with performance documentation." }
    }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "9 Steps to Picking The Right Industrial Centrifuge",
  "description": "A 9-step guide to selecting the right industrial centrifuge covering fluid analysis, centrifuge types, capacity, options, new vs remanufactured, supplier selection, and post-purchase support.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Engineering Manager",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  },
  "datePublished": "2021-01-01",
  "dateModified": "2026-01-01",
  "mainEntityOfPage": "https://dolphincentrifuge.com/picking-the-right-industrial-centrifuge/"
};
