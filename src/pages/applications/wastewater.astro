---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const title = "Wastewater Centrifuge Applications";
const description = "Disc stack and decanter centrifuge systems for wastewater treatment, algae, manure, and biodiesel applications. Proven solutions from Dolphin Centrifuge.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": "https://dolphincentrifuge.com/applications/wastewater/",
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
};

const toc = [
  { id: "overview", label: "Overview" },
  { id: "municipal-industrial-wastewater", label: "Municipal & Industrial Wastewater" },
  { id: "algae-harvesting", label: "Algae Harvesting" },
  { id: "manure-separation", label: "Manure Separation" },
  { id: "liquid-humus-production", label: "Liquid Humus Production" },
  { id: "biodiesel-processing", label: "Biodiesel Processing" },
  { id: "choosing-the-right-centrifuge", label: "Choosing the Right Centrifuge" },
];

const relatedApplications = [
  { label: "Wastewater Centrifuge", href: "/wastewater-centrifuge/" },
  { label: "Industrial Wastewater Treatment", href: "/industrial-wastewater-treatment-centrifuge/" },
];

const relatedProducts = [
  { label: "DMPX-042 Disc Centrifuge", href: "/centrifuges/dmpx-042/" },
  { label: "Alfa Laval NX-418 Decanter", href: "/alfa-laval-nx-418-decanter-centrifuge/" },
];

const accent = "#8aad6e";
const icon = "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064";

const applications = [
  {
    title: "Wastewater Centrifuge",
    href: "/wastewater-centrifuge/",
    subtitle: "Municipal & Industrial Treatment",
    description: "Disc stack and decanter centrifuges for municipal and industrial wastewater treatment. Remove suspended solids, oils, and sludge to meet discharge permit requirements.",
    capacity: "20–80 GPM",
    tag: "Most Popular",
    accent,
    icon,
  },
  {
    title: "Algae Harvesting Centrifuge",
    href: "/algae-centrifuge/",
    subtitle: "Continuous Biomass Recovery",
    description: "Harvest algae cells from water at industrial scale using self-cleaning disc stack centrifuges. Process continuously with automatic biomass ejection.",
    capacity: "5–100+ GPM",
    tag: null,
    accent,
    icon,
  },
  {
    title: "Manure Centrifuge Separator",
    href: "/manure-centrifuge-separator/",
    subtitle: "Solids–Liquid Separation",
    description: "Separate manure into dry solids and nutrient-rich liquid using decanter centrifuges. Reduce storage volumes and produce high-value fertilizer.",
    capacity: "25+ GPM",
    tag: null,
    accent,
    icon,
  },
  {
    title: "Liquid Humus Centrifuge",
    href: "/liquid-humus-centrifuge/",
    subtitle: "Commercial Humus Production",
    description: "Produce liquid humus fertilizer at commercial scale. Decanter centrifuges separate humus biomass from nutrient-rich water.",
    capacity: "15–40 GPM",
    tag: null,
    accent,
    icon,
  },
  {
    title: "Biodiesel Centrifuge",
    href: "/biodiesel-centrifuge/",
    subtitle: "ASTM D6751 Compliance",
    description: "Wash and polish biodiesel to ASTM D6751 specs. Remove glycerin, soap, water, and catalyst residue continuously.",
    capacity: "10–40 GPM",
    tag: null,
    accent,
    icon,
  },
];
---
<ApplicationLayout
  title={title}
  description={description}
  canonicalUrl="https://dolphincentrifuge.com/applications/wastewater/"
  category="applications"
  categoryLabel="Wastewater Applications"
  heroImage="/images/wastewater-centrifuge/DMPX-028-Self-Cleaning-Disc-Stack-Centrifuge-for-WasteWater-600.webp"
  heroImageAlt="Self-cleaning disc stack centrifuge for wastewater treatment"
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
  jsonLd={jsonLd}
>
  <article class="prose-dolphin max-w-none">

    <h2 id="overview">Overview</h2>
    <p>
      From municipal sludge dewatering to algae harvesting and manure processing, our
      <a href="/disc-stack-centrifuge-applications/">disc stack</a> and
      <a href="/decanter-centrifuge/">decanter centrifuges</a> deliver reliable solids–liquid
      separation for the toughest wastewater streams. Dolphin Centrifuge provides turnkey systems
      backed by 40+ years of field experience and over 150 centrifuges in stock.
    </p>

    <h2 id="municipal-industrial-wastewater">Municipal &amp; Industrial Wastewater</h2>
    <p>
      Our <a href="/wastewater-centrifuge/">wastewater centrifuge systems</a> handle municipal
      and industrial wastewater treatment at flow rates of 20–80 GPM. They remove suspended solids,
      oils, and sludge to help facilities meet discharge permit requirements. Both disc stack and
      decanter configurations are available depending on particle size and solids concentration.
    </p>

    {/* Application Tiles */}
    <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-5 my-8">
      {applications.map((app) => (
        <a href={app.href} class="group relative bg-navy rounded-xl p-6 md:p-8 flex flex-col items-start text-white overflow-hidden hover:scale-[1.02] transition-transform duration-200 shadow-md hover:shadow-xl">
          <div class="absolute top-0 right-0 w-32 h-32 rounded-full opacity-15 blur-2xl -translate-y-10 translate-x-10" style={`background: ${app.accent};`}></div>
          <div class="flex items-start gap-4 w-full mb-4">
            <div class="w-12 h-12 rounded-lg flex items-center justify-center shrink-0" style={`background: ${app.accent}22;`}>
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke={app.accent} stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={app.icon} />
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-lg md:text-xl font-bold font-heading leading-tight group-hover:text-gold transition-colors">{app.title}</h3>
              <p class="text-xs font-semibold mt-0.5" style={`color: ${app.accent};`}>{app.subtitle}</p>
            </div>
            {app.capacity && <span class="bg-white/10 text-white text-xs font-mono px-2.5 py-1 rounded shrink-0">{app.capacity}</span>}
          </div>
          <p class="text-sm text-gray-300 leading-relaxed flex-1">{app.description}</p>
          <div class="mt-5">
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-gold opacity-0 group-hover:opacity-100 transition-opacity">
              Learn More
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </span>
          </div>
          {app.tag && <span class="absolute top-4 right-4 bg-gold text-navy text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">{app.tag}</span>}
        </a>
      ))}
    </div>

    <h2 id="algae-harvesting">Algae Harvesting</h2>
    <p>
      <a href="/algae-centrifuge/">Algae harvesting centrifuges</a> use self-cleaning disc stack
      technology to continuously separate algae cells from water at flow rates of 5–100+ GPM.
      Automatic biomass ejection keeps the process running without manual intervention, making
      these systems ideal for large-scale biofuel and nutraceutical operations.
    </p>

    <h2 id="manure-separation">Manure Separation</h2>
    <p>
      <a href="/manure-centrifuge-separator/">Manure centrifuge separators</a> use decanter
      centrifuge technology to split manure into dry solids and nutrient-rich liquid. This reduces
      storage volumes, controls odor, and produces high-value fertilizer — a critical tool for
      modern dairy and livestock operations processing 25+ GPM.
    </p>

    <h2 id="liquid-humus-production">Liquid Humus Production</h2>
    <p>
      For commercial humus production, <a href="/liquid-humus-centrifuge/">liquid humus centrifuges</a>
      separate humus biomass from nutrient-rich water at 15–40 GPM. Decanter centrifuges provide
      the continuous throughput and consistent separation efficiency that commercial fertilizer
      producers require.
    </p>

    <h2 id="biodiesel-processing">Biodiesel Processing</h2>
    <p>
      <a href="/biodiesel-centrifuge/">Biodiesel centrifuges</a> wash and polish biodiesel to ASTM
      D6751 specifications, continuously removing glycerin, soap, water, and catalyst residue at
      10–40 GPM. Disc stack centrifuges are the preferred technology for this application due to
      their ability to handle fine liquid–liquid separation.
    </p>

    <h2 id="choosing-the-right-centrifuge">Choosing the Right Centrifuge</h2>
    <p>
      The right centrifuge type depends on your wastewater characteristics — particle size, solids
      concentration, and required throughput. <a href="/disc-stack-centrifuge-applications/">Disc stack
      centrifuges</a> excel at fine-particle and liquid–liquid separation, while
      <a href="/decanter-centrifuge/">decanter centrifuges</a> handle high-solids slurries and
      dewatering tasks. Our engineers can run
      <a href="/industrial-centrifuge-sample-testing/">sample tests</a> on your specific waste stream
      to recommend the optimal system.
    </p>

  </article>
</ApplicationLayout>

<style is:global>
  /* ── Prose styling for application page content ── */
  .prose-dolphin {
    font-family: var(--font-family-body);
    color: var(--color-text);
    line-height: 1.75;
  }

  .prose-dolphin h2 {
    font-family: var(--font-family-heading);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-navy);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
    scroll-margin-top: 5rem;
  }

  .prose-dolphin h3 {
    font-family: var(--font-family-heading);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    scroll-margin-top: 5rem;
  }

  .prose-dolphin h4 {
    font-family: var(--font-family-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .prose-dolphin p {
    margin-bottom: 1.125rem;
  }

  .prose-dolphin strong {
    font-weight: 600;
    color: var(--color-text);
  }

  .prose-dolphin a {
    color: var(--color-navy);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: var(--color-gold);
    text-underline-offset: 3px;
    transition: color 0.15s;
  }

  .prose-dolphin a:hover {
    color: var(--color-gold-dark);
  }

  .prose-dolphin ul, .prose-dolphin ol {
    margin-bottom: 1.125rem;
    padding-left: 1.5rem;
  }

  .prose-dolphin ul { list-style: disc; }
  .prose-dolphin ol { list-style: decimal; }

  .prose-dolphin li {
    margin-bottom: 0.375rem;
  }

  .prose-dolphin img {
    max-width: 100%;
    height: auto;
    border-radius: 0.625rem;
    margin: 1.25rem 0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .prose-dolphin table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.875rem;
    border-radius: 0.625rem;
    overflow: hidden;
    border: 1px solid #e5e7eb;
  }

  .prose-dolphin thead th,
  .prose-dolphin th {
    background-color: var(--color-navy);
    color: white;
    font-weight: 600;
    text-align: left;
    padding: 0.625rem 0.875rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .prose-dolphin td {
    padding: 0.5rem 0.875rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .prose-dolphin tbody tr:nth-child(even) td {
    background-color: var(--color-light-bg);
  }

  .prose-dolphin blockquote {
    border-left: 4px solid var(--color-gold);
    padding: 0.875rem 1.25rem;
    margin: 1.25rem 0;
    background-color: var(--color-light-bg);
    border-radius: 0 0.5rem 0.5rem 0;
    color: var(--color-text-light);
    font-style: italic;
  }

  .prose-dolphin hr {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 2rem 0;
  }
</style>
