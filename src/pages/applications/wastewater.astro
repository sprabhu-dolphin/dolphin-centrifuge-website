---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Wastewater Centrifuge Applications";
const description = "Disc stack and decanter centrifuge systems for wastewater treatment, algae, manure, and biodiesel applications. Proven solutions from Dolphin Centrifuge.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": "https://dolphincentrifuge.com/applications/wastewater/",
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
};

const accent = "#8aad6e";
const icon = "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064";

const applications = [
  {
    title: "Wastewater Centrifuge",
    href: "/wastewater-centrifuge/",
    subtitle: "Municipal & Industrial Treatment",
    description: "Disc stack and decanter centrifuges for municipal and industrial wastewater treatment. Remove suspended solids, oils, and sludge to meet discharge permit requirements.",
    capacity: "20–80 GPM",
    tag: "Most Popular",
    accent,
    icon,
  },
  {
    title: "Algae Harvesting Centrifuge",
    href: "/algae-centrifuge/",
    subtitle: "Continuous Biomass Recovery",
    description: "Harvest algae cells from water at industrial scale using self-cleaning disc stack centrifuges. Process continuously with automatic biomass ejection.",
    capacity: "5–100+ GPM",
    tag: null,
    accent,
    icon,
  },
  {
    title: "Manure Centrifuge Separator",
    href: "/manure-centrifuge-separator/",
    subtitle: "Solids–Liquid Separation",
    description: "Separate manure into dry solids and nutrient-rich liquid using decanter centrifuges. Reduce storage volumes and produce high-value fertilizer.",
    capacity: "25+ GPM",
    tag: null,
    accent,
    icon,
  },
  {
    title: "Liquid Humus Centrifuge",
    href: "/liquid-humus-centrifuge/",
    subtitle: "Commercial Humus Production",
    description: "Produce liquid humus fertilizer at commercial scale. Decanter centrifuges separate humus biomass from nutrient-rich water.",
    capacity: "15–40 GPM",
    tag: null,
    accent,
    icon,
  },
  {
    title: "Biodiesel Centrifuge",
    href: "/biodiesel-centrifuge/",
    subtitle: "ASTM D6751 Compliance",
    description: "Wash and polish biodiesel to ASTM D6751 specs. Remove glycerin, soap, water, and catalyst residue continuously.",
    capacity: "10–40 GPM",
    tag: null,
    accent,
    icon,
  },
];
---
<BaseLayout title={title} description={description} breadcrumbs={[{ label: "Applications", href: "/applications/" }, { label: "Wastewater" }]} jsonLd={jsonLd}>

  {/* Hero */}
  <section class="relative bg-navy text-white overflow-hidden">
    <img
      src="/images/wastewater-centrifuge/DMPX-028-Self-Cleaning-Disc-Stack-Centrifuge-for-WasteWater-600.webp"
      alt="Self-cleaning disc stack centrifuge for wastewater treatment"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
      loading="eager"
    />
    <div class="relative z-10 container-dolphin py-12 md:py-16 lg:py-20">
      <div class="max-w-3xl">
        <span class="inline-block text-gold text-xs font-bold tracking-wider uppercase mb-3">Applications</span>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading leading-tight mb-4">Wastewater Centrifuge Applications</h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-6 max-w-2xl">From municipal sludge dewatering to algae harvesting and manure processing, our disc stack and decanter centrifuges deliver reliable solids–liquid separation for the toughest wastewater streams.</p>
        <div class="flex flex-wrap gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">
            Get a Free Quote
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
          <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            (248) 522-2573
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Application Tiles */}
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {applications.map((app) => (
          <a href={app.href} class="group relative bg-navy rounded-xl p-6 md:p-8 flex flex-col items-start text-white overflow-hidden hover:scale-[1.02] transition-transform duration-200 shadow-md hover:shadow-xl">
            <div class="absolute top-0 right-0 w-32 h-32 rounded-full opacity-15 blur-2xl -translate-y-10 translate-x-10" style={`background: ${app.accent};`}></div>
            <div class="flex items-start gap-4 w-full mb-4">
              <div class="w-12 h-12 rounded-lg flex items-center justify-center shrink-0" style={`background: ${app.accent}22;`}>
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke={app.accent} stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={app.icon} />
                </svg>
              </div>
              <div class="flex-1">
                <h2 class="text-lg md:text-xl font-bold font-heading leading-tight group-hover:text-gold transition-colors">{app.title}</h2>
                <p class="text-xs font-semibold mt-0.5" style={`color: ${app.accent};`}>{app.subtitle}</p>
              </div>
              {app.capacity && <span class="bg-white/10 text-white text-xs font-mono px-2.5 py-1 rounded shrink-0">{app.capacity}</span>}
            </div>
            <p class="text-sm text-gray-300 leading-relaxed flex-1">{app.description}</p>
            <div class="mt-5">
              <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-gold opacity-0 group-hover:opacity-100 transition-opacity">
                Learn More
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
              </span>
            </div>
            {app.tag && <span class="absolute top-4 right-4 bg-gold text-navy text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">{app.tag}</span>}
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Bottom CTA */}
  <section class="bg-white border-t border-gray-200">
    <div class="container-dolphin py-12 md:py-16">
      <div class="bg-navy rounded-2xl p-8 md:p-10 text-white text-center md:text-left md:flex md:items-center md:justify-between">
        <div class="mb-6 md:mb-0">
          <h3 class="text-xl md:text-2xl font-bold font-heading mb-2">Not sure which centrifuge fits your process?</h3>
          <p class="text-gray-300 text-sm">Send us a sample — our engineers will test it and recommend the right system.</p>
        </div>
        <div class="flex flex-wrap justify-center md:justify-end gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Get a Free Quote</a>
          <a href="/industrial-centrifuge-sample-testing/" class="inline-flex items-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">Sample Testing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
