---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Centrifuge Applications";
const description = "Industrial centrifuge applications across oil & fuel, industrial fluids, food & beverage, and environmental processing. Find the right centrifuge for your industry.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Industrial Centrifuge Applications",
  "description": description,
  "url": "https://dolphincentrifuge.com/applications/",
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
};

const apps = [
  { title: "Wastewater", subtitle: "Clarification & Purification", href: "/applications/wastewater/", description: "Municipal & industrial sludge dewatering, effluent treatment, algae harvesting, and manure separation.", icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064", accent: "#8aad6e" },
  { title: "Used Motor Oil", subtitle: "Mineral Oil Recovery", href: "/applications/used-motor-oil/", description: "Re-refining, crankcase drainings, waste oil emulsion breaking, black diesel, and fleet waste oil processing.", icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z", accent: "#999" },
  { title: "Waste Veggie Oil", subtitle: "UCO & WVO Processing", href: "/applications/waste-veggie-oil/", description: "WVO, UCO, yellow grease, brown grease, and biodiesel feedstock preparation.", icon: "M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z", accent: "#e8b84a" },
  { title: "Water-Based Fluids", subtitle: "Coolant & Metalworking", href: "/applications/water-based-fluids/", description: "Machining coolant, stamping coolant, synthetic & semi-synthetic metalworking fluids, and wash water.", icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z", accent: "#5ba3d9" },
  { title: "Oil-Based Fluids", subtitle: "Quench, Cutting & Draw", href: "/applications/oil-based-fluids/", description: "Quench oil, cutting oil, draw oil, rolling oil, tapping oil, and heat treating fluids.", icon: "M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z", accent: "#e07040" },
  { title: "Industrial Oils", subtitle: "Lube, Hydraulic & Gear", href: "/applications/industrial-oils/", description: "Turbine lube oil, hydraulic oil, compressor oil, transformer oil, and gear oil purification.", icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z", accent: "#e8cc5a" },
  { title: "Fuels", subtitle: "Diesel, HFO & Kerosene", href: "/applications/fuels/", description: "Diesel polishing, heavy fuel oil, kerosene, marine fuel, and generator fuel systems.", icon: "M13 10V3L4 14h7v7l9-11h-7z", accent: "#d4b878" },
  { title: "Crude Oil", subtitle: "Tank Bottoms & BS&W", href: "/applications/crude-oil/", description: "Tank bottoms, refinery slop, condensate, produced water, OBM, and BS&W recovery.", icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4", accent: "#c49044" },
];

const quickLinks = [
  { label: "Waste Oil", href: "/waste-oil-centrifuge/" },
  { label: "Wastewater", href: "/wastewater-centrifuge/" },
  { label: "Lube Oil", href: "/lube-oil-centrifuge/" },
  { label: "Diesel Fuel", href: "/diesel-centrifuge/" },
  { label: "Beer & Wine", href: "/beer-wine-centrifuge/" },
  { label: "Machining Coolant", href: "/machine-coolant-centrifuge/" },
  { label: "Crude Oil", href: "/crude-oil-centrifuge/" },
  { label: "Algae Harvesting", href: "/algae-centrifuge/" },
  { label: "All Applications A-Z", href: "/disc-stack-centrifuge-applications/" },
];
---

<BaseLayout title={title} description={description} breadcrumbs={[{ label: "Applications" }]} jsonLd={jsonLd}>
  {/* Hero */}
  <section class="relative bg-navy text-white overflow-hidden">
    <img
      src="/images/disc-stack-centrifuge-applications/Alfa-Laval-Stainless-Steel-Disc-Stack-Centrifuge-600.webp"
      alt="Industrial disc stack centrifuge applications by Dolphin Centrifuge"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
      loading="eager"
    />
    <div class="relative z-10 container-dolphin py-14 md:py-20 lg:py-24">
      <div class="max-w-3xl">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading leading-tight mb-5">Centrifuge Applications</h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-8 max-w-2xl">
          Over 40 years of centrifuge expertise across dozens of industries. From oil recovery to food processing, our purpose-modified industrial centrifuge systems deliver proven separation performance.
        </p>
        <div class="flex flex-wrap gap-2">
          {quickLinks.map((link) => (
            <a href={link.href} class="inline-block bg-white/10 hover:bg-gold hover:text-navy text-white text-sm font-medium px-4 py-2 rounded-full transition-all duration-200">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* Application Tiles -- 8 categories linking to sub-cat landing pages */}
  <section class="bg-warm-white">
    <div class="container-dolphin py-14 md:py-20">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5">
        {apps.map((app) => (
          <a
            href={app.href}
            class="group relative bg-navy rounded-xl p-5 md:p-6 flex flex-col items-start text-white overflow-hidden hover:scale-[1.03] transition-transform duration-200 shadow-md hover:shadow-xl"
          >
            <div class="absolute top-0 right-0 w-24 h-24 rounded-full opacity-15 blur-2xl -translate-y-8 translate-x-8" style={`background: ${app.accent};`}></div>
            <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-3" style={`background: ${app.accent}22;`}>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke={app.accent} stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={app.icon} />
              </svg>
            </div>
            <h2 class="text-base md:text-lg font-bold font-heading leading-tight mb-1 group-hover:text-gold transition-colors">{app.title}</h2>
            <p class="text-xs font-semibold mb-2" style={`color: ${app.accent};`}>{app.subtitle}</p>
            <p class="text-xs text-gray-400 leading-snug flex-1">{app.description}</p>
            <div class="mt-4">
              <span class="inline-flex items-center gap-1 text-xs font-semibold text-gold opacity-0 group-hover:opacity-100 transition-opacity">
                Learn More
                <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-8 text-center">
        <a href="/disc-stack-centrifuge-applications/" class="inline-flex items-center gap-2 bg-navy hover:bg-navy/90 text-white font-bold text-sm px-8 py-3.5 rounded-lg transition-colors">
          View All Applications A-Z
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
      </div>
    </div>
  </section>

  {/* Bottom CTA */}
  <section class="bg-white border-t border-gray-200">
    <div class="container-dolphin py-12 md:py-16">
      <div class="bg-navy rounded-2xl p-8 md:p-10 text-white text-center md:text-left md:flex md:items-center md:justify-between">
        <div class="mb-6 md:mb-0">
          <h3 class="text-xl md:text-2xl font-bold font-heading mb-2">Don't see your application?</h3>
          <p class="text-gray-300 text-sm">We've processed hundreds of different fluids. Contact us — chances are we've done it before.</p>
        </div>
        <div class="flex flex-wrap justify-center md:justify-end gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Contact Us</a>
          <a href="/industrial-centrifuge-sample-testing/" class="inline-flex items-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">Sample Testing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
