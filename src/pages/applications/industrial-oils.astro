const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": canonicalUrl,
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
};

const toc = [
  { id: "why-centrifuges-for-industrial-oils", label: "Why Centrifuges for Industrial Oils" },
  { id: "lube-oil-purification", label: "Lube Oil Purification" },
  { id: "hydraulic-oil-cleaning", label: "Hydraulic Oil Cleaning" },
