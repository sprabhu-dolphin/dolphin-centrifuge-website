---

<ApplicationLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  category="applications"
  categoryLabel="Water-Based Fluid Applications"
  heroImage="/images/machine-coolant-centrifuge/Alfa-Laval-Industrial-Centrifuge-Coolant-1000.webp"
  heroImageAlt="Industrial centrifuge for machining coolant and water-based fluid recovery by Dolphin Centrifuge"
  toc={toc}
  relatedApplications={[
    { label: "Wastewater Centrifuge", href: "/wastewater-centrifuge/" },
    { label: "Industrial Wastewater Treatment", href: "/industrial-wastewater-treatment-centrifuge/" },
    { label: "Coolant Centrifuge", href: "/coolant-centrifuge/" },
  ]}
