---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Water-Based Fluids Centrifuge Applications";
const description = "Industrial centrifuge systems for machining coolant recovery and parts washer fluid recycling. Water-based fluid purification solutions from Dolphin Centrifuge.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": "https://dolphincentrifuge.com/applications/water-based-fluids/",
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
};

const accent = "#5ba3d9";
const icon = "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z";

const applications = [
  {
    title: "Machining Coolant Centrifuge",
    href: "/machine-coolant-centrifuge/",
    subtitle: "Tramp Oil & Fines Removal",
    description: "Remove tramp oil, metal fines, and bacteria from water-based coolants. Our 3-phase disc stack centrifuges extend coolant life 5–20x and eliminate odor.",
    capacity: "8–40 GPM",
    tag: "Most Popular",
    accent,
    icon,
  },
  {
    title: "Industrial Washer Fluid",
    href: "/industrial-washer-fluid-centrifuge/",
    subtitle: "Aqueous Cleaning Fluid Recovery",
    description: "Extend the life of aqueous cleaning fluids and parts washer solutions by continuously removing oil and sediment. Reduce fluid costs up to 90%.",
    capacity: "3–15 GPM",
    tag: null,
    accent,
    icon,
  },
];

const caseStudies = [
  {
    title: "Coolant Recovery with Pasteurizing",
    href: "/machining-coolant-recovery-centrifuge/",
    description: "How a major machining facility extended coolant life from weeks to years using centrifuge separation with integrated pasteurization.",
  },
  {
    title: "Hydraulic Oil in Extrusion Presses",
    href: "/extrusion-industry-centrifuge-application/",
    description: "Centrifuge application for maintaining hydraulic fluid cleanliness in aluminum extrusion press operations.",
  },
];
---
<BaseLayout title={title} description={description} breadcrumbs={[{ label: "Applications", href: "/applications/" }, { label: "Water-Based Fluids" }]} jsonLd={jsonLd}>

  {/* Hero */}
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16 lg:py-20">
      <div class="max-w-3xl">
        <span class="inline-block text-gold text-xs font-bold tracking-wider uppercase mb-3">Applications</span>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading leading-tight mb-4">Water-Based Fluids Centrifuge Applications</h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-6 max-w-2xl">Extend the life of machining coolants, parts washer fluids, and aqueous cleaning solutions. Our 3-phase disc stack centrifuges remove tramp oil, metal fines, and biological contamination — cutting fluid replacement costs by up to 90%.</p>
        <div class="flex flex-wrap gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">
            Get a Free Quote
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
          <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            (248) 522-2573
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Application Tiles */}
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {applications.map((app) => (
          <a href={app.href} class="group relative bg-navy rounded-xl p-6 md:p-8 flex flex-col items-start text-white overflow-hidden hover:scale-[1.02] transition-transform duration-200 shadow-md hover:shadow-xl">
            <div class="absolute top-0 right-0 w-32 h-32 rounded-full opacity-15 blur-2xl -translate-y-10 translate-x-10" style={`background: ${app.accent};`}></div>
            <div class="flex items-start gap-4 w-full mb-4">
              <div class="w-12 h-12 rounded-lg flex items-center justify-center shrink-0" style={`background: ${app.accent}22;`}>
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke={app.accent} stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={app.icon} />
                </svg>
              </div>
              <div class="flex-1">
                <h2 class="text-lg md:text-xl font-bold font-heading leading-tight group-hover:text-gold transition-colors">{app.title}</h2>
                <p class="text-xs font-semibold mt-0.5" style={`color: ${app.accent};`}>{app.subtitle}</p>
              </div>
              {app.capacity && <span class="bg-white/10 text-white text-xs font-mono px-2.5 py-1 rounded shrink-0">{app.capacity}</span>}
            </div>
            <p class="text-sm text-gray-300 leading-relaxed flex-1">{app.description}</p>
            <div class="mt-5">
              <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-gold opacity-0 group-hover:opacity-100 transition-opacity">
                Learn More
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
              </span>
            </div>
            {app.tag && <span class="absolute top-4 right-4 bg-gold text-navy text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">{app.tag}</span>}
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Case Studies */}
  <section class="bg-white">
    <div class="container-dolphin py-12 md:py-16">
      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-2">Related Case Studies</h2>
      <p class="text-gray-500 text-sm mb-8">Real-world centrifuge applications in water-based fluid processing.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {caseStudies.map((study) => (
          <a href={study.href} class="group flex items-start gap-4 bg-warm-white border border-gray-200 rounded-xl p-6 hover:border-gold/50 hover:shadow-md transition-all duration-200">
            <div class="w-10 h-10 rounded-lg bg-navy/5 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-base font-bold font-heading text-navy group-hover:text-gold transition-colors">{study.title}</h3>
              <p class="text-sm text-gray-500 mt-1 leading-relaxed">{study.description}</p>
              <span class="inline-flex items-center gap-1 text-sm font-semibold text-gold mt-3 opacity-0 group-hover:opacity-100 transition-opacity">
                Read Case Study
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Bottom CTA */}
  <section class="bg-white border-t border-gray-200">
    <div class="container-dolphin py-12 md:py-16">
      <div class="bg-navy rounded-2xl p-8 md:p-10 text-white text-center md:text-left md:flex md:items-center md:justify-between">
        <div class="mb-6 md:mb-0">
          <h3 class="text-xl md:text-2xl font-bold font-heading mb-2">Need help choosing the right system?</h3>
          <p class="text-gray-300 text-sm">Send us a fluid sample — we'll test it free and recommend the optimal centrifuge.</p>
        </div>
        <div class="flex flex-wrap justify-center md:justify-end gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Get a Free Quote</a>
          <a href="/industrial-centrifuge-sample-testing/" class="inline-flex items-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">Sample Testing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
