---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const title = "Crude Oil Centrifuge Applications";
const description = "Centrifuge systems for crude oil recovery from tank bottoms, slop oil, and production waste streams. Oil Recovery Systems (ORS) process crude to less than 0.5% BS&W.";
const canonicalUrl = "https://dolphincentrifuge.com/applications/crude-oil/";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": canonicalUrl,
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
};

const toc = [
  { id: "overview", label: "Overview" },
  { id: "crude-oil-applications", label: "Crude Oil Applications" },
  { id: "how-it-works", label: "How Centrifuge Oil Recovery Works" },
  { id: "why-dolphin", label: "Why Dolphin Centrifuge" },
];

const relatedApplications = [
  { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
  { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
  { label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/" },
];

const relatedProducts = [
  { label: "DMPX-042 Disc Centrifuge", href: "/centrifuges/dmpx-042/" },
  { label: "DMPX-070 Disc Centrifuge", href: "/centrifuges/dmpx-070/" },
];

const applications = [
  {
    title: "Crude Oil Centrifuge",
    href: "/crude-oil-centrifuge/",
    description: "Recover sale oil from tank bottoms, slop oil, and production waste streams. Our Oil Recovery Systems (ORS) process crude to less than 0.5% BS&W.",
    capacity: "15–60 GPM",
    accent: "#c49044",
    icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4",
    subtitle: "Tank Bottom & Slop Oil Recovery",
    tag: "Most Popular",
  },
  {
    title: "Oil Centrifuge (General)",
    href: "/oil-centrifuge/",
    description: "Overview of all oil separation applications. Whether you need to purify, clarify, or polish any petroleum or bio-based oil — we have a solution.",
    capacity: "5–60 GPM",
    accent: "#c49044",
    icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4",
    subtitle: "All Oil Separation Applications",
  },
];
---

<ApplicationLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  heroImage="/images/crude-oil-centrifuge/Crude-Oil-Tank-Bottom-Recovery-System.webp"
  heroImageAlt="Crude oil tank bottom recovery centrifuge system by Dolphin Centrifuge"
  category="applications"
  categoryLabel="Crude Oil Applications"
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
  jsonLd={jsonLd}
>
  <article class="prose-dolphin max-w-none">
    <h2 id="overview">Overview</h2>
    <p>
      Dolphin Centrifuge provides turnkey Oil Recovery Systems (ORS) engineered to reclaim sale-quality crude from tank bottoms, slop oil, and production waste. Our <a href="/disc-stack-centrifuge/">disc stack centrifuge</a> platforms have processed millions of barrels across upstream and midstream operations, consistently delivering crude at less than 0.5% BS&W.
    </p>
    <p>
      Whether you are dealing with high-solids tank bottoms or emulsified slop oil, our systems combine high-speed <a href="/centrifuge-technology/">centrifuge technology</a> with automated controls to maximize recovery rates while minimizing operating costs.
    </p>

    <h2 id="crude-oil-applications">Crude Oil Applications</h2>
    <p>Explore our specialized crude oil centrifuge solutions below.</p>

    <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-5 my-6">
      {applications.map((app) => (
        <a href={app.href} class="group relative bg-navy rounded-xl p-6 md:p-8 flex flex-col items-start text-white overflow-hidden hover:scale-[1.02] transition-transform duration-200 shadow-md hover:shadow-xl">
          <div class="absolute top-0 right-0 w-32 h-32 rounded-full opacity-15 blur-2xl -translate-y-10 translate-x-10" style={`background: ${app.accent};`}></div>
          <div class="flex items-start gap-4 w-full mb-4">
            <div class="w-12 h-12 rounded-lg flex items-center justify-center shrink-0" style={`background: ${app.accent}22;`}>
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke={app.accent} stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={app.icon} />
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-lg md:text-xl font-bold font-heading leading-tight group-hover:text-gold transition-colors">{app.title}</h3>
              <p class="text-xs font-semibold mt-0.5" style={`color: ${app.accent};`}>{app.subtitle}</p>
            </div>
            {app.capacity && <span class="bg-white/10 text-white text-xs font-mono px-2.5 py-1 rounded shrink-0">{app.capacity}</span>}
          </div>
          <p class="text-sm text-gray-300 leading-relaxed flex-1">{app.description}</p>
          <div class="mt-5">
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-gold opacity-0 group-hover:opacity-100 transition-opacity">
              Learn More
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </span>
          </div>
          {app.tag && <span class="absolute top-4 right-4 bg-gold text-navy text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">{app.tag}</span>}
        </a>
      ))}
    </div>

    <h2 id="how-it-works">How Centrifuge Oil Recovery Works</h2>
    <p>
      A <a href="/disc-stack-centrifuge/">disc stack centrifuge</a> separates crude oil from water and solids using centrifugal force up to 8,000 G. The feed stream enters the rotating bowl, where heavy solids and water are driven outward while clean oil is collected at the center. This three-phase separation produces pipeline-quality crude in a single pass.
    </p>
    <p>
      Our ORS platforms include feed heating, chemical injection, and PLC-based automation for unattended operation. Each system is designed around the specific gravity and viscosity of your crude, ensuring optimal separation efficiency. For clients who need to validate performance before committing, we offer <a href="/industrial-centrifuge-sample-testing/">sample testing</a> at our Warren, MI facility.
    </p>

    <h2 id="why-dolphin">Why Dolphin Centrifuge</h2>
    <p>
      With over 40 years of experience and 150+ centrifuges in stock, Dolphin Centrifuge delivers faster lead times and lower costs than OEM alternatives. Every system ships fully <a href="/centrifuge-services/">factory-reconditioned</a> with a performance guarantee. Our engineers handle system sizing, installation support, and ongoing <a href="/contact-for-alfa-laval-centrifuges/">technical consultation</a> for the life of your equipment.
    </p>
  </article>
</ApplicationLayout>
