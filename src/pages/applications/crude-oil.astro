---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const title = "Crude Oil Centrifuge Applications";
const description = "Centrifuge systems for crude oil recovery from tank bottoms, slop oil, and production waste streams. Oil Recovery Systems (ORS) process crude to less than 0.5% BS&W.";
const canonicalUrl = "https://dolphincentrifuge.com/applications/crude-oil/";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": title,
    "description": description,
    "url": canonicalUrl,
    "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "url": canonicalUrl,
    "author": {
      "@type": "Person",
      "name": "Sanjay Prabhu MSME",
      "jobTitle": "Centrifuge Applications Engineer",
      "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" }
    },
    "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
    "datePublished": "2021-01-01",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is BS&W and why does it matter in crude oil?",
        "acceptedAnswer": { "@type": "Answer", "text": "BS&W stands for Basic Sediment and Water — the combined percentage of water, solids, and emulsified material in crude oil. Pipeline specifications typically require less than 0.5% BS&W. High BS&W crude is penalized at the point of sale, so reducing it directly increases revenue per barrel." }
      },
      {
        "@type": "Question",
        "name": "Can a centrifuge recover oil from tank bottoms?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Dolphin Centrifuge's Oil Recovery Systems (ORS) are specifically designed for tank bottom recovery. They process high-solids, emulsified tank bottoms — separating sellable crude oil from water and sludge — at flow rates of 15–60 GPM. These are three-phase disc stack centrifuge systems with integrated heating and chemical injection." }
      },
      {
        "@type": "Question",
        "name": "What is a three-phase centrifuge and when is it needed?",
        "acceptedAnswer": { "@type": "Answer", "text": "A three-phase disc stack centrifuge separates oil, water, and solids simultaneously in a single pass. It is needed when the crude oil stream contains significant water content (as in tank bottoms or produced water) alongside solid particulates. Two-phase clarifiers are used when the stream is primarily oil with solids but minimal free water." }
      },
      {
        "@type": "Question",
        "name": "How fast can Dolphin Centrifuge deliver a crude oil recovery system?",
        "acceptedAnswer": { "@type": "Answer", "text": "Dolphin Centrifuge maintains 150+ centrifuges in stock at their Warren, MI facility. Reconditioned Oil Recovery Systems (ORS) are typically available for rapid deployment. Custom-built or larger systems have longer lead times — contact our team for current availability." }
      },
      {
        "@type": "Question",
        "name": "Does Dolphin Centrifuge offer sample testing for crude oil applications?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Dolphin Centrifuge offers free sample testing at our Warren, MI facility. Send us a representative crude oil, tank bottom, or slop oil sample and our engineers will test it to confirm separation performance and recommend the correct centrifuge model and operating parameters." }
      }
    ]
  }
];

const toc = [
  { id: "ai-summary", label: "Overview" },
  { id: "crude-oil-applications", label: "Crude Oil Applications" },
  { id: "how-it-works", label: "How Centrifuge Oil Recovery Works" },
  { id: "why-dolphin", label: "Why Dolphin Centrifuge" },
  { id: "faq", label: "Frequently Asked Questions" },
];

const relatedApplications = [
  { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
  { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
  { label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/" },
];

const relatedProducts = [
  { label: "DMPX-042 Disc Centrifuge", href: "/centrifuges/dmpx-042/" },
  { label: "DMPX-070 Disc Centrifuge", href: "/centrifuges/dmpx-070/" },
];

const applications = [
  {
    title: "Crude Oil Centrifuge",
    href: "/crude-oil-centrifuge/",
    description: "Recover sale oil from tank bottoms, slop oil, and production waste streams. Our Oil Recovery Systems (ORS) process crude to less than 0.5% BS&W.",
    capacity: "15–60 GPM",
    accent: "#c49044",
    icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4",
    subtitle: "Tank Bottom & Slop Oil Recovery",
    tag: "Most Popular",
  },
  {
    title: "Oil Centrifuge (General)",
    href: "/oil-centrifuge/",
    description: "Overview of all oil separation applications. Whether you need to purify, clarify, or polish any petroleum or bio-based oil — we have a solution.",
    capacity: "5–60 GPM",
    accent: "#c49044",
    icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4",
    subtitle: "All Oil Separation Applications",
    tag: null,
  },
];
---

<ApplicationLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  heroImage="/images/crude-oil-centrifuge/Crude-Oil-Tank-Bottom-Recovery-System.webp"
  heroImageAlt="Crude oil tank bottom recovery centrifuge system by Dolphin Centrifuge"
  category="applications"
  categoryLabel="Crude Oil Applications"
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
  jsonLd={jsonLd}
>
  <article class="prose-dolphin max-w-none">

    <!-- AI Summary -->
    <div id="ai-summary" class="bg-navy/5 border-l-4 border-gold/40 rounded-r-lg p-4 mb-6 not-prose">
      <p class="text-sm text-gray-600 leading-relaxed italic">Dolphin Centrifuge provides turnkey Oil Recovery Systems (ORS) engineered to reclaim sale-quality crude from tank bottoms, slop oil, and production waste. Operating at up to 8,000 G with three-phase disc stack separation, these systems process 15–60 GPM continuously, delivering crude at less than 0.5% BS&W. Based in Warren, Michigan, with over 40 years of upstream and midstream oil separation experience.</p>
    </div>

    <h2 id="overview">Overview</h2>
    <p>
      Dolphin Centrifuge provides turnkey Oil Recovery Systems (ORS) engineered to reclaim sale-quality crude from tank bottoms, slop oil, and production waste. Our <a href="/disc-stack-centrifuge/">disc stack centrifuge</a> platforms have processed millions of barrels across upstream and midstream operations, consistently delivering crude at less than 0.5% BS&W.
    </p>
    <p>
      Whether you are dealing with high-solids tank bottoms or emulsified slop oil, our systems combine high-speed <a href="/centrifuge-technology/">centrifuge technology</a> with automated controls to maximize recovery rates while minimizing operating costs.
    </p>

    <h2 id="crude-oil-applications">Crude Oil Applications</h2>
    <p>Explore our specialized crude oil centrifuge solutions below.</p>

    <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-5 my-6">
      {applications.map((app) => (
        <a href={app.href} class="group relative bg-navy rounded-xl p-6 md:p-8 flex flex-col items-start text-white overflow-hidden hover:scale-[1.02] transition-transform duration-200 shadow-md hover:shadow-xl">
          <div class="absolute top-0 right-0 w-32 h-32 rounded-full opacity-15 blur-2xl -translate-y-10 translate-x-10" style={`background: ${app.accent};`}></div>
          <div class="flex items-start gap-4 w-full mb-4">
            <div class="w-12 h-12 rounded-lg flex items-center justify-center shrink-0" style={`background: ${app.accent}22;`}>
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke={app.accent} stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={app.icon} />
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-lg md:text-xl font-bold font-heading leading-tight group-hover:text-gold transition-colors">{app.title}</h3>
              <p class="text-xs font-semibold mt-0.5" style={`color: ${app.accent};`}>{app.subtitle}</p>
            </div>
            {app.capacity && <span class="bg-white/10 text-white text-xs font-mono px-2.5 py-1 rounded shrink-0">{app.capacity}</span>}
          </div>
          <p class="text-sm text-gray-300 leading-relaxed flex-1">{app.description}</p>
          <div class="mt-5">
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-gold opacity-0 group-hover:opacity-100 transition-opacity">
              Learn More
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </span>
          </div>
          {app.tag && <span class="absolute top-4 right-4 bg-gold text-navy text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">{app.tag}</span>}
        </a>
      ))}
    </div>

    <h2 id="how-it-works">How Centrifuge Oil Recovery Works</h2>
    <p>
      A <a href="/disc-stack-centrifuge/">disc stack centrifuge</a> separates crude oil from water and solids using centrifugal force up to 8,000 G. The feed stream enters the rotating bowl, where heavy solids and water are driven outward while clean oil is collected at the center. This three-phase separation produces pipeline-quality crude in a single pass.
    </p>
    <p>
      Our ORS platforms include feed heating, chemical injection, and PLC-based automation for unattended operation. Each system is designed around the specific gravity and viscosity of your crude, ensuring optimal separation efficiency. For clients who need to validate performance before committing, we offer <a href="/industrial-centrifuge-sample-testing/">sample testing</a> at our Warren, MI facility.
    </p>

    <!-- Mid-Page CTA -->
    <div class="not-prose my-10 bg-gold/10 border border-gold/40 rounded-xl p-6 md:p-8">
      <h3 class="text-xl font-bold text-navy mb-2">Recovering Crude from Tank Bottoms or Slop Oil?</h3>
      <p class="text-gray-700 mb-4">Our ORS systems deliver crude at less than 0.5% BS&W. Send us a sample — we'll test your oil and size the right centrifuge system for your throughput and API gravity.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/industrial-centrifuge-sample-testing/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold/90 text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Free Sample Testing</a>
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-navy hover:bg-navy/90 text-white font-bold text-sm px-6 py-3 rounded-lg transition-colors">Get a Free Quote</a>
      </div>
    </div>

    <h2 id="why-dolphin">Why Dolphin Centrifuge</h2>
    <p>
      With over 40 years of experience and 150+ centrifuges in stock, Dolphin Centrifuge delivers faster lead times and lower costs than OEM alternatives. Every system ships fully <a href="/centrifuge-services/">factory-reconditioned</a> with a performance guarantee. Our engineers handle system sizing, installation support, and ongoing <a href="/contact-for-alfa-laval-centrifuges/">technical consultation</a> for the life of your equipment.
    </p>

    <!-- FAQ Section -->
    <h2 id="faq">Frequently Asked Questions</h2>

    <details class="border-l-4 border-gold/40 pl-4 mb-4">
      <summary class="font-semibold text-navy cursor-pointer py-2">What is BS&W and why does it matter in crude oil?</summary>
      <p class="mt-2 text-gray-700">BS&W stands for Basic Sediment and Water — the combined percentage of water, solids, and emulsified material in crude oil. Pipeline specifications typically require less than 0.5% BS&W. High BS&W crude is penalized at the point of sale, so reducing it directly increases revenue per barrel.</p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4">
      <summary class="font-semibold text-navy cursor-pointer py-2">Can a centrifuge recover oil from tank bottoms?</summary>
      <p class="mt-2 text-gray-700">Yes. Dolphin Centrifuge's Oil Recovery Systems (ORS) are specifically designed for tank bottom recovery. They process high-solids, emulsified tank bottoms — separating sellable crude oil from water and sludge — at flow rates of 15–60 GPM. These are three-phase disc stack centrifuge systems with integrated heating and chemical injection.</p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4">
      <summary class="font-semibold text-navy cursor-pointer py-2">What is a three-phase centrifuge and when is it needed?</summary>
      <p class="mt-2 text-gray-700">A three-phase disc stack centrifuge separates oil, water, and solids simultaneously in a single pass. It is needed when the crude oil stream contains significant water content (as in tank bottoms or produced water) alongside solid particulates. Two-phase clarifiers are used when the stream is primarily oil with solids but minimal free water.</p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4">
      <summary class="font-semibold text-navy cursor-pointer py-2">How fast can Dolphin Centrifuge deliver a crude oil recovery system?</summary>
      <p class="mt-2 text-gray-700">Dolphin Centrifuge maintains 150+ centrifuges in stock at their Warren, MI facility. Reconditioned Oil Recovery Systems (ORS) are typically available for rapid deployment. Custom-built or larger systems have longer lead times — contact our team for current availability.</p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4">
      <summary class="font-semibold text-navy cursor-pointer py-2">Does Dolphin Centrifuge offer sample testing for crude oil applications?</summary>
      <p class="mt-2 text-gray-700">Yes. Dolphin Centrifuge offers free sample testing at our Warren, MI facility. Send us a representative crude oil, tank bottom, or slop oil sample and our engineers will test it to confirm separation performance and recommend the correct centrifuge model and operating parameters.</p>
    </details>

  </article>

  <!-- Bottom CTA Bar -->
  <div class="not-prose mt-10 bg-navy rounded-xl p-8 text-white text-center">
    <h3 class="text-2xl font-bold mb-2">Get Pipeline-Quality Crude from Your Waste Streams</h3>
    <p class="text-white/80 mb-6 max-w-xl mx-auto">Dolphin Centrifuge ORS systems. Less than 0.5% BS&W guaranteed. 150+ units in stock. Fast delivery from Warren, MI.</p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold/90 text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Free Quote</a>
      <a href="/crude-oil-centrifuge/" class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-3 rounded-lg transition-colors border border-white/20">Crude Oil Centrifuge Details</a>
      <a href="tel:+12485222573" class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-3 rounded-lg transition-colors border border-white/20">(248) 522-2573</a>
    </div>
  </div>
</ApplicationLayout>
