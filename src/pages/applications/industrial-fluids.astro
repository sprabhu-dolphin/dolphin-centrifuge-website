---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Industrial Fluids Centrifuges";
const description = "Centrifuge systems for machining coolant recovery, cutting oil purification, quench oil filtration, and wash water cleaning. Extend fluid life up to 20x.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": "https://dolphincentrifuge.com/applications/industrial-fluids/",
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
};

const applications = [
  {
    title: "Machining Coolant Centrifuge",
    href: "/machine-coolant-centrifuge/",
    image: "/images/applications/machine-coolant-centrifuge-hero.jpg",
    description: "Remove tramp oil, metal fines, and bacteria from water-based coolants. Our 3-phase disc stack centrifuges separate all three contaminant phases simultaneously, extending coolant life 5–20x and eliminating odor issues.",
    capacity: "8–40 GPM",
    tag: "Most Popular",
  },
  {
    title: "Cutting Oil Centrifuge",
    href: "/cutting-oil-centrifuge/",
    image: "/images/applications/cutting-oil-centrifuge-hero.jpg",
    description: "Purify straight cutting oils and neat oils used in precision machining. Centrifugal separation removes metal swarf, grinding dust, and moisture to maintain oil performance and surface finish quality.",
    capacity: "5–30 GPM",
  },
  {
    title: "Quench Oil Filtration",
    href: "/quench-oil-centrifuge/",
    image: "/images/applications/quench-oil-centrifuge-hero.jpg",
    description: "Maintain quench oil clarity and thermal performance by removing scale, carbon, and oxidation byproducts. Clean quench oil ensures consistent metallurgical properties in heat-treated components.",
    capacity: "5–30 GPM",
  },
  {
    title: "Industrial Washer Fluid",
    href: "/industrial-washer-fluid-centrifuge/",
    image: "/images/applications/industrial-washer-fluid-centrifuge-hero.jpg",
    description: "Extend the life of aqueous cleaning fluids and parts washer solutions by continuously removing oil and sediment contamination. Reduce fluid replacement costs by up to 90%.",
    capacity: "3–15 GPM",
  },
];

const caseStudies = [
  {
    title: "Coolant Recovery with Pasteurizing",
    href: "/machining-coolant-recovery-centrifuge/",
    description: "How combining disc centrifuge separation with pasteurization eliminates bacteria, tramp oil, and metal particles — producing odor-free coolant for reuse.",
  },
  {
    title: "Hydraulic Oil in Extrusion Presses",
    href: "/extrusion-industry-centrifuge-application/",
    description: "Case study showing how centrifuge-cleaned hydraulic oil reduced oil-related downtime by 98% and extended pump life 2–4x in aluminum extrusion facilities.",
  },
];
---

<BaseLayout title={title} description={description} breadcrumbs={[{ label: "Applications", href: "/applications/" }, { label: "Industrial Fluids" }]} jsonLd={jsonLd}>
  {/* Hero */}
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16 lg:py-20">
      <div class="max-w-3xl">
        <span class="inline-block text-gold text-xs font-bold tracking-wider uppercase mb-3">Applications</span>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading leading-tight mb-4">Industrial Fluids Centrifuge Applications</h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-6 max-w-2xl">
          Keep your machining coolants, cutting oils, quench fluids, and wash waters clean and productive. Our centrifuge systems remove contaminants that filters miss — extending fluid life and reducing operating costs.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">
            Get a Free Quote
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
          <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            (248) 522-2573
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Application Cards */}
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {applications.map((app) => (
          <a href={app.href} class="group bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg hover:border-gold/40 transition-all duration-300 overflow-hidden flex flex-col">
            <div class="relative h-48 bg-light-bg overflow-hidden">
              <div class="absolute inset-0 bg-navy/5 flex items-center justify-center">
                <svg class="w-16 h-16 text-navy/10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              {app.tag && <span class="absolute top-3 left-3 bg-gold text-navy text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">{app.tag}</span>}
              {app.capacity && <span class="absolute bottom-3 right-3 bg-navy/80 text-white text-xs font-mono px-2 py-1 rounded">{app.capacity}</span>}
            </div>
            <div class="p-5 flex-1 flex flex-col">
              <h3 class="text-lg font-bold font-heading text-navy group-hover:text-gold-dark transition-colors mb-2">{app.title}</h3>
              <p class="text-sm text-text-light leading-relaxed flex-1">{app.description}</p>
              <div class="mt-4 flex items-center gap-1 text-gold font-semibold text-sm">
                Learn More
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      {/* Case Studies */}
      <div class="mt-12">
        <h2 class="text-2xl font-extrabold font-heading text-navy mb-6">Related Case Studies</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {caseStudies.map((cs) => (
            <a href={cs.href} class="group bg-white rounded-xl p-6 border border-gray-200 hover:border-gold/40 hover:shadow-md transition-all">
              <h3 class="text-base font-bold text-navy group-hover:text-gold-dark transition-colors mb-2">{cs.title}</h3>
              <p class="text-sm text-text-light leading-relaxed">{cs.description}</p>
              <span class="inline-flex items-center gap-1 text-gold font-semibold text-sm mt-3">
                Read Case Study
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* Bottom CTA */}
  <section class="bg-white border-t border-gray-200">
    <div class="container-dolphin py-12 md:py-16">
      <div class="bg-navy rounded-2xl p-8 md:p-10 text-white text-center md:text-left md:flex md:items-center md:justify-between">
        <div class="mb-6 md:mb-0">
          <h3 class="text-xl md:text-2xl font-bold font-heading mb-2">Need help choosing the right system?</h3>
          <p class="text-gray-300 text-sm">Send us a fluid sample — we'll test it free and recommend the optimal centrifuge.</p>
        </div>
        <div class="flex flex-wrap justify-center md:justify-end gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Get a Free Quote</a>
          <a href="/industrial-centrifuge-sample-testing/" class="inline-flex items-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">Sample Testing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
