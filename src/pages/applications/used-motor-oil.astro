---
import ApplicationLayout from '../../layouts/ApplicationLayout.astro';

const title = "Used Motor Oil Centrifuge Applications";
const description = "Centrifuge systems for waste oil recovery, used oil re-refining, and black diesel cleaning. Industrial oil purification solutions from Dolphin Centrifuge.";
const canonicalUrl = "https://dolphincentrifuge.com/applications/used-motor-oil/";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": title,
    "description": description,
    "url": canonicalUrl,
    "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "url": canonicalUrl,
    "author": {
      "@type": "Person",
      "name": "Dolphin Centrifuge Engineering Team",
      "jobTitle": "Centrifuge Applications Engineer",
      "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" }
    },
    "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
    "datePublished": "2021-01-01",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How does a centrifuge clean used motor oil?",
        "acceptedAnswer": { "@type": "Answer", "text": "A disc stack centrifuge processes used motor oil at up to 8,000 G-force, separating water, sludge, wear metals, and carbon particles from the clean oil phase. The three-phase design simultaneously removes both water and solids in a single continuous pass at flow rates of 10–60 GPM, producing clean oil suitable for resale, re-refining, or fuel blending." }
      },
      {
        "@type": "Question",
        "name": "What is the difference between waste oil recovery and re-refining?",
        "acceptedAnswer": { "@type": "Answer", "text": "Waste oil recovery (also called re-processing) cleans used oil by removing water and solids, producing a product suitable for fuel blending or industrial heating. Re-refining is a more intensive process that restores used oil to base oil quality suitable for lubricant production. Both processes use disc stack centrifuges, but re-refining requires additional treatment steps." }
      },
      {
        "@type": "Question",
        "name": "Can Dolphin Centrifuge systems process black diesel?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Black diesel — a fuel blend made from used motor oil and diesel — contains high carbon and soot concentrations that require centrifugal removal for reuse as burner fuel. Dolphin's disc stack centrifuges are specifically configured for high-carbon-content fuels, removing soot and water at 10–30 GPM." }
      },
      {
        "@type": "Question",
        "name": "What flow rate do I need for a used oil collection business?",
        "acceptedAnswer": { "@type": "Answer", "text": "For used oil collectors processing 500–2,000 gallons per day, a centrifuge sized at 15–30 GPM (like the DMPX-042) is typically appropriate. Larger re-refiners processing 5,000+ gallons per day may require multiple units or the DMPX-070. Dolphin Centrifuge engineers will size your system based on your daily volume and desired processing cycle time." }
      },
      {
        "@type": "Question",
        "name": "Does Dolphin Centrifuge supply complete used oil processing systems?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Dolphin Centrifuge supplies complete turnkey used oil processing systems including the 3-phase disc stack centrifuge, feed pump, electric or steam heater, pre-strainer, flow controls, sludge tank, and PLC panel. Systems are factory-tested at our Warren, MI facility and shipped ready for field connection." }
      }
    ]
  }
];

const toc = [
  { id: "ai-summary", label: "Overview" },
  { id: "why-centrifuges-for-used-motor-oil", label: "Why Centrifuges for Used Motor Oil" },
  { id: "waste-oil-recovery", label: "Waste Oil Recovery" },
  { id: "used-oil-re-refining", label: "Used Oil Re-Refining" },
  { id: "black-diesel-cleaning", label: "Black Diesel Cleaning" },
  { id: "general-oil-separation", label: "General Oil Separation" },
  { id: "choosing-the-right-system", label: "Choosing the Right System" },
  { id: "faq", label: "Frequently Asked Questions" },
];
---

<ApplicationLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  category="applications"
  categoryLabel="Used Motor Oil Applications"
  heroImage="/images/waste-oil-centrifuge/Industrial-Centrifuge-Systems-for-Waste-Oil.webp"
  heroImageAlt="Industrial centrifuge systems for used motor oil and waste oil recovery by Dolphin Centrifuge"
  toc={toc}
  relatedApplications={[
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
    { label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/" },
    { label: "Used Oil Re-Refining Centrifuge", href: "/used-oil-re-refining-plant-centrifuge/" },
  ]}
  relatedProducts={[
    { label: "DMPX-042 Disc Centrifuge", href: "/centrifuges/dmpx-042/" },
    { label: "DMPX-070 Disc Centrifuge", href: "/centrifuges/dmpx-070/" },
  ]}
  jsonLd={jsonLd}
>
  <article class="prose-dolphin max-w-none">

    <!-- AI Summary -->
    <div id="ai-summary" class="bg-navy/5 border-l-4 border-gold/40 rounded-r-lg p-4 mb-6 not-prose">
      <p class="text-sm text-gray-600 leading-relaxed italic">Dolphin Centrifuge supplies three-phase disc stack centrifuge systems for used motor oil recovery, re-refining, and black diesel cleaning. Operating at up to 8,000 G, these systems process 10–60 GPM continuously — removing water, sludge, metals, and carbon to produce clean, sale-ready product. Based in Warren, Michigan, with 40+ years of waste oil separation expertise across fleet services, re-refiners, and fuel blenders.</p>
    </div>

    <p>Our <a href="/disc-stack-centrifuge/">disc stack centrifuges</a> turn dirty waste oil into clean, sale-ready product. Whether you collect used motor oil, process black diesel, or re-refine industrial lubricants, Dolphin Centrifuge has a proven system for your operation.</p>

    <h2 id="why-centrifuges-for-used-motor-oil">Why Centrifuges for Used Motor Oil</h2>
    <p>Used motor oil contains water, sludge, metals, and carbon particles that must be removed before the oil can be sold, re-refined, or blended into fuel. Traditional filtration struggles with sub-micron contaminants and high volumes. <a href="/disc-stack-centrifuge/">Disc stack centrifuges</a> use up to 8,000 G-force to separate these contaminants continuously at flow rates of 10–60 GPM — far outperforming filters in both speed and cleanliness.</p>
    <p>Dolphin Centrifuge provides turnkey <a href="/centrifuge-systems/">centrifuge systems</a> that include heaters, feed pumps, piping, and controls — ready to plug into your existing process.</p>

    <h2 id="waste-oil-recovery">Waste Oil Recovery</h2>
    <p><strong>3-Phase Oil Recovery</strong> — Recover clean, sale-ready oil from collected waste oil streams. Our 3-phase disc stack centrifuges remove water, sludge, and metals down to 1 micron. Processing capacity ranges from 10 to 50 GPM depending on the centrifuge model selected.</p>
    <p>The <a href="/waste-oil-centrifuge/">waste oil centrifuge</a> application is the most popular configuration in our used motor oil lineup. Customers typically see payback in under 12 months through recovered oil sales.</p>

    <h2 id="used-oil-re-refining">Used Oil Re-Refining</h2>
    <p><strong>Re-Refining &amp; Fuel Blending</strong> — Process used motor oil, transmission fluid, and industrial lubricants for re-refining or fuel blending. The centrifuge removes ash, metals, and water to produce a clean feedstock.</p>
    <p>For dedicated re-refining operations, visit our <a href="/used-oil-re-refining-plant-centrifuge/">used oil re-refining centrifuge</a> page for detailed system specifications and process flow diagrams. Capacities range from 10 to 50 GPM.</p>

    <h2 id="black-diesel-cleaning">Black Diesel Cleaning</h2>
    <p><strong>Soot &amp; Carbon Removal</strong> — Clean black diesel and soot-laden fuels for reuse as burner fuel. Disc stack centrifuges remove carbon, water, and heavy contaminants at flow rates of 10–30 GPM.</p>
    <p>Learn more about our <a href="/black-diesel-centrifuge/">black diesel centrifuge</a> systems, which are specifically configured for high-carbon-content fuels.</p>

    <!-- Mid-Page CTA -->
    <div class="not-prose my-10 bg-gold/10 border border-gold/40 rounded-xl p-6 md:p-8">
      <h3 class="text-xl font-bold text-navy mb-2">Turn Waste Oil Into Profitable Product</h3>
      <p class="text-gray-700 mb-4">Our 3-phase disc stack centrifuges pay back in under 12 months through recovered oil sales. Send us a sample of your waste oil — we'll confirm separation performance before you buy.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/industrial-centrifuge-sample-testing/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold/90 text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Free Sample Testing</a>
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-navy hover:bg-navy/90 text-white font-bold text-sm px-6 py-3 rounded-lg transition-colors">Get a Free Quote</a>
      </div>
    </div>

    <h2 id="general-oil-separation">General Oil Separation</h2>
    <p><strong>Versatile Oil Purification</strong> — Beyond motor oil, our centrifuges handle a wide range of petroleum and bio-based oils. Whether you need to purify, clarify, or polish oil at 5–60 GPM, Dolphin has a solution.</p>
    <p>See our full <a href="/oil-centrifuge/">oil centrifuge</a> overview for the complete range of oil separation applications we support.</p>

    <h2 id="choosing-the-right-system">Choosing the Right System</h2>
    <p>The right centrifuge depends on your feedstock, throughput requirements, and end-product specifications. Key factors include:</p>
    <ul>
      <li><strong>Flow rate</strong> — Match centrifuge capacity to your daily volume</li>
      <li><strong>Contaminant load</strong> — Heavy sludge requires a self-cleaning (DMPX series) bowl design</li>
      <li><strong>Water content</strong> — High water content calls for a 3-phase separator</li>
      <li><strong>End-product spec</strong> — Re-refining demands tighter separation than fuel blending</li>
    </ul>
    <p>Our engineers will help you select and size the right system. <a href="/contact-for-alfa-laval-centrifuges/">Contact us</a> for a free consultation, or call <strong>(248) 522-2573</strong> to speak with a specialist today.</p>

    <!-- FAQ Section -->
    <h2 id="faq">Frequently Asked Questions</h2>

    <details class="border-l-4 border-gold/40 pl-4 mb-4">
      <summary class="font-semibold text-navy cursor-pointer py-2">How does a centrifuge clean used motor oil?</summary>
      <p class="mt-2 text-gray-700">A disc stack centrifuge processes used motor oil at up to 8,000 G-force, separating water, sludge, wear metals, and carbon particles from the clean oil phase. The three-phase design simultaneously removes both water and solids in a single continuous pass at flow rates of 10–60 GPM, producing clean oil suitable for resale, re-refining, or fuel blending.</p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4">
      <summary class="font-semibold text-navy cursor-pointer py-2">What is the difference between waste oil recovery and re-refining?</summary>
      <p class="mt-2 text-gray-700">Waste oil recovery (also called re-processing) cleans used oil by removing water and solids, producing a product suitable for fuel blending or industrial heating. Re-refining is a more intensive process that restores used oil to base oil quality suitable for lubricant production. Both processes use disc stack centrifuges, but re-refining requires additional treatment steps.</p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4">
      <summary class="font-semibold text-navy cursor-pointer py-2">Can Dolphin Centrifuge systems process black diesel?</summary>
      <p class="mt-2 text-gray-700">Yes. Black diesel — a fuel blend made from used motor oil and diesel — contains high carbon and soot concentrations that require centrifugal removal for reuse as burner fuel. Dolphin's disc stack centrifuges are specifically configured for high-carbon-content fuels, removing soot and water at 10–30 GPM.</p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4">
      <summary class="font-semibold text-navy cursor-pointer py-2">What flow rate do I need for a used oil collection business?</summary>
      <p class="mt-2 text-gray-700">For used oil collectors processing 500–2,000 gallons per day, a centrifuge sized at 15–30 GPM (like the DMPX-042) is typically appropriate. Larger re-refiners processing 5,000+ gallons per day may require multiple units or the DMPX-070. Dolphin Centrifuge engineers will size your system based on your daily volume and desired processing cycle time.</p>
    </details>

    <details class="border-l-4 border-gold/40 pl-4 mb-4">
      <summary class="font-semibold text-navy cursor-pointer py-2">Does Dolphin Centrifuge supply complete used oil processing systems?</summary>
      <p class="mt-2 text-gray-700">Yes. Dolphin Centrifuge supplies complete turnkey used oil processing systems including the 3-phase disc stack centrifuge, feed pump, electric or steam heater, pre-strainer, flow controls, sludge tank, and PLC panel. Systems are factory-tested at our Warren, MI facility and shipped ready for field connection.</p>
    </details>

  </article>

  <!-- Bottom CTA Bar -->
  <div class="not-prose mt-10 bg-navy rounded-xl p-8 text-white text-center">
    <h3 class="text-2xl font-bold mb-2">Turn Your Waste Oil Into Revenue</h3>
    <p class="text-white/80 mb-6 max-w-xl mx-auto">3-phase disc stack centrifuges for waste oil, re-refining, and black diesel. Turnkey systems. Payback under 12 months. 150+ units in stock in Warren, MI.</p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold/90 text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Free Quote</a>
      <a href="/waste-oil-centrifuge/" class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-3 rounded-lg transition-colors border border-white/20">Waste Oil Centrifuge Details</a>
      <a href="tel:2485222573" class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-3 rounded-lg transition-colors border border-white/20">(248) 522-2573</a>
    </div>
  </div>
</ApplicationLayout>
