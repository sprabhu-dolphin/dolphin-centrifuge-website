---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Oil & Fuel Centrifuge Applications";
const description = "Industrial centrifuge systems for waste oil recovery, fuel purification, lube oil cleaning, and crude oil processing. Proven solutions from Dolphin Centrifuge.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": "https://dolphincentrifuge.com/applications/oil-fuel/",
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
};

const applications = [
  {
    title: "Waste Oil Centrifuge",
    href: "/waste-oil-centrifuge/",
    image: "/images/applications/waste-oil-centrifuge-hero.jpg",
    description: "Recover clean, sale-ready oil from collected waste oil streams. Our 3-phase disc stack centrifuges remove water, sludge, and metals down to 1 micron — producing oil that meets burner-fuel or re-refining specs.",
    capacity: "10–50 GPM",
    tag: "Most Popular",
  },
  {
    title: "Used Oil Centrifuge",
    href: "/used-oil-centrifuge/",
    image: "/images/applications/used-oil-centrifuge-hero.jpg",
    description: "Process used motor oil, transmission fluid, and industrial lubricants for re-refining or fuel blending. Centrifugal separation removes ash, metals, and water that gravity settling cannot.",
    capacity: "10–50 GPM",
  },
  {
    title: "Lube Oil Centrifuge",
    href: "/lube-oil-centrifuge/",
    image: "/images/applications/lube-oil-centrifuge-hero.jpg",
    description: "Extend lubricant life by continuously removing wear metals, oxidation products, and moisture. Kidney-loop centrifuge systems keep ISO cleanliness codes within OEM specifications.",
    capacity: "5–30 GPM",
  },
  {
    title: "Hydraulic Oil Centrifuge",
    href: "/hydraulic-oil-centrifuge/",
    image: "/images/applications/hydraulic-oil-centrifuge-hero.jpg",
    description: "Maintain hydraulic fluid cleanliness to prevent valve sticking, pump wear, and unplanned downtime. Particularly critical for extrusion presses and heavy machinery.",
    capacity: "5–30 GPM",
  },
  {
    title: "Diesel Fuel Centrifuge",
    href: "/diesel-centrifuge/",
    image: "/images/applications/diesel-centrifuge-hero.jpg",
    description: "Remove water, particulates, and asphaltenes from diesel fuel. Essential for bulk storage, fleet operations, and generator fuel systems where clean fuel prevents injector failures.",
    capacity: "10–40 GPM",
  },
  {
    title: "Fuel Oil / HFO Centrifuge",
    href: "/fuel-oil-centrifuge/",
    image: "/images/applications/fuel-oil-centrifuge-hero.jpg",
    description: "Purify heavy fuel oil, bunker fuel, and residual fuel oils. High-temperature centrifugal separation removes cat fines, water, and sludge to meet combustion specifications.",
    capacity: "10–60 GPM",
  },
  {
    title: "Crude Oil Centrifuge",
    href: "/crude-oil-centrifuge/",
    image: "/images/applications/crude-oil-centrifuge-hero.jpg",
    description: "Recover sale oil from tank bottoms, slop oil, and production waste streams. Our Oil Recovery Systems (ORS) process crude to less than 0.5% BS&W.",
    capacity: "15–60 GPM",
  },
  {
    title: "Black Diesel Centrifuge",
    href: "/black-diesel-centrifuge/",
    image: "/images/applications/black-diesel-centrifuge-hero.jpg",
    description: "Clean black diesel and soot-laden fuels for reuse as burner fuel. Disc stack centrifuges remove carbon particles, water, and heavy contaminants efficiently.",
    capacity: "10–30 GPM",
  },
  {
    title: "WVO / Used Cooking Oil",
    href: "/wvo-centrifuge-separator/",
    image: "/images/applications/wvo-centrifuge-hero.jpg",
    description: "Purify waste vegetable oil, yellow grease, and restaurant fryer oil for biodiesel feedstock or direct sale. Remove free fatty acids, water, and food particles.",
    capacity: "15–40 GPM",
  },
  {
    title: "Oil Centrifuge (General)",
    href: "/oil-centrifuge/",
    image: "/images/applications/oil-centrifuge-hero.jpg",
    description: "Overview of all oil separation applications. Whether you need to purify, clarify, or polish any petroleum or bio-based oil — we have a centrifuge solution.",
    capacity: "5–60 GPM",
  },
];
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbs={[{ label: "Applications", href: "/applications/" }, { label: "Oil & Fuel" }]}
  jsonLd={jsonLd}
>
  {/* Hero */}
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16 lg:py-20">
      <div class="max-w-3xl">
        <span class="inline-block text-gold text-xs font-bold tracking-wider uppercase mb-3">Applications</span>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading leading-tight mb-4">Oil & Fuel Centrifuge Applications</h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-6 max-w-2xl">
          From waste oil recovery to crude oil tank bottom processing, our industrial centrifuge systems handle every oil and fuel purification challenge. Proven across 40+ years and hundreds of installations worldwide.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">
            Get a Free Quote
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
          <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            (248) 522-2573
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Application Cards Grid */}
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {applications.map((app) => (
          <a href={app.href} class="group bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg hover:border-gold/40 transition-all duration-300 overflow-hidden flex flex-col">
            {/* Image */}
            <div class="relative h-48 bg-light-bg overflow-hidden">
              <div class="absolute inset-0 bg-navy/5 flex items-center justify-center">
                <svg class="w-16 h-16 text-navy/10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              {app.tag && (
                <span class="absolute top-3 left-3 bg-gold text-navy text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">{app.tag}</span>
              )}
              {app.capacity && (
                <span class="absolute bottom-3 right-3 bg-navy/80 text-white text-xs font-mono px-2 py-1 rounded">{app.capacity}</span>
              )}
            </div>
            {/* Content */}
            <div class="p-5 flex-1 flex flex-col">
              <h3 class="text-lg font-bold font-heading text-navy group-hover:text-gold-dark transition-colors mb-2">{app.title}</h3>
              <p class="text-sm text-text-light leading-relaxed flex-1">{app.description}</p>
              <div class="mt-4 flex items-center gap-1 text-gold font-semibold text-sm">
                Learn More
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Bottom CTA */}
  <section class="bg-white border-t border-gray-200">
    <div class="container-dolphin py-12 md:py-16">
      <div class="bg-navy rounded-2xl p-8 md:p-10 text-white text-center md:text-left md:flex md:items-center md:justify-between">
        <div class="mb-6 md:mb-0">
          <h3 class="text-xl md:text-2xl font-bold font-heading mb-2">Not sure which centrifuge fits your oil?</h3>
          <p class="text-gray-300 text-sm">Send us a sample — our engineers will test it and recommend the right system.</p>
        </div>
        <div class="flex flex-wrap justify-center md:justify-end gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Get a Free Quote</a>
          <a href="/industrial-centrifuge-sample-testing/" class="inline-flex items-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">Sample Testing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
