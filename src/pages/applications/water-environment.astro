---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Water & Environmental Centrifuges";
const description = "Industrial centrifuges for wastewater treatment, algae harvesting, manure separation, biodiesel production, and liquid humus fertilizer processing.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": "https://dolphincentrifuge.com/applications/water-environment/",
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
};

const applications = [
  {
    title: "Wastewater Centrifuge",
    href: "/wastewater-centrifuge/",
    image: "/images/applications/wastewater-centrifuge-hero.jpg",
    description: "Disc stack and decanter centrifuges for municipal and industrial wastewater treatment. Remove suspended solids, oils, and sludge to meet discharge permit requirements. Operating at up to 12,000 Gs for superior clarification.",
    capacity: "20–80 GPM",
    tag: "Most Popular",
  },
  {
    title: "Algae Harvesting Centrifuge",
    href: "/algae-centrifuge/",
    image: "/images/applications/algae-centrifuge-hero.jpg",
    description: "Harvest algae cells from water at industrial scale using self-cleaning disc stack centrifuges. Process 5–100+ GPM continuously with automatic biomass ejection. Stainless steel construction handles saltwater algae.",
    capacity: "5–100+ GPM",
  },
  {
    title: "Manure Centrifuge Separator",
    href: "/manure-centrifuge-separator/",
    image: "/images/applications/manure-centrifuge-hero.jpg",
    description: "Separate manure into dry solids and nutrient-rich liquid using decanter centrifuges. Reduce storage volumes, cut transportation costs, and produce high-value fertilizer. Solids achieve 50%+ dryness.",
    capacity: "25+ GPM",
  },
  {
    title: "Biodiesel Centrifuge",
    href: "/biodiesel-centrifuge/",
    image: "/images/applications/biodiesel-centrifuge-hero.jpg",
    description: "Wash and polish biodiesel to ASTM D6751 specifications. Remove glycerin, soap, water, and catalyst residue. Continuous centrifugal processing eliminates settling tanks and water wash systems.",
    capacity: "10–40 GPM",
  },
  {
    title: "Liquid Humus Centrifuge",
    href: "/liquid-humus-centrifuge/",
    image: "/images/applications/liquid-humus-centrifuge-hero.jpg",
    description: "Produce liquid humus fertilizer at commercial scale. Decanter centrifuges separate humus biomass from nutrient-rich water, while disc stack polishers clarify the final liquid humate product.",
    capacity: "15–40 GPM",
  },
];
---

<BaseLayout title={title} description={description} breadcrumbs={[{ label: "Applications", href: "/applications/" }, { label: "Water & Environment" }]} jsonLd={jsonLd}>
  {/* Hero */}
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16 lg:py-20">
      <div class="max-w-3xl">
        <span class="inline-block text-gold text-xs font-bold tracking-wider uppercase mb-3">Applications</span>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading leading-tight mb-4">Water & Environmental Applications</h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-6 max-w-2xl">
          Efficient centrifuge solutions for wastewater treatment, biomass harvesting, agricultural waste processing, and renewable fuel production. Reduce disposal costs and turn waste streams into valuable products.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">
            Get a Free Quote
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
          <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            (248) 522-2573
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Application Cards */}
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {applications.map((app) => (
          <a href={app.href} class="group bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg hover:border-gold/40 transition-all duration-300 overflow-hidden flex flex-col">
            <div class="relative h-48 bg-light-bg overflow-hidden">
              <div class="absolute inset-0 bg-navy/5 flex items-center justify-center">
                <svg class="w-16 h-16 text-navy/10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              {app.tag && <span class="absolute top-3 left-3 bg-gold text-navy text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">{app.tag}</span>}
              {app.capacity && <span class="absolute bottom-3 right-3 bg-navy/80 text-white text-xs font-mono px-2 py-1 rounded">{app.capacity}</span>}
            </div>
            <div class="p-5 flex-1 flex flex-col">
              <h3 class="text-lg font-bold font-heading text-navy group-hover:text-gold-dark transition-colors mb-2">{app.title}</h3>
              <p class="text-sm text-text-light leading-relaxed flex-1">{app.description}</p>
              <div class="mt-4 flex items-center gap-1 text-gold font-semibold text-sm">
                Learn More
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Bottom CTA */}
  <section class="bg-white border-t border-gray-200">
    <div class="container-dolphin py-12 md:py-16">
      <div class="bg-navy rounded-2xl p-8 md:p-10 text-white text-center md:text-left md:flex md:items-center md:justify-between">
        <div class="mb-6 md:mb-0">
          <h3 class="text-xl md:text-2xl font-bold font-heading mb-2">Have a unique separation challenge?</h3>
          <p class="text-gray-300 text-sm">Send us a sample — our lab will test it and recommend the optimal centrifuge system.</p>
        </div>
        <div class="flex flex-wrap justify-center md:justify-end gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Get a Free Quote</a>
          <a href="/industrial-centrifuge-sample-testing/" class="inline-flex items-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">Sample Testing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
