---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval MAB 104 Centrifuge",
  "description": "Alfa Laval MAB 104 solid-retaining manual-clean disc-stack centrifuge. 2 HP, 8,100 RPM, 6 GPM on diesel fuel. Specs, dimensions, applications, modifications, and operation.",
  "brand": {
    "@type": "Brand",
    "name": "Alfa Laval"
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "telephone": "(248) 522-2573",
    "email": "sales@dolphincentrifuge.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "24248 Gibson Dr",
      "addressLocality": "Warren",
      "addressRegion": "MI",
      "postalCode": "48089"
    }
  },
  "model": "MAB 104 B 24-60",
  "url": "https://dolphincentrifuge.com/alfa-laval-mab-104-centrifuge/",
  "offers": {
    "@type": "Offer",
    "seller": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the capacity of the Alfa Laval MAB 104 centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Alfa Laval MAB 104 centrifuge can process 6 GPM of 13 cSt diesel fuel, 5 GPM of turbine lube oil, or 4 GPM of hydraulic oil. The WSB 104 variant processes 2 GPM of water-based synthetic coolant."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between the MAB 104 and the WSB 104?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The MAB 104 is a purifier designed to separate water and sediment from mineral oils and fuels. The WSB 104 is a concentrator version designed specifically for water-based industrial fluids like machining coolant and washer fluid. The WSB 104 features all-stainless-steel bowl components and cast iron top covers instead of aluminum alloy."
      }
    },
    {
      "@type": "Question",
      "name": "Can the MAB 104 be used in explosion-proof environments?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The MAB 104 can be configured for explosion-proof operation with modifications including direct drive (replacing friction clutch) and non-sparking friction blocks. For offshore applications, it is configured similar to the OCM-104-Ex configuration with explosion-proof ATEX Zone II."
      }
    },
    {
      "@type": "Question",
      "name": "What modifications are available for the MAB 104?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Common modifications include explosion-proof configuration (direct drive, non-sparking friction blocks), pump reconfiguration for different fluids, seal elastomer changes (Viton/EPDM) for biodiesel or corrosive chemicals, gear pump replacement for water-based fluids, frequency conversion, single-phase motor adaptation, bowl parts material upgrade to stainless steel, and purifier-to-clarifier conversion."
      }
    }
  ]
};
