import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqItems = [
  {
    question: "What is the capacity of the Alfa Laval MAB 104 centrifuge?",
    answer: "The Alfa Laval MAB 104 centrifuge can process 6 GPM of 13 cSt diesel fuel, 5 GPM of turbine lube oil, or 4 GPM of hydraulic oil. The WSB 104 variant processes 2 GPM of water-based synthetic coolant. Actual capacity depends on fluid viscosity, contamination levels, and desired separation quality."
  },
  {
    question: "What is the difference between the MAB 104 and the WSB 104?",
    answer: "The MAB 104 is a purifier designed to separate water and sediment from mineral oils and fuels such as diesel, lube oil, and hydraulic oil. The WSB 104 is a concentrator version designed specifically for water-based industrial fluids like machining coolant and washer fluid. A key construction difference is that the WSB 104 features all-stainless-steel bowl components (distributor and top disc are 316L Duplex Stainless Steel) and cast iron top covers instead of the aluminum alloy (Silium) covers used on the MAB 104."
  },
  {
    question: "Can the MAB 104 be used in explosion-proof environments?",
    answer: "Yes. The MAB 104 can be configured for explosion-proof operation with modifications including direct drive (replacing the friction clutch) and non-sparking friction blocks. For offshore applications, it is configured similar to the OCM-104-Ex configuration with explosion-proof ATEX Zone II certification. Dolphin Centrifuge regularly supplies explosion-proof MAB 104 modules for offshore platforms and refineries."
  },
  {
    question: "What modifications are available for the MAB 104?",
    answer: "Common modifications include explosion-proof configuration (direct drive, non-sparking friction blocks), pump reconfiguration for different fluid viscosities, seal elastomer changes (Viton or EPDM) for biodiesel or corrosive chemicals, gear pump replacement for water-based fluids, operating frequency conversion (50 or 60 Hz), single-phase motor adaptation (110 V or 220 V), bowl parts material upgrade to stainless steel for aqueous ammonia applications, and purifier-to-clarifier conversion to change from three-phase to two-phase separation mode."
  },
  {
    question: "What is the Dolphin Centrifuge equivalent of the Alfa Laval MAB 104?",
    answer: "The Dolphin DMB-007 is the functional equivalent of the Alfa Laval MAB 104 centrifuge. The DMB-007 is a complete system module rated at 6–8 GPM on diesel, built around the same centrifuge bowl size as the MAB 104. The module includes a pre-heater, feed pump, PLC controls, and starter in a skid-mounted package. Contact Dolphin Centrifuge at (248) 522-2573 for specs and pricing."
  }
];

