---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "url": "https://dolphincentrifuge.com/fish-processing-centrifuge/",
  "name": "Fish Processing Centrifuge System",
  "description": "Industrial centrifuges for fish oil and fish meal production. Tricanter, decanter, and disc-stack centrifuge systems for surimi and hydrolyzed fish protein.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a fish oil processing centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A fish oil processing centrifuge is an industrial centrifuge that separates fish oil and fish meal from process water (stick water). It uses high centrifugal force to separate the three phases — fish oil, stick water, and protein — from inedible fish processing residue such as skin, guts, heads, bones, offal, and fins."
      }
    },
    {
      "@type": "Question",
      "name": "What is a tricanter centrifuge used for in fish processing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A tricanter (three-phase decanter centrifuge) separates oil, water, and solids simultaneously. In fish processing, it processes the strained liquid phase to separate remaining fish meal from stick water and fish oil. However, it generates lower centrifugal force than a disc-stack centrifuge, which may limit separation efficiency."
      }
    },
    {
      "@type": "Question",
      "name": "What is surimi and how is a centrifuge used in surimi production?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Surimi is a refined white fish paste used in imitation seafood products like imitation lobster, crab meat, and fish balls. An Alfa Laval decanter centrifuge replaces the traditional screw press in surimi production, eliminating several washing steps and achieving recovery rates over 70% from feedstock — significantly higher than the 50% yield from traditional methods."
      }
    },
    {
      "@type": "Question",
      "name": "What centrifuge models are used for fish meal processing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Common fish meal centrifuge models include the Alfa Laval FPNX 309 decanter (10 GPM capacity, 5 HP motor), Alfa Laval UVNX 314 tricanter (40 GPM capacity, 10 HP motor), and Alfa Laval NX 418 tricanter (80 GPM capacity, 20 HP motor). The NX 418 is ideal for processing up to 8 tons per hour of minced fish and water mix."
      }
    },
    {
      "@type": "Question",
      "name": "What is hydrolyzed fish protein and how are centrifuges used to produce it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Hydrolyzed fish protein (FPH) is produced when enzymes break down fish processing byproducts into Fish Protein Hydrolysates. Alfa Laval decanter centrifuges dewater the reacted fish protein slurry at controlled temperatures, while a food-grade three-phase disc centrifuge such as the Alfa Laval AFPX213 Purifier separates fish oil before the enzyme reaction step."
      }
    }
  ]
};

const faqItems = [
