---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqItems = [
  {
    question: "What is an industrial centrifuge used for?",
    answer: "An industrial centrifuge separates solids from liquids and immiscible liquids from each other using centrifugal force thousands of times that of gravity. Applications include waste oil purification, wastewater treatment, biodiesel production, food processing, chemical manufacturing, pharmaceutical production, and metalworking coolant recycling."
  },
  {
    question: "How much does an industrial centrifuge cost?",
    answer: "Small filtration-type centrifuges from established manufacturers start at approximately $30K, while high-capacity units can exceed $300K. Remanufactured units typically cost 60% of comparable new filtration centrifuges. Small decanter centrifuges start around $50K; high-capacity decanters can exceed $1M. Contact Dolphin Centrifuge for a quote on your specific application."
  },
  {
    question: "What is the difference between a decanter and a disc stack centrifuge?",
    answer: "Both are solid bowl (sedimentation) centrifuges. A decanter centrifuge uses a scroll (auger) to continuously push separated solids out of the bowl and handles high solids loads (up to 40%+ solids). A disc stack centrifuge uses a stack of conical discs to achieve very high g-forces (up to 12,000 Gs) for fine particle and liquid-liquid separation, ideal for clarification and 3-phase separation."
  },
  {
    question: "What centrifugal force (G-force) do industrial centrifuges generate?",
    answer: "Sedimentation-type centrifuges generate 3,000 to 12,000 Gs of centrifugal force. Filtration-type centrifuges typically operate below 2,000 Gs. The higher the G-force, the finer the particles that can be separated — down to 0.5 microns in high-speed disc stack centrifuges."
  },
  {
    question: "What capacity (GPM) do industrial centrifuges handle?",
    answer: "Decanter centrifuges process 5 to 300+ gallons per minute. Industrial disc stack centrifuges handle 1 to 200+ GPM. The actual capacity depends on the process fluid, viscosity, temperature, and solids concentration. Contact Dolphin Centrifuge for sizing guidance."
  },
  {
    question: "What is the difference between filtration and sedimentation centrifuges?",
    answer: "A filtration centrifuge has a perforated bowl that allows the liquid to pass through while retaining solids — similar to a screen or filter. A sedimentation centrifuge has a solid bowl that uses differential settling under centrifugal force to separate solids from liquids. Sedimentation centrifuges generate higher G-forces (3,000–10,000 Gs vs. less than 2,000 Gs) and can separate finer particles."
  },
  {
    question: "How long do industrial centrifuges last?",
    answer: "Industrial centrifuges from quality OEM manufacturers are heavy-duty machines with an expected life expectancy of 30+ years. With proper maintenance and periodic overhauls, many centrifuges remain in service for decades. Dolphin Centrifuge specializes in remanufacturing centrifuges to extend their operational life even further."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Industrial Centrifuge Systems",
  "url": "https://dolphincentrifuge.com/industrial-centrifuge/",
  "description": "Comprehensive industrial centrifuge systems: disc stack and decanter separators for liquid-solid and liquid-liquid separation across oil, water, food, and chemical processing industries.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "image": "https://dolphincentrifuge.com/images/industrial-centrifuge/Industrial-Centrifuge-Systems-for-Waste-Oil.webp",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const jsonLd = [productJsonLd, faqJsonLd];

const toc = [
  { id: 'what-is', label: 'What is an Industrial Centrifuge?' },
  { id: 'types', label: 'Types of Industrial Centrifuges' },
  { id: 'difference', label: 'Filtration vs Sedimentation' },
  { id: 'capacity', label: 'Capacity' },
  { id: 'size', label: 'Size' },
  { id: 'cost', label: 'Cost' },
  { id: 'manufacturers', label: 'Manufacturers' },
  { id: 'faq', label: 'FAQ' },
  { id: 'applications', label: 'Applications' },
  { id: 'benefits', label: 'Benefits' },
  { id: 'summary', label: 'Summary' },
];

const relatedApplications = [
  { label: 'Disc Stack Centrifuge Applications', href: '/disc-stack-centrifuge-applications/' },
  { label: 'Waste Oil Centrifuge', href: '/waste-oil-centrifuge/' },
  { label: 'Wastewater Centrifuge', href: '/wastewater-centrifuge/' },
  { label: 'Biodiesel Centrifuge', href: '/biodiesel-centrifuge/' },
];

const relatedProducts = [
  { label: 'Disc Stack Centrifuge', href: '/disc-stack-centrifuge/', description: 'High-speed disc stack separators — up to 12,000 Gs' },
  { label: 'Decanter Centrifuge', href: '/decanter-centrifuge/', description: 'Scroll-type decanters for high-solids slurries' },
  { label: 'Centrifuge Selection Guide', href: '/alfa-laval-centrifuge-selection-guide/', description: 'Match the right centrifuge to your application' },
];
---

<ApplicationLayout
  title="Industrial Centrifuge | Types, Applications, Cost & Benefits | Dolphin Centrifuge"
  description="Industrial centrifuges for liquid-solid and liquid-liquid separation: disc stack and decanter types, 1-300+ GPM, 3,000-12,000 Gs. Dolphin Centrifuge."
  heroImage="/images/industrial-centrifuge/Industrial-Centrifuge-Systems-for-Waste-Oil.webp"
  heroImageAlt="Industrial Centrifuge Systems for Waste Oil — Dolphin Centrifuge"
  category="products"
  categoryLabel="Products"
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
  canonicalUrl="https://dolphincentrifuge.com/industrial-centrifuge/"
  jsonLd={jsonLd}
>

  <!-- AI Summary -->
  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies industrial disc stack and decanter centrifuge systems for liquid-solid and liquid-liquid separation at 3,000 to 12,000 Gs. Processing 1 to 300+ GPM across oil, wastewater, food, and chemical industries without filter media. Warren, Michigan — over 40 years of experience.</p>
  </div>

  <!-- ══ What is an Industrial Centrifuge? ══ Pattern A: Image + Text side by side -->
  <div id="what-is" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">What is an Industrial Centrifuge?</h2>
    <div class="flex flex-col md:flex-row gap-6 items-start">
      <div class="md:w-2/5 shrink-0">
        <img
          src="/images/industrial-centrifuge/Industrial-Centrifuge-Systems-for-Waste-Oil.webp"
          alt="Industrial Centrifuge Systems for Waste Oil — Dolphin Centrifuge"
          width="600"
          height="300"
          loading="lazy"
          class="rounded-lg shadow-sm w-full object-cover"
        />
        <p class="text-gray-500 text-sm mt-1 text-center">Industrial Centrifuge Systems for Waste Oil</p>
      </div>
      <div>
        <p class="text-[#2D2D2D] text-lg font-semibold mb-4">
          An industrial centrifuge is a separation machine that uses centrifugal force to separate solids from liquids. A centrifuge exerts a centrifugal force that is thousands of times that of gravity.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          This force causes the immediate separation of solids from liquids. And, in the case of immiscible liquids with different densities, it separates the fluids as well.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          You can think of an industrial centrifuge as a scaled-up version of a lab centrifuge (test tube) except at a much bigger scale with a flow-through design.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          That means the separated solids and liquid(s) continuously exit the centrifuge. This continuous flow-through design enables high-capacity, uninterrupted operation without the downtime associated with batch-style filtration or manual separation methods.
        </p>
        <p class="text-[#2D2D2D]">
          Industrial centrifuges are used across virtually every processing industry — from <a href="/waste-oil-centrifuge/" class="text-navy underline hover:text-gold-dark">waste oil recovery</a> and <a href="/wastewater-centrifuge/" class="text-navy underline hover:text-gold-dark">wastewater treatment</a> to food and beverage production, pharmaceutical manufacturing, and chemical processing. Their ability to deliver continuous, reliable separation at high throughput makes them indispensable in modern industrial operations.
        </p>
      </div>
    </div>
  </div>

  <!-- ══ Types of Industrial Centrifuges ══ -->
  <div id="types" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Types of Industrial Centrifuges</h2>
    <p class="text-[#2D2D2D] mb-6">
      Industrial centrifuges fall into two main categories: <strong>Filtration</strong> type and <strong>Sedimentation</strong> type. Each category uses a fundamentally different approach to separation, and the choice between them depends on the nature of the solids, the liquid properties, and the desired separation efficiency.
    </p>

    <!-- Filtration Type — Pattern A side-by-side -->
    <h3 class="text-xl font-bold text-navy mb-3">Filtration Type</h3>
    <div class="flex flex-col md:flex-row gap-6 items-start mb-8">
      <div class="md:w-2/5 shrink-0">
        <img
          src="/images/industrial-centrifuge/Filtration-Centrifuge-600.webp"
          alt="Filtration Centrifuge — Perforated Bowl Design for Solid-Liquid Separation"
          width="600"
          height="243"
          loading="lazy"
          class="rounded-lg shadow-sm w-full object-cover"
        />
      </div>
      <div>
        <p class="text-[#2D2D2D] mb-4">
          A perforated media allows the fluid to exit the 'screen' bowl in a <a href="https://en.wikipedia.org/wiki/Filtration" class="text-navy underline hover:text-gold-dark" target="_blank" rel="noopener">filtration</a> centrifuge while retaining the solids. The separated liquid collects in the bowl casing and drains out.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          A relatively lower rotational speed (lower centrifugal force) is adequate for filtration centrifuges.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          They are suitable for separating large amounts of coarse solids from a liquid. An example would be separating crystallized sugar from syrup or a chemical precipitate from the supernatant.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          There are various mechanisms to collect the separated solids. A description of some of these methods is in the following section.
        </p>
        <p class="text-[#2D2D2D] mb-3">There are a variety of filtration centrifuges.</p>
        <p class="text-[#2D2D2D] mb-3">
          A <strong>peeler centrifuge</strong> has cloth media, which the user 'peels' away with the solids. A <strong>basket centrifuge</strong> has a perforated 'basket' that retains the separated solids.
        </p>
        <p class="text-[#2D2D2D]">
          <strong>Pusher centrifuges</strong> have slotted bowls with an articulated pusher arm to 'push' the accumulated solids. A wire mesh 'screen' holds the solids in <strong>screening centrifuges</strong>.
        </p>
      </div>
    </div>

    <!-- Sedimentation Type — Pattern A side-by-side -->
    <h3 class="text-xl font-bold text-navy mb-3">Sedimentation or Solid Bowl</h3>
    <div class="flex flex-col md:flex-row gap-6 items-start mb-4">
      <div class="md:w-2/5 shrink-0 space-y-4">
        <div>
          <img
            src="/images/industrial-centrifuge/Decanter-Cross-Section-600.webp"
            alt="Decanter Centrifuge Cross Section Diagram showing scroll and bowl"
            width="600"
            height="223"
            loading="lazy"
            class="rounded-lg shadow-sm w-full object-cover"
          />
          <p class="text-gray-500 text-sm mt-1 text-center">Decanter Centrifuge Cross Section Diagram</p>
        </div>
        <div>
          <img
            src="/images/shared/Dewatering-Centrifuge-Animation.gif"
            alt="Dewatering Centrifuge Animation showing scroll separation process"
            width="533"
            height="188"
            loading="lazy"
            class="rounded-lg shadow-sm w-full object-cover"
          />
          <p class="text-gray-500 text-sm mt-1 text-center">Dewatering Centrifuge Animation</p>
        </div>
      </div>
      <div>
        <p class="text-[#2D2D2D] mb-4">
          A sedimentation centrifuge does not use a flow-through or perforated screen or media. This centrifuge uses a solid bowl, which is also known as a 'solid bowl centrifuge.'
        </p>
        <p class="text-[#2D2D2D] mb-4">
          The centrifugal force causes the denser solids to collect along the bowl wall. The lighter liquid thus separates from the solids. A liquid pathway allows the separated fluid to exit the bowl.
        </p>
        <p class="text-[#2D2D2D]">
          This 'solid bowl' feature adds an extra benefit to these sedimentation centrifuges.
        </p>
      </div>
    </div>

    <!-- Disc centrifuge diagrams — Pattern A -->
    <div class="flex flex-col md:flex-row gap-6 items-start mb-4">
      <div class="md:w-2/5 shrink-0 space-y-4">
        <div>
          <img
            src="/images/industrial-centrifuge/alfa-laval-disc-centrifuge-bowl-cross-section-1000-e1614693519387.webp"
            alt="Disc Centrifuge Cross Section Diagram — Bowl Parts and Disc Stack"
            width="600"
            height="334"
            loading="lazy"
            class="rounded-lg shadow-sm w-full object-cover"
          />
          <p class="text-gray-500 text-sm mt-1 text-center">Disc Centrifuge Cross Section Diagram</p>
        </div>
        <div>
          <img
            src="/images/shared/Disc-Centrifuge-Self-Cleaning-Animation-600.gif"
            alt="Disc Centrifuge Self-Cleaning Animation showing solids ejection"
            width="599"
            height="460"
            loading="lazy"
            class="rounded-lg shadow-sm w-full object-cover"
          />
          <p class="text-gray-500 text-sm mt-1 text-center">Disc Centrifuge Self-Cleaning Animation</p>
        </div>
      </div>
      <div>
        <p class="text-[#2D2D2D] mb-4">
          The same <a href="/decanter-centrifuge-differential-speed/" class="text-navy underline hover:text-gold-dark">centrifugal force also causes the differential settling</a> of two immiscible liquids. In this case, the centrifuge separates all three phases, liquid, liquid, and solid. This separator is known as a <strong>3-phase centrifuge</strong>.
        </p>
        <p class="text-[#2D2D2D]">
          Solid bowl centrifuges are further sub-categorized into two types which are <a href="/decanter-centrifuge/" class="text-navy underline hover:text-gold-dark">decanter centrifuges</a> and <a href="/disc-stack-centrifuge/" class="text-navy underline hover:text-gold-dark">disc stack centrifuges</a>.
        </p>
      </div>
    </div>
  </div>

  <!-- ══ Difference Between Filtration and Sedimentation ══ Pattern A -->
  <div id="difference" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Difference Between Filtration and Sedimentation Centrifuges</h2>
    <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
      <div class="md:w-2/5 shrink-0">
        <img
          src="/images/industrial-centrifuge/Filtration-Sedimentation-Centrifuge-Difference-800.webp"
          alt="Filtration and Sedimentation Centrifuge Difference — Comparison Diagram"
          width="800"
          height="283"
          loading="lazy"
          class="rounded-lg shadow-sm w-full object-cover"
        />
        <p class="text-gray-500 text-sm mt-1 text-center">Filtration and Sedimentation Centrifuge Difference</p>
      </div>
      <div>
        <p class="text-[#2D2D2D] mb-4">
          The primary difference between filtration and sedimentation <a href="/industrial-centrifuge-design/" class="text-navy underline hover:text-gold-dark">centrifuges is the bowl design</a>. A filtration centrifuge has a pass-through bowl that allows the liquid to pass through and retain the solids. The sedimentation centrifuge has a solid bowl that uses differential settling to separate the solids from the liquid.
        </p>
        <p class="text-[#2D2D2D] mb-4">The following summarizes the other differences between these two types of centrifuges.</p>
        <p class="text-[#2D2D2D]">
          For more information, please read our detailed article on the <a href="/ethanol-extraction-centrifuges-technical-comparison/" class="text-navy underline hover:text-gold-dark">technical difference between basket (filtration type) and decanter (sedimentation type) centrifuges</a>.
        </p>
      </div>
    </div>

    <!-- Separation Efficiency -->
    <h3 class="text-lg font-bold text-navy mb-2">Separation Efficiency</h3>
    <p class="text-[#2D2D2D] mb-3">
      The particle size efficiency of industrial centrifuges varies in size primarily due to the centrifuge design and other operating parameters such as flow rate, fluid viscosity, centrifugal force, etc.
    </p>
    <p class="text-[#2D2D2D] mb-3">
      The media or mesh perforation size in the filtration-type centrifuge defines the particle size efficiency. Therefore, a filtration centrifuge separates particles bigger than the perforation size in the bowl wall or screen. This separation ability limits the application of filtration-type centrifuges to the preset size of the screen media or mesh size.
    </p>
    <p class="text-[#2D2D2D] mb-3">
      The sedimentation centrifuge, however, uses the centrifugal force for separation. The scroll pushes all the separated solids out of the centrifuge bowl, regardless of size. <strong>Therefore, a solid bowl or sedimentation centrifuge can separate a wide range of particle sizes from the liquid.</strong>
    </p>
    <p class="text-[#2D2D2D] mb-6">
      In general, the particle size efficiency of the sedimentation centrifuge is higher than that of filtration-type centrifuges.
    </p>

    <!-- Gravitational or Centrifugal Force -->
    <h3 class="text-lg font-bold text-navy mb-2">Gravitational or Centrifugal Force</h3>
    <p class="text-[#2D2D2D] mb-3">
      Sedimentation centrifuges use the difference between the specific gravity of the solids and liquids to affect separation. Therefore, these centrifuges exert a high centrifugal force (RCF) for effective separation.
    </p>
    <p class="text-[#2D2D2D] mb-3">
      Filtration-type centrifuges need a lower <a href="https://en.wikipedia.org/wiki/G-force" class="text-navy underline hover:text-gold-dark" target="_blank" rel="noopener">g-force</a> to push the liquid through the bowl perforations.
    </p>
    <p class="text-[#2D2D2D] mb-3">
      Typically the sedimentation-type centrifuges have centrifugal force from <strong>3,000 Gs to 10,000 Gs</strong>, while the filtration-type centrifuges have <strong>less than 2,000 Gs.</strong>
    </p>
    <p class="text-[#2D2D2D] mb-6">
      Read our article about <a href="/centrifuge-rcf-rpm-difference-calculation/" class="text-navy underline hover:text-gold-dark">the difference between RPM and RCF</a>.
    </p>

    <!-- Separated Solids Extraction -->
    <h3 class="text-lg font-bold text-navy mb-2">Separated Solids Extraction</h3>
    <p class="text-[#2D2D2D] mb-3">
      The sedimentation centrifuge ejects the separated solids continuously during sedimentation. A rotating scroll (auger) within the bowl pushes out the separated solids.
    </p>
    <p class="text-[#2D2D2D] mb-6">
      A filtration-type centrifuge accumulates the separated solids, which a scraper scrapes out of the bowl periodically.
    </p>

    <!-- Separated Liquid Discharge -->
    <h3 class="text-lg font-bold text-navy mb-2">Separated Liquid Discharge</h3>
    <p class="text-[#2D2D2D] mb-3">
      The flow-through bowl of the filtration centrifuge allows the liquid to flow out of the bowl. The separated fluid discharges under gravity from the centrifuge vessel.
    </p>
    <p class="text-[#2D2D2D] mb-6">
      The separated fluid in a sedimentation centrifuge rotates at high speed. The built-in pump converts the rotational energy into pressure that discharges the separated liquid under pressure.
    </p>

    <!-- Replaceable Media -->
    <h3 class="text-lg font-bold text-navy mb-2">Replaceable Media</h3>
    <p class="text-[#2D2D2D] mb-3">
      As the name suggests, a filtration centrifuge often uses replaceable filtration media. This media replacement adds to labor and material costs.
    </p>
    <p class="text-[#2D2D2D] mb-6">
      A solid bowl sedimentation centrifuge uses the amplified force of gravity to separate the liquid from the solids. This type of centrifuge does not require replaceable media, thereby saving cost and time.
    </p>

    <!-- Centrifuge Design -->
    <h3 class="text-lg font-bold text-navy mb-2">Centrifuge Design</h3>
    <p class="text-[#2D2D2D] mb-4">
      There are essential differences between the sedimentation and filtration centrifuges in their design. The following are the key differences between these centrifuges.
    </p>

    <h4 class="font-bold text-navy mb-2">Moving Parts</h4>
    <p class="text-[#2D2D2D] mb-3">
      The moving parts in this section refer to internal moving parts within the centrifuge. The rotating bowl is a standard moving part in all centrifuges.
    </p>
    <p class="text-[#2D2D2D] mb-3">
      The filtration-type centrifuge typically has an articulated scraper or blade that periodically scrapes the separated solids from the inside surface of the bowl. The scraped solids then fall out from the bowl by gravity.
    </p>
    <p class="text-[#2D2D2D] mb-6">
      A rotating scroll within the sedimentation centrifuge bowl pushes out the separated solids. This solids ejection is a continuous process during which the solids eject out from the rotating bowl due to the centrifugal force.
    </p>

    <h4 class="font-bold text-navy mb-2">Bowl Construction</h4>
    <p class="text-[#2D2D2D] mb-3">
      The filtration-type centrifuge has a perforated bowl to separate liquid from solids and let the separated liquid pass through. The size of these perforations determines the separation particle size.
    </p>
    <p class="text-[#2D2D2D] mb-6">
      A sedimentation centrifuge has a solid bowl; therefore, it is also known as a solid bowl centrifuge. The absence of perforations makes the solid bowl centrifuge more durable with a long service life.
    </p>

    <h4 class="font-bold text-navy mb-2">Erosion Protection</h4>
    <p class="text-[#2D2D2D] mb-3">
      Certain areas of the centrifuge bowl are prone to erosion due to contact with moving abrasive particles. The application of erosion-protecting coatings is essential for centrifuge durability.
    </p>
    <p class="text-[#2D2D2D] mb-3">
      The solid particles passing through bowl perforations in a filtration centrifuge can wear out the pores expanding the perforation sizes over time. The application of erosion protection to these pores is not always feasible.
    </p>
    <p class="text-[#2D2D2D] mb-3">
      The solid scraper or plow in the filtration centrifuge is susceptible to wear. A hard surface coating on the plow edge ensures wear resistance.
    </p>
    <p class="text-[#2D2D2D]">
      The rotating scroll in the sedimentation centrifuge bowl pushes out the solids. The scroll flights are always in contact with the solids and experience erosion wear. The application of erosion-resistant material, such as <strong>tungsten carbide</strong>, protects the scroll flights from wear.
    </p>
  </div>

  <!-- ══ Capacity ══ Pattern A side-by-side -->
  <div id="capacity" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Capacity</h2>
    <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
      <div class="md:w-2/5 shrink-0 space-y-4">
        <div>
          <img
            src="/images/industrial-centrifuge/Industrial-Centrifuge-DMPX-028-for-Wastewater-600.webp"
            alt="Industrial Centrifuge DMPX-028 for Wastewater — Dolphin Centrifuge"
            width="600"
            height="745"
            loading="lazy"
            class="rounded-lg shadow-sm w-full object-cover"
          />
          <p class="text-gray-500 text-sm mt-1 text-center">Industrial Centrifuge DMPX-028 for Wastewater</p>
        </div>
        <div>
          <img
            src="/images/industrial-centrifuge/disc-stack-centrifuge-wastewater-clarifier.webp"
            alt="Alfa Laval WHPX-513 Disc Stack Self-Cleaning Centrifuge for Wastewater Clarification"
            width="600"
            height="600"
            loading="lazy"
            class="rounded-lg shadow-sm w-full object-cover"
          />
          <p class="text-gray-500 text-sm mt-1 text-center">Alfa Laval WHPX-513 Centrifuge for Wastewater</p>
        </div>
      </div>
      <div>
        <p class="text-[#2D2D2D] mb-4">
          An industrial centrifuge capacity (throughput) is the volume of fluid the centrifuge can process in a given time. A <strong>decanter-type industrial centrifuge</strong> can process <strong>5 to 300+ gallons per minute</strong>. An <strong>industrial disc centrifuge</strong> has a capacity range of <strong>1 to 200+ GPM</strong>. The actual processing capacity depends on the process fluid and contaminant level.
        </p>
        <p class="text-[#2D2D2D] mb-4">The following table lists the capacities of popular sedimentation centrifuges.</p>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
