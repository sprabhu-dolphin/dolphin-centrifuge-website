---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "Why is centrifugal separation important for liquid humus production?",
    answer: "Raw humus extract contains undissolved organic solids, fine sediment, and colloidal particles that cause settling, cloudiness, and nozzle clogging in spray equipment. Centrifugal separation removes these contaminants mechanically — without chemicals or filtration aids — producing a clear, shelf-stable liquid fertilizer suitable for foliar spray, drip irrigation, and retail bottling."
  },
  {
    question: "Can I test my humus material before purchasing a centrifuge system?",
    answer: "Yes. Dolphin Centrifuge offers <a href='/industrial-centrifuge-sample-testing/'>sample testing</a> at our Warren, Michigan facility. Send 5–10 gallons of your humus extract and we will process it through lab-scale centrifuge equipment to determine optimal G-force, flow rate, expected clarity, and whether single-stage or two-stage separation is required. Results include a detailed report and system recommendation."
  },
  {
    question: "What equipment is needed for a complete liquid humus production line?",
    answer: "A full production system typically requires two centrifuge stages: a decanter centrifuge (such as a stainless steel NX-314) for primary bulk solids removal from the raw extract, followed by a self-cleaning disc stack centrifuge for final polishing to remove particles down to 1 micron. The two-stage approach produces the cleanest product for premium retail and fertigation markets."
  },
  {
    question: "Why is a disc stack polishing step needed after the decanter?",
    answer: "The decanter removes bulk solids and coarse organic matter but cannot capture fine colloidal particles below approximately 25 microns. A disc stack centrifuge operating at up to 12,000 Gs removes particles down to 1 micron — essential for foliar spray applications (prevents nozzle clogging), drip irrigation (prevents emitter fouling), and retail products (ensures visual clarity on the shelf)."
  },
  {
    question: "What flow rates are available for liquid humus centrifuge systems?",
    answer: "Dolphin Centrifuge offers disc stack polishing systems at 15, 25, and 40 GPM for the clarification stage, plus a 30 GPM stainless steel decanter for primary separation. Higher-capacity systems are available by contacting our engineering team. System sizing depends on your production volume, extract solids content, and desired throughput."
  }
];

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Liquid Humus Centrifuge | Commercial Scale Production",
  "description": "Industrial centrifuge systems for liquid humus fertilizer production. Decanter centrifuges for bulk separation and disc stack polishers for humic acid extracts.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge",
      "url": "https://dolphincentrifuge.com"
    }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/liquid-humus-centrifuge/",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const jsonLd = [articleJsonLd, faqJsonLd];

const toc = [
  { id: 'how-liquid-humus-is-made', label: 'How Liquid Humus Is Made' },
  { id: 'large-scale-production', label: 'Large-Scale Production' },
  { id: 'lab-testing', label: 'Lab Testing' },
  { id: 'humus-clarifier', label: 'Humus Clarifier (Disc Stack Polisher)' },
  { id: 'specifications', label: 'Specifications' },
];

const relatedApplications = [
  { label: 'Algae Centrifuge', href: '/algae-centrifuge/' },
  { label: 'Wastewater Centrifuge', href: '/wastewater-centrifuge/' },
  { label: 'Decanter Centrifuge Applications', href: '/decanter-centrifuge-applications/' },
  { label: 'Disc Stack Centrifuge Applications', href: '/disc-stack-centrifuge-applications/' },
];

const relatedProducts = [
  { label: 'NX-314 Decanter', href: '/alfa-laval-nx-314-decanter-centrifuge/', description: 'Primary humus separation &mdash; 30 GPM' },
  { label: 'Self-Cleaning Disc Stack &mdash; 15 GPM', href: '/centrifuges/dmpx-042/', description: 'Polishing clarifier for small batches' },
  { label: 'Self-Cleaning Disc Stack &mdash; 25 GPM', href: '/centrifuges/dmpx-042/', description: 'Mid-range polishing clarifier' },
  { label: 'Self-Cleaning Disc Stack &mdash; 40 GPM', href: '/centrifuges/dmpx-070/', description: 'High-capacity polishing clarifier' },
];
---

<ApplicationLayout
  title="Liquid Humus Centrifuge | Dolphin Centrifuge"
  description="Centrifuge systems for liquid humus fertilizer: NX-314 decanter removes bulk solids, disc stack clarifies humic acid extracts to 1 micron. Dolphin Centrifuge."
  category="applications"
  categoryLabel="Applications"
  canonicalUrl="https://dolphincentrifuge.com/liquid-humus-centrifuge/"
  heroImage="/images/liquid-humus-centrifuge/humus-fertilizer-centrifuge-opgpxokym4qm04vdti0t0l0btt3f9qc2o7cj8b4mj8.webp"
  heroImageAlt="Humus fertilizer centrifuge system for liquid humus production"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies industrial centrifuge systems for liquid humus fertilizer production — decanter centrifuges for bulk solids removal and disc stack polishers clarifying humic acid extracts down to 1 micron. Warren, Michigan. 40+ years experience.</p>
  </div>

  <h2 id="how-liquid-humus-is-made">How Liquid Humus Is Made</h2>

  <p>Dolphin Centrifuge, based in Warren, Michigan, supplies decanter and <a href="/disc-stack-centrifuge/">disc stack centrifuge</a> systems for liquid humus fertilizer production. Liquid humus fertilizer is produced by extracting humic and fulvic acids from organic humus material. The process is straightforward: raw humus (composted organic matter, leonardite, or peat) is mixed with water and an alkaline agent, then allowed to steep for a controlled residence time. During this period, humic substances dissolve into the water phase.
  </p>

  <p>
    After extraction, the challenge becomes separation. The slurry contains undissolved organic solids, fine sediment, and colloidal particles that must be removed to produce a clean, stable liquid fertilizer. This is where centrifugal separation becomes essential.
  </p>

  <p>
    A two-stage centrifuge process delivers the best results:
  </p>

  <ol>
    <li><strong>Primary separation (decanter):</strong> Removes bulk solids and coarse organic matter from the extract</li>
    <li><strong>Polishing (disc stack):</strong> Clarifies the liquid to remove fine particles down to 1 micron, producing a shelf-stable product</li>
  </ol>

  <h2 id="large-scale-production">Large-Scale Production with Decanter Centrifuge</h2>

  <p>
    For bulk humus extraction, a <a href="/decanter-centrifuge/">decanter centrifuge</a> provides the primary separation step. The horizontal scroll decanter handles the high solids load of raw humus slurry &mdash; typically 10&ndash;30% solids &mdash; and produces a clarified liquid extract with minimal residual solids.
  </p>

  <h3>NX-314 Stainless Steel Decanter</h3>

  <div class="flex flex-col md:flex-row gap-6 items-start not-prose my-6">
    <div class="md:w-1/2">
      <img
        src="/images/liquid-humus-centrifuge/biomass-centrifuge-Alfa-Laval-NX314.webp"
        alt="Biomass centrifuge NX-314 stainless steel decanter for liquid humus production"
        width="600" height="600"
        loading="lazy"
        class="rounded-lg w-full h-auto"
      />
    </div>
    <div class="md:w-1/2">
      <p class="text-base text-text-DEFAULT leading-relaxed">
        The NX-314 decanter is the recommended primary separator for liquid humus production. Constructed entirely in <strong>316L stainless steel</strong>, it resists the corrosive alkaline environment of humus extraction and meets food-grade contact requirements for agricultural fertilizer products.
      </p>
    </div>
  </div>

  <p>
    Key advantages for humus production:
  </p>

  <ul>
    <li><strong>Continuous operation:</strong> No batch cycling &mdash; feed raw slurry and collect clarified extract without interruption</li>
    <li><strong>Adjustable scroll differential:</strong> Fine-tune solids dryness and liquid clarity by varying the speed difference between bowl and scroll</li>
    <li><strong>High solids handling:</strong> Processes slurries with up to 30% solids content without clogging</li>
    <li><strong>316L stainless steel:</strong> Full corrosion resistance for alkaline humus extraction chemistry</li>
    <li><strong>Low moisture solids discharge:</strong> Produces dewatered solids at less than 5% moisture for disposal or re-extraction</li>
  </ul>

  <h2 id="lab-testing">Lab Testing of Humic Acid Samples</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start not-prose my-6">
    <div class="md:w-1/2">
      <img
        src="/images/liquid-humus-centrifuge/Humic-Acid-Disc-Stack-Centrifuge-Testing-Results.webp"
        alt="Humic Acid Disc Stack Centrifuge Testing Results — solids retained in bowl after separation"
        width="800" height="600"
        loading="lazy"
        class="rounded-lg w-full h-auto"
      />
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/liquid-humus-centrifuge/Before-n-After-Centrifuge.webp"
        alt="Humic acid before and after centrifuge processing — clarity comparison"
        width="800" height="730"
        loading="lazy"
        class="rounded-lg w-full h-auto"
      />
    </div>
  </div>

  <p>
    We offer <a href="/industrial-centrifuge-sample-testing/">sample testing</a> to evaluate your specific humus material before committing to a production system. Our lab-scale disc stack centrifuge processes small batches of humic acid extract to determine:
  </p>

  <ul>
    <li>Optimal G-force and flow rate for your extract characteristics</li>
    <li>Expected clarity and color of the finished product</li>
    <li>Recommended discharge interval and solids handling</li>
    <li>Whether single-stage or two-stage separation is required</li>
  </ul>

  <p>
    Send 5&ndash;10 gallons of representative humus extract to our Warren, Michigan facility. We provide a detailed test report with centrifuge recommendations and process parameters.
  </p>

  <!-- Mid-Page CTA -->
  <div class="bg-gold/10 border border-gold rounded-xl p-6 my-8 not-prose">
    <p class="text-navy font-bold text-lg mb-2">Test Your Humus Extract Before You Invest</p>
    <p class="text-sm text-gray-600 mb-4">Send us a sample of your liquid humus and we will process it through our pilot-scale centrifuge — confirming separation efficiency and recommending the right production system.</p>
    <a href="/industrial-centrifuge-sample-testing/" class="inline-block bg-gold text-white font-semibold px-5 py-2 rounded-lg hover:opacity-90 transition">Request Sample Testing &rarr;</a>
  </div>

  <h2 id="humus-clarifier">Humus Clarifier &mdash; Disc Stack Polisher</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start not-prose my-6">
    <div class="md:w-1/2">
      <img
        src="/images/liquid-humus-centrifuge/algae-centrifuge-alfa-laval-40GPM.webp"
        alt="Self-cleaning disc stack centrifuge 40 GPM for liquid humus polishing"
        width="300" height="300"
        loading="lazy"
        class="rounded-lg w-full h-auto"
      />
    </div>
    <div class="md:w-1/2">
      <p class="text-base text-text-DEFAULT leading-relaxed">
        After the decanter removes bulk solids, a <a href="/disc-stack-centrifuge/">self-cleaning disc stack centrifuge</a> polishes the liquid extract to production-grade clarity. Operating at up to <strong>12,000 Gs</strong>, the disc stack captures particles down to <strong>1 micron</strong> &mdash; including colloidal organic matter and fine sediment that would cause settling or cloudiness in the finished product.
      </p>
    </div>
  </div>

  <p>
    The polishing step is critical for premium liquid humus products destined for:
  </p>

  <ul>
    <li><strong>Foliar spray applications:</strong> Requires particle-free liquid to prevent nozzle clogging in spray equipment</li>
    <li><strong>Drip irrigation (fertigation):</strong> Fine particles clog emitters and drip lines; polished extract flows cleanly</li>
    <li><strong>Retail bottled products:</strong> Consumer-grade humic acid must be clear and free of visible sediment for shelf appeal</li>
  </ul>

  <p>
    The self-cleaning disc stack ejects accumulated solids automatically at timed intervals. No manual cleaning, no batch processing, no downtime. This production step is similar to the clarification approach used for <a href="/algae-centrifuge/">algae harvesting</a>.
  </p>

