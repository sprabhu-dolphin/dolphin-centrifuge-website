---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "What is the Alfa Laval WSPX 207 used for?",
    answer: "The WSPX 207 is a compact self-cleaning disc stack centrifuge for water-based coolant and metalworking fluid processing at 100–200 LPH. It continuously removes sub-micron metal fines and tramp oil from coolant without interrupting fluid flow, making it ideal for point-of-use installation at individual CNC machining centers or grinding cells."
  },
  {
    question: "How does the WSPX 207 discharge accumulated solids?",
    answer: "The WSPX 207 uses a self-cleaning bowl that discharges accumulated metal fines and tramp oil sludge at preset intervals via hydraulically operated discharge valves — without stopping production or requiring manual intervention. This allows continuous unattended operation in production environments."
  },
  {
    question: "What is the difference between the WSPX 207 and the WSPX 303?",
    answer: "The WSPX 303 is the larger mid-size model with 200–400 LPH throughput, suited for central coolant systems serving multiple machines. The WSPX 207 is the entry-level model at 100–200 LPH, designed for point-of-use installation at a single machining center. Choose the WSPX 303 for central coolant systems; the WSPX 207 for individual machine installations."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval WSPX 207 Self-Cleaning Coolant Centrifuge",
  "description": "Alfa Laval WSPX 207 self-cleaning 3-phase disc centrifuge. 20 GPM rated capacity, 6,500 Gs, stainless steel wetted parts. For coolant recovery and wash water deoiling.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const jsonLd = [productJsonLd, faqJsonLd];

const toc = [
  { id: 'overview', label: 'WSPX 207 Operation' },
  { id: 'specifications', label: 'WSPX 207 Specifications' },
  { id: 'applications', label: 'Applications' },
  { id: 'wspx-series', label: 'WSPX Series Comparison' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedApplications = [
  { label: 'Machine Coolant Centrifuge', href: '/machine-coolant-centrifuge/' },
  { label: 'Cutting Oil Centrifuge', href: '/cutting-oil-centrifuge/' },
  { label: 'Machining Coolant Recovery', href: '/machining-coolant-recovery-centrifuge/' },
];

const relatedProducts = [
  { label: 'WSPX 303 Centrifuge', href: '/alfa-laval-wspx-303-centrifuge/', description: '200–400 LPH mid-size coolant' },
  { label: 'WSPX 307 Centrifuge', href: '/alfa-laval-wspx-307/', description: '400–800 LPH high-volume' },
  { label: 'WSPX 407 Centrifuge', href: '/alfa-laval-wspx-407/', description: '800+ LPH highest capacity' },
];
---

<ApplicationLayout
  title="Alfa Laval WSPX 207 Self-Cleaning Coolant Centrifuge | Dolphin Centrifuge"
  description="Alfa Laval WSPX 207 self-cleaning 3-phase disc centrifuge for coolant recovery. 20 GPM, 6,500 Gs, stainless steel wetted parts. Dolphin Centrifuge."
  category="products"
  categoryLabel="Products"
  heroImage="/images/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/Alfa-Laval-Industrial-Centrifuge-Coolant-1000.webp"
  heroImageAlt="Alfa Lava Industrial Centrifuge Coolant Separation"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">The Alfa Laval WSPX 207 is a self-cleaning 3-phase disc stack centrifuge rated at 20 GPM, generating over 6,500 Gs at 6,300 RPM with all stainless steel wetted parts. Dolphin Centrifuge supplies the WSPX 207 for coolant recovery, tramp oil removal, and wash water deoiling from Warren, Michigan.</p>
  </div>

  <h2 id="overview">WSPX 207 Operation</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-1/2">
      <p>
        The Alfa Laval WSPX 207 is a 3-phase <a href="/disc-stack-centrifuge/">disc stack centrifuge</a> designed to separate tramp oil and small particles from machine coolant. The centrifuge bowl rotates at 6,300 RPM exerting over 6,500 Gs of centrifugal force. This 3-phase centrifuge features all stainless steel wetted parts with automatic sludge discharge capability.
      </p>
      <p>
        The WSPX 207 is perfect for the recovery of water-based coolants, semi-synthetic and synthetic, deoiling of wash water, and high or low pH chemical separation applications. With a rated capacity of 20 GPM, the WSPX 207 is the entry-level model in the WSPX series. Its compact footprint allows installation directly adjacent to CNC machining centers or grinding cells.
      </p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/Alfa-Laval-Stainless-Steel-Centrifuge-600.webp"
        alt="Alfa Laval Stainless Steel Centrifuge"
        width="600"
        height="600"
        loading="lazy"
        class="rounded-lg w-full"
      />
    </div>
  </div>

  <h2 id="specifications">WSPX 207 Specifications</h2>

  <table>
    <tbody>
      <tr><td><strong>Model Type</strong></td><td>Alfa Laval WSPX 207 TGP-74</td></tr>
      <tr><td><strong>Rated Capacity</strong></td><td>20 GPM</td></tr>
      <tr><td><strong>Sludge Space</strong></td><td>0.82 Gallons</td></tr>
      <tr><td><strong>Bowl Type</strong></td><td>Self-Cleaning (Automatic Discharge)</td></tr>
      <tr><td><strong>Separation Type</strong></td><td>3-Phase (Liquid-Liquid-Solid)</td></tr>
      <tr><td><strong>Bowl Speed</strong></td><td>6,300 RPM</td></tr>
      <tr><td><strong>G-Force</strong></td><td>6,500+ Gs</td></tr>
      <tr><td><strong>Motor HP</strong></td><td>7.5 HP</td></tr>
      <tr><td><strong>Voltages</strong></td><td>230 / 460 V; 3-Phase</td></tr>
      <tr><td><strong>Wetted Parts</strong></td><td>All Stainless Steel</td></tr>
    </tbody>
  </table>

  <h2 id="applications">Applications</h2>

  <div class="grid md:grid-cols-2 gap-x-8 gap-y-2 mb-8 not-prose">
    <ul class="text-text-light space-y-2">
      <li>&#8226; <a href="/machine-coolant-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Machining coolant recovery</a> (water-based, semi-synthetic, synthetic)</li>
      <li>&#8226; <a href="/cutting-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Cutting oil clarification</a></li>
      <li>&#8226; Metal fines removal from grinding fluid</li>
      <li>&#8226; Tramp oil separation from water-based coolant</li>
      <li>&#8226; Deoiling of wash water</li>
    </ul>
    <ul class="text-text-light space-y-2">
      <li>&#8226; CNC machining center coolant systems</li>
      <li>&#8226; Grinding and honing fluid recovery</li>
      <li>&#8226; Washer liquid clarification</li>
      <li>&#8226; High or low pH chemical separation</li>
      <li>&#8226; Small-volume central coolant systems</li>
    </ul>
  </div>

  <div class="bg-navy/5 border border-navy/10 rounded-lg p-5 mb-8 not-prose">
    <p class="text-sm text-text-light leading-relaxed"><strong>Not sure if the WSPX 207 is right for your application?</strong> Dolphin Centrifuge offers <a href="/industrial-centrifuge-sample-testing/" class="text-navy font-semibold hover:text-gold transition-colors">free sample testing</a> to evaluate separation performance before purchase. For help choosing between disc stack models, see our <a href="/disc-stack-centrifuge-faq/" class="text-navy font-semibold hover:text-gold transition-colors">disc stack centrifuge FAQ</a>.</p>
  </div>

  <h2 id="wspx-series">WSPX Series — Model Comparison</h2>

  <p>
    The WSPX 207 is the smallest model in the WSPX line. For higher-volume coolant systems, Dolphin also supplies the <a href="/alfa-laval-wspx-303-centrifuge/">WSPX 303</a> and <a href="/alfa-laval-wspx-407/">WSPX 407</a> (800+ LPH top model) and larger WSPX models.
  </p>

  <div class="grid md:grid-cols-3 gap-6 mb-8 not-prose">
    <div class="bg-white rounded-xl p-6 border-2 border-gold">
      <h3 class="text-lg font-bold text-navy mb-2">WSPX 207 — Current</h3>
      <p class="text-sm text-text-light">100–200 LPH. Compact footprint for individual machine or small cell installations.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2"><a href="/alfa-laval-wspx-303-centrifuge/" class="text-navy hover:text-gold transition-colors">WSPX 303</a></h3>
      <p class="text-sm text-text-light">200–400 LPH. Mid-size model for central coolant systems and larger machining operations.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2"><a href="/alfa-laval-wspx-307/" class="text-navy hover:text-gold transition-colors">WSPX 307 / 407</a></h3>
      <p class="text-sm text-text-light">400–800+ LPH. High-volume models for automotive and aerospace production facilities.</p>
    </div>
  </div>

  <p>
    <a href="/machine-coolant-centrifuge/">Learn more about coolant centrifuge systems and ROI &rarr;</a>
  </p>

  <FAQ items={faqItems} />

  <div class="bg-navy rounded-xl p-8 text-center mt-12 not-prose">
    <h2 class="text-2xl font-bold text-white mb-3">Interested in the WSPX 207?</h2>
    <p class="text-gray-300 mb-6 max-w-lg mx-auto">Contact our team for pricing, availability, and application evaluation. Paid sample testing is available for qualifying applications.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Quote</a>
      <a href="tel:2485222573" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">(248) 522-2573</a>
    </div>
  </div>

</ApplicationLayout>
