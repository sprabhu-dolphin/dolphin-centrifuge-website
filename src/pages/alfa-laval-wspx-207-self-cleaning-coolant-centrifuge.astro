---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the Alfa Laval WSPX 207 used for?",
      "acceptedAnswer": { "@type": "Answer", "text": "The WSPX 207 is a compact self-cleaning disc stack centrifuge for water-based coolant and metalworking fluid processing at 100–200 LPH. It continuously removes sub-micron metal fines and tramp oil from coolant without interrupting fluid flow, making it ideal for point-of-use installation at individual CNC machining centers or grinding cells." }
    },
    {
      "@type": "Question",
      "name": "How does the WSPX 207 discharge accumulated solids?",
      "acceptedAnswer": { "@type": "Answer", "text": "The WSPX 207 uses a self-cleaning bowl that discharges accumulated metal fines and tramp oil sludge at preset intervals via hydraulically operated discharge valves — without stopping production or requiring manual intervention. This allows continuous unattended operation in production environments." }
    },
    {
      "@type": "Question",
      "name": "What is the difference between the WSPX 207 and the WSPX 303?",
      "acceptedAnswer": { "@type": "Answer", "text": "The WSPX 303 is the larger mid-size model with 200–400 LPH throughput, suited for central coolant systems serving multiple machines. The WSPX 207 is the entry-level model at 100–200 LPH, designed for point-of-use installation at a single machining center. Choose the WSPX 303 for central coolant systems; the WSPX 207 for individual machine installations." }
    }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval WSPX 207 Self-Cleaning Coolant Centrifuge",
  "description": "Alfa Laval WSPX 207 self-cleaning disc centrifuge for machining coolant recovery and metalworking fluid recycling.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/",
};
---

<BaseLayout
  title="Alfa Laval WSPX 207 Coolant Centrifuge"
  description="Alfa Laval WSPX 207 self-cleaning disc centrifuge for metalworking coolant — tramp oil and fines separation at 7,000+ Gs, 53–79 LPH. Dolphin Centrifuge, Warren MI."
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/"
  breadcrumbs={[{label: 'Products', href: '/disc-stack-centrifuge/'}, {label: 'WSPX 207'}]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">Products</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">Alfa Laval WSPX 207 Self-Cleaning Coolant Centrifuge</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">Dolphin Centrifuge provides expert service, genuine parts, and fully reconditioned units for this model. A compact self-cleaning disc centrifuge engineered for continuous coolant recovery in machining and metalworking environments. The WSPX 207 removes metal fines and tramp oil from water-based coolants, extending fluid life and reducing disposal costs.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Request a Quote</a>
        <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
      </div>
    </div>
  </section>

  <!-- Specs & Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-4xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
        <p class="text-sm text-text-light leading-relaxed italic">The Alfa Laval WSPX 207 is a self-cleaning disc stack centrifuge for water-based coolant and metalworking fluid processing at 100–200 LPH. Dolphin Centrifuge supplies the WSPX 207 as the DMPX-007C coolant centrifuge module — removing sub-micron metal fines and tramp oil continuously without stopping fluid flow. Compact footprint for point-of-use installation at individual CNC machining centers or grinding cells. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in WSPX-series coolant centrifuge systems.</p>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Operation</h2>
      <p class="text-text-light mb-4">
        The Alfa Laval WSPX 207 is a self-cleaning <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">disc stack centrifuge</a> purpose-built for water-based fluid processing. Its concentrator-style bowl discharges solids automatically while maintaining continuous liquid throughput — making it well suited for unmanned production environments.
      </p>
      <p class="text-text-light mb-8">
        With a flow rate of approximately 100–200 LPH depending on coolant type and contamination load, the WSPX 207 is the entry-level model in the WSPX series. Its compact footprint allows installation directly adjacent to CNC machining centers or grinding cells without requiring significant floor space.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">WSPX 207 Specifications</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <tbody>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Centrifuge Model</td>
              <td class="px-4 py-3 font-mono text-text-light">Alfa Laval WSPX 207</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Typical Flow Rate</td>
              <td class="px-4 py-3 font-mono text-text-light">100–200 LPH (application-dependent)</td>
            </tr>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Bowl Type</td>
              <td class="px-4 py-3 font-mono text-text-light">Self-Cleaning (Automatic Discharge)</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Separation Type</td>
              <td class="px-4 py-3 font-mono text-text-light">Concentrator (Liquid-Solid)</td>
            </tr>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Motor Power</td>
              <td class="px-4 py-3 font-mono text-text-light">7.5 HP</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Bowl Speed</td>
              <td class="px-4 py-3 font-mono text-text-light">~6,400 RPM</td>
            </tr>
            <tr class="bg-white">
              <td class="px-4 py-3 font-semibold text-navy">Voltages</td>
              <td class="px-4 py-3 font-mono text-text-light">230 / 460 V; 3-Phase</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Applications</h2>
      <div class="grid md:grid-cols-2 gap-x-8 gap-y-2 mb-8">
        <ul class="text-text-light space-y-2">
          <li>&#8226; <a href="/machine-coolant-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Machining coolant recovery</a></li>
          <li>&#8226; <a href="/cutting-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Cutting oil clarification</a></li>
          <li>&#8226; Metal fines removal from grinding fluid</li>
          <li>&#8226; Tramp oil separation from water-based coolant</li>
        </ul>
        <ul class="text-text-light space-y-2">
          <li>&#8226; CNC machining center coolant systems</li>
          <li>&#8226; Grinding and honing fluid recovery</li>
          <li>&#8226; Washer liquid clarification</li>
          <li>&#8226; Small-volume central coolant systems</li>
        </ul>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">WSPX Series — Model Comparison</h2>
      <p class="text-text-light mb-4">
        The WSPX 207 is the smallest model in the WSPX line. For higher-volume coolant systems, Dolphin also supplies the <a href="/alfa-laval-wspx-303-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">WSPX 303</a> and <a href="/alfa-laval-wspx-407/" class="text-navy font-semibold hover:text-gold transition-colors">WSPX 407</a> (800+ LPH top model) and larger WSPX models.
      </p>
      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-xl p-6 border-2 border-gold">
          <h3 class="text-lg font-bold text-navy mb-2">WSPX 207 — Current</h3>
          <p class="text-sm text-text-light">100–200 LPH. Compact footprint for individual machine or small cell installations.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">WSPX 303</h3>
          <p class="text-sm text-text-light">200–400 LPH. Mid-size model for central coolant systems and larger machining operations.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">WSPX 307 / 407</h3>
          <p class="text-sm text-text-light">400–800+ LPH. High-volume models for automotive and aerospace production facilities.</p>
        </div>
      </div>

      <p class="text-text-light mb-8">
        <a href="/machine-coolant-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Learn more about coolant centrifuge systems and ROI &rarr;</a>
      </p>

      <!-- FAQ -->
      <div id="faq" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-6">
        <h2 class="text-xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What is the Alfa Laval WSPX 207 used for?</h3>
            <p class="text-text-light text-sm">The WSPX 207 is a compact self-cleaning disc stack centrifuge for water-based coolant and metalworking fluid processing at 100–200 LPH. It continuously removes sub-micron metal fines and tramp oil from coolant without interrupting fluid flow, making it ideal for point-of-use installation at individual CNC machining centers or grinding cells.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">How does the WSPX 207 discharge accumulated solids?</h3>
            <p class="text-text-light text-sm">The WSPX 207 uses a self-cleaning bowl that discharges accumulated metal fines and tramp oil sludge at preset intervals via hydraulically operated discharge valves — without stopping production or requiring manual intervention. This allows continuous unattended operation in production environments.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What is the difference between the WSPX 207 and the WSPX 303?</h3>
            <p class="text-text-light text-sm">The WSPX 303 is the larger mid-size model with 200–400 LPH throughput, suited for central coolant systems serving multiple machines. The WSPX 207 is the entry-level model at 100–200 LPH, designed for point-of-use installation at a single machining center. Choose the WSPX 303 for central coolant systems; the WSPX 207 for individual machine installations.</p>
          </div>
        </div>
      </div>
      <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

      <!-- Bottom CTA -->
      <div class="bg-navy rounded-xl p-8 text-center mt-12">
        <h2 class="text-2xl font-bold text-white mb-3">Interested in the WSPX 207?</h2>
        <p class="text-gray-300 mb-6 max-w-lg mx-auto">Contact our team for pricing, availability, and application evaluation. Paid sample testing is available for qualifying applications.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Quote</a>
          <a href="tel:2485222573" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">(248) 522-2573</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
