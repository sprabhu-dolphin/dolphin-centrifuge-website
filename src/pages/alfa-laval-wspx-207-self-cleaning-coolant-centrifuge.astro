---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqItems = [
  {
    question: "What is the Alfa Laval WSPX 207 used for?",
    answer: "The WSPX 207 is a compact self-cleaning disc stack centrifuge for water-based coolant and metalworking fluid processing at 20 GPM. It continuously removes sub-micron metal fines and tramp oil from coolant without interrupting fluid flow, making it ideal for point-of-use installation at individual CNC machining centers or grinding cells."
  },
  {
    question: "How does the WSPX 207 discharge accumulated solids?",
    answer: "The WSPX 207 uses a self-cleaning bowl that discharges accumulated metal fines and tramp oil sludge at preset intervals via hydraulically operated discharge valves — without stopping production or requiring manual intervention. This allows continuous unattended operation in production environments."
  },
  {
    question: "What is the difference between the WSPX 207 and the WSPX 303?",
    answer: "The WSPX 303 is the larger mid-size model with 8 GPM throughput, suited for central coolant systems serving multiple machines. The WSPX 207 is the entry-level model at 20 GPM on a more compact frame, designed for point-of-use installation at a single machining center. Choose the WSPX 303 for central coolant systems; the WSPX 207 for individual machine installations."
  },
  {
    question: "What G-force does the WSPX 207 generate?",
    answer: "The WSPX 207 bowl rotates at 6,300 RPM generating over 6,500 Gs of centrifugal force. All wetted parts are stainless steel, making it suitable for high or low pH coolant and chemical separation applications."
  },
  {
    question: "Can Dolphin Centrifuge supply parts or rebuild the WSPX 207?",
    answer: "Yes. Dolphin Centrifuge supplies genuine and compatible replacement parts for the WSPX 207, including disc stacks, seals, bearings, and discharge valve components. Complete bowl rebuilds and remanufactured WSPX 207 centrifuges are available. Contact us for parts availability and service scheduling."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval WSPX 207 Self-Cleaning Coolant Centrifuge",
  "description": "Alfa Laval WSPX 207 self-cleaning 3-phase disc centrifuge. 20 GPM rated capacity, 6,500 Gs, stainless steel wetted parts. For coolant recovery and wash water deoiling.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Alfa Laval WSPX 207 Self-Cleaning Coolant Centrifuge",
  "description": "Technical overview of the Alfa Laval WSPX 207 self-cleaning 3-phase disc centrifuge for machine coolant recovery, tramp oil removal, and wash water deoiling.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  },
  "url": "https://dolphincentrifuge.com/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/"
};

const jsonLd = [productJsonLd, faqJsonLd, articleJsonLd];

const toc = [
  { id: 'overview', label: 'WSPX 207 Operation' },
  { id: 'specifications', label: 'WSPX 207 Specifications' },
  { id: 'applications', label: 'Applications' },
  { id: 'wspx-series', label: 'WSPX Series Comparison' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedApplications = [
  { label: 'Machine Coolant Centrifuge', href: '/machine-coolant-centrifuge/' },
  { label: 'Cutting Oil Centrifuge', href: '/cutting-oil-centrifuge/' },
  { label: 'Machining Coolant Recovery', href: '/machining-coolant-recovery-centrifuge/' },
];

const relatedProducts = [
  { label: 'WSPX 303 Centrifuge', href: '/alfa-laval-wspx-303-centrifuge/', description: 'Mid-size coolant centrifuge' },
  { label: 'WSPX 307 Centrifuge', href: '/alfa-laval-wspx-307/', description: '22 GPM high-volume' },
  { label: 'WSPX 407 Centrifuge', href: '/alfa-laval-wspx-407/', description: '25 GPM highest capacity' },
];
---

<ApplicationLayout
  title="Alfa Laval WSPX 207 Coolant Centrifuge | Dolphin"
  description="Alfa Laval WSPX 207 self-cleaning 3-phase disc centrifuge for coolant recovery. 20 GPM, 6,500 Gs, all stainless steel wetted parts. Parts, repairs, and remanufactured units from Dolphin Centrifuge."
  category="products"
  categoryLabel="Products"
  heroImage="/images/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/Alfa-Laval-Industrial-Centrifuge-Coolant-1000.webp"
  heroImageAlt="Alfa Laval WSPX 207 industrial centrifuge coolant separation system"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="bg-navy/5 border-l-4 border-gold/40 rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies parts, repairs, and remanufactured Alfa Laval WSPX 207 self-cleaning 3-phase disc stack centrifuges rated at 20 GPM, generating over 6,500 Gs at 6,300 RPM with all stainless steel wetted parts. Ideal for coolant recovery, tramp oil removal, and wash water deoiling. Warren, Michigan — over 40 years of experience.</p>
  </div>

  <h2 id="overview">WSPX 207 Operation</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-1/2">
      <p>
        The Alfa Laval WSPX 207 is a 3-phase <a href="/disc-stack-centrifuge/">disc stack centrifuge</a> designed to separate tramp oil and small particles from machine coolant. The centrifuge bowl rotates at 6,300 RPM exerting over 6,500 Gs of centrifugal force. This 3-phase centrifuge features all stainless steel wetted parts with automatic sludge discharge capability.
      </p>
      <p>
        The WSPX 207 is perfect for the recovery of water-based coolants, semi-synthetic and synthetic, deoiling of wash water, and high or low pH chemical separation applications. With a rated capacity of 20 GPM, the WSPX 207 is the entry-level model in the WSPX series. Its compact footprint allows installation directly adjacent to CNC machining centers or grinding cells.
      </p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/Alfa-Laval-Stainless-Steel-Centrifuge-600.webp"
        alt="Alfa Laval WSPX 207 stainless steel centrifuge for coolant separation"
        width="600"
        height="600"
        loading="lazy"
        class="rounded-lg w-full"
      />
    </div>
  </div>

  <h2 id="specifications">WSPX 207 Specifications</h2>

  <table>
    <tbody>
      <tr><td><strong>Model Type</strong></td><td>Alfa Laval WSPX 207 TGP-74</td></tr>
      <tr><td><strong>Rated Capacity</strong></td><td>20 GPM</td></tr>
      <tr><td><strong>Sludge Space</strong></td><td>0.82 Gallons</td></tr>
      <tr><td><strong>Bowl Type</strong></td><td>Self-Cleaning (Automatic Discharge)</td></tr>
      <tr><td><strong>Separation Type</strong></td><td>3-Phase (Liquid-Liquid-Solid)</td></tr>
      <tr><td><strong>Bowl Speed</strong></td><td>6,300 RPM</td></tr>
      <tr><td><strong>G-Force</strong></td><td>6,500+ Gs</td></tr>
      <tr><td><strong>Motor HP</strong></td><td>7.5 HP</td></tr>
      <tr><td><strong>Voltages</strong></td><td>230 / 460 V; 3-Phase</td></tr>
      <tr><td><strong>Wetted Parts</strong></td><td>All Stainless Steel</td></tr>
    </tbody>
  </table>

  <div class="bg-gold/10 border-l-4 border-gold rounded-r-xl p-5 my-8 not-prose">
    <p class="text-base font-semibold text-navy mb-1">Need parts, repairs, or a remanufactured WSPX 207?</p>
    <p class="text-sm text-text-light mb-3">Dolphin Centrifuge supplies the WSPX 207 along with parts, rebuild services, and application support. Not sure if it fits your coolant system? <a href="/industrial-centrifuge-sample-testing/" class="text-navy font-semibold hover:text-gold">Free sample testing</a> is available to validate performance.</p>
    <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold hover:bg-gold/80 text-navy font-bold px-6 py-2 rounded-lg transition-colors text-sm">Request a Quote &rarr;</a>
  </div>

  <h2 id="applications">Applications</h2>

  <div class="grid md:grid-cols-2 gap-x-8 gap-y-2 mb-8 not-prose">
    <ul class="text-text-light space-y-2">
      <li>&#8226; <a href="/machine-coolant-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Machining coolant recovery</a> (water-based, semi-synthetic, synthetic)</li>
      <li>&#8226; <a href="/cutting-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Cutting oil clarification</a></li>
      <li>&#8226; Metal fines removal from grinding fluid</li>
      <li>&#8226; Tramp oil separation from water-based coolant</li>
      <li>&#8226; Deoiling of wash water</li>
    </ul>
    <ul class="text-text-light space-y-2">
      <li>&#8226; CNC machining center coolant systems</li>
      <li>&#8226; Grinding and honing fluid recovery</li>
      <li>&#8226; Washer liquid clarification</li>
      <li>&#8226; High or low pH chemical separation</li>
      <li>&#8226; Small-volume central coolant systems</li>
    </ul>
  </div>

  <div class="bg-navy/5 border border-navy/10 rounded-lg p-5 mb-8 not-prose">
    <p class="text-sm text-text-light leading-relaxed"><strong>Not sure if the WSPX 207 is right for your application?</strong> Dolphin Centrifuge offers <a href="/industrial-centrifuge-sample-testing/" class="text-navy font-semibold hover:text-gold transition-colors">free sample testing</a> to evaluate separation performance before purchase. For help choosing between disc stack models, see our <a href="/disc-stack-centrifuge-faq/" class="text-navy font-semibold hover:text-gold transition-colors">disc stack centrifuge FAQ</a>. Our <a href="/industrial-disc-centrifuge-repair/" class="text-navy font-semibold hover:text-gold transition-colors">repair and rebuild services</a> keep your WSPX running at peak efficiency.</p>
  </div>

  <h2 id="wspx-series">WSPX Series — Model Comparison</h2>

  <p>
    The WSPX 207 is the entry-level model in the WSPX line. For higher-volume coolant systems, Dolphin also supplies the <a href="/alfa-laval-wspx-303-centrifuge/">WSPX 303</a>, <a href="/alfa-laval-wspx-307/">WSPX 307</a>, and <a href="/alfa-laval-wspx-407/">WSPX 407</a> (25 GPM top model).
  </p>

  <div class="grid md:grid-cols-3 gap-6 mb-8 not-prose">
    <div class="bg-white rounded-xl p-6 border-2 border-gold">
      <h3 class="text-lg font-bold text-navy mb-2">WSPX 207 — Current</h3>
      <p class="text-sm text-text-light">20 GPM. Compact footprint for individual machine or small cell installations.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2"><a href="/alfa-laval-wspx-303-centrifuge/" class="text-navy hover:text-gold transition-colors">WSPX 303</a></h3>
      <p class="text-sm text-text-light">8 GPM. Mid-size model for central coolant systems and larger machining operations.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2"><a href="/alfa-laval-wspx-307/" class="text-navy hover:text-gold transition-colors">WSPX 307 / 407</a></h3>
      <p class="text-sm text-text-light">22–25 GPM. High-volume models for automotive and aerospace production facilities.</p>
    </div>
  </div>

  <p>
    <a href="/machine-coolant-centrifuge/">Learn more about coolant centrifuge systems and ROI &rarr;</a>
  </p>

  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What is the Alfa Laval WSPX 207 used for?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The WSPX 207 is a compact self-cleaning disc stack centrifuge for water-based coolant and metalworking fluid processing at 20 GPM. It continuously removes sub-micron metal fines and tramp oil from coolant without interrupting fluid flow, making it ideal for point-of-use installation at individual CNC machining centers or grinding cells.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      How does the WSPX 207 discharge accumulated solids?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The WSPX 207 uses a self-cleaning bowl that discharges accumulated metal fines and tramp oil sludge at preset intervals via hydraulically operated discharge valves — without stopping production or requiring manual intervention. This allows continuous unattended operation in production environments.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What is the difference between the WSPX 207 and the WSPX 303?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The WSPX 303 is the larger mid-size model with 8 GPM throughput, suited for central coolant systems serving multiple machines. The WSPX 207 is the entry-level model at 20 GPM on a more compact frame, designed for point-of-use installation at a single machining center. Choose the WSPX 303 for central coolant systems; the WSPX 207 for individual machine installations.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What G-force does the WSPX 207 generate?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The WSPX 207 bowl rotates at 6,300 RPM generating over 6,500 Gs of centrifugal force. All wetted parts are stainless steel, making it suitable for high or low pH coolant and chemical separation applications.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      Can Dolphin Centrifuge supply parts or rebuild the WSPX 207?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">Yes. Dolphin Centrifuge supplies genuine and compatible replacement parts for the WSPX 207, including disc stacks, seals, bearings, and discharge valve components. Complete bowl rebuilds and remanufactured WSPX 207 centrifuges are available. Contact us for parts availability and service scheduling.</p>
  </details>

  <div class="bg-navy rounded-xl p-8 text-center mt-12 not-prose">
    <h2 class="text-2xl font-bold text-white mb-3">Parts, Repairs &amp; Remanufactured WSPX 207</h2>
    <p class="text-gray-300 mb-6 max-w-lg mx-auto">Contact Dolphin Centrifuge for pricing, availability, and application evaluation. Free sample testing available for qualifying applications.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold/80 text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Quote</a>
      <a href="/industrial-centrifuge-sample-testing/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">Free Sample Testing</a>
      <a href="tel:+12485222573" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">(248) 522-2573</a>
    </div>
  </div>

</ApplicationLayout>
