const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Disc Centrifuge Won't Reach Operating Speed: 10 Causes & Fixes",
    "description": "10 reasons a disc stack centrifuge cannot reach rated RPM: friction clutch, motor, bearings, and drive issues with diagnosis and fix steps. Dolphin Centrifuge.",
    "author": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
