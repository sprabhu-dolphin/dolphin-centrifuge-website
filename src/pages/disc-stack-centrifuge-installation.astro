>

  <!-- Hero Section -->
  <section class="bg-[#1B3A5C] text-white relative overflow-hidden">
    <div class="container mx-auto px-4 py-12 md:py-16">
      <div class="grid md:grid-cols-2 gap-8 items-center max-w-6xl mx-auto">
        <div>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading leading-tight mb-4">
            Disc Stack Centrifuge Installation
          </h1>
          <p class="text-lg md:text-xl text-gray-200 mb-6">
            An Illustrated Step-by-Step Guide to Proper Storage, Placement, Piping, and Utility Connections
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="tel:+12485222573" class="inline-flex items-center bg-[#E8A317] text-white font-semibold px-6 py-3 rounded-lg hover:bg-yellow-600 transition">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              (248) 522-2573
            </a>
            <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center border-2 border-white text-white font-semibold px-6 py-3 rounded-lg hover:bg-white/10 transition">
