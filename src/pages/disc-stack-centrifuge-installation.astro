const toc = [
  { id: 'storage-before-installation', label: 'Storage Before Installation' },
  { id: 'physical-installation', label: 'Physical Installation' },
  { id: 'indoor-and-outdoor-installations', label: 'Indoor and Outdoor Installations' },
  { id: 'centrifuge-location-in-relation-to-accessory-tanks', label: 'Centrifuge Location & Accessory Tanks' },
  { id: 'location-of-electrical-control-system', label: 'Location of Electrical Control System' },
  { id: 'piping', label: 'Piping' },
  { id: 'utilities', label: 'Utilities' },
  { id: 'venting', label: 'Venting' },
  { id: 'summary', label: 'Summary' },
