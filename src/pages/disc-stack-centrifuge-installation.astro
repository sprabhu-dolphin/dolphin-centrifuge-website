const relatedApplications = [
  { label: 'Disc Centrifuge Backpressure Guide', href: '/disc-centrifuge-backpressure/' },
  { label: 'Disc Stack Centrifuge Operating Water', href: '/disc-stack-centrifuge-operating-water/' },
  { label: 'Industrial Centrifuge Controls', href: '/industrial-centrifuge-controls/' },
  { label: 'Disc Stack Centrifuge FAQ', href: '/disc-stack-centrifuge-faq/' },
  { label: 'Disadvantages of a Disc-Stack Centrifuge', href: '/disadvantages-disc-stack-centrifuge/' },
