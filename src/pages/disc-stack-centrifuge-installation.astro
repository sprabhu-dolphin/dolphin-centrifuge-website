---
import BaseLayout from '../layouts/BaseLayout.astro';

const defined = {
  title: 'Disc Stack Centrifuge Installation Guide | Dolphin',
  description: 'Illustrated guide to disc stack centrifuge installation covering storage, clearances, foundation requirements, piping, utilities, venting, and tank placement.',
  canonicalUrl: 'https://dolphincentrifuge.com/disc-stack-centrifuge-installation/',
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What clearances are required around a disc stack centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Disc stack centrifuges require a minimum of 36 inches clearance on the service side (for bowl removal) and 24 inches on other sides. Overhead clearance must accommodate bowl lift during service — typically 4–6 feet above the bowl top. Always consult the specific centrifuge model's installation manual for exact clearance requirements."
      }
    },
    {
      "@type": "Question",
      "name": "Does a disc stack centrifuge require a special foundation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most disc stack centrifuges can be installed on a standard reinforced concrete floor rated for the centrifuge weight plus dynamic loads. Anti-vibration mounts are recommended to isolate normal operating vibration from the building structure. Some larger models may require anchor bolts into the floor. The floor must be level to within 2mm across the centrifuge base frame."
      }
    },
    {
      "@type": "Question",
      "name": "What utilities does a disc stack centrifuge require?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A disc stack centrifuge typically requires: (1) Electrical power — 230/460 VAC three-phase for the main motor; (2) Operating water — clean water at 10–15 PSI for bowl ejection cycles; (3) Compressed air — 80–100 PSI for pneumatically operated valves (if equipped); (4) Steam or hot water for feed preheating (if heaters are not electric). Specific utilities depend on the model and configuration."
      }
    },
    {
      "@type": "Question",
      "name": "Can a disc stack centrifuge be installed outdoors?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Standard disc stack centrifuges are not designed for outdoor installation — they require shelter from rain, direct sunlight, and freezing temperatures. For outdoor or remote applications, a weatherproof enclosure or containerized centrifuge system (ISO container) provides the necessary protection. Explosion-proof models can be specified for outdoor hazardous area locations."
      }
    },
    {
      "@type": "Question",
      "name": "How high should the feed and discharge tanks be positioned relative to the centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The feed tank should ideally be positioned above the centrifuge feed pump to provide positive suction head. The clean oil discharge tank should be at or below the centrifuge discharge level to avoid back pressure from static head. Sludge and water discharge lines should drain by gravity to collection tanks — avoid any upward runs that create back pressure on centrifuge discharge ports."
      }
    }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": defined.title,
  "description": defined.description,
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu",
    "jobTitle": "Engineering Manager",
    "affiliation": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  },
  "datePublished": "2021-03-01",
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://dolphincentrifuge.com/images/Dolphin-Centrifuge.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": defined.canonicalUrl
  },
  "image": "https://dolphincentrifuge.com/images/disc-stack-centrifuge-installation/Alfa-Laval-Centrifuge-Installation-Manual.webp"
};
---

