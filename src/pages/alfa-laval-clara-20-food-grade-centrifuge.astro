---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Alfa Laval Clara 20 Disc Centrifuge | Food and Fermentation",
  "description": "Alfa Laval Clara 20 disc centrifuge module for edible oil, beverage, and fermentation applications. Reconditioned separator with new USA-made controls, skid, and piping. Supplied by Dolphin Centrifuge.",
  "url": "https://dolphincentrifuge.com/alfa-laval-clara-20-food-grade-centrifuge/",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" }
};

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval Clara 20 Food Grade Disc Centrifuge Module",
  "description": "Alfa Laval Clara 20 disc centrifuge module for edible oil, beverage, and fermentation applications. Reconditioned separator with new USA-made controls, skid, and piping.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/alfa-laval-clara-20-food-grade-centrifuge/",
};

const jsonLd = [articleJsonLd, productJsonLd];

const toc = [
  { id: 'overview', label: 'Overview' },
  { id: 'clarification-technology', label: 'Clarification Technology' },
  { id: 'applications', label: 'Key Processing Applications' },
  { id: 'specifications', label: 'Technical Specifications' },
  { id: 'module-features', label: 'Dolphin Module Features' },
];

const relatedProducts = [
  { label: 'Disc Stack Centrifuge Overview', href: '/disc-stack-centrifuge/', description: 'Complete disc stack centrifuge systems' },
  { label: 'Stainless Steel Centrifuges', href: '/stainless-steel-centrifuge/', description: 'Hygienic stainless steel models' },
];

const relatedApplications = [
  { label: 'Food Grade Centrifuge Systems', href: '/food-grade-centrifuge/' },
  { label: 'Beer & Wine Centrifuge', href: '/beer-wine-centrifuge/' },
  { label: 'All Centrifuge Applications', href: '/disc-stack-centrifuge-applications/' },
];
---

<ApplicationLayout
  title="Alfa Laval Clara 20 Disc Centrifuge | Food and Fermentation"
  pageTitle="Alfa Laval Clara 20 Centrifuge Module"
  disableTitleSuffix={true}
  description="Alfa Laval Clara 20 disc centrifuge module for edible oil, beverage, and fermentation applications. Reconditioned separator with new USA-made controls, skid, and piping. Supplied by Dolphin Centrifuge."
  heroImage="/images/alfa-laval-clara-20-food-grade-centrifuge/Alfa_Laval_Clara-20_Centrifuge_Module_Dolphin_Centrifuge_Hero.webp"
  heroImageAlt="Alfa Laval Clara 20 Centrifuge Module Skid with New USA Controls"
  category="products"
  categoryLabel="Products"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-clara-20-food-grade-centrifuge/"
  jsonLd={jsonLd}
  toc={toc}
  relatedProducts={relatedProducts}
  relatedApplications={relatedApplications}
>

  <!-- Overview -->
  <h2 id="overview">Alfa Laval Clara 20 Centrifuge Module</h2>

  <h3>Premium Edible Oil &amp; Beverage Clarification System</h3>

  <p>
    The Alfa Laval Clara 20 Centrifuge Module by <a href="/about-dolphin-centrifuge/">Dolphin Centrifuge</a> combines a professionally reconditioned Clara 20 separator with brand-new, USA-made controls, skid, and piping. This fully automatic, self-cleaning <a href="/disc-stack-centrifuge/">disc stack separator</a> is the industry standard for high-volume Edible Oil Purification and demanding Beverage Clarification, delivering maximum yield and superior product quality.
  </p>

  <figure class="not-prose">
    <img
      src="/images/alfa-laval-clara-20-food-grade-centrifuge/Alfa_Laval_LAPX-404_Clara_20_850.webp"
      alt="Alfa Laval Clara 20 Centrifuge Module — Dolphin Centrifuge"
      loading="lazy"
      width="850"
      height="850"
      class="img-cap-400"
    />
    <figcaption>Alfa Laval Clara 20 Centrifuge Module — Dolphin Centrifuge</figcaption>
  </figure>


  <!-- Superior Clarification Technology -->
  <h2 id="clarification-technology">Superior Clarification Technology</h2>
  <p>
    The Clara 20 is specifically designed as a high-performance clarifier for removing solids from liquids:
  </p>
  <ul>
    <li><strong>Clarifier Execution</strong> — Removes fine solid impurities from a single liquid phase with exceptional efficiency. Ideal for beverage clarification and oil polishing.</li>
    <li><strong>Gentle Product Handling</strong> — Unique design ensures gentle treatment of sensitive products like fruit juices, wines, and teas.</li>
  </ul>
  <p>
    All wetted parts are made of high-grade stainless steel (s.s. 1.4462 UNS S31803 / 1.4401 UNS 31600).
  </p>

  <!-- Applications -->
  <h2 id="applications">Key Processing Applications</h2>

  <h3>Edible Oil Polishing</h3>
  <p>
    Ideally suited for the final polishing of vegetable and animal oils, efficiently removing residual fines, gums, and soapstock to improve quality and extend shelf life.
  </p>

  <h3>Beverage Clarification</h3>
  <p>
    Provides high clarity for fruit juices, wine, beer, tea, and coffee extracts by efficiently removing haze-forming particles and suspended solids.
  </p>

  <h3>Fermentation Broths</h3>
  <p>
    Excellent for clarifying broths and harvesting biomass in industrial fermentation processes, maximizing product recovery and separation efficiency.
  </p>

  <figure class="not-prose">
    <img
      src="/images/alfa-laval-clara-20-food-grade-centrifuge/LAPX-404-Bowl-Cross-Section.webp"
      alt="Alfa Laval Clara 20 Bowl Cross-Section"
      loading="lazy"
      width="602"
      height="722"
      class="img-cap-600"
    />
    <figcaption>Alfa Laval Clara 20 Bowl Cross-Section</figcaption>
  </figure>

  <!-- Specifications -->
  <h2 id="specifications">Technical Specifications (Clara 20)</h2>
  <div class="overflow-x-auto mb-8 not-prose">
    <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
      <tbody>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Max. Throughput (High Flow)</td>
          <td class="px-4 py-3 font-mono text-text-light">17.6 GPM (4,000 l/h)</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Max. Throughput (Low Flow)</td>
          <td class="px-4 py-3 font-mono text-text-light">4.4 GPM (1,000 l/h)</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Bowl Speed</td>
          <td class="px-4 py-3 font-mono text-text-light">9,512 RPM</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Max. G-Force</td>
          <td class="px-4 py-3 font-mono text-text-light">11,130 g</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Motor Power</td>
          <td class="px-4 py-3 font-mono text-text-light">5.0 HP (3.7 kW)</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Bowl Liquid Volume</td>
          <td class="px-4 py-3 font-mono text-text-light">0.6 Gal (2.2 L)</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Sludge Space Volume</td>
          <td class="px-4 py-3 font-mono text-text-light">~0.3 Gal (1.1 L)</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Net Weight (Module incl. Bowl)</td>
          <td class="px-4 py-3 font-mono text-text-light">827 Lbs (375 kg)</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-semibold text-navy">Module Dimensions (LxWxH)</td>
          <td class="px-4 py-3 font-mono text-text-light">59" x 31.5" x 57"</td>
        </tr>
      </tbody>
    </table>
  </div>
  <p class="text-sm text-text-light italic mb-8">&#8224;Actual capacity depends on process liquid characteristics and required clarity.</p>

  <!-- Dolphin Integrated Module Features -->
  <h2 id="module-features">Dolphin Integrated Module Features</h2>

  <h3>New Domestic Components &amp; Integration</h3>
  <p>
    While the core centrifuge is a professionally reconditioned Alfa Laval Clara 20, the entire support module is newly manufactured in the USA:
  </p>
  <ul>
    <li><strong>New Control Panel:</strong> Domestic PLC and Touchscreen control system for intuitive operation and monitoring.</li>
    <li><strong>New Skid &amp; Piping:</strong> Custom-fabricated stainless steel skid with all-new process piping.</li>
    <li><strong>New Wiring &amp; Pneumatics:</strong> Completely new electrical wiring and pneumatic systems.</li>
    <li><strong>Fully Tested:</strong> The complete module undergoes rigorous testing before shipment.</li>
  </ul>

  <h3>Advanced Functionality</h3>
  <ul>
    <li><strong>Self-Cleaning Bowl:</strong> Automatically discharges solids for continuous operation.</li>
    <li><strong>VFD Operation:</strong> Variable Frequency Drive for smooth starting, optimized speed control, and energy efficiency.</li>
    <li><strong>Integrated Automation:</strong> Includes automatic feed valve, flow meter with totalizer, and pressure indicators.</li>
    <li><strong>Small Footprint:</strong> Compact mobile design minimizes required floor space for installation.</li>
  </ul>


</ApplicationLayout>
