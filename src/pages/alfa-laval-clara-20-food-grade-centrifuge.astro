---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Alfa Laval Clara 20 Food Grade Centrifuge — Edible Oil & Beverage Clarification",
  "description": "Complete guide to the Alfa Laval Clara 20 disc centrifuge module for edible oil polishing and beverage clarification. 4,000 l/h, 11,130 g, CIP compatible. Supplied by Dolphin Centrifuge.",
  "url": "https://dolphincentrifuge.com/alfa-laval-clara-20-food-grade-centrifuge/",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" }
};

const jsonLd = [
  articleJsonLd,
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Alfa Laval Clara 20 Food Grade Disc Centrifuge Module",
    "description": "Alfa Laval Clara 20 disc centrifuge module for edible oil, beverage, and fermentation applications. Reconditioned separator with new USA-made controls, skid, and piping.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
    "url": "https://dolphincentrifuge.com/alfa-laval-clara-20-food-grade-centrifuge/",
  },
];

const toc = [
  { id: 'overview', label: 'Overview' },
  { id: 'clarification-technology', label: 'Clarification Technology' },
  { id: 'applications', label: 'Applications' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'module-features', label: 'Dolphin Module Features' },
  { id: 'material-of-construction', label: 'Material of Construction' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedProducts = [
  { label: 'Disc Stack Centrifuge Overview', href: '/disc-stack-centrifuge/', description: 'Complete disc stack centrifuge systems' },
  { label: 'Stainless Steel Centrifuges', href: '/stainless-steel-centrifuge/', description: 'Hygienic stainless steel models' },
];

const relatedApplications = [
  { label: 'Food Grade Centrifuge Systems', href: '/food-grade-centrifuge/' },
  { label: 'Beer & Wine Centrifuge', href: '/beer-wine-centrifuge/' },
  { label: 'All Centrifuge Applications', href: '/disc-stack-centrifuge-applications/' },
];
---

<ApplicationLayout
  title="Clara 20 Food Grade Centrifuge | Dolphin Centrifuge"
  description="Alfa Laval Clara 20 disc centrifuge module — edible oil polishing and beverage clarification. 4,000 l/h, 11,130 g, new USA controls. Dolphin Centrifuge."
  heroImage="/images/alfa-laval-clara-20-food-grade-centrifuge/LAPX-404-Bowl-Cross-Section.webp"
  heroImageAlt="Alfa Laval Clara 20 Food Grade Disc Centrifuge Module Skid"
  category="products"
  categoryLabel="Products"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-clara-20-food-grade-centrifuge/"
  jsonLd={jsonLd}
  toc={toc}
  relatedProducts={relatedProducts}
  relatedApplications={relatedApplications}
>

  <!-- AI Summary — 42 words -->
  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">The Alfa Laval Clara 20 is a self-cleaning disc stack centrifuge module for edible oil polishing and beverage clarification, processing up to 4,000 l/h at 11,130 g-force with stainless steel wetted surfaces. Dolphin Centrifuge supplies reconditioned Clara 20 modules with new USA-made controls from Warren, Michigan.</p>
  </div>

  <!-- Overview -->
  <h2 id="overview">Alfa Laval Clara 20 Centrifuge Module</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-1/2">
      <p>
        The Alfa Laval Clara 20 Centrifuge Module by <a href="/about-dolphin-centrifuge/">Dolphin Centrifuge</a> combines a professionally reconditioned Clara 20 separator with brand-new, USA-made controls, skid, and piping. This fully automatic, self-cleaning <a href="/disc-stack-centrifuge/">disc stack separator</a> is the industry standard for high-volume edible oil purification and demanding beverage clarification, delivering maximum yield and superior product quality.
      </p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/alfa-laval-clara-20-food-grade-centrifuge/LAPX-404-Bowl-Cross-Section.webp"
        alt="Alfa Laval Clara 20 Centrifuge Module Skid with New USA Controls"
        loading="lazy"
        width="602"
        height="722"
        class="rounded-xl shadow-md w-full"
      />
    </div>
  </div>

  <!-- Superior Clarification Technology -->
  <h2 id="clarification-technology">Superior Clarification Technology</h2>
  <p>
    The Clara 20 is specifically designed as a high-performance clarifier for removing solids from liquids:
  </p>
  <ul class="mb-6">
    <li><strong>Clarifier Execution</strong> — Removes fine solid impurities from a single liquid phase with exceptional efficiency. Ideal for beverage clarification and oil polishing.</li>
    <li><strong>Gentle Product Handling</strong> — Unique design ensures gentle treatment of sensitive products like fruit juices, wines, and teas.</li>
  </ul>
  <p>
    All wetted parts are made of high-grade stainless steel (s.s. 1.4462 UNS S31803 / 1.4401 UNS 31600). The machine is designed for clean-in-place (CIP) sanitation — a critical requirement for <a href="/food-grade-centrifuge/">food-grade operations</a>. Seals and gaskets are FDA-compliant elastomers (EPDM or PTFE depending on configuration), and the control panel can be configured for automated CIP sequences. Dolphin Centrifuge provides full <a href="/industrial-disc-centrifuge-repair/">disc centrifuge repair and service</a> for Clara 20 units, including <a href="/disc-stack-centrifuge-parts/">replacement parts</a> and field service.
  </p>

  <!-- Applications -->
  <h2 id="applications">Key Processing Applications</h2>

  <h3>Edible Oil Polishing</h3>
  <p>
    Ideally suited for the final polishing of vegetable and animal oils, efficiently removing residual fines, gums, and soapstock to improve quality and extend shelf life.
  </p>

  <h3>Beverage Clarification</h3>
  <p>
    Provides high clarity for fruit juices, wine, beer, tea, and coffee extracts by efficiently removing haze-forming particles and suspended solids.
  </p>

  <h3>Fermentation Broths</h3>
  <p>
    Excellent for clarifying broths and harvesting biomass in industrial fermentation processes, maximizing product recovery and separation efficiency.
  </p>

  <div class="grid md:grid-cols-2 gap-x-8 gap-y-2 mb-8 not-prose">
    <ul class="text-text-light space-y-2">
      <li>&#8226; Edible oil polishing (vegetable and animal oils)</li>
      <li>&#8226; <a href="/beer-wine-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Beer and ale clarification</a></li>
      <li>&#8226; <a href="/beer-wine-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Wine clarification and stabilization</a></li>
      <li>&#8226; Cider and hard seltzer clarification</li>
    </ul>
    <ul class="text-text-light space-y-2">
      <li>&#8226; <a href="/food-grade-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Juice and beverage clarification</a></li>
      <li>&#8226; Tea and coffee extract clarification</li>
      <li>&#8226; Fermentation broth processing</li>
      <li>&#8226; Yeast removal and harvesting</li>
    </ul>
  </div>

  <!-- Specifications -->
  <h2 id="specifications">Clara 20 Technical Specifications</h2>
  <div class="overflow-x-auto mb-8 not-prose">
    <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
      <tbody>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Centrifuge Model</td>
          <td class="px-4 py-3 font-mono text-text-light">Alfa Laval Clara 20</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Max. Throughput (High Flow)</td>
          <td class="px-4 py-3 font-mono text-text-light">17.6 GPM (4,000 l/h)</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Max. Throughput (Low Flow)</td>
          <td class="px-4 py-3 font-mono text-text-light">4.4 GPM (1,000 l/h)</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Bowl Speed</td>
          <td class="px-4 py-3 font-mono text-text-light">9,512 RPM</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Max. G-Force</td>
          <td class="px-4 py-3 font-mono text-text-light">11,130 g</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Motor Power</td>
          <td class="px-4 py-3 font-mono text-text-light">5.0 HP (3.7 kW)</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Bowl Liquid Volume</td>
          <td class="px-4 py-3 font-mono text-text-light">0.6 Gal (2.2 L)</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Sludge Space Volume</td>
          <td class="px-4 py-3 font-mono text-text-light">~0.3 Gal (1.1 L)</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Bowl Type</td>
          <td class="px-4 py-3 font-mono text-text-light">Self-Cleaning (Automatic Discharge)</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Wetted Material</td>
          <td class="px-4 py-3 font-mono text-text-light">Stainless Steel (1.4462 / 1.4401)</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Seals</td>
          <td class="px-4 py-3 font-mono text-text-light">FDA-Compliant EPDM / PTFE</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Sanitation</td>
          <td class="px-4 py-3 font-mono text-text-light">CIP Compatible</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Net Weight (Module incl. Bowl)</td>
          <td class="px-4 py-3 font-mono text-text-light">827 Lbs (375 kg)</td>
        </tr>
        <tr class="bg-gray-50">
          <td class="px-4 py-3 font-semibold text-navy">Module Dimensions (L x W x H)</td>
          <td class="px-4 py-3 font-mono text-text-light">59" x 31.5" x 57"</td>
        </tr>
      </tbody>
    </table>
  </div>
  <p class="text-sm text-text-light italic mb-8">Actual capacity depends on process liquid characteristics and required clarity.</p>

  <!-- Dolphin Integrated Module Features -->
  <h2 id="module-features">Dolphin Integrated Module Features</h2>

  <h3>New Domestic Components &amp; Integration</h3>
  <p>
    While the core centrifuge is a professionally reconditioned Alfa Laval Clara 20, the entire support module is newly manufactured in the USA:
  </p>
  <ul class="mb-6">
    <li><strong>New Control Panel</strong> — Domestic PLC and touchscreen control system for intuitive operation and monitoring.</li>
    <li><strong>New Skid &amp; Piping</strong> — Custom-fabricated stainless steel skid with all-new process piping.</li>
    <li><strong>New Wiring &amp; Pneumatics</strong> — Completely new electrical wiring and pneumatic systems.</li>
    <li><strong>Fully Tested</strong> — The complete module undergoes rigorous testing before shipment.</li>
  </ul>

  <h3>Advanced Functionality</h3>
  <ul class="mb-6">
    <li><strong>Self-Cleaning Bowl</strong> — Automatically discharges solids for continuous operation.</li>
    <li><strong>VFD Operation</strong> — Variable Frequency Drive for smooth starting, optimized speed control, and energy efficiency.</li>
    <li><strong>Integrated Automation</strong> — Includes automatic feed valve, flow meter with totalizer, and pressure indicators.</li>
    <li><strong>Small Footprint</strong> — Compact mobile design minimizes required floor space for installation.</li>
  </ul>

  <p>
    For <a href="/industrial-centrifuge-sample-testing/">sample testing</a> or application review, contact Dolphin Centrifuge to discuss your specific separation requirements.
  </p>

  <!-- Material of Construction -->
  <h2 id="material-of-construction">Material of Construction</h2>
  <div class="overflow-x-auto mb-8 not-prose">
    <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
      <tbody>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Bowl Body &amp; Hood</td>
          <td class="px-4 py-3 text-text-light">Stainless Steel (1.4462 UNS S31803 / 1.4401 UNS 31600)</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Disc Stack</td>
          <td class="px-4 py-3 text-text-light">Stainless Steel (1.4462 / 1.4401)</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Inlet / Outlet Connections</td>
          <td class="px-4 py-3 text-text-light">Stainless Steel — Hygienic Tri-Clamp or DIN</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Seals &amp; Gaskets</td>
          <td class="px-4 py-3 text-text-light">FDA-Compliant EPDM (standard); PTFE (optional)</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-semibold text-navy">Frame</td>
          <td class="px-4 py-3 text-text-light">Stainless Steel (exterior-polished)</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Mid-page CTA -->
  <div class="not-prose bg-gold/10 border border-gold rounded-xl p-6 my-8 text-center">
    <p class="text-lg font-bold text-navy mb-2">Upgrade Your Edible Oil or Beverage Processing with Clara 20</p>
    <p class="text-sm text-text-light mb-4">Dolphin Centrifuge supplies Clara 20 modules with new USA-made controls, skid, and piping. Contact us for pricing and application review.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold/80 text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Get a Quote</a>
      <a href="tel:+12485222573" class="inline-flex items-center gap-2 border border-navy/20 hover:border-gold text-navy font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
    </div>
  </div>

  <!-- FAQ Section -->
  <div id="faq" class="mt-12 mb-8">
    <h2 class="text-2xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
    <div class="space-y-4 not-prose">
      <details class="border-l-4 border-gold/40 rounded-xl p-5">
        <summary class="font-semibold text-navy cursor-pointer">What applications is the Alfa Laval Clara 20 used for?</summary>
        <p class="text-text-light mt-3 text-sm">The Alfa Laval Clara 20 is a food-grade disc centrifuge used for edible oil polishing, <a href="/beer-wine-centrifuge/">beer and ale clarification</a>, wine clarification and stabilization, cider processing, juice and beverage clarification, fermentation broth processing, and yeast removal and harvesting. Its stainless steel construction and CIP-compatible design make it suitable for hygienic food and beverage production environments.</p>
      </details>
      <details class="border-l-4 border-gold/40 rounded-xl p-5">
        <summary class="font-semibold text-navy cursor-pointer">What is the maximum throughput of the Clara 20?</summary>
        <p class="text-text-light mt-3 text-sm">The Alfa Laval Clara 20 has a maximum throughput of approximately 4,000 l/h (17.6 GPM) at high flow and 1,000 l/h (4.4 GPM) at low flow, depending on the application and feed characteristics. Actual capacity depends on process liquid characteristics and required clarity. <a href="/contact-for-alfa-laval-centrifuges/">Contact Dolphin Centrifuge</a> for application-specific sizing.</p>
      </details>
      <details class="border-l-4 border-gold/40 rounded-xl p-5">
        <summary class="font-semibold text-navy cursor-pointer">Is the Clara 20 CIP compatible?</summary>
        <p class="text-text-light mt-3 text-sm">Yes. The Alfa Laval Clara 20 features full clean-in-place (CIP) design with stainless steel product-contact surfaces, FDA-compliant EPDM or PTFE seals and gaskets, and hygienic tri-clamp or DIN connections. The control panel can be configured for automated CIP sequences, making it suitable for 24/7 <a href="/food-grade-centrifuge/">food-grade centrifuge</a> production environments.</p>
      </details>
      <details class="border-l-4 border-gold/40 rounded-xl p-5">
        <summary class="font-semibold text-navy cursor-pointer">What does the Dolphin Centrifuge Clara 20 module include?</summary>
        <p class="text-text-light mt-3 text-sm">The Dolphin Centrifuge Clara 20 module combines a professionally reconditioned Alfa Laval Clara 20 separator with brand-new, USA-made components including a domestic PLC and touchscreen control panel, custom-fabricated stainless steel skid with all-new process piping, new electrical wiring and pneumatic systems, and VFD operation. The complete module is rigorously tested before shipment.</p>
      </details>
      <details class="border-l-4 border-gold/40 rounded-xl p-5">
        <summary class="font-semibold text-navy cursor-pointer">What material of construction is used in the Clara 20?</summary>
        <p class="text-text-light mt-3 text-sm">All wetted parts of the Alfa Laval Clara 20 are made of high-grade stainless steel (1.4462 UNS S31803 / 1.4401 UNS 31600). Seals and gaskets are FDA-compliant EPDM (standard) or PTFE (optional). Hygienic tri-clamp or DIN connections are used throughout, making the Clara 20 suitable for <a href="/food-grade-centrifuge/">food, beverage, and pharmaceutical</a> production environments.</p>
      </details>
    </div>
  </div>

  <!-- Bottom CTA -->
  <div class="bg-navy rounded-xl p-8 text-center mt-12 not-prose">
    <h2 class="text-2xl font-bold text-white mb-3">Upgrade Your Separation Process with the Clara 20 Module</h2>
    <p class="text-gray-300 mb-6 max-w-lg mx-auto">Contact Dolphin Centrifuge for pricing, availability, and application review. Paid <a href="/industrial-centrifuge-sample-testing/" class="text-gold hover:text-gold-light underline">sample testing</a> is available for qualifying applications.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Quote</a>
      <a href="tel:+12485222573" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">(248) 522-2573</a>
    </div>
  </div>

</ApplicationLayout>
