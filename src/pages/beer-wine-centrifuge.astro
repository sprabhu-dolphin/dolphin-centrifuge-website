---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "How much beer can a centrifuge recover from fermentation tank bottoms?",
    answer: "Tank bottom slurry typically contains 80% or more recoverable beer. A disc stack centrifuge processes this slurry and recovers 5–10% more sellable beer per batch — bright, quality product that would otherwise be lost to the drain or sold as animal feed. For a mid-size brewery, this recovery alone can pay for the centrifuge system."
  },
  {
    question: "Can a centrifuge replace diatomaceous earth (DE) filtration?",
    answer: "Yes. A disc stack centrifuge is a purely mechanical separator that produces bright beer without DE powder, filter sheets, or any consumable media. This eliminates DE purchase costs, disposal costs (DE is increasingly classified as hazardous waste), and the labor of filter setup and media changes. Many breweries use the centrifuge as their sole clarification step."
  },
  {
    question: "What capacity beer and wine centrifuges are available?",
    answer: "Dolphin Centrifuge beverage systems range from 26 GPM for mid-size wine operations to 52 GPM for large-format wine and 40 GPM for high-capacity beer clarification. All systems feature 316 stainless steel product-contact surfaces and food-grade seals. <a href='/contact-for-alfa-laval-centrifuges/'>Contact us</a> for sizing based on your production volume."
  },
  {
    question: "Can a beverage centrifuge process cider and fruit juice?",
    answer: "Yes. The same disc stack centrifuge technology handles hard cider, mead, kombucha, and fruit juice clarification. It removes pulp, pectin, yeast, and suspended solids for crystal-clear product without filtration aids. The centrifuge adapts to variable solids loading across different fruit varieties and seasons without performance degradation."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "url": "https://dolphincentrifuge.com/beer-wine-centrifuge/",
  "name": "Beer, Wine & Beverage Centrifuge System",
  "description": "Stainless steel disc stack centrifuges for beer clarification, wine polishing, cider and juice processing. Recover 5-10% more product from fermentation bottoms with food-grade separation at 7,000+ Gs.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const jsonLd = [productJsonLd, faqJsonLd];

const toc = [
  { id: 'overview', label: 'Overview' },
  { id: 'beer-centrifuge', label: 'Beer Centrifuge' },
  { id: 'benefits', label: 'Benefits of Beer Centrifuge' },
  { id: 'wine-centrifuge', label: 'Wine Centrifuge' },
  { id: 'cider-juice', label: 'Cider & Juice Clarification' },
  { id: 'specifications', label: 'Specifications' },
];

const relatedApplications = [
  { label: 'Food-Grade Centrifuge', href: '/food-grade-centrifuge/' },
  { label: 'Fish Processing Centrifuge', href: '/fish-processing-centrifuge/' },
  { label: 'Algae Centrifuge', href: '/algae-centrifuge/' },
];

const relatedProducts = [
  { label: 'Dolphin Beer Clarifier - 40 GPM', href: '/contact-for-alfa-laval-centrifuges/', description: 'High-capacity beer clarification system' },
  { label: 'Dolphin Wine Clarifier - 44 GPM', href: '/contact-for-alfa-laval-centrifuges/', description: 'Large-format wine clarification system' },
  { label: 'Dolphin Wine Clarifier - 26 GPM', href: '/contact-for-alfa-laval-centrifuges/', description: 'Mid-range wine and juice system' },
];
---

<ApplicationLayout
  title="Beer, Wine & Beverage Centrifuge"
  description="Stainless steel disc centrifuges for beer clarification, wine polishing, and cider processing. Recover 5–10% more product from tank bottoms. Dolphin Centrifuge."
  category="applications"
  categoryLabel="Applications"
  heroImage="/images/beer-wine-centrifuge/Alfa-Laval-BRPX309-Beer-Wine-Centrifuge.webp"
  heroImageAlt="Alfa Laval BRPX309 Beer Wine Centrifuge"
  canonicalUrl="https://dolphincentrifuge.com/beer-wine-centrifuge/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies food-grade stainless steel disc stack centrifuge systems for beer, wine, cider, and fruit juice clarification. Operating at 7,000+ Gs with separation down to 0.5 microns, these self-cleaning centrifuges remove yeast, sediment, and suspended solids continuously while recovering 5–10% more product from tank bottoms. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in food and beverage centrifugal clarification.</p>
  </div>

  <h2 id="overview">Disc Centrifuges for Beverage Clarification</h2>

  <p>Dolphin Centrifuge, based in Warren, Michigan, supplies purpose-built disc stack centrifuge systems for this application at 7000 Gs with separation down to 0.5 microns. Disc stack centrifuges are the industry standard for clarifying <strong>beer, wine, cider, and fruit juice</strong>. These food-grade stainless steel systems generate thousands of Gs of centrifugal force to separate yeast, sediment, pulp, and other suspended solids from the finished beverage &mdash; continuously, without filter media or consumables.
  </p>

  <p>
    Unlike plate-and-frame filters or diatomaceous earth (DE) systems, a centrifuge operates as a <strong>purely mechanical separator</strong>. There are no filter sheets to replace, no DE to purchase and dispose of, and no risk of taste or aroma stripping from excessive filtration. The centrifuge simply spins the beverage at high speed, forcing heavier particles outward while clean product exits through the center.
  </p>

  <p>
    All Dolphin beverage centrifuges are constructed with <strong>316 stainless steel</strong> product-contact surfaces and food-grade seals, meeting the hygiene requirements of brewing, winemaking, and juice processing facilities.
  </p>

  <!-- ── Beer Centrifuge ── -->
  <h2 id="beer-centrifuge">Beer Centrifuge</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start not-prose mb-6">
    <div class="md:w-1/3 flex-shrink-0">
      <img
        src="/images/beer-wine-centrifuge/Alfa-Laval-BRPX313-Beer-Wine-Centrifuge.webp"
        alt="Alfa Laval Beer and Wine Centrifuge BRPX 313"
        width="450"
        height="450"
        loading="lazy"
        class="rounded-lg w-full"
      />
    </div>
    <div class="md:w-2/3">
      <p class="text-gray-700 leading-relaxed">
        A beer centrifuge generates over <strong>7,000 Gs</strong> of centrifugal force to separate yeast, haze-forming proteins, and hop residue from beer. The disc stack design creates thin fluid layers between each disc, enabling separation of particles down to <strong>0.5 microns</strong> &mdash; well below the threshold for bright beer.
      </p>
    </div>
  </div>

  <p>
    One of the most valuable applications is <strong>recovering beer from fermentation tank bottoms</strong>. When a fermenter is drained, the yeast and trub slurry at the bottom typically contains <strong>80% or more recoverable beer</strong>. Without a centrifuge, this product is lost to the drain or sold as animal feed. A centrifuge processes this slurry and recovers <strong>5&ndash;10% more beer per batch</strong>, returning bright, sellable product to the process.
  </p>

  <h3>Beer Clarification Process</h3>
  <p>
    The centrifuge is typically installed <strong>between the fermenter and the bright beer tank</strong>. Beer flows through the centrifuge at rated capacity, and the separated yeast and sediment collect at the bowl periphery. Self-cleaning models automatically eject the accumulated solids at timed intervals, allowing continuous operation without manual intervention.
  </p>

  <p>
    The centrifuge can also be used for <strong>pre-filtration</strong> ahead of a membrane or sheet filter to extend filter life dramatically, or as the <strong>sole clarification step</strong> for craft breweries that prefer a less polished, naturally hazy product with reduced solids.
  </p>

  <!-- ── Benefits ── -->
  <h2 id="benefits">Benefits of a Beer Centrifuge</h2>

  <ul>
    <li><strong>Recover 5&ndash;10% more beer:</strong> Extract sellable beer from fermentation tank bottoms that would otherwise be discarded. At 80% beer content in typical tank bottoms, this represents significant revenue recovery</li>
    <li><strong>Eliminate filter media costs:</strong> No DE powder, no filter sheets, no cartridges. The centrifuge is a purely mechanical process with no consumables</li>
    <li><strong>Reduce labor and downtime:</strong> No filter setup, no media changes, no filter press cleaning. A centrifuge runs continuously with minimal operator attention</li>
    <li><strong>Multi-purpose operation:</strong> The same centrifuge handles bright beer clarification, tank bottom recovery, yeast harvesting, and pre-filtration &mdash; switching between tasks with a simple valve change</li>
    <li><strong>Consistent product quality:</strong> Centrifugal separation delivers repeatable results regardless of solids loading, unlike filters that degrade as they load</li>
    <li><strong>No oxygen pickup:</strong> Sealed, pressurized flow path minimizes dissolved oxygen exposure, preserving beer freshness and shelf life</li>
  </ul>

  <!-- Mid-Page CTA -->
  <div class="bg-gradient-to-r from-[#1B3A5C] to-[#2a4f7a] rounded-xl p-6 md:p-8 text-white my-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <h3 class="text-xl font-bold mb-2">Need a Beverage Centrifuge System?</h3>
        <p class="text-blue-100">Our engineers will evaluate your brewery or winery production volume and recommend the optimal centrifuge system.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] hover:bg-yellow-500 text-white font-semibold px-6 py-3 rounded-lg transition whitespace-nowrap">Get a Quote</a>
        <a href="tel:+12485222573" class="border border-white text-white hover:bg-white hover:text-[#1B3A5C] font-semibold px-6 py-3 rounded-lg transition whitespace-nowrap">(248) 522-2573</a>
      </div>
    </div>
  </div>

  <!-- ── Wine Centrifuge ── -->
  <h2 id="wine-centrifuge">Wine Centrifuge</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start not-prose mb-6">
    <div class="md:w-1/3 flex-shrink-0">
      <img
        src="/images/beer-wine-centrifuge/Alfa-Laval-Food-Grade-Centrifuge-AFPX213.webp"
        alt="Alfa Laval Food Grade Centrifuge AFPX213 for wine clarification"
        width="450"
        height="450"
        loading="lazy"
        class="rounded-lg w-full"
      />
    </div>
    <div class="md:w-2/3">
      <p class="text-gray-700 leading-relaxed">
        Wine clarification presents unique challenges compared to beer processing. Wines contain a wide range of suspended solids &mdash; from coarse grape solids and yeast lees to fine colloidal particles that affect clarity and stability. A disc stack centrifuge handles all of these in a single pass.
      </p>
    </div>
  </div>

  <h3>Must Clarification</h3>
  <p>
    Freshly pressed grape must (juice) contains grape skin fragments, pulp, seeds, and pectins that must be removed before fermentation. Centrifugal clarification produces clean must in <strong>minutes</strong> rather than the 12&ndash;24 hours required for cold settling. This speed is critical during crush season when tank space is at a premium.
  </p>

  <h3>Lees Clarification</h3>
  <p>
    After fermentation, wine is racked off its lees (dead yeast sediment). The lees slurry typically contains <strong>60&ndash;75% recoverable wine</strong>. A centrifuge processes this slurry and returns clear wine to the process, recovering product that would otherwise be lost. This is analogous to beer tank bottom recovery and delivers similar economic benefits.
  </p>

  <h3>Finished Wine Polishing</h3>
  <p>
    Before bottling, wine requires final polishing to remove residual haze-forming particles. The centrifuge delivers <strong>brilliant clarity</strong> without the risk of stripping flavor or aroma compounds, which can occur with excessive pad filtration. Many premium wineries use centrifugal clarification as their primary or sole clarification method.
  </p>

  <h3>Fermentation Control for Dessert Wines</h3>
  <p>
    For sweet wines and dessert wines, fermentation must be stopped at a precise residual sugar level. A centrifuge rapidly removes active yeast from the wine, halting fermentation without the use of <strong>sulfur dioxide</strong> or other chemical additives. This produces a cleaner, more naturally sweet wine.
  </p>

  <!-- ── Cider & Juice ── -->
  <h2 id="cider-juice">Cider &amp; Juice Clarification</h2>

  <p>
    Hard cider and fruit juice production benefit from the same centrifugal clarification principles used in beer and wine processing. Freshly pressed apple, pear, or citrus juice contains pulp, pectins, and yeast that must be removed for a clear, shelf-stable product.
  </p>

  <p>
    A disc stack centrifuge provides <strong>high-efficiency clarification</strong> with several advantages over traditional juice processing methods:
  </p>

  <ul>
    <li><strong>No manual filter changes:</strong> Unlike plate-and-frame filters that require frequent sheet replacement during heavy pulp loads, the centrifuge ejects solids automatically and runs continuously</li>
    <li><strong>Handles variable solids loading:</strong> Fruit juice solids content varies widely by variety, season, and pressing method. A centrifuge adapts to these variations without performance degradation</li>
    <li><strong>Preserves fresh flavor:</strong> Mechanical separation avoids the flavor-stripping effects of tight filtration or fining agents</li>
    <li><strong>Cost savings:</strong> Eliminates ongoing filter media purchases and reduces labor for filter maintenance. For high-volume operations, the centrifuge pays for itself through media cost savings alone</li>
    <li><strong>Rapid processing:</strong> During harvest season, the ability to process juice immediately &mdash; rather than waiting for settling &mdash; frees tank space and prevents spoilage</li>
  </ul>

  <p>
    Cider producers also use the centrifuge for <strong>yeast removal</strong> at the end of fermentation, providing the same fermentation-control benefits described for dessert wines.
  </p>

  <!-- ── Specifications ── -->
  <h2 id="specifications">Available Systems &mdash; Specifications</h2>

  <p>
    Dolphin offers a range of beverage centrifuge systems sized for craft producers through mid-scale commercial operations. All systems feature 316 stainless steel product-contact surfaces and food-grade seals.
  </p>

  <table>
    <thead>
      <tr>
        <th>System</th>
        <th>Capacity</th>
