      </tr>
    </thead>
    <tbody>
      <tr>
        <td><strong>Beer Clarifier &ndash; 40 GPM</strong></td>
        <td>40 GPM</td>
        <td>20 HP</td>
        <td>4,150 RPM</td>
        <td>6,500 Gs</td>
        <td>4' &times; 5' &times; 6'</td>
        <td>3,500 lbs</td>
      </tr>
      <tr>
        <td><strong>Beer Clarifier &ndash; 30 GPM</strong></td>
        <td>30 GPM</td>
        <td>10 HP</td>
        <td>5,200 RPM</td>
        <td>6,700 Gs</td>
        <td>4' &times; 5' &times; 6'</td>
