---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Disc Stack Centrifuge — Top 10 Mechanical Issues & Fixes",
  "description": "Comprehensive troubleshooting guide for disc stack centrifuge mechanical problems: excessive vibration, unusual smell, noise, low speed, high/low startup current, long start/stop times, water in gearbox, oil leaks.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Engineering Manager",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  },
  "datePublished": "2021-01-01",
  "dateModified": "2026-01-01",
  "mainEntityOfPage": "https://dolphincentrifuge.com/disc-stack-centrifuge-mechanical-issues-fixes/"
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Why is my disc stack centrifuge vibrating excessively?",
      "acceptedAnswer": { "@type": "Answer", "text": "Excessive vibration in a disc stack centrifuge is most commonly caused by an unbalanced bowl due to uneven sludge accumulation, worn or failed bearings, a bent spindle, or disc stack damage. Other causes include resonance from a loose foundation, operating at an incorrect speed, or a failed sludge discharge that left asymmetric sludge in the bowl. The machine should be shut down immediately if vibration significantly increases, as continued operation risks catastrophic bowl failure." }
    },
    {
      "@type": "Question",
      "name": "What causes a disc stack centrifuge to make unusual noise?",
      "acceptedAnswer": { "@type": "Answer", "text": "Unusual noise from a disc centrifuge includes grinding or rumbling (worn bearings), clicking or popping (debris in the bowl or disc stack contact), squealing (belt or friction clutch wear), and knocking (loose bowl parts or damaged gear teeth). Any new or changed noise should be investigated immediately — most noise issues escalate quickly into serious mechanical failures if ignored." }
    },
    {
      "@type": "Question",
      "name": "Why does my disc centrifuge have a burning smell?",
      "acceptedAnswer": { "@type": "Answer", "text": "A burning smell from a disc stack centrifuge typically indicates one of three causes: overheated motor windings due to overloading or cooling failure, a slipping friction clutch generating frictional heat during startup, or overheated gear oil from insufficient lubrication. Each cause requires a different corrective action — motor thermal issues need load reduction or cooling repair, clutch issues need disc replacement, and gear oil issues need immediate level check and oil change." }
    },
    {
      "@type": "Question",
      "name": "Why does my disc centrifuge take too long to reach operating speed?",
      "acceptedAnswer": { "@type": "Answer", "text": "Slow startup in a disc centrifuge is usually caused by a worn friction clutch that cannot fully engage, a seized or dragging bearing increasing rotational resistance, or a motor that is undersized or losing power. Belt-driven machines may also have a worn or incorrectly tensioned drive belt. Slow startup should not be ignored — if the friction clutch is worn, it will eventually fail to spin up the bowl at all." }
    }
  ]
};
---

<BaseLayout
  title="Disc Stack Centrifuge: Top 10 Mechanical Issues & Fixes"
  description="Troubleshooting guide for disc stack centrifuge mechanical problems — vibration, noise, low speed, high current, oil leaks — causes and fixes."
  canonicalUrl="https://dolphincentrifuge.com/disc-stack-centrifuge-mechanical-issues-fixes/"
  breadcrumbs={[
    { label: 'Knowledge Center', href: '/disc-stack-centrifuge-faq/' },
    { label: 'Disc Stack Centrifuge Mechanical Issues & Fixes' }
  ]}
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <section class="bg-navy text-white py-14 md:py-20">
    <div class="container-dolphin max-w-5xl">
      <div class="md:flex md:items-center md:gap-10">
        <div class="md:w-1/2">
