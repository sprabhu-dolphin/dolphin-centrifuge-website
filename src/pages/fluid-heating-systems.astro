          <span class="text-navy font-medium group-hover:text-gold transition-colors">Used Oil Centrifuge</span>
        </a>
        <a href="/fuel-oil-centrifuge/" class="group flex items-center gap-3 p-4 bg-warm-white rounded-lg hover:bg-gray-100 transition">
          <svg class="w-5 h-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          <span class="text-navy font-medium group-hover:text-gold transition-colors">Fuel Oil Centrifuge</span>
        </a>
        <a href="/disc-stack-centrifuge/" class="group flex items-center gap-3 p-4 bg-warm-white rounded-lg hover:bg-gray-100 transition">
          <svg class="w-5 h-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          <span class="text-navy font-medium group-hover:text-gold transition-colors">Disc Stack Centrifuge</span>
        </a>
        <a href="/alfa-laval-disc-centrifuge-accessories/" class="group flex items-center gap-3 p-4 bg-warm-white rounded-lg hover:bg-gray-100 transition">
          <svg class="w-5 h-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          <span class="text-navy font-medium group-hover:text-gold transition-colors">Centrifuge Accessories</span>
        </a>
        <a href="/disc-stack-centrifuge-performance/" class="group flex items-center gap-3 p-4 bg-warm-white rounded-lg hover:bg-gray-100 transition">
          <svg class="w-5 h-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          <span class="text-navy font-medium group-hover:text-gold transition-colors">Disc Stack Centrifuge Performance</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
