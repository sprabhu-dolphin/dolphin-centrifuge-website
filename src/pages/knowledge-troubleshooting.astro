---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Centrifuge Troubleshooting — Diagnose & Fix Common Issues";
const description = "Centrifuge troubleshooting guides: fix vibration, leaking bowls, poor separation, and speed issues in disc stack and decanter centrifuges. Step-by-step solutions.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Centrifuge Troubleshooting Guides",
  "description": description,
  "url": "https://dolphincentrifuge.com/knowledge-troubleshooting/",
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "email": "sales@dolphincentrifuge.com",
  },
};

const articles = [
  {
    title: "Top 10 Mechanical Issues & Fixes",
    href: "/disc-stack-centrifuge-mechanical-issues-fixes/",
    description: "The most common mechanical problems found in disc stack centrifuges and their proven solutions — from bearing failures to seal leaks.",
    tag: "Most Popular",
  },
  {
    title: "Cannot Reach Operating Speed",
    href: "/disc-centrifuge-cannot-reach-operating-speed/",
    description: "Diagnose why your disc centrifuge won't reach full RPM. Covers motor issues, clutch slip, bowl imbalance, and drive system faults.",
  },
  {
    title: "Troubleshooting Bowl Leaking",
    href: "/disc-stack-centrifuge-troubleshooting-bowl-leaking/",
    description: "Step-by-step guide to diagnosing and fixing bowl leaks — from worn O-rings and gaskets to hood/bottom cracks and spindle issues.",
  },
  {
    title: "Bad Separation — 6 Common Causes",
    href: "/disc-stack-centrifuge-bad-separation/",
    description: "Why your centrifuge isn't separating properly. Six root causes including wrong gravity disc, temperature issues, and throughput problems.",
  },
  {
    title: "Disc Stack Centrifuge Vibration",
    href: "/disc-stack-centrifuge-vibration/",
    description: "Causes and solutions for excessive vibration in disc stack centrifuges — bowl imbalance, bearing wear, foundation problems, and more.",
  },
  {
    title: "Decanter Centrifuge Vibration",
    href: "/decanter-centrifuge-vibration/",
    description: "Troubleshoot vibration issues specific to decanter centrifuges — scroll wear, differential speed problems, and feed inconsistencies.",
  },
  {
    title: "Clogged Bowl & Discs",
    href: "/centrifuge-clogged-bowl-discs/",
    description: "How to prevent and fix clogged bowls and disc stacks. Covers sludge buildup, improper discharge timing, and cleaning procedures.",
  },
  {
    title: "Liquid Seal Break",
    href: "/disc-stack-centrifuge-liquid-seal-break/",
    description: "Understanding and preventing liquid seal breaks — causes include wrong gravity disc size, air ingestion, and operating water failure.",
  },
  {
    title: "Paring Disc Block",
    href: "/disc-centrifuge-troubleshooting-paring-disc-block/",
    description: "Diagnose paring disc blockages that cause high backpressure, reduced throughput, and poor discharge quality.",
  },
  {
    title: "Backpressure Guide",
    href: "/disc-centrifuge-backpressure/",
    description: "Understanding centrifuge backpressure — how it affects separation, proper measurement, and adjustment techniques.",
  },
  {
    title: "Friction Clutch Problems",
    href: "/disc-centrifuge-friction-clutch/",
    description: "Diagnose friction clutch issues including slipping, overheating, and premature wear. Covers adjustment and replacement procedures.",
  },
  {
    title: "Product Loss During Discharge",
    href: "/centrifuge-product-loss-during-discharge/",
    description: "Why valuable product is lost during bowl discharge and how to minimize it through timing, water settings, and operating adjustments.",
  },
  {
    title: "Troubleshoot Bowl Issues",
    href: "/disc-centrifuge-troubleshoot-bowl/",
    description: "Comprehensive guide to diagnosing disc centrifuge bowl problems — from assembly errors to worn components and cracked parts.",
  },
  {
    title: "Disadvantages of Disc Stack Centrifuges",
    href: "/disadvantages-disc-stack-centrifuge/",
    description: "An honest look at the limitations and drawbacks of disc stack centrifuges — when other separation technologies may be a better fit.",
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl="https://dolphincentrifuge.com/knowledge-troubleshooting/"
  breadcrumbs={[{ label: "Knowledge Center", href: "/knowledge-center/" }, { label: "Troubleshooting" }]}
  jsonLd={jsonLd}
>
  {/* Hero */}
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16 lg:py-20">
      <div class="max-w-3xl">
        <span class="inline-block text-gold text-xs font-bold tracking-wider uppercase mb-3">Knowledge Center</span>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading leading-tight mb-4">
          Centrifuge Troubleshooting
        </h1>
        <p class="text-lg text-gray-300 leading-relaxed max-w-2xl mb-6">
          Diagnose and fix the most common disc stack and decanter centrifuge problems. Step-by-step guides backed by 40+ years of hands-on repair experience at Dolphin Centrifuge.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">
            Get Expert Help
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
          <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            (248) 522-2573
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Article Cards Grid */}
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16">
      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8 max-w-4xl">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge publishes industrial centrifuge troubleshooting guides covering vibration, bad separation, liquid seal break, bowl leaking, cannot reach operating speed, lubrication failures, operating water problems, sludge ejection issues, and paring disc blockage. All guides are based on 40+ years of Alfa Laval disc centrifuge service experience. Based in Warren, Michigan — call (248) 522-2573 for immediate troubleshooting support.</p>
      </div>
      <div class="flex items-center gap-4 mb-8">
        <div class="w-12 h-12 rounded-xl bg-red-50 text-red-500 flex items-center justify-center shrink-0">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" />
          </svg>
        </div>
        <div>
          <h2 class="text-xl font-bold font-heading text-navy">Troubleshooting Guides</h2>
          <span class="text-xs text-text-muted font-medium">{articles.length} articles</span>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {articles.map((article) => (
          <a href={article.href} class="group bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg hover:border-red-300/40 transition-all duration-300 overflow-hidden flex flex-col">
            {/* Icon Header */}
            <div class="relative h-32 bg-gradient-to-br from-red-500/10 to-red-600/5 flex items-center justify-center">
              <svg class="w-12 h-12 text-red-400/30 group-hover:text-red-400/50 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" />
              </svg>
              {article.tag && (
                <span class="absolute top-3 left-3 bg-gold text-navy text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">{article.tag}</span>
              )}
            </div>
            {/* Content */}
            <div class="p-5 flex-1 flex flex-col">
              <h3 class="text-lg font-bold font-heading text-navy group-hover:text-red-600 transition-colors mb-2">{article.title}</h3>
              <p class="text-sm text-text-light leading-relaxed flex-1">{article.description}</p>
              <div class="mt-4 flex items-center gap-1 text-gold font-semibold text-sm">
                Read Guide
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Related Categories */}
  <section class="bg-white border-t border-gray-200">
    <div class="container-dolphin py-10 md:py-12">
      <h2 class="text-lg font-bold font-heading text-navy mb-5">Explore Other Knowledge Categories</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="/knowledge-guides/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-blue-300/40 hover:shadow-md transition-all">
          <div class="w-10 h-10 rounded-lg bg-blue-50 text-blue-500 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
          </div>
          <span class="text-sm font-bold text-navy group-hover:text-blue-600 transition-colors">Guides & How-To</span>
        </a>
        <a href="/knowledge-comparisons/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-emerald-300/40 hover:shadow-md transition-all">
          <div class="w-10 h-10 rounded-lg bg-emerald-50 text-emerald-500 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z" /></svg>
          </div>
          <span class="text-sm font-bold text-navy group-hover:text-emerald-600 transition-colors">Comparisons</span>
        </a>
        <a href="/knowledge-product-brand/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-amber-300/40 hover:shadow-md transition-all">
          <div class="w-10 h-10 rounded-lg bg-amber-50 text-amber-500 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.991l1.004.827c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <span class="text-sm font-bold text-navy group-hover:text-amber-600 transition-colors">Product & Brand</span>
        </a>
        <a href="/knowledge-case-studies/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-purple-300/40 hover:shadow-md transition-all">
          <div class="w-10 h-10 rounded-lg bg-purple-50 text-purple-500 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
          </div>
          <span class="text-sm font-bold text-navy group-hover:text-purple-600 transition-colors">Case Studies & FAQ</span>
        </a>
      </div>
    </div>
  </section>

  {/* Bottom CTA */}
  <section class="bg-white border-t border-gray-200">
    <div class="container-dolphin py-12 md:py-16">
      <div class="bg-navy rounded-2xl p-8 md:p-10 text-white text-center md:text-left md:flex md:items-center md:justify-between">
        <div class="mb-6 md:mb-0">
          <h2 class="text-2xl font-bold font-heading mb-2">Need Hands-On Troubleshooting Help?</h2>
          <p class="text-gray-300">Our centrifuge technicians can diagnose and fix any issue — remotely or on-site.</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 justify-center md:justify-end">
          <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center justify-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">
            Contact Us
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
          <a href="tel:2485222573" class="inline-flex items-center justify-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            (248) 522-2573
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
