---
import BaseLayout from '../layouts/BaseLayout.astro';

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "url": "https://dolphincentrifuge.com/crude-oil-tank-bottom-recovery-centrifuge/",
  "name": "Crude Oil Tank Bottom Recovery System (ORS)",
  "description": "Industrial centrifuge system for recovering crude oil from tank bottoms. 3-step ORS process: pre-straining, decanter de-sludging, and disc stack polishing to less than 0.5% BS&W.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "image": "https://dolphincentrifuge.com/images/crude-oil-tank-bottom-recovery-centrifuge/crude-oil-centrifuge-1380.jpg",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a crude oil tank bottom recovery system?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A crude oil tank bottom recovery system (ORS) is a modular industrial centrifuge system designed to recover saleable crude oil from the sludge that accumulates at the bottom of storage tanks. Dolphin Centrifuge's ORS uses a 3-step process — pre-treatment and screening, de-sludging through a decanter centrifuge (down to 200 microns), and final polishing through a high-speed disc stack centrifuge (down to 1 micron, less than 1% BS&W). Tank bottoms with 60% BSW can be processed to less than 0.5% BSW."
      }
    },
    {
      "@type": "Question",
      "name": "How does centrifugal separation compare to gravity settling for crude oil recovery?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An industrial centrifuge exerts a centrifugal force up to 10,000 times the force of gravity, causing near-instant separation of oil, water, and solids. Gravity settling (heat-and-settle) is much slower, recovers less oil, and leaves significant amounts of saleable crude trapped in sludge. Centrifugal processing reduces sludge volume, increases oil yield, reduces tank cleaning frequency, and can even break emulsions that gravity alone cannot separate."
      }
    },
    {
      "@type": "Question",
      "name": "What configurations are available for the Dolphin ORS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dolphin Centrifuge's Oil Recovery System is available in two configurations: a skid-mounted system with three separate skids (pre-treatment, decanter de-sludging, and disc stack polishing) designed for indoor installation in existing buildings, and a fully containerized system housed in a prefabricated shipping container with built-in service cranes, lighting, surge tanks, and servicing tools — ideal for remote field locations with minimal infrastructure."
      }
    },
    {
      "@type": "Question",
      "name": "What is the ROI on a crude oil tank bottom recovery centrifuge system?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Based on Dolphin Centrifuge's case study processing crude oil at 0.76 BPM with 25% oil content in tank bottoms, the system produces approximately 170 barrels of sale oil per day. At $25 per barrel, that generates around $4,250 in daily revenue or $85,000 per month (based on 16 hours/day operation, 20 working days/month). With higher oil content (56%), revenue can reach $185,000 per month. The payback period is typically very short given these revenue figures."
      }
    },
    {
      "@type": "Question",
      "name": "What factors affect crude oil centrifuge separation efficiency?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Three primary factors affect ORS efficiency: processing temperature (heavier oils require 180°F while lighter oils process well at 145°F), homogeneity of the process crude oil (solids must be kept in suspension to prevent equipment overload), and chemical/polymer/demulsifier selection (emulsion-breaking agents may be needed for oils with significant emulsion phases). Proper control of these factors ensures consistent, high-quality separation."
      }
    }
  ]
};
---

<BaseLayout
  title="Crude Oil Tank Bottom Recovery"
  description="Industrial centrifuges recover crude oil from tank bottoms efficiently. Dolphin's 3-step ORS processes 60% BSW down to <0.5% BSW. Case study with ROI & fluid balance data."
