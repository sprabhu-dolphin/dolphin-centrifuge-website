---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "How does an oil centrifuge work?",
    answer: "An oil centrifuge works on the principle of differential settling using high centrifugal force to separate oil from solid and liquid contaminants. The centrifuge exerts up to 10,000 Gs of force to separate particles as small as 1 micron from the oil. It also separates any immiscible liquid contaminants from the oil. Industrial oil centrifuges use a stack of conical discs inside the bowl to magnify the effective g-force, creating thousands of thin separation channels that make them highly efficient three-phase separators capable of continuously processing oil without interruption."
  },
  {
    question: "What are the advantages of an oil centrifuge over filters?",
    answer: "Oil centrifuges offer several key advantages over conventional filters: high separation efficiency down to 0.5 microns at over 7,000 Gs of centrifugal force, simultaneous three-phase separation of water and solids in a single pass, compact size relative to processing capacity, low operating cost since no filter media is needed, the ability to break simple emulsions, and consistent processing capacity that does not diminish over time unlike filter pores that become blocked. The operating cost per gallon processed is a fraction of a cent, making centrifuges highly economical for continuous oil purification."
  },
  {
    question: "What is the cost of an oil centrifuge?",
    answer: "A small manual clean oil centrifuge with a processing capacity of 3 GPM costs around $15,000 for the bare centrifuge, while a high capacity 100 GPM unit costs over $120,000. Remanufactured centrifuges typically cost around 60% of new units. Optional accessories such as feed pumps, heaters, and control panels can add significantly to the system cost. The operating cost per gallon is a fraction of a cent since centrifuges are mechanical separators that do not require filter media or other consumables."
  },
  {
    question: "What types of oil centrifuges are available?",
    answer: "Oil centrifuges are available in two main types: Manual Clean centrifuges, where liquid phases discharge continuously but separated solids are retained in the bowl for manual extraction after stopping the machine; and Automatic Self-Clean centrifuges, which eject separated sludge automatically while still rotating, with oil and water exiting continuously and solids intermittently self-ejecting. Manual clean units are simpler and less expensive, while self-cleaning units are better for applications with higher solids content that require continuous uninterrupted operation."
  },
  {
    question: "What applications use oil centrifuges?",
    answer: "Oil centrifuges are used across many industries for applications including <a href='/lube-oil-centrifuge/'>lube oil purification</a> (steam turbine oil, engine lubricating oil), <a href='/diesel-centrifuge/'>diesel fuel cleaning</a> from storage tank contaminants, <a href='/fuel-oil-centrifuge/'>fuel oil treatment</a> for power plants and marine engines, <a href='/cutting-oil-centrifuge/'>cutting oil recovery</a> from metal-forming operations, <a href='/waste-oil-centrifuge/'>waste oil recycling</a>, and used vegetable oil processing. The versatility of disc stack centrifuges makes them suitable for virtually any application where oil needs to be separated from water and solid contaminants."
  }
];

