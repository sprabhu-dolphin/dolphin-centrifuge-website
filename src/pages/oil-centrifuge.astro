  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Industrial Oil Centrifuge Systems",
  "url": "https://dolphincentrifuge.com/oil-centrifuge/",
  "description": "Complete guide to industrial oil centrifuges — how they work, advantages and disadvantages, sizes, types (manual clean and self-cleaning), applications (lube oil, diesel, fuel oil, cutting oil), cost breakdown, and plant layout configurations.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "image": "https://dolphincentrifuge.com/images/oil-centrifuge/Oil-Centrifuge-Interior-Details.webp",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
