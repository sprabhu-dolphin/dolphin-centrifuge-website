  { id: 'material', label: 'Material of Construction' },
  { id: 'types', label: 'Types' },
  { id: 'examples', label: 'Examples of Applications' },
  { id: 'costs', label: 'Costs' },
  { id: 'plant-layout', label: 'Plant Layout Configuration' },
  { id: 'faq', label: 'Frequently Asked Questions' },
