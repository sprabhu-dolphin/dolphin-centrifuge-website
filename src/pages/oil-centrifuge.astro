---
import BaseLayout from '../layouts/BaseLayout.astro';

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Industrial Oil Centrifuge Systems",
  "url": "https://dolphincentrifuge.com/oil-centrifuge/",
  "description": "Complete guide to industrial oil centrifuges — how they work, advantages and disadvantages, sizes, types (manual clean and self-cleaning), applications (lube oil, diesel, fuel oil, cutting oil), cost breakdown, and plant layout configurations.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does an oil centrifuge work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An oil centrifuge works on the principle of differential settling using high centrifugal force to separate oil from solid and liquid contaminants. The centrifuge exerts up to 10,000 Gs of force to separate particles as small as 1 micron from the oil. It also separates any immiscible liquid contaminants from the oil. Industrial oil centrifuges use a stack of conical discs inside the bowl to magnify the effective g-force, making them highly efficient three-phase separators."
      }
    },
    {
      "@type": "Question",
      "name": "What are the advantages of an oil centrifuge over filters?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oil centrifuges offer several key advantages over conventional filters: high separation efficiency (down to 0.5 microns at 7,000+ Gs), simultaneous three-phase separation of water and solids, compact size relative to processing capacity, low operating cost since no filter media is needed, the ability to break simple emulsions, and consistent processing capacity that does not diminish over time like filter pores do."
      }
    },
    {
      "@type": "Question",
      "name": "What is the cost of an oil centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A small manual clean oil centrifuge with a processing capacity of 3 GPM costs around $15,000 for the bare centrifuge, while a high capacity 100 GPM unit costs over $120,000. Remanufactured centrifuges typically cost around 60% of new units. Optional accessories can add significantly to the system cost. The operating cost per gallon is a fraction of a cent since centrifuges are mechanical separators that do not require filter media."
      }
    },
    {
      "@type": "Question",
      "name": "What types of oil centrifuges are available?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oil centrifuges are available in two main types: Manual Clean centrifuges, where liquid phases discharge continuously but separated solids are retained in the bowl for manual extraction after stopping; and Automatic Self-Clean centrifuges, which eject separated sludge automatically while still rotating, with oil and water exiting continuously and solids intermittently self-ejecting."
      }
    },
    {
      "@type": "Question",
      "name": "What applications use oil centrifuges?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oil centrifuges are used across many industries for applications including lube oil purification (steam turbine oil, engine lubricating oil), diesel fuel cleaning from storage tank contaminants, fuel oil treatment for power plants and marine engines, cutting oil recovery from metal-forming operations, waste oil recycling, and used vegetable oil processing. They find uses in food and beverage, waste processing, chemical, and crude oil production industries."
      }
    }
  ]
};

const jsonLd = [productJsonLd, faqJsonLd];
