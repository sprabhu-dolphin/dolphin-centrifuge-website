        <tr><td class="px-5 py-3 font-medium text-navy">Solids @ 8 GPM</td><td class="px-5 py-3 text-text">0.85%</td></tr>
        <tr><td class="px-5 py-3 font-medium text-navy">Solids @ 6 GPM</td><td class="px-5 py-3 text-text">0.79%</td></tr>
        <tr><td class="px-5 py-3 font-medium text-navy">Solids @ 4 GPM</td><td class="px-5 py-3 text-text">0.72%</td></tr>
        <tr><td class="px-5 py-3 font-medium text-navy">Solids @ 2 GPM</td><td class="px-5 py-3 text-text">0.62%</td></tr>
      </tbody>
    </table>
