        <tr><td class="px-5 py-3 font-medium text-navy">Solids @ 14 GPM</td><td class="px-5 py-3 text-text">0.98%</td></tr>
        <tr><td class="px-5 py-3 font-medium text-navy">Solids @ 12 GPM</td><td class="px-5 py-3 text-text">0.93%</td></tr>
