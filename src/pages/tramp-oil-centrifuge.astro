  "@type": "Product",
  "name": "Tramp Oil Removal Centrifuge",
  "url": "https://dolphincentrifuge.com/tramp-oil-centrifuge/",
  "description": "Three-phase disc-stack centrifuge systems for continuous tramp oil removal from metalworking coolant. Rotating at 8,500 RPM and generating over 7,000 Gs to separate tramp oil and metal particles from water-based coolant.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "image": "https://dolphincentrifuge.com/images/tramp-oil-centrifuge/Dolphin-Centrifuge.webp",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "url": "https://dolphincentrifuge.com/tramp-oil-centrifuge/",
  "headline": "Tramp Oil Removal Using a 3-Phase Disc-Stack Centrifuge",
  "description": "Three-phase disc-stack centrifuge for tramp oil removal from machining coolant. 8,500 RPM, 7,000+ Gs, 1-micron separation. Dolphin Centrifuge, Warren MI.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" }
};

const jsonLd = [productJsonLd, faqJsonLd, articleJsonLd];

const toc = [
  { id: 'what-is-tramp-oil', label: 'Tramp Oil' },
  { id: 'where-originate', label: 'Where Does Tramp Oil Originate?' },
  { id: 'problems', label: 'Problems With Tramp Oil' },
  { id: 'conventional-methods', label: 'Conventional Removal Methods' },
  { id: 'tramp-oil-centrifuge', label: 'Tramp Oil Centrifuge' },
  { id: 'advantages', label: 'Centrifuge Advantages' },
  { id: 'disadvantages', label: 'Centrifuge Disadvantages' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'summary', label: 'Summary' },
  { id: 'faq', label: 'FAQ' },
];

const relatedApplications = [
  { label: 'Machine Coolant Centrifuge', href: '/machine-coolant-centrifuge/' },
  { label: 'Cutting Oil Centrifuge', href: '/cutting-oil-centrifuge/' },
  { label: 'Disc Stack Centrifuge Applications', href: '/disc-stack-centrifuge-applications/' },
];

const relatedProducts = [
  { label: 'DMPX-010', href: '/centrifuges/dmpx-010/', description: 'Small sump &mdash; 7 GPM' },
  { label: 'DMPX-028', href: '/centrifuges/dmpx-028/', description: 'Medium sump &mdash; 20&ndash;26 GPM' },
  { label: 'DMPX-042', href: '/centrifuges/dmpx-042/', description: 'Large sump &mdash; 32&ndash;47 GPM' },
