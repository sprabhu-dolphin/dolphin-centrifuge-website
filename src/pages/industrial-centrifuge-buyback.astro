---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "What brands of centrifuge does Dolphin Centrifuge buy?",
    answer: "Dolphin Centrifuge purchases used centrifuges of all brands including Alfa Laval, Westfalia, Sharples, Bird, GEA, Flottweg, Pieralisi, and others. We buy disc stack centrifuges, decanter centrifuges, basket centrifuges, and scroll centrifuges in any condition — working, non-working, complete, or for parts."
  },
  {
    question: "How do I get an offer for my used centrifuge?",
    answer: "Send photos of the machine, the model number (found on the nameplate), and basic information about the condition to sales@dolphincentrifuge.com or call (248) 522-2573. We typically respond with a preliminary offer within 1–2 business days. For larger lots or estate sales, we can arrange an on-site inspection."
  },
  {
    question: "Does Dolphin Centrifuge offer pickup or handle removal?",
    answer: "Yes. For purchased centrifuges, Dolphin Centrifuge can arrange freight pickup from your facility. We handle all logistics including rigging and trucking. This is especially convenient for facilities decommissioning equipment or clearing warehouse space."
  },
  {
    question: "What condition does my centrifuge need to be in to sell it?",
    answer: "We buy centrifuges in any condition — operational, non-operational, incomplete, or for parts. A machine that does not run can still have significant value in its bowl, discs, frame, drive components, or control panel. Send us photos and we will evaluate it."
  }
];

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Centrifuge Buyback & Trade-In Program",
  "description": "We buy used industrial centrifuges in any condition. Sell your surplus Alfa Laval or other brand centrifuge equipment. Fast evaluation, fair offers, free pickup.",
  "provider": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "address": { "@type": "PostalAddress", "streetAddress": "24248 Gibson Dr.", "addressLocality": "Warren", "addressRegion": "MI", "postalCode": "48089", "addressCountry": "US" },
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "url": "https://dolphincentrifuge.com/industrial-centrifuge-buyback/",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const jsonLd = [serviceJsonLd, faqJsonLd];

const toc = [
  { id: 'buyback', label: 'Buyback Program' },
  { id: 'consignment', label: 'Consignment Option' },
  { id: 'what-we-buy', label: 'What We Buy' },
  { id: 'process', label: 'How the Buyback Process Works' },
  { id: 'trade-in', label: 'Trade-In Program' },
  { id: 'info-needed', label: 'What Information We Need' },
  { id: 'faq', label: 'FAQ' },
];

const relatedApplications = [
  { label: 'Centrifuge Rental', href: '/disc-stack-centrifuge-rental/' },
  { label: 'Decanter Centrifuge Rental', href: '/decanter-centrifuge-rental/' },
  { label: 'Centrifuge Service & Repair', href: '/centrifuge-service-and-repair/' },
  { label: 'About Dolphin Centrifuge', href: '/about-dolphin-centrifuge/' },
];

const relatedProducts = [
  { label: 'Alfa Laval Centrifuges', href: '/alfa-laval-centrifuges/', description: 'Full inventory of models' },
  { label: 'Centrifuge Parts', href: '/alfa-laval-centrifuge-parts/', description: 'OEM and aftermarket parts' },
];
---

<ApplicationLayout
  title="Centrifuge Buyback & Trade-In"
  description="Sell your used industrial centrifuge to Dolphin Centrifuge. We buy all brands and conditions with fast evaluation, fair offers, and free pickup nationwide."
  category="services"
  categoryLabel="Services"
  heroImage="/images/about-dolphin-centrifuge/Dolphin-Centrifuge-Shop-Warren-1000.webp"
  heroImageAlt="Dolphin Centrifuge Shop Warren"
  canonicalUrl="https://dolphincentrifuge.com/industrial-centrifuge-buyback/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge purchases used industrial disc stack and decanter centrifuges of all makes and conditions. With 200+ units in inventory and over 40 years of refurbishment experience in Warren, Michigan, Dolphin provides immediate evaluation and fair market offers nationwide.</p>
  </div>

  <h2 id="buyback">Buyback</h2>
  <p>
    Industrial Centrifuge buyback by Dolphin Centrifuge is one way to monetize your used centrifuge inventory. Send us details &amp; photographs of your centrifuge, and we will get back to you with an offer.
  </p>
  <p>
    We can offer you credit for your old centrifuge towards purchasing a new system from Dolphin Centrifuge. We also provide full <a href="/centrifuge-service-and-repair/">centrifuge service and repair</a> if you prefer to keep your equipment running.
  </p>

  <h2 id="consignment">Consignment</h2>
  <p>
    If a customer has a functional centrifuge system originally supplied by Dolphin Centrifuge or others, the customer may choose to send the centrifuge to Dolphin Centrifuge on consignment.
  </p>
  <p>
    The customer retains ownership of the equipment on consignment centrifuges, and Dolphin Centrifuge will offer the centrifuge to potential buyers.
  </p>

  <h3>Turn Idle Equipment Into Cash</h3>
  <div class="flex flex-col md:flex-row gap-6 items-start not-prose">
    <div class="md:w-2/3">
      <p class="mb-4">
        Industrial centrifuges are high-value assets. If you have a centrifuge that is no longer in service&mdash;whether from a process change, plant closure, upgrade, or simply because it needs repair&mdash;Dolphin Centrifuge will buy it from you. We purchase disc stack separators, decanter centrifuges, and complete centrifuge systems from any manufacturer.
      </p>
      <p>
        Because we operate a full-service <a href="/industrial-disc-centrifuge-repair/" class="text-gold hover:text-navy underline">centrifuge repair and rebuild facility</a>, we can refurbish equipment that other buyers would consider scrap. This means we can offer competitive prices for centrifuges in any condition&mdash;including non-functional units.
      </p>
    </div>
    <div class="md:w-1/3 shrink-0">
      <img src="/images/about-dolphin-centrifuge/Dolphin-Centrifuge-Shop-600.webp" alt="Dolphin Centrifuge Shop" width="600" height="400" loading="lazy" class="rounded-xl shadow-md w-full" />
    </div>
  </div>

  <h2 id="what-we-buy">What We Buy</h2>

  <h3>Equipment Types</h3>
  <ul>
    <li><strong>Disc Stack Separators:</strong> Self-cleaning and manual-clean models from <a href="/alfa-laval-centrifuges/">Alfa Laval</a>, Westfalia, Mitsubishi, and others</li>
    <li><strong>Decanter Centrifuges:</strong> Horizontal scroll decanters of all sizes and manufacturers</li>
    <li><strong>Complete Systems:</strong> Centrifuge skids with pumps, controls, heaters, and piping</li>
    <li><strong>Spare Parts &amp; Components:</strong> Bowl assemblies, disc stacks, spindles, gearboxes, and <a href="/alfa-laval-centrifuge-parts/">centrifuge parts</a></li>
    <li><strong>Ancillary Equipment:</strong> Feed pumps, heat exchangers, control panels, and VFDs that were part of a centrifuge system</li>
  </ul>

  <h3>Any Condition</h3>
  <ul>
    <li><strong>Working:</strong> Operational centrifuges ready to run&mdash;highest value</li>
    <li><strong>Needs Repair:</strong> Units with known issues such as bad bearings, worn seals, or vibration problems</li>
    <li><strong>Non-Functional:</strong> Centrifuges that have not run in years or have unknown condition</li>
    <li><strong>Incomplete:</strong> Missing parts, controls, or accessories&mdash;we still want the core rotating assembly</li>
    <li><strong>Damaged:</strong> Crash-damaged bowls, corroded frames, or fire-damaged equipment</li>
  </ul>

  <h2 id="process">How the Buyback Process Works</h2>
  <ol>
    <li>
      <strong>Send Us Information:</strong> Email photos of the centrifuge (nameplate, bowl, frame, control panel) to <a href="mailto:sales@dolphincentrifuge.com">sales@dolphincentrifuge.com</a> along with the model number, serial number (if visible), and a brief description of the condition and history. Alternatively, call <a href="tel:2485222573">(248) 522-2573</a> to discuss.
    </li>
    <li>
      <strong>We Evaluate:</strong> Our technical team reviews the information and assesses the equipment value based on model, age, condition, and market demand. We typically provide an initial offer within 1&ndash;2 business days.
    </li>
    <li>
      <strong>We Make an Offer:</strong> You receive a firm purchase offer. No obligation&mdash;accept or decline at your discretion.
    </li>
    <li>
      <strong>We Arrange Pickup:</strong> Once you accept, we coordinate freight and rigging to pick up the equipment from your facility. We handle all logistics at no cost to you for most locations in the continental U.S.
    </li>
    <li>
      <strong>You Get Paid:</strong> Payment is issued upon receipt and verification of the equipment at our Warren, MI facility.
    </li>
  </ol>

  <h2 id="trade-in">Trade-In Program</h2>
  <p>
    Upgrading to a newer or larger centrifuge system? Apply the value of your existing equipment toward the purchase of a new Dolphin centrifuge system. <a href="/contact-for-alfa-laval-centrifuges/">Contact us for a trade-in quote</a> &mdash; our program makes upgrading more affordable:
  </p>
  <ul>
    <li>We credit the agreed trade-in value directly against your new system purchase price</li>
    <li>We handle removal and shipping of your old equipment</li>
    <li>Trade-in can be combined with our <a href="/disc-stack-centrifuge-rental/">rental program</a>&mdash;rent a unit while we build your new system, then trade in the old one at delivery</li>
  </ul>

  <h2 id="info-needed">What Information Do We Need?</h2>
  <p>
    To provide an accurate offer, please gather the following if available:
  </p>
  <ul>
    <li><strong>Photos:</strong> Nameplate (with model and serial number), overall view, bowl, frame, and control panel</li>
    <li><strong>Model &amp; Serial Number:</strong> Found on the nameplate, typically on the frame or bowl housing</li>
    <li><strong>Condition Description:</strong> Is it running? When was it last operated? Any known issues?</li>
    <li><strong>Location:</strong> City and state where the equipment is located (for freight estimation)</li>
    <li><strong>Accessories:</strong> List any included items such as spare bowl, tools, manuals, spare parts, or control panel</li>
  </ul>
  <p>
    Do not worry if you cannot provide all of this information. We can work with photos alone and will ask follow-up questions as needed.
  </p>

  <h3>Not Ready to Sell?</h3>
  <p>
    If you are not ready to part with your centrifuge but it is sitting idle, consider our <a href="/disc-stack-centrifuge-rental/">centrifuge rental program</a> as an alternative revenue source, or contact us about our <a href="/industrial-disc-centrifuge-repair/">repair services</a> to get it back in operation.
  </p>

  <FAQ items={faqItems} />

</ApplicationLayout>
