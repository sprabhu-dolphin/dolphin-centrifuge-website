---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "How does a centrifuge remove tramp oil from machining coolant?",
    answer: "A disc stack centrifuge exploits the density difference between tramp oil (specific gravity 0.85–0.90) and water-based coolant (specific gravity ~1.0) to achieve clean separation. At forces exceeding 7,000 Gs, even finely emulsified tramp oil droplets are broken out of the coolant and collected through a dedicated light-phase outlet, while clean coolant returns to the machining system."
  },
  {
    question: "How much can a centrifuge reduce coolant costs?",
    answer: "Continuous centrifuge purification typically reduces coolant concentrate purchases by 80% or more by extending coolant life from weeks to months or even years. Combined with dramatically reduced hazardous waste disposal costs (fewer tank dumps), most operations achieve full ROI within the first year. <a href='/contact-for-alfa-laval-centrifuges/'>Contact us</a> for a cost analysis on your system."
  },
  {
    question: "Does removing tramp oil improve worker health and safety?",
    answer: "Yes. Tramp oil creates an anaerobic surface film on coolant that promotes rapid bacterial growth — the source of foul 'Monday morning' odors, coolant mist toxicity, and operator skin irritation (dermatitis). Continuous centrifuge removal of tramp oil eliminates this anaerobic environment, significantly improving air quality and reducing health risks for machine operators."
  },
  {
    question: "What coolant flow rates are available?",
    answer: "Dolphin Centrifuge coolant purification systems range from 3 GPM for individual CNC machines up to 50 GPM for large central coolant systems serving entire production lines. All systems feature self-cleaning disc stack construction for simultaneous tramp oil and metal fines removal with automatic sludge ejection."
  },
  {
    question: "How does a coolant centrifuge compare to paper-band filters?",
    answer: "A disc stack centrifuge provides far finer separation (down to 1 micron vs. 10–50 microns for paper-band filters) with zero ongoing media costs. Unlike filters that clog and require frequent media changes and operator attention, a self-cleaning centrifuge ejects accumulated sludge automatically and runs unattended. For high-volume central coolant systems, centrifuges are consistently more cost-effective over a 2–3 year horizon."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "url": "https://dolphincentrifuge.com/machine-coolant-centrifuge/",
  "name": "Machine Coolant Centrifuge System",
  "description": "Industrial machining coolant centrifuges remove tramp oil, metal fines, and bacteria-causing contaminants from water-based coolants. Disc stack separation at 7,000+ Gs cleans to 1 micron without consumable filters.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "url": "https://dolphincentrifuge.com/machine-coolant-centrifuge/",
  "headline": "Machine Coolant Centrifuge | Tramp Oil & Metal Fines Removal",
  "description": "Industrial machining coolant centrifuge removes tramp oil and metal fines at 7,000+ Gs. Systems from 3–50 GPM. Dolphin Centrifuge, Warren MI.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" }
};

const jsonLd = [productJsonLd, faqJsonLd, articleJsonLd];

const toc = [
  { id: 'what-is-machining-coolant', label: 'What is Machining Coolant' },
  { id: 'coolant-centrifuge', label: 'Coolant Centrifuge' },
  { id: 'operation', label: 'Operation' },
  { id: 'advantages', label: 'Advantages' },
  { id: 'disadvantages', label: 'Disadvantages' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'sizes', label: 'Sizes' },
  { id: 'what-is-tramp-oil', label: 'What is Tramp Oil' },
  { id: 'tramp-oil-problems', label: 'Tramp Oil Problems' },
  { id: 'tramp-oil-centrifuge', label: 'Tramp Oil Centrifuge' },
  { id: 'tramp-oil-operation', label: 'Tramp Oil Centrifuge Operation' },
  { id: 'tramp-oil-specifications', label: 'Tramp Oil Centrifuge Specs' },
];

const relatedApplications = [
  { label: 'Cutting Oil Centrifuge', href: '/cutting-oil-centrifuge/' },
  { label: 'Machining Coolant Recovery Centrifuge', href: '/machining-coolant-recovery-centrifuge/' },
  { label: 'Industrial Washer Fluid Centrifuge', href: '/industrial-washer-fluid-centrifuge/' },
  { label: 'Oil Centrifuge (General)', href: '/oil-centrifuge/' },
];

const relatedProducts = [
  { label: 'DMPX-014 Self-Cleaning', href: '/centrifuges/dmpx-014/', description: '3 GPM on coolant' },
  { label: 'DMPX-028 Self-Cleaning', href: '/centrifuges/dmpx-028/', description: '28 GPM on coolant' },
  { label: 'DMPX-042 Self-Cleaning', href: '/centrifuges/dmpx-042/', description: '50 GPM on coolant' },
];
---

<ApplicationLayout
  title="Machine Coolant Centrifuge | Dolphin Centrifuge"
  description="Disc stack centrifuge removes tramp oil and metal fines from machining coolant at 7,000+ Gs to 1 micron. Systems from 3–50 GPM. Dolphin Centrifuge, Warren MI."
  heroImage="/images/machine-coolant-centrifuge/Alfa-Laval-Industrial-Centrifuge-Coolant-1000.webp"
  heroImageAlt="Alfa Laval Industrial Centrifuge Coolant"
