---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Disc Stack Centrifuge Rental",
  "description": "Rent industrial disc stack centrifuges for short-term or long-term use. DMPX self-cleaning separators available for pilot testing and temporary capacity.",
  "provider": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "address": { "@type": "PostalAddress", "streetAddress": "24248 Gibson Dr.", "addressLocality": "Warren", "addressRegion": "MI", "postalCode": "48089", "addressCountry": "US" },
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "url": "https://dolphincentrifuge.com/disc-stack-centrifuge-rental/",
};
---

<BaseLayout
  title="Disc Stack Centrifuge Rental"
  description="Rent industrial disc stack centrifuges for short-term or long-term use. DMPX self-cleaning separators available for pilot testing and temporary capacity."
  canonicalUrl="https://dolphincentrifuge.com/disc-stack-centrifuge-rental/"
  breadcrumbs={[
    { label: 'Services', href: '/industrial-centrifuge-design/' },
    { label: 'Disc Stack Centrifuge Rental' },
  ]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">Services</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">Disc Stack Centrifuge Rental</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">
        Dolphin Centrifuge offers industrial disc stack centrifuges for rent on flexible short-term and long-term schedules. Our rental fleet includes DMPX-series self-cleaning separators ready for immediate deployment across oil, fuel, wastewater, and specialty applications.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Get a Free Quote</a>
        <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-4xl">

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Why Rent a Disc Stack Centrifuge?</h2>
      <p class="text-text-muted mb-4">
        Purchasing an industrial centrifuge is a significant capital investment. Renting gives you immediate access to high-performance separation equipment without the upfront cost, allowing you to validate your process, cover temporary needs, or bridge the gap while your own unit is being <a href="/industrial-disc-centrifuge-repair/" class="text-navy font-semibold hover:text-gold transition-colors">repaired or rebuilt</a>.
      </p>
      <p class="text-text-muted mb-8">
        Every rental centrifuge in our fleet has been fully rebuilt in our Warren, Michigan facility and tested on our high-speed test stand before deployment. You receive a production-ready machine&mdash;not a worn-out demo unit.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Rental Applications</h2>
      <ul class="list-disc list-inside space-y-2 text-text-muted mb-8 ml-4">
        <li><strong>Pilot Testing:</strong> Validate centrifuge performance on your specific fluid before committing to a purchase. Pair with our <a href="/industrial-centrifuge-sample-testing/" class="text-navy font-semibold hover:text-gold transition-colors">sample testing service</a> for lab-scale data first</li>
        <li><strong>Temporary Capacity:</strong> Cover seasonal demand spikes, plant turnarounds, or emergency spill response without purchasing additional equipment</li>
        <li><strong>Trial Before Purchase:</strong> Run the centrifuge in your facility for weeks or months before deciding to buy</li>
        <li><strong>Bridge During Repair:</strong> Keep your process running while your own centrifuge is in our shop for rebuild</li>
        <li><strong>Project-Based Work:</strong> Short-duration contracts, remediation projects, or construction dewatering</li>
      </ul>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Available Rental Models</h2>
      <p class="text-text-muted mb-4">
        Our disc stack rental fleet includes self-cleaning DMPX-series separators covering a wide range of flow rates and applications:
      </p>

      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm text-left border border-gray-200 rounded-lg overflow-hidden">
          <thead class="bg-navy text-white">
            <tr>
              <th class="px-4 py-3 font-semibold">Model</th>
              <th class="px-4 py-3 font-semibold">Type</th>
              <th class="px-4 py-3 font-semibold">Flow Rate</th>
              <th class="px-4 py-3 font-semibold">Typical Applications</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200 text-text-muted">
            <tr>
              <td class="px-4 py-3 font-mono font-semibold">DMPX-010</td>
              <td class="px-4 py-3">Self-Cleaning</td>
              <td class="px-4 py-3">Up to 8 GPM</td>
              <td class="px-4 py-3">Small-volume oil, fuel, biodiesel</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-mono font-semibold">DMPX-014</td>
              <td class="px-4 py-3">Self-Cleaning</td>
              <td class="px-4 py-3">Up to 16 GPM</td>
              <td class="px-4 py-3">Waste oil, lube oil, diesel</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-mono font-semibold">DMPX-028</td>
              <td class="px-4 py-3">Self-Cleaning</td>
              <td class="px-4 py-3">Up to 28 GPM</td>
              <td class="px-4 py-3">Fuel oil, process water, food-grade</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-mono font-semibold">DMPX-042</td>
              <td class="px-4 py-3">Self-Cleaning</td>
              <td class="px-4 py-3">Up to 47 GPM</td>
              <td class="px-4 py-3">Large-volume oil, wastewater, marine</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-mono font-semibold">DMPX-070</td>
              <td class="px-4 py-3">Self-Cleaning</td>
              <td class="px-4 py-3">Up to 72 GPM</td>
              <td class="px-4 py-3">High-volume industrial, refinery</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-text-muted mb-8">
        Manual-clean DMB-series separators are also available for applications with low solids loading. Contact us to discuss which model fits your process.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">What's Included in a Rental</h2>
      <ul class="list-disc list-inside space-y-2 text-text-muted mb-8 ml-4">
        <li><strong>Fully Rebuilt Centrifuge:</strong> Every rental unit is rebuilt to OEM specifications with new bearings, seals, and O-rings</li>
        <li><strong>Complete System:</strong> Centrifuge, feed pump, motor, starter, and basic piping connections</li>
        <li><strong>Operating Manual:</strong> Process-specific setup guide and recommended operating parameters</li>
        <li><strong>Technical Support:</strong> Phone and email support from our engineers during the rental period</li>
        <li><strong>Startup Assistance:</strong> Remote or on-site commissioning support available</li>
        <li><strong>Spare Parts Kit:</strong> Basic consumables included for the rental duration</li>
      </ul>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Rental vs. Purchase</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm text-left border border-gray-200 rounded-lg overflow-hidden">
          <thead class="bg-navy text-white">
            <tr>
              <th class="px-4 py-3 font-semibold">Factor</th>
              <th class="px-4 py-3 font-semibold">Rental</th>
              <th class="px-4 py-3 font-semibold">Purchase</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200 text-text-muted">
            <tr>
              <td class="px-4 py-3 font-semibold">Upfront Cost</td>
              <td class="px-4 py-3">Low monthly payments</td>
              <td class="px-4 py-3">Full capital expenditure</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-semibold">Commitment</td>
              <td class="px-4 py-3">Flexible&mdash;return when done</td>
              <td class="px-4 py-3">Long-term ownership</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-semibold">Maintenance</td>
              <td class="px-4 py-3">Included during rental</td>
              <td class="px-4 py-3">Owner responsibility</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-semibold">Best For</td>
              <td class="px-4 py-3">Testing, short-term, temporary needs</td>
              <td class="px-4 py-3">Continuous, long-term operation</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-semibold">Rent-to-Own</td>
              <td class="px-4 py-3" colspan="2">Available&mdash;rental payments can apply toward purchase price</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Rental Terms</h2>
      <p class="text-text-muted mb-4">
        We offer flexible rental terms tailored to your project timeline:
      </p>
      <ul class="list-disc list-inside space-y-2 text-text-muted mb-8 ml-4">
        <li><strong>Short-Term:</strong> 1&ndash;3 months for pilot testing, emergency response, or project work</li>
        <li><strong>Long-Term:</strong> 6&ndash;12+ months with reduced monthly rates</li>
        <li><strong>Rent-to-Own:</strong> Apply rental payments toward eventual purchase</li>
        <li><strong>Shipping:</strong> We arrange freight to and from your facility anywhere in the continental U.S.</li>
      </ul>

      <p class="text-text-muted mb-4">
        Looking for a decanter centrifuge instead? See our <a href="/decanter-centrifuge-rental/" class="text-navy font-semibold hover:text-gold transition-colors">decanter centrifuge rental program</a> for NX and G2-series units.
      </p>

    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-navy">
    <div class="container-dolphin py-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Ready to Rent a Centrifuge?</h2>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">Tell us about your application and timeline. We will recommend the right model and provide a rental quote within 24 hours.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3.5 rounded-lg transition-colors">Contact Us Today</a>
        <a href="/industrial-centrifuge-sample-testing/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3.5 rounded-lg transition-colors">Sample Testing</a>
      </div>
    </div>
  </section>
</BaseLayout>
