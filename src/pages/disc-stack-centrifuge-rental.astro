---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Disc Stack Centrifuge Rental",
  "description": "Rent industrial disc stack centrifuges for short-term or long-term use. DMPX self-cleaning separators available for pilot testing and temporary capacity.",
  "provider": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "address": { "@type": "PostalAddress", "streetAddress": "24248 Gibson Dr.", "addressLocality": "Warren", "addressRegion": "MI", "postalCode": "48089", "addressCountry": "US" },
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "url": "https://dolphincentrifuge.com/disc-stack-centrifuge-rental/",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What disc stack centrifuge models are available for rental from Dolphin Centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dolphin Centrifuge offers rental of DMPX-series self-cleaning disc stack centrifuges for short-term and long-term applications. Models range from DMPX-010 (7 GPM) to DMPX-070 (59–72 GPM on diesel). Units are available as standalone centrifuge skids or as complete systems with controls, pumps, and heating. Contact us for current availability."
      }
    },
    {
      "@type": "Question",
      "name": "What are the common reasons to rent a disc stack centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Common rental use cases include: pilot testing before a capital purchase decision, emergency backup during a machine rebuild or repair, temporary capacity for seasonal production spikes, project work at a site without permanent centrifuge equipment, and proving a new application before committing to permanent installation."
      }
    },
    {
      "@type": "Question",
      "name": "Can I rent a centrifuge to test my application before buying?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Dolphin Centrifuge rental programs are specifically designed for application validation. You can rent a DMPX-series centrifuge, run it on your process fluid at your facility, and evaluate separation quality and throughput before making a purchase decision. Our sample testing service can also pre-qualify your fluid in our lab before you commit to a rental."
      }
    }
  ]
};
---

<BaseLayout
  title="Disc Stack Centrifuge Rental"
  description="Rent industrial disc stack centrifuges for short-term or long-term use. DMPX self-cleaning separators available for pilot testing and temporary capacity."
  canonicalUrl="https://dolphincentrifuge.com/disc-stack-centrifuge-rental/"
  breadcrumbs={[
    { label: 'Services', href: '/industrial-centrifuge-design/' },
    { label: 'Disc Stack Centrifuge Rental' },
  ]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">Services</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">Disc Stack Centrifuge Rental</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">
        Dolphin Centrifuge offers industrial disc stack centrifuges for rent on flexible short-term and long-term schedules. Our rental fleet includes DMPX-series self-cleaning separators ready for immediate deployment across oil, fuel, wastewater, and specialty applications.
      </p>
