            <thead>
              <tr class="bg-navy text-white">
                <th class="text-left px-4 py-3 font-semibold">Spec</th>
                <th class="text-left px-4 py-3 font-semibold">Value</th>
              </tr>
            </thead>
            <tbody class="bg-white">
              <tr class="border-t border-gray-100"><td class="px-4 py-2 font-medium text-navy">Capacity</td><td class="px-4 py-2 text-text-light">42 GPM on Diesel Fuel</td></tr>
