---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "What disc stack centrifuge models are available for rental from Dolphin Centrifuge?",
    answer: "Dolphin Centrifuge offers rental of DMPX-series self-cleaning disc stack centrifuges for short-term and long-term applications. Models range from DMPX-010 (7 GPM) to DMPX-070 (59–72 GPM on diesel). Units are available as standalone centrifuge skids or as complete systems with controls, pumps, and heating. Contact us for current availability."
  },
  {
    question: "What are the common reasons to rent a disc stack centrifuge?",
    answer: "Common rental use cases include: pilot testing before a capital purchase decision, emergency backup during a machine rebuild or repair, temporary capacity for seasonal production spikes, project work at a site without permanent centrifuge equipment, and proving a new application before committing to permanent installation."
  },
  {
    question: "Can I rent a centrifuge to test my application before buying?",
    answer: "Yes. Dolphin Centrifuge rental programs are specifically designed for application validation. You can rent a DMPX-series centrifuge, run it on your process fluid at your facility, and evaluate separation quality and throughput before making a purchase decision. Our sample testing service can also pre-qualify your fluid in our lab before you commit to a rental."
  },
  {
    question: "What is included in the disc stack centrifuge rental package?",
    answer: "Every Dolphin disc stack centrifuge rental includes a fully rebuilt centrifuge with new bearings, seals, and O-rings, along with the feed pump, motor, starter, and basic piping connections. An operating manual with process-specific parameters, phone and email technical support, and startup commissioning assistance (remote or on-site) are also included. A spare parts kit covering basic consumables for the rental duration is provided."
  },
  {
    question: "How quickly can a rental disc stack centrifuge be delivered?",
    answer: "Dolphin Centrifuge can typically ship a rental disc stack centrifuge within 5–10 business days from rental agreement execution for most DMPX models. Delivery time depends on model availability, your location, and freight scheduling. For urgent emergency situations, contact us directly at (248) 522-2573 to discuss expedited availability."
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Disc Stack Centrifuge Rental",
  "description": "Rent industrial disc stack centrifuges for short-term or long-term use. DMPX self-cleaning separators available for pilot testing and temporary capacity.",
  "provider": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "address": { "@type": "PostalAddress", "streetAddress": "24248 Gibson Dr.", "addressLocality": "Warren", "addressRegion": "MI", "postalCode": "48089", "addressCountry": "US" },
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "url": "https://dolphincentrifuge.com/disc-stack-centrifuge-rental/",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Disc Stack Centrifuge Rental Program",
  "description": "Rent industrial DMPX-series disc stack centrifuges from Dolphin Centrifuge for pilot testing, emergency backup, and temporary capacity. Fully rebuilt units, short- and long-term rental from Warren, Michigan.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/disc-stack-centrifuge-rental/",
  "mainEntityOfPage": "https://dolphincentrifuge.com/disc-stack-centrifuge-rental/"
};

const toc = [
  { id: 'overview', label: 'Rental Fleet Overview' },
  { id: 'mapx207', label: 'MAPX 207 Rental Centrifuge' },
  { id: 'mapx210', label: 'MAPX 210 Rental Centrifuge' },
  { id: 'why-rent', label: 'Why Rent a Disc Stack Centrifuge?' },
  { id: 'rental-apps', label: 'Rental Applications' },
  { id: 'models', label: 'Available Rental Models' },
  { id: 'included', label: "What's Included" },
  { id: 'comparison', label: 'Rental vs. Purchase' },
  { id: 'terms', label: 'Rental Terms' },
  { id: 'faq', label: 'FAQ' },
];

const relatedApplications = [
  { label: 'Decanter Centrifuge Rental', href: '/decanter-centrifuge-rental/' },
  { label: 'Disc Stack Applications', href: '/disc-stack-centrifuge-applications/' },
  { label: 'Sample Testing Service', href: '/industrial-centrifuge-sample-testing/' },
];

const relatedProducts = [
  { label: 'Disc Stack Centrifuge', href: '/disc-stack-centrifuge/', description: 'Overview of disc stack technology' },
  { label: 'Centrifuge Repair', href: '/industrial-disc-centrifuge-repair/', description: 'Rebuild and service' },
  { label: 'Centrifuge Buyback', href: '/industrial-centrifuge-buyback/', description: 'Sell or trade your centrifuge' },
];
---

<ApplicationLayout
  title="Disc Stack Centrifuge Rental & Leasing | Dolphin Centrifuge"
  description="Rent industrial disc stack centrifuges from Dolphin Centrifuge. DMPX self-cleaning separators for pilot testing, emergency backup, and temporary capacity."
  category="services"
  categoryLabel="Services"
  heroImage="/images/disc-stack-centrifuge-rental/Alfa-Laval-Disc-Centrifuge-Rental.webp"
  heroImageAlt="Alfa Laval Disc Centrifuge Rental Skid"
  canonicalUrl="https://dolphincentrifuge.com/disc-stack-centrifuge-rental/"
  jsonLd={[jsonLd, faqJsonLd, articleJsonLd]}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>
  <!-- AI Summary -->
  <div class="not-prose bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge rents fully rebuilt disc stack centrifuges for pilot testing, emergency backup, and temporary capacity. DMPX-series self-cleaning separators from 8 to 72 GPM are available for short- or long-term projects. Based in Warren, Michigan — call (248) 522-2573.</p>
  </div>

  <!-- Legacy Content -->
  <h2 id="overview">Rental Fleet Overview</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-1/2">
      <p>Dolphin Centrifuge maintains a fleet of Rental Disc-stack Centrifuges that are suited for:</p>
      <ul>
        <li>Centrifuge Evaluation for your specific process</li>
        <li>Emergency Service in case your centrifuge breaks down or is in service</li>
        <li>Short-term process capacity augmentation</li>
      </ul>
      <p>In some cases, Dolphin Centrifuge can accommodate long-term rental requirements by building a skid for specific customer applications.</p>
      <p><strong>A rental contract requires a minimum rental period commitment, deposit, execution of a formal rental contract, and other standard conditions.</strong></p>
    </div>
    <div class="md:w-1/2">
      <img loading="lazy" src="/images/disc-stack-centrifuge-rental/Alfa-Laval-28-GPM-Self-Cleaning-Centrifuge-Rental-600.webp" alt="Alfa Laval 28 GPM Self Cleaning Centrifuge Rental" width="600" height="600" class="rounded-xl" />
    </div>
  </div>

  <!-- MAPX 207 Disc Stack Centrifuge Rental -->
  <h2 id="mapx207">MAPX 207 Disc Stack Centrifuge Rental</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-1/2">
      <p><strong><a href="/alfa-laval-mopx-207-centrifuge/" class="text-navy hover:text-gold transition-colors">Alfa Laval MAPX 207</a> 22 GPM Self-Cleaning, Disc Stack, Rental Centrifuge</strong></p>
      <h3>Applications</h3>
      <ul>
        <li><a href="/diesel-centrifuge/"><strong>Diesel Fuel</strong></a></li>
        <li><a href="/lube-oil-centrifuge/"><strong>Engine Oil</strong></a></li>
        <li><a href="/hydraulic-oil-centrifuge/"><strong>Hydraulic Oil</strong></a></li>
        <li><a href="/crude-oil-centrifuge/"><strong>Light Crude Oil</strong></a></li>
        <li><a href="/waste-oil-centrifuge/"><strong>Waste Oil – Used Oil</strong></a></li>
        <li><a href="/oil-centrifuge/"><strong>Industrial Oils</strong></a></li>
        <li><a href="/wvo-centrifuge-separator/"><strong>WVO, UCO, Grease Trap/Yellow Grease</strong></a></li>
        <li>and other 3-phase separation with &lt;5% solids (v/v).</li>
      </ul>
    </div>
    <div class="md:w-1/2">
      <img loading="lazy" src="/images/disc-stack-centrifuge-rental/Alfa-Laval-28-GPM-Self-Cleaning-Centrifuge-Rental-600.webp" alt="Alfa Laval 28 GPM Self Cleaning Centrifuge Rental" width="600" height="600" class="rounded-xl" />
    </div>
  </div>

  <h3>MAPX 207 Specifications</h3>
  <table>
    <thead>
      <tr><th>Spec</th><th>Value</th></tr>
    </thead>
