---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';




const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Disc Stack Centrifuge Rental",
  "description": "Dolphin Centrifuge rents disc stack centrifuges for qualifying oil applications including crude oil, used oil, waste oil, lube oil, hydraulic oil, and diesel fuel purification. Rentals are limited and not broadly available for non-oil applications.",
  "provider": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "address": { "@type": "PostalAddress", "streetAddress": "24248 Gibson Dr.", "addressLocality": "Warren", "addressRegion": "MI", "postalCode": "48089", "addressCountry": "US" },
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "url": "https://dolphincentrifuge.com/disc-stack-centrifuge-rental/",
};



const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Disc Stack Centrifuge Rental - Oil Applications Only",
  "description": "Dolphin Centrifuge rents disc stack centrifuges for qualifying oil applications including crude oil, used oil, waste oil, lube oil, hydraulic oil, and diesel fuel. Rentals are not broadly available. Contact us to check availability.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/disc-stack-centrifuge-rental/",
  "mainEntityOfPage": "https://dolphincentrifuge.com/disc-stack-centrifuge-rental/"
};

const toc = [
  { id: 'rental-notice', label: 'Rental Availability Notice' },
  { id: 'overview', label: 'Rental Fleet Overview' },
  { id: 'mapx207', label: 'MAPX 207 Rental Centrifuge' },
  { id: 'mapx210', label: 'MAPX 210 Rental Centrifuge' },
  { id: 'qualifying-apps', label: 'Qualifying Oil Applications' },
  { id: 'models', label: 'Available Rental Models' },
  { id: 'included', label: "What's Included" },
  { id: 'comparison', label: 'Rental vs. Purchase' },
  { id: 'terms', label: 'Rental Terms' },

];

const relatedApplications = [
  { label: 'Decanter Centrifuge Rental', href: '/decanter-centrifuge-rental/' },
  { label: 'Disc Stack Applications', href: '/disc-stack-centrifuge-applications/' },
  { label: 'Sample Testing Service', href: '/industrial-centrifuge-sample-testing/' },
];

const relatedProducts = [
  { label: 'Disc Stack Centrifuge', href: '/disc-stack-centrifuge/', description: 'Overview of disc stack technology' },
  { label: 'Centrifuge Repair', href: '/industrial-disc-centrifuge-repair/', description: 'Rebuild and service' },
  { label: 'Centrifuge Buyback', href: '/industrial-centrifuge-buyback/', description: 'Sell or trade your centrifuge' },
];
---

<ApplicationLayout
  title="Disc Stack Centrifuge Rental | Oil Applications Only | Dolphin Centrifuge"
  description="Dolphin Centrifuge rents disc stack centrifuges for qualifying oil applications only, including crude oil, used oil, waste oil, lube oil, hydraulic oil, and diesel fuel. Rentals are not broadly available. Contact us to check whether your application qualifies."
  category="services"
  categoryLabel="Services"
  heroImage="/images/disc-stack-centrifuge-rental/Alfa-Laval-Disc-Centrifuge-Rental.webp"
  heroImageAlt="Alfa Laval Disc Centrifuge Rental Skid"
  canonicalUrl="https://dolphincentrifuge.com/disc-stack-centrifuge-rental/"
  jsonLd={[jsonLd, articleJsonLd]}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
  hideBottomCTA={true}
>

  <!-- Rental Availability Notice -->
  <div id="rental-notice" class="not-prose bg-amber-50 border-l-4 border-amber-500 rounded-r-lg p-5 mb-6">
    <p class="text-base font-bold text-gray-900 mb-2">Rental Availability is Limited</p>
    <p class="text-sm text-gray-800 leading-relaxed">Dolphin Centrifuge typically rents disc stack centrifuges only for qualifying oil applications, including crude oil, used oil, waste oil, lube oil, hydraulic oil, diesel/fuel oil, and similar oil separation work. Rentals are usually not the best fit for most non-oil applications. For those projects, contact Dolphin to discuss sample testing, purchase, or rebuild options.</p>
  </div>

  <!-- Legacy Content -->
  <h2 id="overview">Rental Fleet Overview</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-1/2">
      <p>Dolphin Centrifuge maintains a limited fleet of rental disc stack centrifuges. These units are reserved for qualifying oil separation applications, including:</p>
      <ul>
        <li>Crude oil and light crude purification</li>
        <li>Used oil and waste oil recovery</li>
        <li>Lube oil, engine oil, and hydraulic oil cleaning</li>
        <li>Diesel fuel and fuel oil polishing</li>
      </ul>
      <p>Rental is available for process evaluation, emergency backup during a machine repair, or short-term capacity needs within these qualifying oil applications.</p>
      <p><strong>A rental contract requires a minimum rental period commitment, deposit, execution of a formal rental contract, and other standard conditions. Contact Dolphin first to confirm your application qualifies before requesting a rental quote.</strong></p>
    </div>
    <div class="md:w-1/2">
      <figure>
        <img loading="lazy" src="/images/disc-stack-centrifuge-rental/Alfa-Laval-28-GPM-Self-Cleaning-Centrifuge-Rental-600.webp" alt="Alfa Laval 28 GPM Self Cleaning Centrifuge Rental" width="600" height="600" class="img-cap-600" />
        <figcaption>Alfa Laval 28 GPM Self-Cleaning Disc Stack Rental Centrifuge</figcaption>
      </figure>
    </div>
  </div>

  <!-- MAPX 207 Disc Stack Centrifuge Rental -->
  <h2 id="mapx207">MAPX 207 Disc Stack Centrifuge Rental</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-1/2">
      <p><strong><a href="/alfa-laval-mopx-207-centrifuge/" class="text-navy hover:text-gold transition-colors">Alfa Laval MAPX 207</a> 22 GPM Self-Cleaning, Disc Stack, Rental Centrifuge</strong></p>
      <h3>Qualifying Oil Applications</h3>
      <ul>
        <li><a href="/diesel-centrifuge/"><strong>Diesel Fuel</strong></a></li>
        <li><a href="/lube-oil-centrifuge/"><strong>Engine Oil</strong></a></li>
        <li><a href="/hydraulic-oil-centrifuge/"><strong>Hydraulic Oil</strong></a></li>
        <li><a href="/crude-oil-centrifuge/"><strong>Light Crude Oil</strong></a></li>
        <li>Other oil-phase separation with less than 5% solids (v/v) - contact us to confirm fit</li>
      </ul>
    </div>
    <div class="md:w-1/2">
      <figure>
        <img loading="lazy" src="/images/disc-stack-centrifuge-rental/Alfa-Laval-28-GPM-Self-Cleaning-Centrifuge-Rental-600.webp" alt="Alfa Laval 28 GPM Self Cleaning Centrifuge Rental" width="600" height="600" class="img-cap-600" />
        <figcaption>Alfa Laval MAPX 207 - 28 GPM Self-Cleaning Rental Centrifuge</figcaption>
      </figure>
    </div>
  </div>

  <h3>MAPX 207 Specifications</h3>
  <div class="not-prose overflow-x-auto border border-gray-100 rounded-xl">
    <table>
      <thead>
        <tr><th>Spec</th><th>Value</th></tr>
      </thead>
      <tbody>
        <tr><td>Capacity</td><td>28 GPM on Diesel Fuel</td></tr>
        <tr><td>Motor</td><td>460V / 3Ph - 7.5 HP Motor</td></tr>
        <tr><td>Skid Size</td><td>5' x 4' x 6' (H)</td></tr>
        <tr><td>Weight</td><td>~ 2,500 Lbs</td></tr>
        <tr><td>Power</td><td>460 VAC Power - 50 A Circuit</td></tr>
        <tr><td>Water</td><td>Filtered, Potable through 3/4" Line @ 5 GPM and 30 psig</td></tr>
        <tr><td>Air</td><td>100 psig, filtered, dry air</td></tr>
        <tr><td>Included options</td><td>PC Touch-Screen Control System and Water Harness</td></tr>
      </tbody>
    </table>
  </div>

  <p><em><strong>In some cases, Dolphin Centrifuge can accommodate long-term rental requirements for qualifying oil applications by building a skid for specific customer needs.</strong></em></p>

  <!-- MAPX 210 Disc Stack Centrifuge Rental -->
  <h2 id="mapx210">MAPX 210 Disc Stack Centrifuge Rental</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-1/2">
      <p><strong><a href="/alfa-laval-whpx-510-centrifuge/" class="text-navy hover:text-gold transition-colors">Alfa Laval MAPX 210</a> 42 GPM Self-Cleaning, Disc Stack, Rental Centrifuge</strong></p>
      <h3>Qualifying Oil Applications</h3>
      <ul>
        <li><a href="/diesel-centrifuge/"><strong>Diesel Fuel</strong></a></li>
        <li><a href="/lube-oil-centrifuge/"><strong>Engine Oil</strong></a></li>
        <li><a href="/hydraulic-oil-centrifuge/"><strong>Hydraulic Oil</strong></a></li>
        <li><a href="/crude-oil-centrifuge/"><strong>Light Crude Oil</strong></a></li>
        <li>Other oil-phase separation with less than 5% solids (v/v) - contact us to confirm fit</li>
      </ul>
    </div>
    <div class="md:w-1/2">
      <figure>
        <img loading="lazy" src="/images/disc-stack-centrifuge-rental/Alfa-Laval-42-GPM-Self-Cleaning-Rental-Centrifuge.webp" alt="Alfa Laval 42 GPM Self Cleaning Rental Centrifuge" width="600" height="600" class="img-cap-600" />
        <figcaption>Alfa Laval MAPX 210 - 42 GPM Self-Cleaning Rental Centrifuge</figcaption>
      </figure>
    </div>
  </div>

  <p><em><strong>If you have routine questions about disc stack centrifuges, we have condensed our 40+ years of experience into <a href="/disc-stack-centrifuge-faq/">101 Frequently Asked Questions about Disc Stack Centrifuges!</a></strong></em></p>

  <h3>MAPX 210 Specifications</h3>
  <div class="not-prose overflow-x-auto border border-gray-100 rounded-xl">
    <table>
      <thead>
        <tr><th>Spec</th><th>Value</th></tr>
      </thead>
      <tbody>
        <tr><td>Capacity</td><td>42 GPM on Diesel Fuel</td></tr>
        <tr><td>Motor</td><td>460V / 3Ph - 15 HP Motor</td></tr>
        <tr><td>Skid Size</td><td>6' x 6' x 6' (H)</td></tr>
        <tr><td>Weight</td><td>~ 3,500 Lbs</td></tr>
        <tr><td>Power</td><td>460 VAC Power - 50 A Circuit</td></tr>
        <tr><td>Water</td><td>Filtered, Potable through 3/4" Line @ 5 GPM and 30 psig</td></tr>
        <tr><td>Air</td><td>100 psig, filtered, dry air</td></tr>
        <tr><td>Included options</td><td>Sludge Tank, Sludge Pump, Feed Pump w/ VFD Control, PLC Touch-Screen Control System, etc.</td></tr>
      </tbody>
    </table>
  </div>

  <!-- Qualifying Applications -->
  <h2 id="qualifying-apps">Qualifying Oil Applications for Disc Stack Rental</h2>
  <p>Disc stack centrifuge rentals from Dolphin Centrifuge are limited to oil separation work. If your application involves one of the following fluids, contact us to discuss rental availability:</p>
  <ul>
    <li><strong>Crude Oil and Light Crude:</strong> Tank bottom recovery, crude oil polishing, oilfield separation</li>
    <li><strong>Diesel Fuel and Fuel Oil:</strong> Water and solids removal from stored or bulk diesel</li>
    <li><strong>Lube Oil and Engine Oil:</strong> Extending oil life by continuous centrifugal cleaning</li>
    <li><strong>Hydraulic Oil:</strong> Removing water and fine particles from hydraulic systems</li>
  </ul>
  <p>If your application is outside oil separation - such as wastewater treatment, food and beverage, chemical processing, or construction dewatering - rental is generally not available. Contact Dolphin to discuss whether sample testing, a direct purchase, or a rebuild is a better path.</p>

  <!-- Available Rental Models -->
  <h2 id="models">Available Rental Models</h2>
  <p>Our <a href="/disc-stack-centrifuge-applications/">disc stack rental fleet</a> is pre-configured for oil separation applications. The DMPX-series models below are the starting point for rental discussions, subject to current availability:</p>
  <div class="not-prose overflow-x-auto border border-gray-100 rounded-xl">
    <table>
      <thead>
        <tr><th>Model</th><th>Type</th><th>Flow Rate</th><th>Oil Applications (Qualifying)</th></tr>
      </thead>
      <tbody>
        <tr><td>DMPX-010</td><td>Self-Cleaning</td><td>Up to 8 GPM</td><td>Small-volume oil, diesel, biodiesel</td></tr>
        <tr><td>DMPX-014</td><td>Self-Cleaning</td><td>Up to 16 GPM</td><td>Waste oil, lube oil, diesel</td></tr>
        <tr><td>DMPX-028</td><td>Self-Cleaning</td><td>Up to 28 GPM</td><td>Fuel oil, hydraulic oil, crude oil</td></tr>
        <tr><td>DMPX-042</td><td>Self-Cleaning</td><td>Up to 47 GPM</td><td>Large-volume waste oil, used oil</td></tr>
        <tr><td>DMPX-070</td><td>Self-Cleaning</td><td>Up to 72 GPM</td><td>High-volume oil, refinery, crude oil</td></tr>
      </tbody>
    </table>
  </div>
  <p>Model availability changes. Contact us before assuming any specific unit is available for your timeline.</p>

  <!-- What's Included -->
  <h2 id="included">What's Included in a Rental</h2>
  <ul>
    <li><strong>Fully Rebuilt Centrifuge:</strong> Every rental unit is rebuilt to OEM specifications with new <a href="/disc-stack-centrifuge-parts/">bearings, seals, and O-rings</a></li>
    <li><strong>Complete System:</strong> Centrifuge, feed pump, motor, starter, and basic piping connections</li>
    <li><strong>Operating Manual:</strong> Process-specific setup guide and recommended operating parameters</li>
    <li><strong>Technical Support:</strong> Phone and email support from our engineers during the rental period</li>
    <li><strong>Startup Assistance:</strong> Remote or on-site commissioning support available</li>
    <li><strong>Spare Parts Kit:</strong> Basic consumables included for the rental duration</li>
  </ul>

  <!-- Mid-Page CTA -->
  <div class="bg-gold/10 border-l-4 border-gold rounded-r-xl p-5 my-8 not-prose">
    <p class="font-semibold text-navy mb-1">Check Rental Availability for Your Oil Application</p>
    <p class="text-sm text-gray-800 mb-3">Dolphin Centrifuge rents disc stack centrifuges for qualifying oil applications only. Contact us to discuss whether your application fits, check current fleet availability, and get a rental estimate.</p>
    <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold text-white font-semibold px-5 py-2 rounded-lg hover:bg-gold/90 transition-colors text-sm">Discuss Rental Fit</a>
  </div>

  <!-- Rental vs. Purchase -->
  <h2 id="comparison">Rental vs. Purchase</h2>
  <p>For most customers, purchasing or rebuilding a centrifuge is a better long-term solution than renting. Rental is a conditional option, not a default service. Use the table below to assess which path fits your situation:</p>
  <div class="not-prose overflow-x-auto border border-gray-100 rounded-xl">
    <table>
      <thead>
        <tr><th>Factor</th><th>Rental (Oil Apps Only)</th><th>Purchase or Rebuild</th></tr>
      </thead>
      <tbody>
        <tr><td>Upfront Cost</td><td>Lower monthly commitment</td><td>Full capital outlay, owned asset</td></tr>
        <tr><td>Commitment</td><td>Flexible, subject to contract minimum</td><td>Long-term ownership</td></tr>
        <tr><td>Application Fit</td><td>Oil separation applications only</td><td>Any qualifying application</td></tr>
        <tr><td>Availability</td><td>Limited fleet, not always available</td><td>Build or source to your spec</td></tr>
        <tr><td>Maintenance</td><td>Shared responsibility during rental</td><td>Owner responsibility</td></tr>
        <tr><td>Best For</td><td>Emergency backup or short-term oil work</td><td>Continuous or long-term operation</td></tr>
      </tbody>
    </table>
  </div>
  <p><strong>Rent-to-Own:</strong> In qualifying cases, rental payments may apply toward a purchase price. Discuss this option with Dolphin directly.</p>

  <!-- Rental Terms -->
  <h2 id="terms">Rental Terms</h2>
  <p>Rentals are subject to application qualification and fleet availability. Standard terms are outlined below:</p>
  <ul>
    <li><strong>Minimum Period:</strong> A minimum rental commitment is required. Duration varies by application and model.</li>
    <li><strong>Short-Term (1 to 3 months):</strong> Available for emergency backup or short-run oil processing needs</li>
    <li><strong>Long-Term (6 to 12+ months):</strong> Reduced monthly rates may apply for extended commitments in qualifying oil applications</li>
    <li><strong>Rent-to-Own:</strong> May be available for qualifying oil applications - contact us to discuss</li>
    <li><strong>Shipping:</strong> We arrange freight to and from your facility within the continental U.S.</li>
    <li><strong>Deposit and Contract:</strong> A deposit and formal rental agreement are required before any unit ships</li>
  </ul>
  <p>Looking for a decanter centrifuge instead? See our <a href="/decanter-centrifuge-rental/">decanter centrifuge rental program</a> for NX and G2-series units.</p>



</ApplicationLayout>
