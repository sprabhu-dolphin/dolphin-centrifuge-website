        </ul>
        <h3 class="text-lg font-bold text-navy mb-3">Specifications</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
            <thead>
              <tr class="bg-navy text-white">
                <th class="text-left px-4 py-3 font-semibold">Spec</th>
                <th class="text-left px-4 py-3 font-semibold">Value</th>
              </tr>
            </thead>
            <tbody class="bg-white">
              <tr class="border-t border-gray-100"><td class="px-4 py-2 font-medium text-navy">Capacity</td><td class="px-4 py-2 text-text-light">28 GPM on Diesel Fuel</td></tr>
              <tr class="border-t border-gray-100"><td class="px-4 py-2 font-medium text-navy">Motor</td><td class="px-4 py-2 text-text-light">460V / 3Ph &ndash; 7.5 HP Motor</td></tr>
              <tr class="border-t border-gray-100"><td class="px-4 py-2 font-medium text-navy">Skid Size</td><td class="px-4 py-2 text-text-light">5&prime; x 4&prime; x 6&prime; (H)</td></tr>
              <tr class="border-t border-gray-100"><td class="px-4 py-2 font-medium text-navy">Weight</td><td class="px-4 py-2 text-text-light">~ 2,500 Lbs</td></tr>
              <tr class="border-t border-gray-100"><td class="px-4 py-2 font-medium text-navy">Power</td><td class="px-4 py-2 text-text-light">460 VAC Power - 50 A Circuit</td></tr>
              <tr class="border-t border-gray-100"><td class="px-4 py-2 font-medium text-navy">Water</td><td class="px-4 py-2 text-text-light">Filtered, Potable through 3/4&Prime; Line @ 5 GPM and 30 psig</td></tr>
              <tr class="border-t border-gray-100"><td class="px-4 py-2 font-medium text-navy">Air</td><td class="px-4 py-2 text-text-light">100 psig, filtered, dry air</td></tr>
              <tr class="border-t border-gray-100"><td class="px-4 py-2 font-medium text-navy">Included options</td><td class="px-4 py-2 text-text-light">PC Touch-Screen Control System and Water Harness</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- MAPX 210 Disc Stack Centrifuge Rental -->
      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mt-10 mb-4">MAPX 210 Disc Stack Centrifuge Rental</h2>
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 md:p-8 mb-10">
        <h3 class="text-lg font-bold text-navy mb-3">Applications</h3>
        <ul class="text-text-light space-y-1 mb-6">
          <li>&#8226; Diesel Fuel</li>
          <li>&#8226; Engine Oil</li>
          <li>&#8226; Hydraulic Oil</li>
          <li>&#8226; Light Crude Oil</li>
          <li>&#8226; Waste Oil &ndash; Used Oil</li>
          <li>&#8226; Industrial Oils</li>
          <li>&#8226; WVO, UCO, Grease Trap/Yellow Grease</li>
