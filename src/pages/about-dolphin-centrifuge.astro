---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "When was Dolphin Centrifuge founded?",
    answer: "Dolphin Centrifuge was founded in 1981, originally as an Alfa Laval aftermarket parts manufacturer. Over 40+ years, the company expanded from parts supply into engineering, manufacturing complete centrifuge system packages, and full-service <a href='/industrial-disc-centrifuge-repair/'>centrifuge repair</a>. Dolphin Centrifuge is based in Warren, Michigan and serves customers globally."
  },
  {
    question: "What types of centrifuges does Dolphin Centrifuge supply?",
    answer: "Dolphin Centrifuge supplies <a href='/disc-stack-centrifuge/'>disc stack centrifuges</a> (self-cleaning and manual-clean), <a href='/decanter-centrifuge/'>decanter centrifuges</a>, and complete centrifuge system packages including pumps, heaters, filters, and PLC control panels. The company also provides centrifuge rebuild and remanufacturing services, parts supply, and on-site technical support."
  },
  {
    question: "Where is Dolphin Centrifuge located?",
    answer: "Dolphin Centrifuge is located at 24248 Gibson Drive, Warren, Michigan 48089. The facility includes engineering offices, centrifuge assembly and testing areas, parts inventory, and a customer demonstration lab. Customers are welcome to visit for factory demonstrations and <a href='/industrial-centrifuge-sample-testing/'>application testing</a> with their own process fluids."
  },
  {
    question: "Does Dolphin Centrifuge offer centrifuge system design?",
    answer: "Yes. Dolphin Centrifuge provides complete <a href='/industrial-centrifuge-design/'>centrifuge system design</a> including 3D modeling, skid and piping fabrication, control panel design, centrifuge remanufacturing, and full system assembly and testing — all performed in-house at the Warren, Michigan facility."
  },
  {
    question: "Can I visit the Dolphin Centrifuge facility?",
    answer: "Absolutely. Dolphin Centrifuge maintains an open invitation for potential customers to tour the Warren, Michigan facility. Visitors can see the centrifuge inventory of 150+ units, the manufacturing shop, and meet the engineering team. <a href='/contact-for-alfa-laval-centrifuges/'>Contact us</a> to schedule a visit."
  }
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "logo": "https://dolphincentrifuge.com/images/dolphin-centrifuge-logo.png",
    "description": "Dolphin Centrifuge is a company specializing in manufacturing industrial centrifuge systems, established in 1981 as an Alfa Laval aftermarket parts manufacturer. Based in Warren, Michigan, Dolphin Centrifuge designs and manufactures complete fluid recovery centrifuge systems for food, environmental, chemical, waste processing, rendering, and metalworking industries.",
    "foundingDate": "1981",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "24248 Gibson Dr",
      "addressLocality": "Warren",
      "addressRegion": "MI",
      "postalCode": "48089",
      "addressCountry": "US"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+1-248-522-2573",
      "contactType": "sales",
      "email": "sales@dolphincentrifuge.com",
      "availableLanguage": "English"
    },
    "areaServed": "Worldwide",
    "numberOfEmployees": {
      "@type": "QuantitativeValue",
      "description": "Team with 100+ cumulative years of centrifuge experience"
    },
    "knowsAbout": [
      "Industrial Centrifuges",
      "Disc Stack Centrifuges",
      "Decanter Centrifuges",
      "Centrifuge System Design",
      "Centrifuge Remanufacturing",
      "Fluid Recovery Systems"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Dolphin Centrifuge",
    "image": "https://dolphincentrifuge.com/images/about-dolphin-centrifuge/Dolphin-Centrifuge-Shop-Warren-1000.webp",
    "url": "https://dolphincentrifuge.com/about-dolphin-centrifuge/",
    "telephone": "+1-248-522-2573",
    "email": "sales@dolphincentrifuge.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "24248 Gibson Dr",
      "addressLocality": "Warren",
      "addressRegion": "MI",
      "postalCode": "48089",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "42.4934",
      "longitude": "-83.0280"
    },
    "description": "Industrial centrifuge manufacturer specializing in complete fluid recovery systems. Over 40 years of experience, 150+ centrifuges in stock, and installations on five continents.",
    "foundingDate": "1981",
    "priceRange": "$$$$"
  }
];
---

<BaseLayout
  title="About Dolphin Centrifuge | Industrial Centrifuge Co."
  description="Dolphin Centrifuge, established 1981 Warren MI — industrial centrifuge systems. 100+ years of team experience, 200+ units in stock, worldwide installations."
  canonicalUrl="https://dolphincentrifuge.com/about-dolphin-centrifuge/"
  breadcrumbs={[{label: 'About', href: '/about-dolphin-centrifuge/'}]}
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <Hero
    title="Dolphin Centrifuge — Your One-Stop Industrial Centrifuge Shop"
    subtitle="About Us"
    description="Engineering and manufacturing complete fluid recovery centrifuge systems since 1981. Warren, Michigan, USA."
    imageSrc="/images/about-dolphin-centrifuge/Dolphin-Centrifuge-Shop-Warren-1000.webp"
    imageAlt="Dolphin Centrifuge Shop in Warren (Detroit Metro), Michigan, USA — industrial centrifuge manufacturing facility"
    overlay="frost"
    ctaLabel="Contact Us"
    ctaHref="/contact-for-alfa-laval-centrifuges/"
    secondaryCtaLabel="Our Products"
    secondaryCtaHref="/industrial-centrifuge/"
  />

  <!-- Table of Contents -->
  <section class="bg-white border-b border-gray-200">
    <div class="container-dolphin max-w-4xl py-8">
      <h2 class="text-lg font-bold text-[#1B3A5C] mb-4">Table of Contents</h2>
      <nav class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm">
        <a href="#who-is-dolphin" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Who is Dolphin Centrifuge?</a>
        <a href="#what-does-dolphin-do" class="text-[#1B3A5C] hover:text-[#E8A317] underline">What does Dolphin Centrifuge do?</a>
        <a href="#where-is-dolphin" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Where is Dolphin Centrifuge based?</a>
        <a href="#our-stock" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Our Industrial Centrifuge Stock</a>
        <a href="#why-choose" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Why Choose Dolphin Centrifuge?</a>
        <a href="#our-team" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Our Team</a>
        <a href="#our-facility" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Our Facility</a>
        <a href="#system-design" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Centrifuge System Design and 3D Modeling</a>
        <a href="#skid-piping" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Skid, Piping, and Support Fabrication</a>
        <a href="#control-panel" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Control Panel Design and Assembly</a>
        <a href="#remanufacture" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Centrifuge Remanufacture</a>
        <a href="#assembly-test" class="text-[#1B3A5C] hover:text-[#E8A317] underline">System Assembly and Test</a>
        <a href="#open-invitation" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Open Invitation</a>
      </nav>
    </div>
  </section>

  <!-- Main Content -->
  <section class="bg-[#F5F5F0]">
    <div class="container-dolphin py-12 md:py-16 max-w-4xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge is a Warren, Michigan industrial centrifuge manufacturer established in 1981. Specializing in Alfa Laval disc stack and decanter centrifuge systems, Dolphin designs, builds, and services complete fluid recovery modules with a global installed capacity exceeding 10 billion gallons annually.</p>
      </div>

      <!-- Who Is Dolphin — Pattern A side-by-side -->
      <div id="who-is-dolphin" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1B3A5C] mb-4">Who is Dolphin Centrifuge?</h2>
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <div class="md:w-1/2">
            <p class="text-[#2D2D2D] text-lg font-semibold mb-4">
              Dolphin Centrifuge is a company specializing in manufacturing industrial centrifuge systems.
            </p>
            <p class="text-[#2D2D2D] mb-4">
              Established in 1981, we started as an Alfa Laval aftermarket parts manufacturer. Over time, we created a niche for ourselves in the industrial centrifuge market. Our niche is complete fluid recovery systems built around <a href="/alfa-laval-industrial-centrifuges/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">Alfa Laval industrial centrifuges</a>.
            </p>
            <p class="text-[#2D2D2D]">
              By 2004 we had supplied centrifuge systems to all five major continents. In 2017 we had a global annual installed capacity of over <strong>10 billion gallons!</strong>
            </p>
          </div>
          <div class="md:w-1/2 space-y-4">
            <img
              src="/images/about-dolphin-centrifuge/Dolphin-Centrifuge-Shop-600.webp"
              alt="Dolphin Centrifuge Shop — Industrial Centrifuge Systems Manufacturing Facility in Warren, Michigan"
              width="600"
              height="400"
              loading="lazy"
              class="rounded-lg shadow-sm w-full object-cover"
            />
            <div class="flex items-center gap-4">
              <img
                src="/images/about-dolphin-centrifuge/Dolphin-Centrifuge-40-Years.webp"
                alt="Dolphin Centrifuge 40 Years of Experience in Industrial Centrifuge Manufacturing"
                width="225"
                height="225"
                loading="lazy"
                class="rounded-lg shadow-sm w-28 h-28 object-cover"
              />
              <p class="text-gray-500 text-sm">Dolphin Centrifuge Shop — Warren, Michigan</p>
            </div>
          </div>
        </div>
      </div>

      <!-- What Does Dolphin Do -->
      <div id="what-does-dolphin-do" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1B3A5C] mb-4">What does Dolphin Centrifuge do?</h2>
        <p class="text-[#2D2D2D] mb-4">
          As an engineering company, we design and manufacture centrifuge systems for <strong>food, environmental chemicals, waste processing, rendering, metalworking</strong>, and similar industries. These centrifuge systems all feature <a href="/alfa-laval-centrifugal-separator/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">Alfa Laval centrifugal separators</a>.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          One of our specialties is re-purposing disc stack centrifuges. We develop <a href="/disc-stack-centrifuge-applications/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">centrifuge-based solutions for applications</a> that even the OEM rates as unlikely!
        </p>
        <p class="text-[#2D2D2D] mb-3">
          Also, we manufacture auxiliary centrifuge systems to complement our centrifuge systems. Some of our proprietary additions include:
        </p>
        <ul class="list-disc pl-6 text-[#2D2D2D] space-y-2 mb-4">
          <li><a href="/fluid-heating-systems/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">Heat Loops (Clog-Free Fluid Heating or Cooling Exchanger)</a></li>
          <li>Hot Fluid Heat Recovery Package</li>
          <li>Containerized Oil Recovery Systems (ORS)</li>
          <li>Heavy-duty Heater, Strainer, and Pump Modules (Crude Oil)</li>
        </ul>
        <p class="text-[#2D2D2D]">
          Dolphin has developed its proprietary <a href="/industrial-centrifuge-controls/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">Centrifuge Control System</a>. It uses state-of-the-art technology for ease of operation and unique built-in troubleshooting features.
        </p>
      </div>

      <!-- Where Is Dolphin Based -->
      <div id="where-is-dolphin" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1B3A5C] mb-4">Where is Dolphin Centrifuge based?</h2>
        <p class="text-[#2D2D2D] mb-4">
          Our location is in the <strong>Detroit Metro area</strong>, in the city of Warren, MI. Our manufacturing location is in an industrial district close to our vendors. Being in Motor City is an advantage with many automotive suppliers in the area.
        </p>
        <div class="bg-[#F5F5F0] rounded-lg p-4 flex flex-wrap gap-4 text-sm text-[#2D2D2D]">
          <div><span class="font-semibold">Address:</span> 24248 Gibson Dr, Warren MI 48089</div>
          <div><span class="font-semibold">Phone:</span> <a href="tel:+12485222573" class="text-[#1B3A5C] hover:text-[#E8A317]">(248) 522-2573</a></div>
          <div><span class="font-semibold">Email:</span> <a href="mailto:sales@dolphincentrifuge.com" class="text-[#1B3A5C] hover:text-[#E8A317]">sales@dolphincentrifuge.com</a></div>
        </div>
      </div>

      <!-- Our Stock -->
      <div id="our-stock" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1B3A5C] mb-4">Our Industrial Centrifuge Stock</h2>
        <p class="text-[#2D2D2D] mb-4">
          We have <strong>over 150 New and Used industrial centrifuges in our stock in Warren, MI.</strong> We source good (gently used) Alfa Laval centrifuges from all over the world. In our stock, you will not find centrifuges from drilling mud or other abrasive applications.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          We can also source new centrifuges for customers who cannot accept reconditioned centrifuges.
        </p>
        <p class="text-[#2D2D2D]">
          Our inventory includes a wide range of <a href="/disc-stack-centrifuge/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">disc stack centrifuges</a> and <a href="/decanter-centrifuge/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">decanter centrifuges</a> in various sizes and configurations, ready for remanufacturing and system integration for your specific application requirements.
        </p>
      </div>

      <!-- Mid-Page CTA -->
      <div class="bg-[#1B3A5C] rounded-xl p-6 md:p-8 text-white text-center mb-8">
        <h3 class="text-xl font-bold mb-2">Have a Centrifuge Application in Mind?</h3>
        <p class="text-blue-100 mb-4">
          Our engineering team can help you select the right centrifuge for your specific process. Contact us to discuss your requirements.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] text-white font-bold px-6 py-3 rounded-lg hover:bg-yellow-500 transition-colors">
            Request a Quote
          </a>
          <a href="tel:+12485222573" class="border border-white text-white font-semibold px-6 py-3 rounded-lg hover:bg-white hover:text-[#1B3A5C] transition-colors">
            Call (248) 522-2573
          </a>
        </div>
      </div>

      <!-- Why Choose Dolphin -->
      <div id="why-choose" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1B3A5C] mb-4">Why Choose Dolphin Centrifuge?</h2>
        <p class="text-[#2D2D2D] mb-4">
          Simply put, we know centrifuges, and we have the expertise! We have supplied centrifuges over the years for most practical applications. Our experience allows us to help our customers select the best centrifuge for their specific purpose.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          Our years of field experience and lessons are built into our centrifuge equipment as an added benefit.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          Dolphin Centrifuge has a spacious, well-equipped industrial facility. Our location has a growing inventory of over <strong>200 centrifuges in stock</strong>.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          Our stock of gently used centrifuges is a significant benefit to our customers. It allows us to offer quality centrifuges from our inventory instead of searching the market after getting your order.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          We take great pride in our <strong>American workmanship</strong> and a well-recognized client list. Our customer list includes our military and other government agencies.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          Also, we have supplied centrifuge systems to <strong>O&amp;G companies, Power Utilities, Rig-builders</strong>, etc.
        </p>
        <p class="text-[#2D2D2D]">
          All our centrifuge equipment comes with a mechanical warranty. We also provide <strong>lifetime technical support</strong> to our customers.
        </p>
      </div>

      <!-- Our Team — Pattern A side-by-side -->
      <div id="our-team" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1B3A5C] mb-4">Our Team</h2>
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <div class="md:w-1/2">
            <p class="text-[#2D2D2D] mb-4">
              Dolphin Centrifuge's primary resource is our people. Our team has a cumulative <strong>100+ years of experience</strong> with <a href="/industrial-centrifuge/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">industrial centrifuges</a>. We have the technical background to produce top-shelf equipment with mechanical and electrical engineers on staff.
            </p>
            <p class="text-[#2D2D2D] mb-4">
              We have the experience and expertise to handle the toughest centrifuge challenges.
            </p>
            <p class="text-[#2D2D2D]">
              From <a href="/industrial-centrifuge-design/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">centrifuge system design</a> and 3D modeling to final assembly and testing, our engineers oversee every step of the manufacturing process. This hands-on approach ensures that every centrifuge system leaving our facility meets the highest standards of quality and performance.
            </p>
          </div>
          <div class="md:w-1/2">
            <img
              src="/images/about-dolphin-centrifuge/alfa-laval-industrial-centrifuge-dolphin-centrifuge-1.webp"
              alt="Dolphin Centrifuge team working on industrial centrifuge systems in Warren, Michigan facility"
              width="800"
              height="500"
              loading="lazy"
              class="rounded-lg shadow-sm w-full object-cover"
            />
          </div>
        </div>
      </div>

      <!-- Our Facility -->
      <div id="our-facility" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1B3A5C] mb-4">Our Facility</h2>
        <p class="text-[#2D2D2D] mb-6">
          Dolphin Centrifuge has the in-house capability to design, manufacture, and test all the components for a complete centrifuge module. We build the following crucial components in our factory in Warren, Michigan.
        </p>

        <!-- System Design — Pattern A side-by-side -->
        <div id="system-design" class="mb-8">
          <h3 class="text-xl font-bold text-[#1B3A5C] mb-3">
            <a href="/industrial-centrifuge-design/" class="hover:text-[#E8A317]">Centrifuge System Design</a> and 3D Modeling
          </h3>
          <div class="flex flex-col md:flex-row gap-6 items-start">
            <div class="md:w-1/2">
              <p class="text-[#2D2D2D] mb-3">
                We create 3D models of complex systems to visualize and design appropriate piping and auxiliaries, general assembly layout, module flow, etc.
              </p>
              <p class="text-[#2D2D2D]">
                We also provide the General Assembly (GA) drawing to the customer for review before building.
              </p>
            </div>
            <div class="md:w-1/2">
              <img
                src="/images/about-dolphin-centrifuge/Centrifugal-Filter-Decanter.webp"
                alt="Decanter System 3D Model — Dolphin Centrifuge Engineering Design and Modeling"
                width="1000"
                height="431"
                loading="lazy"
                class="rounded-lg shadow-sm w-full object-cover"
              />
              <p class="text-gray-500 text-sm mt-1">Decanter System 3D Model</p>
            </div>
          </div>
        </div>

        <!-- Skid Piping -->
        <div id="skid-piping" class="mb-8">
          <h3 class="text-xl font-bold text-[#1B3A5C] mb-3">Skid, Piping, and Support Fabrication</h3>
          <p class="text-[#2D2D2D]">
            All fabrication of skids, piping, support structures, auxiliary tanks, etc., is done in-house to ensure quality and dimensional accuracy based on customer feedback.
          </p>
        </div>

        <!-- Control Panel — Pattern A side-by-side (images left, text right) -->
        <div id="control-panel" class="mb-8">
          <h3 class="text-xl font-bold text-[#1B3A5C] mb-3">
            <a href="/industrial-centrifuge-controls/" class="hover:text-[#E8A317]">Control Panel Design</a> and Assembly
          </h3>
          <div class="flex flex-col md:flex-row gap-6 items-start">
            <div class="md:w-1/2 space-y-4">
              <div>
                <img
                  src="/images/about-dolphin-centrifuge/disc-centrifuge-controls.webp"
                  alt="Industrial Centrifuge Control Screen — Dolphin Centrifuge Proprietary Control System"
                  width="834"
                  height="348"
                  loading="lazy"
                  class="rounded-lg shadow-sm w-full object-cover"
                />
                <p class="text-gray-500 text-sm mt-1">Industrial Centrifuge Control Screen</p>
              </div>
              <div>
                <img
                  src="/images/about-dolphin-centrifuge/XP-Control-Panel.webp"
                  alt="Class 1 Div 2 Centrifuge Control System — Explosion Proof Control Panel"
                  width="266"
                  height="308"
                  loading="lazy"
                  class="rounded-lg shadow-sm w-full object-cover"
                />
                <p class="text-gray-500 text-sm mt-1">Class 1 Div 2 Centrifuge Control System</p>
              </div>
            </div>
            <div class="md:w-1/2">
              <p class="text-[#2D2D2D]">
                Dolphin Centrifuge's proprietary control system uses the latest technologies to offer ease of use and operator feedback with a troubleshooting guide built into the control system.
              </p>
            </div>
          </div>
        </div>

        <!-- Centrifuge Remanufacture -->
        <div id="remanufacture" class="mb-8">
          <h3 class="text-xl font-bold text-[#1B3A5C] mb-3">Centrifuge Remanufacture</h3>
          <p class="text-[#2D2D2D]">
            A used centrifuge is remanufactured from scratch following the OEM rebuild process. From the bare metal (sandblasted) to two-coat surface protection with durable epoxy coats, every aspect of the remanufacturing process is geared towards a reliable centrifuge with a long service life.
          </p>
        </div>

        <!-- System Assembly and Test -->
        <div id="assembly-test">
          <h3 class="text-xl font-bold text-[#1B3A5C] mb-3">System Assembly and Test</h3>
          <p class="text-[#2D2D2D]">
            The centrifuge system wiring, sub-system assembly, and complete module testing using mineral oil or water is a routine exercise for all industrial centrifuge systems from Dolphin Centrifuge.
          </p>
        </div>
      </div>

      <!-- Open Invitation -->
      <div id="open-invitation" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1B3A5C] mb-4">Open Invitation!</h2>
        <p class="text-[#2D2D2D] mb-4">
          We invite all potential customers to visit us at our facility to get a feel for our work and our capabilities.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          Come see our centrifuge inventory, our manufacturing shop, and meet the team that will be building your centrifuge system. We are confident that a visit to our Warren, Michigan facility will demonstrate our commitment to quality and our ability to deliver the right centrifuge solution for your application.
        </p>
