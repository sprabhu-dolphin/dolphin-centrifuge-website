---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "When was Dolphin Centrifuge founded?",
    answer: "Dolphin Centrifuge was founded in 1981, originally as an Alfa Laval aftermarket parts manufacturer. Over 40+ years, the company expanded from parts supply into engineering, manufacturing complete centrifuge system packages, and full-service <a href='/industrial-disc-centrifuge-repair/'>centrifuge repair</a>. Dolphin Centrifuge is based in Warren, Michigan and serves customers globally."
  },
  {
    question: "What types of centrifuges does Dolphin Centrifuge supply?",
    answer: "Dolphin Centrifuge supplies <a href='/disc-stack-centrifuge/'>disc stack centrifuges</a> (self-cleaning and manual-clean), <a href='/decanter-centrifuge/'>decanter centrifuges</a>, and complete centrifuge system packages including pumps, heaters, filters, and PLC control panels. The company also provides centrifuge rebuild and remanufacturing services, parts supply, and on-site technical support."
  },
  {
    question: "Where is Dolphin Centrifuge located?",
    answer: "Dolphin Centrifuge is located at 24248 Gibson Drive, Warren, Michigan 48089. The facility includes engineering offices, centrifuge assembly and testing areas, parts inventory, and a customer demonstration lab. Customers are welcome to visit for factory demonstrations and <a href='/industrial-centrifuge-sample-testing/'>application testing</a> with their own process fluids."
  },
  {
    question: "Does Dolphin Centrifuge offer centrifuge system design?",
    answer: "Yes. Dolphin Centrifuge provides complete <a href='/industrial-centrifuge-design/'>centrifuge system design</a> including 3D modeling, skid and piping fabrication, control panel design, centrifuge remanufacturing, and full system assembly and testing — all performed in-house at the Warren, Michigan facility."
  },
  {
    question: "Can I visit the Dolphin Centrifuge facility?",
    answer: "Absolutely. Dolphin Centrifuge maintains an open invitation for potential customers to tour the Warren, Michigan facility. Visitors can see the centrifuge inventory of 150+ units, the manufacturing shop, and meet the engineering team. <a href='/contact-for-alfa-laval-centrifuges/'>Contact us</a> to schedule a visit."
  }
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "About Dolphin Centrifuge — Industrial Centrifuge Manufacturer Since 1981",
  "description": "Dolphin Centrifuge is a Warren, Michigan industrial centrifuge manufacturer established in 1981. Learn about our team, facility, centrifuge stock, and 40+ years of expertise.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  },
  "url": "https://dolphincentrifuge.com/about-dolphin-centrifuge/",
  "mainEntityOfPage": "https://dolphincentrifuge.com/about-dolphin-centrifuge/"
};

const jsonLd = [
  articleJsonLd,
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "logo": "https://dolphincentrifuge.com/images/dolphin-centrifuge-logo.png",
    "description": "Dolphin Centrifuge is a company specializing in manufacturing industrial centrifuge systems, established in 1981 as an Alfa Laval aftermarket parts manufacturer. Based in Warren, Michigan, Dolphin Centrifuge designs and manufactures complete fluid recovery centrifuge systems for food, environmental, chemical, waste processing, rendering, and metalworking industries.",
    "foundingDate": "1981",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "24248 Gibson Dr",
      "addressLocality": "Warren",
      "addressRegion": "MI",
      "postalCode": "48089",
      "addressCountry": "US"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+1-248-522-2573",
      "contactType": "sales",
      "email": "sales@dolphincentrifuge.com",
      "availableLanguage": "English"
    },
    "areaServed": "Worldwide",
    "numberOfEmployees": {
      "@type": "QuantitativeValue",
      "description": "Team with 100+ cumulative years of centrifuge experience"
    },
    "knowsAbout": [
      "Industrial Centrifuges",
      "Disc Stack Centrifuges",
      "Decanter Centrifuges",
      "Centrifuge System Design",
      "Centrifuge Remanufacturing",
      "Fluid Recovery Systems"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Dolphin Centrifuge",
    "image": "https://dolphincentrifuge.com/images/about-dolphin-centrifuge/Dolphin-Centrifuge-Shop-Warren-1000.webp",
    "url": "https://dolphincentrifuge.com/about-dolphin-centrifuge/",
    "telephone": "+1-248-522-2573",
    "email": "sales@dolphincentrifuge.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "24248 Gibson Dr",
      "addressLocality": "Warren",
      "addressRegion": "MI",
      "postalCode": "48089",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "42.4934",
      "longitude": "-83.0280"
    },
    "description": "Industrial centrifuge manufacturer specializing in complete fluid recovery systems. Over 40 years of experience, 150+ centrifuges in stock, and installations on five continents.",
    "foundingDate": "1981",
    "priceRange": "$$$$"
  },
  faqJsonLd
];

const toc = [
  { id: "who-is-dolphin", label: "Who is Dolphin Centrifuge?" },
  { id: "what-does-dolphin-do", label: "What does Dolphin Centrifuge do?" },
  { id: "where-is-dolphin", label: "Where is Dolphin Centrifuge based?" },
  { id: "our-stock", label: "Our Industrial Centrifuge Stock" },
  { id: "why-choose", label: "Why Choose Dolphin Centrifuge?" },
  { id: "our-team", label: "Our Team" },
  { id: "our-facility", label: "Our Facility" },
  { id: "open-invitation", label: "Open Invitation" },
  { id: "faq", label: "Frequently Asked Questions" },
];
---

<ApplicationLayout
  title="About Dolphin Centrifuge — Industrial Centrifuge Co."
  description="Dolphin Centrifuge — established 1981, Warren MI. Industrial disc stack & decanter centrifuge systems, 100+ years of team expertise, 200+ units in stock."
  canonicalUrl="https://dolphincentrifuge.com/about-dolphin-centrifuge/"
  heroImage="/images/about-dolphin-centrifuge/Dolphin-Centrifuge-Shop-Warren-1000.webp"
  heroImageAlt="Dolphin Centrifuge Shop in Warren (Detroit Metro), Michigan, USA — industrial centrifuge manufacturing facility"
  category="about"
  categoryLabel="About Us"
  toc={toc}
  relatedApplications={[
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
    { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
    { label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/" },
  ]}
  relatedProducts={[
    { label: "DMPX-042 Disc Centrifuge", href: "/centrifuges/dmpx-042/" },
    { label: "DMPX-028 Disc Centrifuge", href: "/centrifuges/dmpx-028/" },
  ]}
  jsonLd={jsonLd}
>

  <article class="prose-dolphin max-w-none">

    <!-- AI Summary -->
    <div class="not-prose bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
      <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge is a Warren, Michigan industrial centrifuge manufacturer established in 1981. Specializing in Alfa Laval disc stack and decanter centrifuge systems, Dolphin designs, builds, and services complete fluid recovery modules with a global installed capacity exceeding 10 billion gallons annually.</p>
    </div>

    <!-- Who Is Dolphin -->
    <h2 id="who-is-dolphin">Who is Dolphin Centrifuge?</h2>
    <div class="flex flex-col md:flex-row gap-6 items-start">
      <div class="md:w-1/2">
        <p class="text-lg font-semibold">
          Dolphin Centrifuge is a company specializing in manufacturing industrial centrifuge systems.
        </p>
        <p>
          Established in 1981, we started as an Alfa Laval aftermarket parts manufacturer. Over time, we created a niche for ourselves in the industrial centrifuge market. Our niche is complete fluid recovery systems built around <a href="/alfa-laval-industrial-centrifuges/">Alfa Laval industrial centrifuges</a>.
        </p>
        <p>
          By 2004 we had supplied centrifuge systems to all five major continents. In 2017 we had a global annual installed capacity of over <strong>10 billion gallons!</strong>
        </p>
      </div>
      <div class="md:w-1/2 space-y-4">
        <img
          src="/images/about-dolphin-centrifuge/Dolphin-Centrifuge-Shop-600.webp"
          alt="Dolphin Centrifuge Shop — Industrial Centrifuge Systems Manufacturing Facility in Warren, Michigan"
          width="600"
          height="400"
          loading="lazy"
          class="rounded-lg shadow-sm w-full object-cover"
        />
        <div class="flex items-center gap-4">
          <img
            src="/images/about-dolphin-centrifuge/Dolphin-Centrifuge-40-Years.webp"
            alt="Dolphin Centrifuge 40 Years of Experience in Industrial Centrifuge Manufacturing"
            width="225"
            height="225"
            loading="lazy"
            class="rounded-lg shadow-sm w-28 h-28 object-cover"
          />
          <p class="text-gray-500 text-sm">Dolphin Centrifuge Shop — Warren, Michigan</p>
        </div>
      </div>
    </div>

    <!-- What Does Dolphin Do -->
    <h2 id="what-does-dolphin-do">What does Dolphin Centrifuge do?</h2>
    <p>
      As an engineering company, we design and manufacture centrifuge systems for <strong>food, environmental chemicals, waste processing, rendering, metalworking</strong>, and similar industries. These centrifuge systems all feature <a href="/alfa-laval-centrifugal-separator/">Alfa Laval centrifugal separators</a>.
    </p>
    <p>
      One of our specialties is re-purposing disc stack centrifuges. We develop <a href="/disc-stack-centrifuge-applications/">centrifuge-based solutions for applications</a> that even the OEM rates as unlikely!
    </p>
    <p>
      Also, we manufacture auxiliary centrifuge systems to complement our centrifuge systems. Some of our proprietary additions include:
    </p>
    <ul>
      <li><a href="/fluid-heating-systems/">Heat Loops (Clog-Free Fluid Heating or Cooling Exchanger)</a></li>
      <li>Hot Fluid Heat Recovery Package</li>
      <li>Containerized Oil Recovery Systems (ORS)</li>
      <li>Heavy-duty Heater, Strainer, and Pump Modules (Crude Oil)</li>
    </ul>
    <p>
      Dolphin has developed its proprietary <a href="/industrial-centrifuge-controls/">Centrifuge Control System</a>. It uses state-of-the-art technology for ease of operation and unique built-in troubleshooting features.
    </p>

    <!-- Where Is Dolphin Based -->
    <h2 id="where-is-dolphin">Where is Dolphin Centrifuge based?</h2>
    <p>
      Our location is in the <strong>Detroit Metro area</strong>, in the city of Warren, MI. Our manufacturing location is in an industrial district close to our vendors. Being in Motor City is an advantage with many automotive suppliers in the area.
    </p>
    <div class="bg-light-bg rounded-lg p-4 flex flex-wrap gap-4 text-sm">
      <div><span class="font-semibold">Address:</span> 24248 Gibson Dr, Warren MI 48089</div>
      <div><span class="font-semibold">Phone:</span> <a href="tel:+12485222573">(248) 522-2573</a></div>
      <div><span class="font-semibold">Email:</span> <a href="mailto:sales@dolphincentrifuge.com">sales@dolphincentrifuge.com</a></div>
    </div>

    <!-- Our Stock -->
    <h2 id="our-stock">Our Industrial Centrifuge Stock</h2>
    <p>
      We have <strong>over 150 New and Used industrial centrifuges in our stock in Warren, MI.</strong> We source good (gently used) Alfa Laval centrifuges from all over the world. In our stock, you will not find centrifuges from drilling mud or other abrasive applications.
    </p>
    <p>
      We can also source new centrifuges for customers who cannot accept reconditioned centrifuges.
    </p>

    <!-- Why Choose Dolphin -->
    <h2 id="why-choose">Why Choose Dolphin Centrifuge?</h2>
    <p>
      Simply put, we know centrifuges, and we have the expertise! We have supplied centrifuges over the years for most practical applications. Our experience allows us to help our customers select the best centrifuge for their specific purpose.
    </p>
    <p>
      Our years of field experience and lessons are built into our centrifuge equipment as an added benefit.
    </p>
    <p>
      Dolphin Centrifuge has a spacious, well-equipped industrial facility. Our location has a growing inventory of over <strong>200 centrifuges in stock</strong>.
    </p>
    <p>
      Our stock of gently used centrifuges is a significant benefit to our customers. It allows us to offer quality centrifuges from our inventory instead of searching the market after getting your order.
    </p>
    <p>
      We take great pride in our <strong>American workmanship</strong> and a well-recognized client list. Our customer list includes our military and other government agencies.
    </p>
    <p>
      Also, we have supplied centrifuge systems to <strong>O&amp;G companies, Power Utilities, Rig-builders</strong>, etc.
    </p>
    <p>
      All our centrifuge equipment comes with a mechanical warranty. We also provide <strong>lifetime technical support</strong> to our customers.
    </p>

    <!-- Our Team -->
    <h2 id="our-team">Our Team</h2>
    <div class="flex flex-col md:flex-row gap-6 items-start">
      <div class="md:w-1/2">
        <p>
          Dolphin Centrifuge's primary resource is our people. Our team has a cumulative <strong>100+ years of experience</strong> with <a href="/industrial-centrifuge/">industrial centrifuges</a>. We have the technical background to produce top-shelf equipment with mechanical and electrical engineers on staff.
        </p>
        <p>
          We have the experience and expertise to handle the toughest centrifuge challenges.
        </p>
      </div>
      <div class="md:w-1/2">
        <img
          src="/images/about-dolphin-centrifuge/alfa-laval-industrial-centrifuge-dolphin-centrifuge-1.webp"
          alt="Dolphin Centrifuge team working on industrial centrifuge systems in Warren, Michigan facility"
          width="800"
          height="500"
          loading="lazy"
          class="rounded-lg shadow-sm w-full object-cover"
        />
      </div>
    </div>

    <!-- Our Facility -->
    <h2 id="our-facility">Our Facility</h2>
    <p>
      Dolphin Centrifuge has the in-house capability to design, manufacture, and test all the components for a complete centrifuge module. We build the following crucial components in our factory in Warren, Michigan.
    </p>

    <h3>
      <a href="/industrial-centrifuge-design/">Centrifuge System Design</a> and 3D Modeling
    </h3>
    <div class="flex flex-col md:flex-row gap-6 items-start">
      <div class="md:w-1/2">
        <p>
          We create 3D models of complex systems to visualize and design appropriate piping and auxiliaries, general assembly layout, module flow, etc.
        </p>
        <p>
          We also provide the General Assembly (GA) drawing to the customer for review before building.
        </p>
      </div>
      <div class="md:w-1/2">
        <img
          src="/images/about-dolphin-centrifuge/Centrifugal-Filter-Decanter.webp"
          alt="Decanter System 3D Model — Dolphin Centrifuge Engineering Design and Modeling"
          width="1000"
          height="431"
          loading="lazy"
          class="rounded-lg shadow-sm w-full object-cover"
        />
        <p class="text-gray-500 text-sm mt-1">Decanter System 3D Model</p>
      </div>
    </div>

    <h3>Skid, Piping, and Support Fabrication</h3>
    <p>
      All fabrication of skids, piping, support structures, auxiliary tanks, etc., is done in-house to ensure quality and dimensional accuracy based on customer feedback.
    </p>

    <h3>
      <a href="/industrial-centrifuge-controls/">Control Panel Design</a> and Assembly
    </h3>
    <div class="flex flex-col md:flex-row gap-6 items-start">
      <div class="md:w-1/2 space-y-4">
        <div>
          <img
            src="/images/about-dolphin-centrifuge/disc-centrifuge-controls.webp"
            alt="Industrial Centrifuge Control Screen — Dolphin Centrifuge Proprietary Control System"
            width="834"
            height="348"
            loading="lazy"
            class="rounded-lg shadow-sm w-full object-cover"
          />
          <p class="text-gray-500 text-sm mt-1">Industrial Centrifuge Control Screen</p>
        </div>
        <div>
          <img
            src="/images/about-dolphin-centrifuge/XP-Control-Panel.webp"
            alt="Class 1 Div 2 Centrifuge Control System — Explosion Proof Control Panel"
            width="266"
            height="308"
            loading="lazy"
            class="rounded-lg shadow-sm w-full object-cover"
          />
          <p class="text-gray-500 text-sm mt-1">Class 1 Div 2 Centrifuge Control System</p>
        </div>
      </div>
      <div class="md:w-1/2">
        <p>
          Dolphin Centrifuge's proprietary control system uses the latest technologies to offer ease of use and operator feedback with a troubleshooting guide built into the control system.
        </p>
      </div>
    </div>

    <h3>Centrifuge Remanufacture</h3>
    <p>
      A used centrifuge is remanufactured from scratch following the OEM rebuild process. From the bare metal (sandblasted) to two-coat surface protection with durable epoxy coats, every aspect of the remanufacturing process is geared towards a reliable centrifuge with a long service life.
    </p>

    <h3>System Assembly and Test</h3>
    <p>
      The centrifuge system wiring, sub-system assembly, and complete module testing using mineral oil or water is a routine exercise for all industrial centrifuge systems from Dolphin Centrifuge.
    </p>

    <!-- Open Invitation -->
    <h2 id="open-invitation">Open Invitation!</h2>
    <p>
      We invite all potential customers to visit us at our facility to get a feel for our work and our capabilities.
    </p>
    <p>
      <a href="/dolphin-centrifuge-customer-testimonials/" class="font-semibold">
        See what our customers have to say about us......
      </a>
    </p>

    <!-- Mid-page CTA -->
    <div class="bg-gold/10 border-l-4 border-gold rounded-r-lg p-5 my-8 not-prose">
      <p class="text-navy font-bold text-lg mb-1">See our centrifuges in person — Warren, MI</p>
      <p class="text-text-light text-sm mb-3">Our facility is open to prospective customers. Inspect 200+ centrifuges in stock, witness factory testing, and meet our engineering team.</p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold text-navy font-bold px-5 py-2.5 rounded-lg hover:bg-yellow-500 transition-colors text-sm">Schedule a Visit</a>
        <a href="/industrial-centrifuge-sample-testing/" class="inline-block border border-navy text-navy font-semibold px-5 py-2.5 rounded-lg hover:bg-navy/5 transition-colors text-sm">Free Sample Testing</a>
      </div>
    </div>

    <!-- FAQ -->
    <h2 id="faq">Frequently Asked Questions</h2>
    <div class="space-y-3 not-prose">
      {faqItems.map(item => (
        <details class="border-l-4 border-gold/40 bg-white rounded-r-xl shadow-sm p-5">
          <summary class="font-semibold text-navy cursor-pointer list-none flex items-center gap-2">
            <span class="text-gold font-bold">+</span> {item.question}
          </summary>
          <p class="text-text-light mt-3 text-sm leading-relaxed" set:html={item.answer} />
        </details>
      ))}
    </div>
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  </article>

  <!-- Bottom CTA Bar -->
  <div class="bg-navy rounded-xl p-6 md:p-8 mt-10 text-center not-prose">
    <p class="text-white text-xl font-bold mb-2">Ready to Work With Dolphin Centrifuge?</p>
    <p class="text-blue-100 text-sm mb-5">40+ years of centrifuge expertise. 200+ units in stock. Lifetime technical support. Call or submit your application details today.</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold text-navy font-bold px-7 py-3 rounded-lg hover:bg-yellow-500 transition-colors">Get a Free Quote</a>
      <a href="/industrial-centrifuge-sample-testing/" class="inline-block border border-white/40 hover:border-white text-white font-semibold px-7 py-3 rounded-lg transition-colors">Free Sample Testing</a>
    </div>
  </div>

</ApplicationLayout>
