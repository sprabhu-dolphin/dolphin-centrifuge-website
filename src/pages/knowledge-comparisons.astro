---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const title = "Centrifuge Comparisons & Explainers — Understand the Differences";
const description = "Compare centrifuge types and separation principles. Purifier vs clarifier, decanter vs disc stack, RCF vs RPM explained by Dolphin Centrifuge.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Centrifuge Comparisons & Explainers",
  "description": description,
  "url": "https://dolphincentrifuge.com/knowledge-comparisons/",
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "email": "sales@dolphincentrifuge.com",
  },
};

const toc = [
  { id: "technical-comparisons", label: "Technical Comparisons & Explainers" },
  { id: "other-knowledge-categories", label: "Explore Other Knowledge Categories" },
];

const articles = [
  {
    title: "Decanter vs Disc Stack Centrifuge",
    href: "/difference-between-decanter-centrifuge-disc-centrifuge/",
    description: "A detailed comparison of the two main industrial centrifuge types — when to use a decanter vs a disc stack, and the key differences in design, performance, and applications.",
    tag: "Most Popular",
  },
  {
    title: "Purifier vs Clarifier — What's the Difference?",
    href: "/disc-centrifuge-purifier-clarifier-difference/",
    description: "The critical difference between purifier and clarifier disc centrifuges — two-phase vs three-phase separation, gravity disc selection, and application matching.",
  },
  {
    title: "RCF vs RPM — Difference & Calculation",
    href: "/centrifuge-rcf-rpm-difference-calculation/",
    description: "Understanding the difference between relative centrifugal force (RCF/G-force) and revolutions per minute (RPM), plus how to calculate and convert between them.",
  },
  {
    title: "Centrifugal Filter Guide",
    href: "/centrifugal-filter/",
    description: "How centrifugal filters work, types of filtration centrifuges, and how they compare to sedimenting centrifuges for different separation applications.",
  },
  {
    title: "Dewatering Centrifuge Explained",
    href: "/dewatering-centrifuge/",
    description: "How dewatering centrifuges work to remove water from sludge and slurries — types, operating principles, and application considerations.",
  },
  {
    title: "Three Phase Decanter Centrifuge",
    href: "/three-phase-decanter/",
    description: "How three-phase decanter centrifuges simultaneously separate two liquid phases and a solid phase — design, applications, and operating principles.",
  },
  {
    title: "Smallest Industrial Centrifuges",
    href: "/smallest-industrial-centrifuges/",
    description: "A guide to the smallest industrial centrifuges available — compact disc stack and decanter models for pilot plants, labs, and low-volume applications.",
  },
  {
    title: "Tramp Oil Centrifuge",
    href: "/tramp-oil-centrifuge/",
    description: "How centrifuges remove tramp oil from machining coolants and wash water — comparison with skimmers, coalescers, and other removal methods.",
  },
  {
    title: "Can a Centrifuge Separate Salt from Water?",
    href: "/can-a-centrifuge-separate-salt-from-water/",
    description: "Exploring whether centrifugal separation can remove dissolved salts from water — the physics behind it and what centrifuges can and cannot do.",
  },
  {
    title: "Ethanol Extraction Centrifuges — Technical Comparison",
    href: "/ethanol-extraction-centrifuges-technical-comparison/",
    description: "Comparing centrifuge types for ethanol extraction applications — disc stack vs decanter vs basket centrifuge performance and suitability.",
  },
];
---

<ApplicationLayout
  title={title}
  description={description}
  canonicalUrl="https://dolphincentrifuge.com/knowledge-comparisons/"
  category="knowledge"
  categoryLabel="Comparisons"
  heroImage="/images/disc-stack-centrifuge/Chamber-Decanter-Disc-Centrifuge-Ae-800.webp"
  heroImageAlt="Comparison of chamber bowl, decanter, and disc stack centrifuge types"
  toc={toc}
  relatedApplications={[
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
    { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
  ]}
  relatedProducts={[
    { label: "DMPX-042 Disc Centrifuge", href: "/centrifuges/dmpx-042/" },
    { label: "DMPX-028 Disc Centrifuge", href: "/centrifuges/dmpx-028/" },
  ]}
  jsonLd={jsonLd}
>
  <article class="prose-dolphin max-w-none">
    <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8 max-w-4xl">
      <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge publishes centrifuge comparison guides to help engineers select the right separation technology — covering <a href="/difference-between-decanter-centrifuge-disc-centrifuge/">disc stack vs. decanter</a>, <a href="/disc-centrifuge-purifier-clarifier-difference/">purifier vs. clarifier</a>, self-cleaning vs. manual-clean, and centrifuge vs. alternative separation methods. Based in Warren, Michigan, with over 40 years of centrifuge application engineering experience.</p>
    </div>

    <h2 id="technical-comparisons">Technical Comparisons & Explainers</h2>
    <p>Browse our library of {articles.length} expert comparison articles covering the most common centrifuge selection questions. Whether you need to understand <a href="/centrifuge-rcf-rpm-difference-calculation/">RCF vs RPM</a> or choose between a <a href="/dewatering-centrifuge/">dewatering centrifuge</a> and a disc stack separator, these guides provide the technical clarity you need.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 not-prose mt-6 mb-10">
      {articles.map((article) => (
        <a href={article.href} class="group bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg hover:border-emerald-300/40 transition-all duration-300 overflow-hidden flex flex-col">
          {/* Icon Header */}
          <div class="relative h-32 bg-gradient-to-br from-emerald-500/10 to-emerald-600/5 flex items-center justify-center">
            <svg class="w-12 h-12 text-emerald-400/30 group-hover:text-emerald-400/50 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z" />
            </svg>
            {article.tag && (
              <span class="absolute top-3 left-3 bg-gold text-navy text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">{article.tag}</span>
            )}
          </div>
          {/* Content */}
          <div class="p-5 flex-1 flex flex-col">
            <h3 class="text-lg font-bold font-heading text-navy group-hover:text-emerald-600 transition-colors mb-2">{article.title}</h3>
            <p class="text-sm text-text-light leading-relaxed flex-1">{article.description}</p>
            <div class="mt-4 flex items-center gap-1 text-gold font-semibold text-sm">
              Read Article
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <h2 id="other-knowledge-categories">Explore Other Knowledge Categories</h2>
    <p>Continue learning with our other <a href="/knowledge-center/">Knowledge Center</a> categories covering troubleshooting, how-to guides, product information, and real-world case studies.</p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 not-prose mt-6">
      <a href="/knowledge-troubleshooting/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-red-300/40 hover:shadow-md transition-all">
        <div class="w-10 h-10 rounded-lg bg-red-50 text-red-500 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" /></svg>
        </div>
        <span class="text-sm font-bold text-navy group-hover:text-red-600 transition-colors">Troubleshooting</span>
      </a>
      <a href="/knowledge-guides/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-blue-300/40 hover:shadow-md transition-all">
        <div class="w-10 h-10 rounded-lg bg-blue-50 text-blue-500 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
        </div>
        <span class="text-sm font-bold text-navy group-hover:text-blue-600 transition-colors">Guides & How-To</span>
      </a>
      <a href="/knowledge-product-brand/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-amber-300/40 hover:shadow-md transition-all">
        <div class="w-10 h-10 rounded-lg bg-amber-50 text-amber-500 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.991l1.004.827c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        </div>
        <span class="text-sm font-bold text-navy group-hover:text-amber-600 transition-colors">Product & Brand</span>
      </a>
      <a href="/knowledge-case-studies/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-purple-300/40 hover:shadow-md transition-all">
        <div class="w-10 h-10 rounded-lg bg-purple-50 text-purple-500 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
        </div>
        <span class="text-sm font-bold text-navy group-hover:text-purple-600 transition-colors">Case Studies & FAQ</span>
      </a>
    </div>
  </article>
</ApplicationLayout>
