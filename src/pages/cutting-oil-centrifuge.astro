  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "url": "https://dolphincentrifuge.com/cutting-oil-centrifuge/",
  "headline": "Cutting Oil Centrifuge | Metal Fines Removal for Machining, Drawing & Rolling",
  "description": "Industrial cutting oil centrifuges remove metal fines from cutting, draw, and rolling oil at 7,000 Gs — separation to 0.5 microns. Dolphin Centrifuge, Warren MI.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" }
};

const jsonLd = [productJsonLd, faqJsonLd, articleJsonLd];

const toc = [
  { id: 'what-is-cutting-oil', label: 'What is Cutting Oil' },
  { id: 'need-to-recycle', label: 'Need to Recycle' },
  { id: 'operation', label: 'Operation' },
