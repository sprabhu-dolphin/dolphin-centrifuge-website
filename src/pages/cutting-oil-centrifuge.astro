  "@type": "Product",
  "url": "https://dolphincentrifuge.com/cutting-oil-centrifuge/",
  "name": "Cutting Oil Centrifuge System",
  "description": "Industrial cutting oil centrifuges for continuous removal of metal fines from cutting oil, draw oil, and rolling oil. Particle separation down to 0.5 microns at 7,000 Gs with self-ejecting disc stack centrifuge technology.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
