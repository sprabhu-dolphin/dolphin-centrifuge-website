---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval MOPX 209 Self-Cleaning Centrifuge",
  "description": "Alfa Laval MOPX 209 self-cleaning disc stack centrifuge for diesel, waste oil, and cutting oil. 22 GPM on draw oil, 15 HP. Also covers WHPX 409 and MAPX 309.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/alfa-laval-mopx-209-centrifuge/",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Alfa Laval MOPX 209 Centrifuge — Parts, Service & Specifications",
  "description": "Dolphin Centrifuge supplies parts, repairs, and remanufactured Alfa Laval MOPX 209 self-cleaning disc-stack centrifuges. 15 HP, 5,180 RPM, 22 GPM on draw oil. DMPX-042 system equivalent.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "datePublished": "2021-01-01",
  "dateModified": "2026-01-01",
  "url": "https://dolphincentrifuge.com/alfa-laval-mopx-209-centrifuge/",
  "mainEntityOfPage": "https://dolphincentrifuge.com/alfa-laval-mopx-209-centrifuge/"
};

const jsonLd = [articleJsonLd, productJsonLd];

const toc = [
  { id: 'overview', label: 'MOPX 209 Total-Discharge Centrifuge' },
  { id: 'specifications', label: 'MOPX 209 Specifications' },
  { id: 'whpx-409', label: 'WHPX 409 Partial-Discharge Disc-Stack' },
  { id: 'mapx-309', label: 'MAPX 309 Full-Discharge Disc-Stack' },
  { id: 'applications', label: 'Applications' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedApplications = [
  { label: 'Waste Oil Centrifuge', href: '/waste-oil-centrifuge/' },
  { label: 'Cutting Oil Centrifuge', href: '/cutting-oil-centrifuge/' },
  { label: 'Diesel Fuel Centrifuge', href: '/diesel-centrifuge/' },
  { label: 'Lube Oil Centrifuge', href: '/lube-oil-centrifuge/' },
  { label: 'Crude Oil Centrifuge', href: '/crude-oil-centrifuge/' },
];

const relatedProducts = [
  { label: 'DMPX-042 Self-Cleaning System', href: '/centrifuges/dmpx-042/', description: '32–47 GPM diesel, MOPX 209 bowl' },
  { label: 'DMPX-014 Self-Cleaning System', href: '/centrifuges/dmpx-014/', description: '13–16 GPM mid-range' },
  { label: 'DMPX-070 Self-Cleaning System', href: '/centrifuges/dmpx-070/', description: '47–72 GPM large-scale' },
];
---

<ApplicationLayout
  title="Alfa Laval MOPX 209 Self-Cleaning Centrifuge | Dolphin"
  description="Alfa Laval MOPX 209 self-cleaning disc stack centrifuge — 15 HP, 5,180 RPM, 22 GPM on draw oil. Also covers WHPX 409 and MAPX 309. Dolphin Centrifuge."
  category="products"
  categoryLabel="Products"
  heroImage="/images/alfa-laval-mopx-209-centrifuge/Alfa-Laval-MOPX209-Cutting-Oil-Centrifuge-300.webp"
  heroImageAlt="Alfa Laval MOPX209 Cutting Oil Centrifuge"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-mopx-209-centrifuge/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">The Alfa Laval MOPX 209 is a self-cleaning disc stack centrifuge with a 15 HP motor at 5,180 RPM, rated at 22 GPM on draw oil and 25 GPM on waste oil. Dolphin Centrifuge supplies it as the DMPX-042 turnkey module for waste oil recovery, cutting oil, and industrial fluid purification.</p>
  </div>

  <h2 id="overview">MOPX 209 Total-Discharge Centrifuge</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <p>
        The Alfa Laval MOPX 209 Centrifuge has a 15 HP Motor, a bowl RPM of 5,180, and can process 25 GPM of waste oil. It is a self-cleaning, <a href="/disc-stack-centrifuge/">disc stack centrifuge</a> designed for the continuous, three-phase separation of fuels, such as <a href="/diesel-centrifuge/">diesel</a>, <a href="/biodiesel-centrifuge/">biodiesel</a>, <a href="/waste-oil-centrifuge/">waste oil</a>, and <a href="/fuel-oil-centrifuge/">fuel oil</a>.
      </p>
      <p>
        Alfa Laval MOPX 209 Centrifuge for Large Scale Processing of Aluminum Drawing Oil.
      </p>
    </div>
    <img
      src="/images/alfa-laval-mopx-209-centrifuge/Alfa-Laval-MOPX209-Cutting-Oil-Centrifuge-300.webp"
      alt="Alfa Laval MOPX209 Cutting Oil Centrifuge"
      width="300"
      height="346"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
  </div>

  <blockquote>
    Dolphin Centrifuge supplies a range of self-cleaning fuel purifiers for diesel, heavy fuel, and waste oils &mdash; available as complete modules with pre-heaters, starters, and PLC control panels. <a href="/contact-for-alfa-laval-centrifuges/">Request a quote</a>.
  </blockquote>

  <h2 id="specifications">MOPX 209 Specifications</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <table>
        <tbody>
          <tr><td><strong>Model Type</strong></td><td>Alfa Laval MOPX 209 TGT 20-60</td></tr>
          <tr><td><strong>Rated Capacity</strong></td><td>22 GPM on Aluminum Draw Oil</td></tr>
          <tr><td><strong>Sludge Space</strong></td><td>2.00 Gallons</td></tr>
          <tr><td><strong>Motor HP</strong></td><td>15 HP</td></tr>
          <tr><td><strong>Voltages</strong></td><td>230 / 460 V</td></tr>
        </tbody>
      </table>
    </div>
    <img
      src="/images/alfa-laval-mopx-209-centrifuge/Alfa-Laval-MOPX209-Machining-Oil-Centrifuge-e1615147323481.webp"
      alt="Alfa Laval MOPX209 Machining Oil Centrifuge"
      width="250"
      height="250"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
  </div>

  <h2 id="whpx-409">Alfa Laval WHPX 409 Partial-Discharge Disc-Stack Centrifuge</h2>

  <blockquote>
    <strong>Also, read our <a href="/alfa-laval-centrifuge-selection-guide/">Alfa Laval Centrifuge Selection Guide</a></strong>
  </blockquote>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <img
      src="/images/alfa-laval-mopx-209-centrifuge/Waste-Oil-Centrifuge-Alfa-Laval-MOPX209-e1614023868488.webp"
      alt="Waste Oil Centrifuge Alfa Laval MOPX209"
      width="300"
      height="300"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
    <div class="flex-1">
      <p>
        The Alfa Laval WHPX 409 Centrifuge is a self-cleaning disc-stack centrifuge designed for the three-phase separation of diesel, <a href="/crude-oil-centrifuge/">light crude oil</a>, and <a href="/fuel-oil-centrifuge/">light fuel oil</a> (LFO). With a 12.5 HP Motor, the WHPX 409 centrifuge has a bowl RPM of 7,125 and can process 40 GPM of #2 Diesel Fuel.
      </p>
      <table>
        <tbody>
          <tr><td><strong>Model Type</strong></td><td>Alfa Laval WHPX 409 TGD 24-60</td></tr>
          <tr><td><strong>Rated Capacity</strong></td><td>45 GPM on Kerosene</td></tr>
          <tr><td><strong>Sludge Space</strong></td><td>1.30 Gallons</td></tr>
          <tr><td><strong>Motor HP</strong></td><td>12.5 HP</td></tr>
          <tr><td><strong>Voltages</strong></td><td>230 / 460 V</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <h2 id="mapx-309">Alfa Laval MAPX 309 BGT-14, Full-Discharge, Disc-Stack Centrifuge</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="flex-1">
      <p>
        The Alfa Laval MAPX 309 Centrifuge is a heavy-duty, self-cleaning disc-stack centrifuge designed for the continuous separation of water and sludge from mineral oils and fuels. With a 10 HP Motor, the MAPX 309 centrifuge has a bowl RPM of 5,200 and can process 32 GPM of light viscosity oil.
      </p>
      <table>
        <tbody>
          <tr><td><strong>Model Type</strong></td><td>Alfa Laval MAPX 309 BGT-14</td></tr>
          <tr><td><strong>Rated Capacity</strong></td><td>24 GPM on Steam Turbine Lube Oil</td></tr>
          <tr><td><strong>Sludge Space</strong></td><td>2.10 Gallons</td></tr>
          <tr><td><strong>Motor HP</strong></td><td>10 HP</td></tr>
          <tr><td><strong>Voltages</strong></td><td>230 / 460 V</td></tr>
        </tbody>
      </table>
    </div>
    <img
      src="/images/alfa-laval-mopx-209-centrifuge/Alfa-Laval-MAPX309-Lube-Oil-Centrifuge-e1614024028815.webp"
      alt="Alfa Laval MAPX309 Lube Oil Centrifuge"
      width="300"
      height="300"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
  </div>

  <h2 id="applications">Applications</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <img
      src="/images/alfa-laval-mopx-209-centrifuge/Reconditioned-Alfa-Laval-MOPX209-WVO-e1615147470906.webp"
      alt="Reconditioned Alfa Laval MOPX209 WVO"
      width="250"
      height="250"
      loading="lazy"
      class="rounded-lg w-full md:w-auto md:max-w-[280px] shrink-0"
    />
    <div class="flex-1">
      <ul>
        <li><a href="/cutting-oil-centrifuge/">Aluminum machining oil recovery</a></li>
        <li><a href="/waste-oil-centrifuge/">Industrial waste oil processing</a></li>
        <li><a href="/crude-oil-centrifuge/">Crude oil dewatering</a></li>
        <li><a href="/lube-oil-centrifuge/">Lube oil purification</a></li>
        <li><a href="/wvo-centrifuge-separator/">WVO / yellow grease purification</a></li>
        <li><a href="/wvo-centrifuge-separator/">Used oil re-refining</a></li>
      </ul>
      <p>
        <a href="/disc-stack-centrifuge/">Looking for a complete turnkey system? See our disc stack centrifuge systems &rarr;</a>
      </p>
    </div>
  </div>

  <!-- Additional Gallery -->
  <div class="grid sm:grid-cols-2 gap-4 mb-8 not-prose">
    <div class="text-center">
      <img
        src="/images/alfa-laval-mopx-209-centrifuge/Reconditioned-Alfa-Laval-MAPX309-Crude-Oil-Dewatering-e1615147112982.webp"
        alt="Reconditioned Alfa Laval MAPX309 Crude Oil Dewatering Centrifuge"
        width="250"
        height="250"
        loading="lazy"
        class="rounded-lg w-full"
      />
      <p class="text-xs text-gray-500 mt-1">Reconditioned MAPX 309 — Crude Oil Dewatering</p>
    </div>
    <div class="text-center">
      <img
        src="/images/alfa-laval-mopx-209-centrifuge/Reconditioned-Alfa-Laval-MAPX309-Used-Oil-Centrifuge-e1615147554939.webp"
        alt="Reconditioned Alfa Laval MAPX309 Used Oil Centrifuge"
        width="250"
        height="250"
        loading="lazy"
        class="rounded-lg w-full"
      />
