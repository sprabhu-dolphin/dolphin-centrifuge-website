---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval MOPX 209 Self-Cleaning Centrifuge",
  "description": "Alfa Laval MOPX 209 self-cleaning disc stack centrifuge for diesel, waste oil, and cutting oil. 22 GPM on draw oil, 15 HP. Also covers WHPX 409 and MAPX 309.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/alfa-laval-mopx-209-centrifuge/",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the Dolphin equivalent of the Alfa Laval MOPX 209 centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Dolphin DMPX-042 centrifuge system is built around the Alfa Laval MOPX 209 (or equivalent WHPX 409 / MAPX 309) centrifuge bowl. The DMPX-042 adds a complete system frame, PLC controls, electric heaters, feed pump, and piping to make a turnkey centrifuge module. Rated at 32–47 GPM on diesel depending on configuration."
      }
    },
    {
      "@type": "Question",
      "name": "What is the flow rate of the Alfa Laval MOPX 209 centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Alfa Laval MOPX 209 is rated at approximately 22 GPM on draw oil (mineral oil at 60 cSt) and 32–47 GPM on diesel at 13 cSt depending on separation requirement and model variant (MOPX 209, MOPX 310). The equivalent Dolphin DMPX-042 system capacity ranges from 32 to 47 GPM on diesel and 15–24 GPM on lube oil."
      }
    },
    {
      "@type": "Question",
      "name": "What applications is the Alfa Laval MOPX 209 / DMPX-042 best suited for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The MOPX 209 / DMPX-042 is a mid-to-large capacity self-cleaning centrifuge well suited for: diesel fuel purification at 30–45 GPM, waste oil recovery, cutting oil and coolant clarification, lube oil purification in power plants and industrial facilities, and crude oil dehydration in oilfield applications."
      }
    },
    {
      "@type": "Question",
      "name": "What is the motor horsepower of the Alfa Laval MOPX 209?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Alfa Laval MOPX 209 centrifuge uses a 15 HP main drive motor. The complete Dolphin DMPX-042 system module typically includes a 15 HP centrifuge motor plus additional pump motor (1–3 HP) and optional electric heaters (up to 60 kW)."
      }
    },
    {
      "@type": "Question",
      "name": "Is the Alfa Laval MOPX 209 centrifuge available explosion-proof?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The Dolphin DMPX-042 (built around the MOPX 209 bowl) is available in Class 1 Division 2 explosion-proof configuration for hazardous area installations. Contact Dolphin Centrifuge at (248) 522-2573 for explosion-proof options."
      }
    }
  ]
};
---

<BaseLayout
  title="Alfa Laval MOPX 209 Centrifuge"
  description="Alfa Laval MOPX 209 self-cleaning disc stack centrifuge for diesel, waste oil, and cutting oil. 22 GPM on draw oil, 15 HP. Also covers WHPX 409 and MAPX 309."
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-mopx-209-centrifuge/"
  breadcrumbs={[{label: 'Products', href: '/disc-stack-centrifuge/'}, {label: 'MOPX 209'}]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">Products</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">Alfa Laval MOPX 209 Self-Cleaning Centrifuge</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">Dolphin Centrifuge provides expert service, genuine parts, and fully reconditioned units for this model. A heavy-duty total-discharge disc stack centrifuge with a 15 HP motor and 5,180 RPM bowl speed, designed for large-scale processing of waste oil, diesel fuel, aluminum drawing oil, and industrial fluids at up to 25 GPM.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Request a Quote</a>
        <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
      </div>
    </div>
  </section>

  <!-- Specs & Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-4xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
        <p class="text-sm text-text-light leading-relaxed italic">The Alfa Laval MOPX 209 is a self-cleaning total-discharge (TGT) three-phase disc stack centrifuge rated at 52–70 GPM (32–47 GPM on diesel). Dolphin Centrifuge supplies the MOPX 209 as the DMPX-042 complete centrifuge module — ideal for waste oil recovery, aluminum drawing oil, and industrial fluid applications with moderate to heavy contamination. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in MOPX-series centrifuge systems.</p>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">MOPX 209 Total-Discharge Centrifuge</h2>
      <p class="text-text-light mb-4">
        The Alfa Laval MOPX 209 is a self-cleaning <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">disc stack centrifuge</a> designed for the continuous three-phase separation of fuels, including <a href="/diesel-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">diesel</a>, <a href="/biodiesel-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">biodiesel</a>, <a href="/waste-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">waste oil</a>, and <a href="/fuel-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">fuel oil</a>.
      </p>
      <p class="text-text-light mb-8">
        With a total-discharge (TGT) bowl design, the MOPX 209 ejects all accumulated solids and separated water during each discharge cycle. This makes it particularly effective for applications with moderate to heavy contamination levels, such as aluminum drawing oil recovery and industrial waste oil processing.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">MOPX 209 Specifications</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <tbody>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Model Type</td>
              <td class="px-4 py-3 font-mono text-text-light">Alfa Laval MOPX 209 TGT 20-60</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Rated Capacity</td>
              <td class="px-4 py-3 font-mono text-text-light">22 GPM on Aluminum Draw Oil</td>
            </tr>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Sludge Space</td>
              <td class="px-4 py-3 font-mono text-text-light">2.00 Gallons</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Motor HP</td>
              <td class="px-4 py-3 font-mono text-text-light">15 HP</td>
            </tr>
            <tr class="bg-white">
              <td class="px-4 py-3 font-semibold text-navy">Voltages</td>
              <td class="px-4 py-3 font-mono text-text-light">230 / 460 V</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Also Available: WHPX 409 Partial-Discharge</h2>
      <p class="text-text-light mb-4">
        The Alfa Laval WHPX 409 is a partial-discharge centrifuge in the same frame class, designed for diesel, <a href="/crude-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">light crude oil</a>, and light fuel oil separation. With a 12.5 HP motor at 7,125 RPM, it processes 40 GPM of #2 diesel fuel.
      </p>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <tbody>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Model Type</td>
              <td class="px-4 py-3 font-mono text-text-light">Alfa Laval WHPX 409 TGD 24-60</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Rated Capacity</td>
              <td class="px-4 py-3 font-mono text-text-light">45 GPM on Kerosene</td>
            </tr>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Sludge Space</td>
              <td class="px-4 py-3 font-mono text-text-light">1.30 Gallons</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Motor HP</td>
              <td class="px-4 py-3 font-mono text-text-light">12.5 HP</td>
            </tr>
            <tr class="bg-white">
              <td class="px-4 py-3 font-semibold text-navy">Voltages</td>
              <td class="px-4 py-3 font-mono text-text-light">230 / 460 V</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Also Available: MAPX 309 Full-Discharge</h2>
      <p class="text-text-light mb-4">
        The Alfa Laval MAPX 309 is a heavy-duty, full-discharge centrifuge for continuous separation of water and sludge from mineral oils and fuels. With a 10 HP motor at 5,200 RPM, it processes 24 GPM of steam turbine lube oil.
      </p>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <tbody>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Model Type</td>
              <td class="px-4 py-3 font-mono text-text-light">Alfa Laval MAPX 309 BGT-14</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Rated Capacity</td>
              <td class="px-4 py-3 font-mono text-text-light">24 GPM on Steam Turbine Lube Oil</td>
            </tr>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Sludge Space</td>
              <td class="px-4 py-3 font-mono text-text-light">2.10 Gallons</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Motor HP</td>
              <td class="px-4 py-3 font-mono text-text-light">10 HP</td>
            </tr>
            <tr class="bg-white">
              <td class="px-4 py-3 font-semibold text-navy">Voltages</td>
              <td class="px-4 py-3 font-mono text-text-light">230 / 460 V</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Applications</h2>
      <div class="grid md:grid-cols-2 gap-x-8 gap-y-2 mb-8">
        <ul class="text-text-light space-y-2">
          <li>&#8226; <a href="/cutting-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Aluminum machining oil recovery</a></li>
          <li>&#8226; <a href="/waste-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Industrial waste oil processing</a></li>
          <li>&#8226; <a href="/crude-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Crude oil dewatering</a></li>
        </ul>
        <ul class="text-text-light space-y-2">
          <li>&#8226; <a href="/lube-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Lube oil purification</a></li>
          <li>&#8226; WVO / yellow grease purification</li>
          <li>&#8226; <a href="/waste-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Used oil re-refining</a></li>
        </ul>
      </div>

      <p class="text-text-light mb-8">
        <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Looking for a complete turnkey system? See our disc stack centrifuge systems &rarr;</a>
      </p>

      <!-- FAQ Section -->
      <div class="mt-12">
        <h2 class="text-2xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-gray-50 rounded-xl border border-gray-200 p-5">
            <summary class="font-semibold text-navy cursor-pointer">What is the Dolphin equivalent of the Alfa Laval MOPX 209?</summary>
            <p class="text-text-light mt-3 text-sm">The Dolphin DMPX-042 centrifuge system is built around the Alfa Laval MOPX 209 (or equivalent WHPX 409 / MAPX 309) centrifuge bowl. The DMPX-042 adds a complete system frame, PLC controls, electric heaters, feed pump, and piping to make a turnkey centrifuge module. Rated at 32–47 GPM on diesel depending on configuration.</p>
          </details>
          <details class="bg-gray-50 rounded-xl border border-gray-200 p-5">
            <summary class="font-semibold text-navy cursor-pointer">What is the flow rate of the Alfa Laval MOPX 209?</summary>
            <p class="text-text-light mt-3 text-sm">The Alfa Laval MOPX 209 is rated at approximately 22 GPM on draw oil (mineral oil at 60 cSt) and 32–47 GPM on diesel at 13 cSt depending on separation requirement and model variant. The equivalent Dolphin DMPX-042 system capacity ranges from 32 to 47 GPM on diesel and 15–24 GPM on lube oil.</p>
          </details>
          <details class="bg-gray-50 rounded-xl border border-gray-200 p-5">
            <summary class="font-semibold text-navy cursor-pointer">What applications is the MOPX 209 / DMPX-042 best suited for?</summary>
            <p class="text-text-light mt-3 text-sm">The MOPX 209 / DMPX-042 is a mid-to-large capacity self-cleaning centrifuge suited for: diesel fuel purification at 30–45 GPM, waste oil recovery, cutting oil and coolant clarification, lube oil purification in power plants, and crude oil dehydration in oilfield applications.</p>
          </details>
          <details class="bg-gray-50 rounded-xl border border-gray-200 p-5">
            <summary class="font-semibold text-navy cursor-pointer">Is the Alfa Laval MOPX 209 / DMPX-042 available explosion-proof?</summary>
            <p class="text-text-light mt-3 text-sm">Yes. The Dolphin DMPX-042 (built around the MOPX 209 bowl) is available in Class 1 Division 2 explosion-proof configuration for hazardous area installations. Contact Dolphin Centrifuge at <a href="tel:+12485222573" class="text-navy font-semibold hover:text-gold">(248) 522-2573</a> for explosion-proof options.</p>
          </details>
        </div>
      </div>

      <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

      <!-- Bottom CTA -->
      <div class="bg-navy rounded-xl p-8 text-center mt-12">
        <h2 class="text-2xl font-bold text-white mb-3">Interested in This Centrifuge?</h2>
        <p class="text-gray-300 mb-6 max-w-lg mx-auto">Contact our team for pricing, availability, and system configuration options.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Quote</a>
          <a href="tel:2485222573" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">(248) 522-2573</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
