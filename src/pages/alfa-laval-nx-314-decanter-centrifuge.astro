      <!-- Applications -->
      <div id="applications" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-5">Applications</h2>
        <p class="text-gray-700 leading-relaxed mb-4">The Alfa Laval NX 314 decanter centrifuge is suited for a wide range of two-phase solid/liquid separation applications across multiple industries. Its robust construction and adjustable differential speed allow it to handle varying solids concentrations and fluid viscosities effectively.</p>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <li class="flex items-start gap-2">
            <span class="text-[#E8A317] font-bold mt-1">&#10003;</span>
            <span class="text-gray-700">Hemp Solvent Extraction</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#E8A317] font-bold mt-1">&#10003;</span>
            <a href="/ethanol-extraction-centrifuges-technical-comparison/" class="text-[#1B3A5C] hover:text-[#E8A317] font-medium">Ethanol Extraction Centrifuge</a>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#E8A317] font-bold mt-1">&#10003;</span>
            <a href="/waste-oil-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317] font-medium">Waste Oil De-sludging</a>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#E8A317] font-bold mt-1">&#10003;</span>
            <a href="/crude-oil-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317] font-medium">Crude Oil Tank Bottom Sludge</a>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#E8A317] font-bold mt-1">&#10003;</span>
            <a href="/wastewater-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317] font-medium">Municipal Wastewater</a>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#E8A317] font-bold mt-1">&#10003;</span>
            <a href="/centrifuge-pyrolysis-oil/" class="text-[#1B3A5C] hover:text-[#E8A317] font-medium">Pyrolysis Sludge Separation</a>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#E8A317] font-bold mt-1">&#10003;</span>
            <a href="/liquid-humus-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317] font-medium">Liquid Humus Fertilizer</a>
