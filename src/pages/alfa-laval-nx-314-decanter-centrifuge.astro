              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Bowl Length</td>
                <td class="py-3 font-mono text-gray-700">34" (860 mm)</td>
              </tr>
              <tr class="border-b border-gray-100 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Beach Angle (Half Cone)</td>
                <td class="py-3 font-mono text-gray-700">8.5 Degrees</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Drive Motor Power</td>
                <td class="py-3 font-mono text-gray-700">10 HP</td>
              </tr>
              <tr class="border-b border-gray-100 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Gearbox Ratio</td>
                <td class="py-3 font-mono text-gray-700">1:159 (2.5 kN-M)</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">AE (Area Equivalent)</td>
                <td class="py-3 font-mono text-gray-700">780</td>
              </tr>
              <tr class="border-b border-gray-100 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Centrifugal Force</td>
                <td class="py-3 font-mono text-gray-700">3,157 Gs <a href="/centrifuge-rcf-rpm-difference-calculation/" class="text-[#1B3A5C] hover:text-[#E8A317]">RCF</a></td>
