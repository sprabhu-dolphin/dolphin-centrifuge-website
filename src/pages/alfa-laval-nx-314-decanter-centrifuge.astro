---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval NX 314 Decanter Centrifuge",
  "description": "The Alfa Laval NX 314 is a horizontal two-phase decanter centrifuge for wastewater dewatering, sludge thickening, waste oil de-sludging, and industrial separation at 3,157 Gs with a 10 HP motor.",
  "brand": {
    "@type": "Brand",
    "name": "Alfa Laval"
  },
  "offers": {
    "@type": "Offer",
    "seller": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge",
      "telephone": "+12485222573",
      "email": "sales@dolphincentrifuge.com"
    }
  },
  "additionalProperty": [
    { "@type": "PropertyValue", "name": "Bowl Diameter", "value": "14 inches (353 mm)" },
    { "@type": "PropertyValue", "name": "Bowl Speed", "value": "4000 RPM" },
    { "@type": "PropertyValue", "name": "Centrifugal Force", "value": "3,157 G" },
    { "@type": "PropertyValue", "name": "Drive Motor Power", "value": "10 HP" },
    { "@type": "PropertyValue", "name": "Bowl Length", "value": "34 inches (860 mm)" },
    { "@type": "PropertyValue", "name": "AE (Area Equivalent)", "value": "780" },
    { "@type": "PropertyValue", "name": "Gearbox Ratio", "value": "1:159 (2.5 kN-M)" },
    { "@type": "PropertyValue", "name": "Rated Capacity", "value": "25 GPM on Hemp Ethanol Slurry" },
    { "@type": "PropertyValue", "name": "Conveyor Protection", "value": "Carbide Tile or Tungsten Carbide Hard-Surfacing" }
  ]
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the capacity of the Alfa Laval NX 314 decanter centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Alfa Laval NX 314 decanter centrifuge has a rated capacity of 25 GPM on hemp ethanol slurry. It is driven by a 10 HP motor with a bowl speed of 4,000 RPM, generating 3,157 Gs of centrifugal force for effective two-phase solid/liquid separation."
      }
    },
    {
      "@type": "Question",
      "name": "What applications is the NX 314 decanter used for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The NX 314 decanter is used for hemp solvent extraction, ethanol extraction, waste oil de-sludging, crude oil tank bottom sludge recovery, municipal wastewater treatment, pyrolysis sludge separation, liquid humus fertilizer processing, and sludge thickening and dewatering."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between the NX 314, AVNX 414, and NX 416 decanters?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The NX 314 is a two-phase decanter with a 10 HP motor and 34-inch bowl length. The AVNX 414 is a three-phase decanter with a 15 HP motor designed for industrial wastewater and WVO desludging. The NX 416 is a larger two-phase decanter with a 20 HP motor, a 46-inch bowl length, and a higher AE of 1,170, capable of processing 40 GPM of UCO at 180 degrees Fahrenheit."
      }
    },
    {
      "@type": "Question",
      "name": "Can the NX 314 be supplied as a modular packaged unit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, the Alfa Laval NX-314 decanter can be supplied as a complete modular packaged unit. This plug and play system includes ancillary equipment such as a sludge conveyor, clean fluid tank with transfer pump, feed pump, and electric pre-heater for efficient standalone operation."
      }
    },
    {
      "@type": "Question",
      "name": "What type of conveyor protection does the NX 314 decanter have?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Alfa Laval NX 314 decanter features carbide tile or tungsten carbide hard-surfacing on the conveyor (auger) for protection against abrasive wear. This extends the service life of the conveyor in demanding applications such as sludge dewatering and tank bottom recovery."
      }
    }
  ]
};
---

<BaseLayout
  title="Alfa Laval NX 314 Decanter | Wastewater Dewatering Centrifuge"
  description="Alfa Laval NX 314 B31-G two-phase decanter centrifuge. 10 HP, 4,000 RPM, 3,157 Gs. Handles wastewater, sludge, waste oil, tank bottoms, and biomass at 25 GPM."
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-nx-314-decanter-centrifuge/"
  breadcrumbs={[{label: 'Products', href: '/centrifuges/'}, {label: 'Alfa Laval NX-314'}]}
  jsonLd={jsonLd}
>

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Hero -->
  <section class="bg-[#1B3A5C] text-white py-16 md:py-20">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="flex flex-col md:flex-row gap-10 items-center">
        <div class="md:w-1/2">
          <p class="text-[#E8A317] font-semibold uppercase tracking-widest text-sm mb-3">Decanter Centrifuge</p>
          <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-5">Alfa Laval NX 314 Decanter<br/>Wastewater Dewatering Centrifuge</h1>
