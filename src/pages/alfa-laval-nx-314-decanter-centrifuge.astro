          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] text-white font-bold px-8 py-3 rounded-lg hover:bg-amber-600 transition text-center">Get a Quote</a>
            <a href="tel:+12485222573" class="border-2 border-white text-white font-bold px-8 py-3 rounded-lg hover:bg-white hover:text-[#1B3A5C] transition text-center">(248) 522-2573</a>
          </div>
        </div>
        <div class="md:w-1/2">
          <img
            src="/images/alfa-laval-nx-314-decanter-centrifuge/Alfa-Laval-NX-314-Decanter-Centrifuge-600.jpg"
            alt="Alfa Laval NX-314 Decanter Centrifuge"
            width="600"
            height="428"
            loading="eager"
            class="rounded-xl shadow-xl w-full"
          />
