      <!-- NX-314 Specifications -->
      <div id="nx314-specifications" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-5">Alfa Laval NX 314 B31-G Specifications</h2>
        <p class="text-gray-700 leading-relaxed mb-6">The following table lists the complete technical specifications for the Alfa Laval NX 314 B31-G two-phase decanter centrifuge. The rated capacity is based on hemp ethanol slurry processing. Actual throughput varies depending on the application, feed solids concentration, and required separation efficiency.</p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <tbody>
              <tr class="border-b border-gray-100">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C] w-1/2">Model Type</td>
                <td class="py-3 font-mono text-gray-700">Alfa Laval NX 314 B31-G</td>
              </tr>
              <tr class="border-b border-gray-100 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Rated Capacity</td>
