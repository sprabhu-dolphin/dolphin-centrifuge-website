  <!-- TOC -->
  <section class="bg-[#F5F5F0] py-8 border-b border-gray-200">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-lg font-bold text-[#1B3A5C] mb-4">Table of Contents</h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm">
        <li><a href="#nx-314-overview" class="text-[#1B3A5C] hover:text-[#E8A317] font-medium">&#8594; Alfa Laval NX 314 B31-G Two-Phase Decanter</a></li>
        <li><a href="#applications" class="text-[#1B3A5C] hover:text-[#E8A317] font-medium">&#8594; Applications</a></li>
        <li><a href="#nx314-specifications" class="text-[#1B3A5C] hover:text-[#E8A317] font-medium">&#8594; NX-314 Specifications</a></li>
        <li><a href="#modularized-unit" class="text-[#1B3A5C] hover:text-[#E8A317] font-medium">&#8594; Modularized NX-314 Units</a></li>
        <li><a href="#avnx-414" class="text-[#1B3A5C] hover:text-[#E8A317] font-medium">&#8594; Alfa Laval AVNX 414 B-31</a></li>
