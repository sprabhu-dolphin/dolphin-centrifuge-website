              </tr>
              <tr class="bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Conveyor Protection</td>
                <td class="py-3 font-mono text-gray-700">Carbide Tile or Tungsten Carbide Hard-Surfacing</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Modularized Units -->
      <div id="modularized-unit" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-5">Modularized NX-314 Decanter Units</h2>
        <p class="text-gray-700 leading-relaxed mb-6">A complete Alfa Laval NX-314 Decanter can be supplied as a modular packaged unit as shown below.</p>

        <img
          src="/images/alfa-laval-nx-314-decanter-centrifuge/Alfa-Laval-NX-314-Decanter-Centrifuge-Module-600.jpg"
          alt="Alfa Laval NX-314 Decanter Centrifuge Module"
