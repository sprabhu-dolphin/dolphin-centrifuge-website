---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Knowledge Center — Industrial Centrifuge Resources";
const description = "Industrial centrifuge knowledge center: troubleshooting guides, technical comparisons, and case studies from Dolphin Centrifuge. 40+ years of expertise.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Dolphin Centrifuge Knowledge Center",
  "description": description,
  "url": "https://dolphincentrifuge.com/knowledge-center/",
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "email": "sales@dolphincentrifuge.com",
  },
};

const categories = [
  {
    id: 'troubleshooting',
    title: 'Troubleshooting',
    subtitle: 'Diagnose & Fix Common Issues',
    icon: 'wrench',
    color: 'from-red-500/10 to-red-600/5',
    borderColor: 'border-red-400/30',
    iconColor: 'text-red-500',
    hubHref: '/knowledge-troubleshooting/',
    articles: [
      { label: 'Top 10 Mechanical Issues & Fixes', href: '/disc-stack-centrifuge-mechanical-issues-fixes/' },
      { label: 'Cannot Reach Operating Speed', href: '/disc-centrifuge-cannot-reach-operating-speed/' },
      { label: 'Troubleshooting Bowl Leaking', href: '/disc-stack-centrifuge-troubleshooting-bowl-leaking/' },
      { label: 'Bad Separation — 6 Common Causes', href: '/disc-stack-centrifuge-bad-separation/' },
