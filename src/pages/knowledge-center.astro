      { label: 'Decanter Centrifuge Vibration', href: '/decanter-centrifuge-vibration/' },
      { label: 'Clogged Bowl & Discs', href: '/centrifuge-clogged-bowl-discs/' },
      { label: 'Liquid Seal Break', href: '/disc-stack-centrifuge-liquid-seal-break/' },
