    color: 'from-red-500/10 to-red-600/5',
    borderColor: 'border-red-400/30',
    iconColor: 'text-red-500',
    hubHref: '/knowledge-troubleshooting/',
    articles: [
      { label: 'Top 10 Mechanical Issues & Fixes', href: '/disc-stack-centrifuge-mechanical-issues-fixes/' },
      { label: 'Cannot Reach Operating Speed', href: '/disc-centrifuge-cannot-reach-operating-speed/' },
      { label: 'Troubleshooting Bowl Leaking', href: '/disc-stack-centrifuge-troubleshooting-bowl-leaking/' },
