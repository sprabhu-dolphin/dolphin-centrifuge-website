---

<ApplicationLayout
  title="Industrial Centrifuge Knowledge Center | Dolphin Centrifuge"
  description={description}
  canonicalUrl="https://dolphincentrifuge.com/knowledge-center/"
  category="knowledge"
  categoryLabel="Knowledge Base"
  heroImage="/images/about-dolphin-centrifuge/Dolphin-Centrifuge-Shop-Warren-1000.webp"
  heroImageAlt="Dolphin Centrifuge shop in Warren, Michigan — industrial centrifuge service facility"
  toc={[
    { id: 'troubleshooting', label: 'Troubleshooting' },
    { id: 'guides', label: 'Guides & How-To' },
    { id: 'comparisons', label: 'Comparisons & Explainers' },
    { id: 'product-brand', label: 'Product & Brand Information' },
    { id: 'case-studies', label: 'Case Studies & FAQ' },
    { id: 'faq', label: 'Frequently Asked Questions' },
  ]}
  relatedApplications={[
    { label: 'Waste Oil Centrifuge', href: '/waste-oil-centrifuge/' },
    { label: 'Fuel Oil Centrifuge', href: '/fuel-oil-centrifuge/' },
    { label: 'Disc Stack Centrifuge Applications', href: '/disc-stack-centrifuge-applications/' },
  ]}
  relatedProducts={[
    { label: 'DMPX-042 Disc Centrifuge', href: '/centrifuges/dmpx-042/' },
    { label: 'DMPX-028 Disc Centrifuge', href: '/centrifuges/dmpx-028/' },
  ]}
  jsonLd={[jsonLd, articleJsonLd, faqJsonLd]}
>
  <div class="max-w-none">
    <div class="not-prose bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8 max-w-4xl">
      <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge publishes industrial centrifuge guides, troubleshooting articles, comparison resources, product brand reference pages, and case studies — all based on 40+ years of hands-on Alfa Laval disc stack and decanter centrifuge experience. Topics cover application selection, vibration diagnosis, separation theory, operating speed problems, liquid seal break, sludge ejection, and more.</p>
    </div>

    <div class="space-y-10">
      {categories.map((cat) => (
        <div id={cat.id} class="scroll-mt-24">
          <div class={`bg-white rounded-xl border ${cat.borderColor} shadow-sm overflow-hidden`}>
            <div class={`bg-gradient-to-r ${cat.color} px-6 py-5 md:px-8 md:py-6 border-b border-gray-100 flex items-center gap-4`}>
              <div class={`w-10 h-10 md:w-12 md:h-12 rounded-lg bg-white shadow-sm flex items-center justify-center shrink-0`}>
                <svg class={`w-5 h-5 md:w-6 md:h-6 ${cat.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={icons[cat.icon]} />
                </svg>
              </div>
              <div>
                <h2 class="text-xl md:text-2xl font-bold font-heading text-navy">{cat.title}</h2>
                <p class="text-sm text-gray-500 mt-0.5">{cat.subtitle} &mdash; {cat.articles.length} articles</p>
              </div>
            </div>

            <div class="p-4 md:p-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1">
                {cat.articles.map((article) => (
                  <a
                    href={article.href}
                    class="group flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-warm-white transition-colors"
                  >
                    <svg class="w-4 h-4 text-gold shrink-0 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                    </svg>
                    <span class="text-sm md:text-base text-gray-700 group-hover:text-navy font-medium transition-colors">{article.label}</span>
                  </a>
                ))}
              </div>
              <div class="mt-4 pt-4 border-t border-gray-100 text-center">
                <a href={cat.hubHref} class="inline-flex items-center gap-1 text-gold hover:text-gold-dark font-semibold text-sm transition-colors">
                  Explore All {cat.title}
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Mid-page CTA -->
    <div class="bg-gold/10 border-l-4 border-gold rounded-r-lg p-5 my-8">
      <p class="text-navy font-bold text-lg mb-1">Need hands-on centrifuge help?</p>
      <p class="text-text-light text-sm mb-3">Our engineers are available for direct technical support, application sizing, and free sample testing. Call or submit your details online.</p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold text-navy font-bold px-5 py-2.5 rounded-lg hover:bg-yellow-500 transition-colors text-sm">Get a Free Quote</a>
        <a href="/industrial-centrifuge-sample-testing/" class="inline-block border border-navy text-navy font-semibold px-5 py-2.5 rounded-lg hover:bg-navy/5 transition-colors text-sm">Free Sample Testing</a>
      </div>
    </div>

    <!-- FAQ Section -->
    <h2 id="faq" class="text-2xl font-bold text-navy font-heading mt-10 mb-4">Frequently Asked Questions</h2>
    <div class="space-y-3">
      {faqItems.map(item => (
        <details class="border-l-4 border-gold bg-white rounded-r-xl shadow-sm p-5">
          <summary class="font-semibold text-navy cursor-pointer list-none flex items-center gap-2">
            <span class="text-gold font-bold">+</span> {item.question}
          </summary>
          <p class="text-text-light mt-3 text-sm leading-relaxed">{item.answer}</p>
        </details>
      ))}
    </div>
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

    <!-- Bottom CTA Bar -->
    <div class="bg-navy rounded-xl p-6 md:p-8 mt-10 text-center">
      <p class="text-white text-xl font-bold mb-2">Ready to solve your centrifuge challenge?</p>
      <p class="text-blue-100 text-sm mb-5">Dolphin Centrifuge engineers are available to help with selection, troubleshooting, and application testing. Based in Warren, Michigan — serving customers worldwide since 1981.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold text-navy font-bold px-7 py-3 rounded-lg hover:bg-yellow-500 transition-colors">Get a Free Quote</a>
        <a href="/industrial-centrifuge-sample-testing/" class="inline-block border border-white/40 hover:border-white text-white font-semibold px-7 py-3 rounded-lg transition-colors">Free Sample Testing</a>
      </div>
    </div>

  </div>
</ApplicationLayout>
