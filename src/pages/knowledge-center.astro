---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl="https://dolphincentrifuge.com/knowledge-center/"
  breadcrumbs={[{ label: "Knowledge Center" }]}
  jsonLd={jsonLd}
>
  {/* Hero */}
  <section class="relative overflow-hidden min-h-[420px] md:min-h-[480px] flex items-center">
    <div class="absolute inset-0">
      <img
        src="/images/about-dolphin-centrifuge/Dolphin-Centrifuge-Shop-Warren-1000.webp"
        alt="Dolphin Centrifuge shop in Warren, Michigan — industrial centrifuge service facility"
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover object-center"
        width="1000"
        height="600"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[#1B3A5C] via-[#1B3A5C]/90 to-[#1B3A5C]/50"></div>
    </div>
    <div class="relative z-10 container-dolphin py-14 md:py-20">
      <div class="max-w-2xl bg-navy/55 backdrop-blur-xl rounded-2xl p-8 md:p-10">
        <span class="inline-block text-gold text-xs font-bold tracking-wider uppercase mb-3">Resource Library</span>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading leading-tight mb-4 text-white">
          Knowledge Center
        </h1>
        <p class="text-lg text-gray-300 leading-relaxed max-w-2xl">
          Expert guides, troubleshooting tips, technical comparisons, and real-world case studies — backed by 40+ years of industrial centrifuge experience. Everything you need to select, operate, and maintain disc stack and decanter centrifuges.
        </p>
      </div>
    </div>
  </section>

  {/* Category Tiles */}
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16">
      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8 max-w-4xl">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge publishes industrial centrifuge guides, troubleshooting articles, comparison resources, product brand reference pages, and case studies — all based on 40+ years of hands-on Alfa Laval disc stack and decanter centrifuge experience. Topics cover application selection, vibration diagnosis, separation theory, operating speed problems, liquid seal break, sludge ejection, and more. Based in Warren, Michigan — (248) 522-2573.</p>
      </div>
      <div class="space-y-10">
        {categories.map((cat) => (
          <div id={cat.id} class="scroll-mt-24">
            {/* Category Header Tile */}
            <div class={`bg-white rounded-xl border ${cat.borderColor} shadow-sm overflow-hidden`}>
              {/* Title Bar */}
              <div class={`bg-gradient-to-r ${cat.color} px-6 py-5 md:px-8 md:py-6 border-b border-gray-100 flex items-center gap-4`}>
                <div class={`w-10 h-10 md:w-12 md:h-12 rounded-lg bg-white shadow-sm flex items-center justify-center shrink-0`}>
                  <svg class={`w-5 h-5 md:w-6 md:h-6 ${cat.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={icons[cat.icon]} />
                  </svg>
                </div>
                <div>
                  <h2 class="text-xl md:text-2xl font-bold font-heading text-navy">{cat.title}</h2>
                  <p class="text-sm text-gray-500 mt-0.5">{cat.subtitle} &mdash; {cat.articles.length} articles</p>
                </div>
              </div>

              {/* Article Links */}
              <div class="p-4 md:p-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1">
                  {cat.articles.map((article) => (
                    <a
                      href={article.href}
                      class="group flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-warm-white transition-colors"
                    >
                      <svg class="w-4 h-4 text-gold shrink-0 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                      </svg>
                      <span class="text-sm md:text-base text-gray-700 group-hover:text-navy font-medium transition-colors">{article.label}</span>
                    </a>
                  ))}
                </div>
                <div class="mt-4 pt-4 border-t border-gray-100 text-center">
                  <a href={cat.hubHref} class="inline-flex items-center gap-1 text-gold hover:text-gold-dark font-semibold text-sm transition-colors">
                    Explore All {cat.title}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Bottom CTA */}
  <section class="bg-white border-t border-gray-200">
    <div class="container-dolphin py-12 md:py-16">
      <div class="bg-navy rounded-2xl p-8 md:p-10 text-white text-center md:text-left md:flex md:items-center md:justify-between">
        <div class="mb-6 md:mb-0">
          <h2 class="text-2xl font-bold font-heading mb-2">Can't Find What You Need?</h2>
          <p class="text-gray-300">Our centrifuge experts are ready to help with any technical question.</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 justify-center md:justify-end">
          <a
            href="/contact-for-alfa-laval-centrifuges/"
            class="inline-flex items-center justify-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors"
          >
            Contact Us
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
          <a
            href="tel:2485222573"
            class="inline-flex items-center justify-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            (248) 522-2573
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
