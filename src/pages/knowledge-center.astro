      { label: 'Pyrolysis Oil from Tire Recycling', href: '/pyrolysis-oil-centrifuge/' },
      { label: 'Decanter Centrifuge Applications A-Z', href: '/decanter-centrifuge-applications/' },
      { label: 'Disc Stack Centrifuge FAQ', href: '/disc-stack-centrifuge-faq/' },
      { label: 'Industrial Centrifuge FAQ', href: '/industrial-centrifuges-faq/' },
