  {
    id: 'comparisons',
    title: 'Comparisons & Explainers',
    subtitle: 'Understand the Differences',
    icon: 'scale',
    color: 'from-emerald-500/10 to-emerald-600/5',
    borderColor: 'border-emerald-400/30',
    iconColor: 'text-emerald-500',
    hubHref: '/knowledge-comparisons/',
