---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "10 Causes & Easy Fixes for Disc Stack Centrifuge Vibration",
    "description": "Identify and fix 10 common causes of disc stack centrifuge vibration: missing discs, spindle runout, bearing wear, sludge buildup, and more. Troubleshooting guide.",
    "author": { "@type": "Person", "name": "Sanjay Prabhu MSME", "jobTitle": "Centrifuge Applications Engineer", "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" } },
    "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
    "datePublished": "2021-05-01",
    "url": "https://dolphincentrifuge.com/disc-stack-centrifuge-vibration/",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What causes excessive vibration in a disc stack centrifuge?",
        "acceptedAnswer": { "@type": "Answer", "text": "The most common causes are: missing or misplaced discs in the bowl stack, spindle runout or bearing wear, sludge accumulation causing bowl imbalance, worn or damaged bowl bottom or hood, incorrect bowl reassembly after maintenance, or erosion/pitting of rotating components. Vibration that develops suddenly after maintenance usually points to an assembly error." }
      },
      {
        "@type": "Question",
        "name": "Is some vibration normal in a disc centrifuge?",
        "acceptedAnswer": { "@type": "Answer", "text": "A small amount of vibration is normal in any rotating machine. Most disc centrifuges have a vibration switch that triggers at 3–5 mm/s (RMS) or equivalent. Vibration that causes the safety switch to trip, that increases over time, or that correlates with bowl discharge cycles indicates a mechanical problem that needs investigation." }
      },
      {
        "@type": "Question",
        "name": "What should I check if my disc centrifuge vibration increases suddenly?",
        "acceptedAnswer": { "@type": "Answer", "text": "After any sudden vibration increase, check: (1) bowl disc count and placement, (2) bowl assembly torque and component seating, (3) bowl and spindle for visible damage, (4) bearing condition and lubrication level, (5) whether sludge buildup in the casing is contacting the rotating bowl. Always stop and inspect before resuming operation." }
      },
      {
        "@type": "Question",
        "name": "How do clutch pads cause centrifuge vibration?",
        "acceptedAnswer": { "@type": "Answer", "text": "Worn or missing clutch pads allow metal-to-metal contact between the friction shoes and the drum. This direct contact scores the drum interior unevenly, creating an imbalance in the horizontal shaft assembly. The uneven drum wear produces progressive vibration that worsens over time until the clutch assembly is inspected and repaired." }
      },
      {
        "@type": "Question",
        "name": "Can I operate a disc centrifuge with above-normal vibration?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. Operating a disc centrifuge with unresolved excessive vibration risks catastrophic damage to bearings, the spindle, and the bowl itself — and can cause personal injury. Stop the machine immediately when vibration exceeds the safety switch threshold. Contact Dolphin Centrifuge at (248) 522-2573 for emergency diagnostic support." }
      }
    ]
  }
];

const toc = [
