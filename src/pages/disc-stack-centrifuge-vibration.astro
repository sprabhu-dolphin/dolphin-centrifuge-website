  { label: 'Cannot Reach Operating Speed', href: '/disc-centrifuge-cannot-reach-operating-speed/', description: 'Causes and solutions for low RPM' },
  { label: 'Sludge Ejection Cycle Time', href: '/disc-stack-centrifuge-sludge-ejection-cycle-time/', description: 'Optimize self-cleaning discharge cycles' },
  { label: 'Centrifuge Lubrication Guide', href: '/disc-stack-centrifuge-lubrication/', description: 'Extend bearing life and prevent vibration' },
