---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "10 Causes & Easy Fixes for Disc Stack Centrifuge Vibration",
  "description": "Identify and fix 10 common causes of disc stack centrifuge vibration: missing discs, spindle runout, bearing wear, sludge buildup, and more. Troubleshooting guide.",
  "author": { "@type": "Person", "name": "Sanjay Prabhu MSME", "jobTitle": "Engineering Manager", "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" } },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "datePublished": "2021-05-01",
  "url": "https://dolphincentrifuge.com/disc-stack-centrifuge-vibration/",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What causes excessive vibration in a disc stack centrifuge?",
      "acceptedAnswer": { "@type": "Answer", "text": "The most common causes are: missing or misplaced discs in the bowl stack, spindle runout or bearing wear, sludge accumulation causing bowl imbalance, worn or damaged bowl bottom or hood, incorrect bowl reassembly after maintenance, or erosion/pitting of rotating components. Vibration that develops suddenly after maintenance usually points to an assembly error." }
    },
    {
      "@type": "Question",
      "name": "Is some vibration normal in a disc centrifuge?",
      "acceptedAnswer": { "@type": "Answer", "text": "A small amount of vibration is normal in any rotating machine. Most disc centrifuges have a vibration switch that triggers at 3–5 mm/s (RMS) or equivalent. Vibration that causes the safety switch to trip, that increases over time, or that correlates with bowl discharge cycles indicates a mechanical problem that needs investigation." }
    },
    {
      "@type": "Question",
      "name": "What should I check if my disc centrifuge vibration increases suddenly?",
      "acceptedAnswer": { "@type": "Answer", "text": "After any sudden vibration increase, check: (1) bowl disc count and placement, (2) bowl assembly torque and component seating, (3) bowl and spindle for visible damage, (4) bearing condition and lubrication level, (5) whether sludge buildup in the casing is contacting the rotating bowl. Always stop and inspect before resuming operation." }
    }
  ]
};
---

<BaseLayout
  title="10 Causes & Easy Fixes for Disc Stack Centrifuge Vibration"
  description="Identify and fix 10 common causes of disc stack centrifuge vibration: missing discs, spindle runout, bearing wear, sludge buildup, and more. Troubleshooting guide."
  canonicalUrl="https://dolphincentrifuge.com/disc-stack-centrifuge-vibration/"
  breadcrumbs={[{label: 'Knowledge', href: '/disc-stack-centrifuge-faq/'}, {label: 'Centrifuge Vibration Causes & Fixes'}]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">Knowledge Base &mdash; Troubleshooting</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">10 Causes &amp; Easy Fixes for Disc Stack Centrifuge Vibration</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">A practical troubleshooting guide covering the most common causes of excessive vibration in disc stack centrifuges, their root causes, and the corrective actions that restore smooth operation.</p>
      <div class="flex flex-wrap gap-3 mt-6">
            <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] hover:bg-yellow-500 text-white font-semibold px-6 py-3 rounded-lg transition">Request a Quote</a>
            <a href="tel:+12485222573" class="border border-white/70 text-white hover:bg-white hover:text-[#1B3A5C] font-semibold px-6 py-3 rounded-lg transition">(248) 522-2573</a>
          </div>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-4xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge provides expert diagnosis and repair for disc stack centrifuge vibration problems — one of the most common and potentially damaging centrifuge issues. Excessive vibration in disc centrifuges rotating at 3,000–8,000+ RPM can rapidly progress from a minor concern to catastrophic bearing or bowl failure if not corrected. Dolphin Centrifuge provides field service, dynamic balancing, bowl rebuilds, and replacement parts for all Alfa Laval and industrial disc centrifuge models. Based in Warren, Michigan, with over 40 years of centrifuge experience.</p>
      </div>

      <img src="/images/disc-stack-centrifuge-vibration/disc-centrifuge-bowl-vibration-animation.gif" alt="Disc stack centrifuge bowl vibration animation showing imbalanced bowl rotation" class="rounded-lg w-full max-w-2xl mx-auto mb-6" width="600" height="400" />
      <!-- Intro -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6 shadow-sm">
        <p class="text-text-light leading-relaxed"><strong>Summary:</strong> <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Disc stack centrifuges</a> contain a metal bowl that rotates at high RPM. Any rotating mass that is not correctly balanced causes vibrations. All disc stack bowls generate vibrations to varying degrees under normal conditions. However, under certain conditions the centrifuge may vibrate more than usual, which is a cause for concern due to its effect on durability. This guide covers the ten most common causes of excessive vibration and how to correct them.</p>
      </div>

      <!-- Safety Warning -->
      <div class="bg-red-50 border border-red-200 rounded-xl p-6 mb-10 shadow-sm">
        <div class="flex items-start gap-3">
          <span class="text-red-600 text-2xl shrink-0">&#9888;</span>
          <div>
            <p class="text-red-800 font-bold mb-1">Safety Warning</p>
            <p class="text-red-700 text-sm leading-relaxed">In rare cases, violent vibrations can cause catastrophic damage to the centrifuge and personal injury to the operator. Always stop the machine immediately when excessive vibration is detected. Never operate a centrifuge with unresolved vibration issues. Contact <a href="tel:+12485222573" class="text-red-800 font-semibold underline">(248) 522-2573</a> for emergency repair service.</p>
          </div>
        </div>
      </div>

      <!-- Cause 1 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">1</span>
          <h2 class="text-xl font-bold text-navy">Missing Bowl Discs</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p>The most common reason for excessive disc centrifuge vibration is missing bowl discs. The bowl lock ring compresses the bowl hood, the disc stack, and all other bowl components during assembly. This action rigidizes the entire bowl into one integral assembly that is dynamically balanced during manufacturing.</p>
          <p>The tightening of the lock ring is a laborious task. It is common for operators to leave out a couple of discs to ease re-assembly. These missing discs prevent the bowl assembly from forming a tight pack and imbalance the bowl. Even the slightest imbalance leads to vibration at the high operating RPM of the centrifuge.</p>
          <p>Over time, discs within the bowl compress and wear, causing the disc stack to settle to a reduced height compared to a new stack. This compression causes a similar issue to missing discs.</p>
          <p><strong class="text-navy">Root Cause:</strong> Missing or worn discs prevent proper compression of the bowl assembly, breaking the factory dynamic balance.</p>
          <p><strong class="text-navy">Fix:</strong> Ensure the correct number of discs are present in the bowl at all times. Replace worn or compressed discs to restore proper stack height and tight compression under the lock ring.</p>
        </div>
      </div>

      <!-- Cause 2 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">2</span>
          <h2 class="text-xl font-bold text-navy">Incorrect Bowl Assembly</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p>Though a disc stack centrifuge's bowl parts have position alignment features, an untrained operator can assemble the bowl incorrectly. A single misaligned component within the dynamically balanced bowl can cause an imbalance and related vibration.</p>
          <p>For example, if the top disc is not aligned correctly on the distributor during bowl assembly, it will imbalance the bowl.</p>
          <p><strong class="text-navy">Root Cause:</strong> Misaligned bowl components (top disc, distributor, hood) during reassembly after cleaning or maintenance.</p>
          <p><strong class="text-navy">Fix:</strong> Follow manufacturer-specified bowl assembly procedures. Verify all alignment features (keyways, locating pins, alignment ribs) are properly engaged before tightening the lock ring. Train all operators on correct assembly sequence.</p>
        </div>
      </div>

      <!-- Cause 3 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">3</span>
          <h2 class="text-xl font-bold text-navy">Bowl Spindle Runout</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p>The bowl spindle transmits rotation to the bowl body placed on it. The slightest deviation (runout) of the spindle will cause amplified vibration of the rotating bowl.</p>
          <p>The repeated impacts sustained by the lock ring during bowl assembly are the primary cause of spindle runout. Runout must be checked periodically during routine maintenance to catch this deviation before it causes excessive vibrations.</p>
          <figure class="my-4">
            <img src="/images/disc-stack-centrifuge-vibration/check-bowl-spindle-wobble.jpg" alt="Disc Centrifuge Spindle Wobble - checking bowl spindle runout with dial indicator" class="rounded-lg w-full max-w-lg" loading="lazy" width="600" height="400" />
            <figcaption class="text-sm text-gray-500 mt-2 text-center font-semibold">Disc Centrifuge Spindle Wobble Check</figcaption>
          </figure>
          <p><strong class="text-navy">Root Cause:</strong> Spindle shaft bent or worn from repeated lock ring impacts during bowl assembly, causing rotational deviation.</p>
          <p><strong class="text-navy">Fix:</strong> Measure spindle runout with a dial indicator. If runout exceeds 0.1 mm (0.004"), the spindle must be replaced. Include spindle runout checks as part of every scheduled maintenance interval.</p>
        </div>
      </div>

      <!-- Cause 4 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">4</span>
          <h2 class="text-xl font-bold text-navy">Interchanging Bowl Parts</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p>Facilities with multiple centrifuges of the same type often have operators who swap useable parts from a non-functional unit to one under repair. This practice is known as interchanging bowl parts.</p>
          <p>Most bowl parts are dynamically balanced as a matched set. Interchanging components between bowls destroys the factory balance, leading to excessive vibrations.</p>
          <figure class="my-4">
            <img src="/images/disc-stack-centrifuge-vibration/disc-centrifuge-bowl-serial-number-match.jpg" alt="Disc Bowl Serial Number Match showing serial numbers punched on bowl components to prevent interchanging" class="rounded-lg w-full max-w-lg" loading="lazy" width="600" height="400" />
            <figcaption class="text-sm text-gray-500 mt-2 text-center">Bowl Serial Number Match</figcaption>
          </figure>
          <p><strong class="text-navy">Root Cause:</strong> Swapping dynamically balanced bowl components between different centrifuge units disrupts the matched balance.</p>
          <p><strong class="text-navy">Fix:</strong> Always keep bowl components matched to their original serial-numbered bowl. The bowl serial number is punched on most large bowl components, making it easy to identify matched parts. Never swap bowl hoods, distributors, or sliding bottoms between units.</p>
        </div>
      </div>

      <!-- Cause 5 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">5</span>
          <h2 class="text-xl font-bold text-navy">Unbalanced Rotating Parts</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p>Certain transmission parts in a disc-stack centrifuge have significant inertia by design. The horizontal shaft assembly includes a heavy drum that maintains the momentum of the bowl during operation. This drum is balanced during manufacturing.</p>
          <p>Replacing this drum (or similar rotating components like gears) with a generic part that has not been properly balanced will cause vibrations during operation.</p>
          <p><strong class="text-navy">Root Cause:</strong> Replacement of factory-balanced rotating transmission components (horizontal shaft drum, gears) with unbalanced generic parts.</p>
          <p><strong class="text-navy">Fix:</strong> Use only dynamically balanced replacement parts for the horizontal shaft drum and other large rotating components. Verify that all replacement gears and shafts meet OEM balance specifications before installation.</p>
        </div>
      </div>

      <!-- Cause 6 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">6</span>
          <h2 class="text-xl font-bold text-navy">Sludge Retained in Bowl</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p>Sometimes the disc centrifuge bowl is accidentally allowed to overpack with solids, often due to an incorrect or delayed <a href="/disc-stack-centrifuge-sludge-ejection-cycle-time/" class="text-navy font-semibold hover:text-gold transition-colors">sludge ejection cycle</a>. If subsequent ejection cycles do not rid the bowl of all solids, especially from the inter-disc space, the retained solids cause a bowl imbalance and vibrations.</p>
          <p>In some cases, the sludge to be separated is very sticky and may not evacuate the bowl entirely during the ejection cycle. The retained sludge causes an imbalance and the bowl to vibrate.</p>
          <p><strong class="text-navy">Root Cause:</strong> Solids accumulation from delayed ejection cycles, sticky sludge, or overpacking that creates uneven mass distribution in the bowl.</p>
          <p><strong class="text-navy">Fix:</strong> Perform a thorough inspection and cleaning of the bowl assembly. Review and optimize sludge ejection cycle timing and frequency. For sticky sludge applications, consider increasing discharge frequency or using operating water flush cycles to ensure complete bowl evacuation.</p>
        </div>
      </div>

      <!-- Cause 7 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">7</span>
          <h2 class="text-xl font-bold text-navy">Bearing Wear or Bearing Failure</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p>Bearings are critical components in disc centrifuges that rotate at high speeds. The high-speed bearings on the vertical spindle are specially designed and made to very close tolerances to minimize vibrations during operation.</p>
          <p>Bearings wear out over time with constant usage. The gradual wear of bearing races and balls deteriorates performance, leading to increased vibration.</p>
          <p>In disc centrifuges, bearings are splash lubricated. The lubricating bath also houses the worm and worm wheel gear-set. Wear of these gears introduces fine metal particles into the lubricating oil, which can cause unanticipated bearing failure during operation.</p>
          <figure class="my-4">
            <img src="/images/disc-stack-centrifuge-vibration/disc-centrifuge-splash-lubrication.jpg" alt="Disc Centrifuge Splash Lubrication diagram showing worm gear set and bearing oil bath" class="rounded-lg w-full max-w-sm" loading="lazy" width="400" height="300" />
            <figcaption class="text-sm text-gray-500 mt-2 text-center font-semibold">Disc Centrifuge Splash Lubrication</figcaption>
          </figure>
          <p><strong class="text-navy">Root Cause:</strong> Normal wear of bearing races and balls over time, accelerated by contaminated lubricating oil containing metal particles from gear wear.</p>
          <p><strong class="text-navy">Fix:</strong> Replace bearings at scheduled intervals before wear becomes critical. Change gearbox <a href="/disc-stack-centrifuge-lubrication/" class="text-navy font-semibold hover:text-gold transition-colors">lubricating oil</a> on schedule to prevent metal particle contamination. Replace both upper and lower bearings as a matched set. Major bearing failure can cause catastrophic damage &mdash; never delay bearing service.</p>
        </div>
      </div>

      <!-- Cause 8 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">8</span>
          <h2 class="text-xl font-bold text-navy">Clutch Pad(s) Worn Out or Missing</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p>Clutch-driven centrifuges have friction pads attached to the rotating shoes. These pads are consumable parts that wear out with use.</p>
          <p>If the friction pads are worn out or fall off due to loose fasteners, the metal blocks make direct contact with the steel drum. This metal-to-metal contact causes the drum to score and wear out unevenly from within.</p>
          <p>The drum's uneven wear causes an imbalance in the horizontal shaft assembly, leading to vibration during operation.</p>
          <p><strong class="text-navy">Root Cause:</strong> Worn or missing friction clutch pads allow metal-to-metal contact, scoring the drum unevenly and creating rotational imbalance.</p>
          <p><strong class="text-navy">Fix:</strong> Monitor the clutch assembly on a periodic schedule. Replace worn friction pads before they wear through to metal. Inspect the clutch drum for scoring and uneven wear. A severely scored drum may require replacement to restore proper balance.</p>
        </div>
      </div>

      <!-- Cause 9 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">9</span>
          <h2 class="text-xl font-bold text-navy">Exposure to Sub-Zero Temperatures</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p>Centrifuges should not be operated in or exposed to sub-zero conditions. When centrifuges are exposed to freezing temperatures, leftover process fluid and <a href="/disc-stack-centrifuge-operating-water/" class="text-navy font-semibold hover:text-gold transition-colors">operating water</a> within the bowl will freeze.</p>
          <p>Freezing causes ice to form unevenly within the bowl cavities, especially if the centrifuge is not perfectly level. On startup, this solid ice mass causes a severe imbalance in the bowl. This unbalanced load can cause violent vibration to the detriment of the equipment.</p>
          <p><strong class="text-navy">Root Cause:</strong> Residual process fluid and operating water freeze unevenly inside bowl cavities, creating a severe mass imbalance on startup.</p>
          <p><strong class="text-navy">Fix:</strong> Never start a centrifuge that has been exposed to freezing temperatures without first draining all residual fluids and allowing the machine to reach ambient temperature. In cold environments, drain the bowl completely after shutdown and protect the machine from sub-zero exposure. If freezing has occurred, disassemble and inspect the bowl before startup.</p>
        </div>
      </div>

      <!-- Cause 10 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">10</span>
          <h2 class="text-xl font-bold text-navy">Spun Discs or Wing Inset</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p>The distributor (disc carrier) has an alignment rib that orients all the disc holes for fluid passage. When the bowl is not assembled correctly or discs are missing, the loose discs (without compression) tend to impact the distributor's locating rib. Repeated impacts cause the disc slot to open up, allowing some discs to spin and lose their orientation.</p>
          <figure class="my-4">
            <img src="/images/disc-stack-centrifuge-vibration/bowl-disc-distributor-alignment.jpg" alt="Bowl Centrifuge Disc Incorrect Alignment showing spun discs on distributor rib" class="rounded-lg w-full" loading="lazy" width="600" height="400" />
            <figcaption class="text-sm text-gray-500 mt-2 text-center">Bowl Disc Distributor Alignment</figcaption>
          </figure>
          <p>Similarly, the wing inset can also lose its orientation in a loosely packed bowl. The wing inset is a relatively heavy part of the bowl. A misaligned wing inset in the rotating bowl causes an imbalance and is another source of centrifuge vibrations.</p>
          <figure class="my-4">
            <img src="/images/disc-stack-centrifuge-vibration/wing-inset-distributor-alignment.jpg" alt="Disc Centrifuge Wing Inset Misaligned showing wing inset position in loosely packed bowl" class="rounded-lg w-full" loading="lazy" width="600" height="400" />
            <figcaption class="text-sm text-gray-500 mt-2 text-center">Wing Inset Misalignment</figcaption>
          </figure>
          <p><strong class="text-navy">Root Cause:</strong> Loose disc packing allows discs to spin on the distributor and the wing inset to shift position, creating rotational imbalance.</p>
          <p><strong class="text-navy">Fix:</strong> Ensure the bowl is always in good compression with the correct number of discs present. Inspect the distributor alignment rib for wear or damage. Replace discs with worn or enlarged keyway slots. Verify the wing inset is properly seated and locked in position before reassembly.</p>
        </div>
      </div>

      <!-- Summary -->
      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mt-10 mb-6">Summary</h2>
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-10">
        <p class="text-text-light leading-relaxed mb-4">There are various causes of disc centrifuge vibrations. In general, excessive vibrations are detrimental to the durability of the centrifuge, specifically to the bearings. In rare cases, violent vibrations can cause catastrophic damage to the machine and personal injury to the operator.</p>
        <p class="text-text-light leading-relaxed">It is imperative to monitor centrifuge vibration levels consistently and to ensure that all instances of excessive vibration are thoroughly checked and remedied promptly. When vibration persists after basic troubleshooting, contact Dolphin Centrifuge for professional <a href="/industrial-disc-centrifuge-repair/" class="text-navy font-semibold hover:text-gold transition-colors">centrifuge repair service</a>.</p>
      </div>

      <!-- Author -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-10">
        <p class="text-sm text-text-light"><em>by Sanjay Prabhu MSME</em><br /><em>Engineering Manager, Dolphin Centrifuge</em></p>
      </div>

      <!-- FAQ -->
      <div id="faq" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mt-10 mb-6">
        <h2 class="text-xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What causes excessive vibration in a disc stack centrifuge?</h3>
            <p class="text-text-light text-sm">Common causes are: missing or misplaced discs in the bowl stack, spindle runout or bearing wear, sludge accumulation causing bowl imbalance, worn or damaged bowl bottom or hood, incorrect bowl reassembly after maintenance, or erosion/pitting of rotating components. Sudden vibration after maintenance usually points to an assembly error.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">Is some vibration normal in a disc centrifuge?</h3>
            <p class="text-text-light text-sm">A small amount of vibration is normal in any rotating machine. Most disc centrifuges have a vibration switch that triggers at 3–5 mm/s RMS. Vibration that causes the safety switch to trip, increases over time, or correlates with bowl discharge cycles indicates a mechanical problem that needs investigation.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What should I check if my disc centrifuge vibration increases suddenly?</h3>
            <p class="text-text-light text-sm">Check: (1) bowl disc count and placement, (2) bowl assembly torque and component seating, (3) bowl and spindle for visible damage, (4) bearing condition and lubrication level, (5) whether sludge buildup in the casing is contacting the rotating bowl. Always stop and inspect before resuming operation.</p>
          </div>
        </div>
      </div>
      <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

      <!-- Related Articles -->
      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-6">Related Articles</h2>
      <div class="grid sm:grid-cols-2 gap-4 mb-6">
        <a href="/disc-stack-centrifuge-mechanical-issues-fixes/" class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:border-gold transition-colors group">
          <h3 class="text-navy font-bold group-hover:text-gold transition-colors">Top 10 Mechanical Issues &amp; Fixes</h3>
          <p class="text-sm text-text-light mt-1">Comprehensive troubleshooting guide for disc stack centrifuge mechanical problems.</p>
        </a>
        <a href="/disc-centrifuge-cannot-reach-operating-speed/" class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:border-gold transition-colors group">
          <h3 class="text-navy font-bold group-hover:text-gold transition-colors">Cannot Reach Operating Speed</h3>
          <p class="text-sm text-text-light mt-1">Causes and solutions when a disc centrifuge fails to reach its rated RPM.</p>
        </a>
        <a href="/disc-stack-centrifuge-sludge-ejection-cycle-time/" class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:border-gold transition-colors group">
          <h3 class="text-navy font-bold group-hover:text-gold transition-colors">Sludge Ejection Cycle Time</h3>
          <p class="text-sm text-text-light mt-1">Understanding and optimizing the self-cleaning discharge cycle for disc stack centrifuges.</p>
        </a>
        <a href="/disc-stack-centrifuge-lubrication/" class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:border-gold transition-colors group">
          <h3 class="text-navy font-bold group-hover:text-gold transition-colors">Centrifuge Lubrication Guide</h3>
          <p class="text-sm text-text-light mt-1">Proper lubrication practices to extend bearing life and prevent vibration issues.</p>
        </a>
      </div>

    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-navy">
