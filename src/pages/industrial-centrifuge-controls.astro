---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "What PLC platforms does Dolphin Centrifuge use for centrifuge controls?",
    answer: "Dolphin Centrifuge's standard control platform uses AutomationDirect CLICK/CLICK PLUS PLCs paired with Maple Systems HMI touchscreens. This combination provides compact expandable control, Ethernet/serial communication, Modbus, EtherNet/IP, MQTT, data logging, and stackable I/O. For plants that require Allen-Bradley (Rockwell) or Siemens hardware, Dolphin also builds panels on those platforms to match existing plant standards."
  },
  {
    question: "Can Dolphin Centrifuge retrofit controls on an existing centrifuge?",
    answer: "Yes. Dolphin Centrifuge provides retrofit control panels for any brand of industrial centrifuge including Alfa Laval, Westfalia, Sharples, and Bird centrifuges. The retrofit replaces obsolete relay panels or outdated PLCs while retaining the existing centrifuge mechanical components."
  },
  {
    question: "What standard features are included in a Dolphin centrifuge control panel?",
    answer: "Standard features include auto-start/stop sequences, adjustable sludge discharge timer, vibration shutdown switch input, bearing temperature monitoring, motor starter with overload protection, hours counter, and alarm outputs. Optional features include PLC/HMI, remote monitoring, data logging, and SCADA integration."
  },
  {
    question: "What enclosure ratings are available for centrifuge control panels?",
    answer: "Dolphin Centrifuge builds panels in NEMA 4 (painted steel), NEMA 4X (stainless steel for washdown environments), NEMA 7/9 (explosion proof for Class I/II hazardous locations), and NEMA 12 enclosures. The enclosure rating is selected based on the installation environment and any applicable area classification."
  },
  {
    question: "Does Dolphin Centrifuge provide remote monitoring for centrifuge systems?",
    answer: "Yes. Dolphin control panels can be equipped with Ethernet or cellular modem connectivity for remote monitoring and diagnostics. Operators can view live process data, alarm history, and trending graphs from any web browser. Remote access also allows Dolphin engineers to provide troubleshooting support without an on-site visit."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Industrial Centrifuge Control Panels",
  "description": "Custom PLC/HMI centrifuge control panels built on AutomationDirect CLICK PLUS PLCs and Maple Systems HMIs. Auto-start sequencing, discharge timing, vibration monitoring, data logging, and SCADA integration. Allen-Bradley and Siemens platforms available on request.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  "category": "Industrial Centrifuge Controls",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Industrial Centrifuge Controls — PLC & HMI",
  "description": "Custom PLC and HMI centrifuge control panels by Dolphin Centrifuge. Auto-start sequencing, vibration monitoring, data logging, and SCADA integration for any centrifuge brand.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu",
    "honorificSuffix": "M.S.M.E.",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" },
    "knowsAbout": [
      "Industrial centrifuges",
      "Disc stack centrifuges",
      "Decanter centrifuges",
      "Alfa Laval centrifuge systems",
      "Centrifuge repair and remanufacturing",
      "Waste oil separation",
      "Coolant recycling",
      "Industrial fluid separation"
    ],
    "hasCredential": {
      "@type": "EducationalOccupationalCredential",
      "name": "Master of Science in Mechanical Engineering",
      "credentialCategory": "Master's degree",
      "recognizedBy": {
        "@type": "CollegeOrUniversity",
        "name": "University of Arkansas",
        "location": "Fayetteville, AR, US"
      },
      "description": "Master of Science in Mechanical Engineering, University of Arkansas, Fayetteville, Class of 1990"
    }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/industrial-centrifuge-controls/",
  "mainEntityOfPage": "https://dolphincentrifuge.com/industrial-centrifuge-controls/"
};

const jsonLd = [productJsonLd, faqJsonLd, articleJsonLd];

const toc = [
  { id: 'modern-controls', label: 'Modern Controls' },
  { id: 'features', label: 'Centrifuge Controls Benefits' },
  { id: 'plc-platforms', label: 'PLC & HMI Platforms' },
  { id: 'decanter-controls', label: 'Decanter Controls' },
  { id: 'explosion-proof', label: 'Explosion-Proof Controls' },
  { id: 'retrofit', label: 'Retrofit Controls' },
  { id: 'turnkey', label: 'Turnkey System Integration' },
  { id: 'specifications', label: 'Panel Specifications' },
  { id: 'faq', label: 'FAQ' },
];

const relatedApplications = [
  { label: 'Disc Stack Centrifuge', href: '/disc-stack-centrifuge/' },
  { label: 'Decanter Centrifuge', href: '/decanter-centrifuge/' },
  { label: 'Explosion Proof Centrifuge', href: '/explosion-proof-centrifuge/' },
  { label: 'Application Directory', href: '/disc-stack-centrifuge-applications/' },
];

const relatedProducts = [
  { label: 'Centrifuge Parts & Spares', href: '/alfa-laval-centrifuge-parts/', description: 'OEM and aftermarket parts' },
  { label: 'System Design & Engineering', href: '/industrial-centrifuge-design/', description: 'Custom turnkey systems' },
];
---

<ApplicationLayout
  title="Industrial Centrifuge Controls | Fully Automatic Operation | Dolphin Centrifuge"
  description="Custom PLC and HMI centrifuge control panels by Dolphin Centrifuge. AutomationDirect CLICK PLUS PLCs and Maple Systems HMIs with auto-start sequencing, vibration monitoring, data logging, and SCADA integration."
  category="products"
  categoryLabel="Controls & Automation"
  heroImage="/images/industrial-centrifuge-controls/dolphin_centrifuge_industrial_centrifuge_controls_hero.png"
  heroImageAlt="Dolphin Centrifuge industrial centrifuge control panel with PLC and HMI touchscreen"
  canonicalUrl="https://dolphincentrifuge.com/industrial-centrifuge-controls/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
  hideBottomCTA={true}
>

  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge has developed its line of Industrial Centrifuge Control Systems. We design, program, and test custom PLC/HMI control panels for disc stack and decanter centrifuge systems rated up to 480V 3-phase. Packages range from basic start/stop panels to fully automated systems with VFD starters, vibration protection, data logging, and SCADA integration. Over 40 years of centrifuge automation experience from Warren, Michigan.</p>
  </div>

  <h2 id="modern-controls">Modern Controls for Industrial Centrifuges</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start not-prose mb-6">
    <div class="md:w-1/2">
      <p class="text-text-light mb-4">
        A centrifuge is only as reliable as the controls that run it. Many older centrifuge installations rely on outdated relay-based panels, obsolete PLCs, or manual start/stop procedures that leave performance on the table and expose operators to unnecessary risk. Dolphin Centrifuge replaces these legacy systems with modern, fully programmable control panels that automate the entire centrifuge operation from startup through shutdown.
      </p>
      <p class="text-text-light">
        Every Dolphin control panel is designed, wired, programmed, and tested in our Warren, Michigan facility by engineers with 40+ years of centrifuge automation experience. We build panels for our own turnkey centrifuge systems and also supply retrofit control upgrades for existing installations running any brand of industrial centrifuge. These controls are specific for Alfa Laval Disc Stack and Decanter Centrifuges.
      </p>
      <p class="text-text-light mt-4">
        Our control panels incorporate the latest technologies available. Ease of use and built-in troubleshooting features are highlights of our control systems. They can be customized to provide unique functionalities and application-specific features including process data storage, DCS interface, and remote operator functionality.
      </p>
    </div>
    <div class="md:w-1/2 flex justify-center">
      <figure class="inline-block" style="max-width: 500px;">
        <img
          src="/images/industrial-centrifuge-controls/dolphin_centrifuge_NEMA_4X_C1D2_control_panel_500.webp"
          alt="Dolphin Centrifuge NEMA 4X Class 1 Div 2 industrial centrifuge control panel"
          width="500"
          height="775"
          loading="lazy"
          class="rounded-lg shadow-md w-full h-auto"
        />
        <figcaption class="text-sm text-text-muted text-center mt-2">Class 1 Div 2 Centrifuge Controls</figcaption>
      </figure>
    </div>
  </div>

  <h2 id="features">Centrifuge Controls Benefits</h2>

  <p>Dolphin's centrifuge control systems use a PLC for process control &amp; HMI (Touchscreen) as a user interface. Key benefits include a detailed graphical display with live on-screen parameter monitoring, fully automatic operation with elaborate manual controls, and primary alarm functions pre-configured. All panels accept inputs for Pressure, Flow, Temperature, and Vibration sensors.</p>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-6 not-prose">
    <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
      <h3 class="text-lg font-bold text-navy mb-2">Auto Start / Stop</h3>
      <p class="text-sm text-text-light">One-button startup sequencing: motor start, bowl acceleration, operating water, feed valve, and discharge timing &mdash; all automated with proper interlocks and delays.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
      <h3 class="text-lg font-bold text-navy mb-2">Discharge Timing</h3>
      <p class="text-sm text-text-light">Programmable solids discharge intervals and durations for self-cleaning centrifuges. Adjustable from the HMI to optimize for varying feed conditions without rewiring.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
      <h3 class="text-lg font-bold text-navy mb-2">Temperature Monitoring</h3>
      <p class="text-sm text-text-light">RTD sensors on feed, discharge, and bearing locations with high-temperature alarms and auto-shutdown protection. Critical for heated oil applications.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
      <h3 class="text-lg font-bold text-navy mb-2">Vibration Monitoring</h3>
      <p class="text-sm text-text-light">Accelerometer-based vibration sensing on the centrifuge frame with alarm and trip setpoints. Detects imbalance, bearing wear, or bowl issues before damage occurs.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
      <h3 class="text-lg font-bold text-navy mb-2">Touch Screen HMI</h3>
      <p class="text-sm text-text-light">Color touch screen operator interface displaying live process data, alarm history, trending graphs, and system status. Intuitive navigation for operators of all skill levels.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
      <h3 class="text-lg font-bold text-navy mb-2">Data Logging</h3>
      <p class="text-sm text-text-light">Continuous recording of temperatures, vibration levels, motor amps, discharge events, and alarm history. Data can be exported via USB or accessed remotely.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
      <h3 class="text-lg font-bold text-navy mb-2">Advanced Troubleshooting Guides</h3>
      <p class="text-sm text-text-light">Advanced Trouble Shooting Guides with System Fault Data Logging and Alarm Functions with Alarm History Log. Administrator Setting with Password Protection for secure access.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
      <h3 class="text-lg font-bold text-navy mb-2">PID Loop Control</h3>
      <p class="text-sm text-text-light">PID Loop Control for VFD Feed Pumps &amp; Level Sensors. Built with hi-quality, off-the-shelf components for quick field serviceability and easy spare parts sourcing.</p>
    </div>
  </div>

  <div class="bg-navy/10 border border-navy/20 rounded-xl p-6 mb-8 not-prose text-center">
    <p class="text-lg font-semibold text-navy mb-2">Need a Custom Control Panel for Your Centrifuge?</p>
    <p class="text-sm text-text-light mb-4">Dolphin Centrifuge builds PLC/HMI panels for new installations and retrofit upgrades. Tell us about your application and we will design the right control solution.</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold hover:bg-gold/90 text-white font-bold py-2 px-6 rounded-lg transition-colors">Get a Quote</a>
      <a href="tel:+12485222573" class="inline-block border-2 border-navy text-navy font-bold py-2 px-6 rounded-lg hover:bg-navy hover:text-white transition-colors">(248) 522-2573</a>
    </div>
  </div>

  <h2 id="plc-platforms">PLC &amp; HMI Platforms</h2>
  <p>
    Dolphin Centrifuge builds control panels on industry-standard PLC and HMI platforms. Our standard platform uses AutomationDirect CLICK/CLICK PLUS PLCs paired with Maple Systems HMI touchscreens. For plants that require Allen-Bradley or Siemens hardware, we also build panels on those platforms to match existing plant standards:
  </p>

  <div class="flex justify-center not-prose mb-6">
    <figure class="inline-block" style="max-width: 600px;">
      <img
        src="/images/industrial-centrifuge-controls/dolphin_centrifuge_HMI_screen_600.webp"
        alt="Dolphin Centrifuge HMI touchscreen displaying live centrifuge process data"
        width="600"
        height="450"
        loading="lazy"
        class="rounded-lg shadow-md w-full h-auto"
      />
      <figcaption class="text-sm text-text-muted text-center mt-2">Industrial Centrifuge Control Screen</figcaption>
    </figure>
  </div>

  <div class="grid md:grid-cols-2 gap-4 not-prose mb-6">
    <div class="bg-white rounded-xl p-6 border-2 border-gold">
      <h3 class="text-lg font-bold text-navy mb-1">AutomationDirect CLICK / CLICK PLUS PLCs</h3>
      <p class="text-xs font-semibold text-gold mb-3">Dolphin Standard PLC Platform</p>
      <p class="text-sm text-text-light mb-3">
        Compact, expandable control with stackable I/O modules. The CLICK PLUS platform provides built-in data logging, PID control, and broad protocol support ideal for centrifuge automation.
      </p>
      <ul class="text-sm space-y-1 text-text-muted">
        <li>&#8226; Ethernet/serial communication</li>
        <li>&#8226; Modbus, EtherNet/IP, MQTT protocols</li>
        <li>&#8226; Built-in data logging</li>
        <li>&#8226; Stackable I/O for flexible configuration</li>
      </ul>
    </div>
    <div class="bg-white rounded-xl p-6 border-2 border-gold">
      <h3 class="text-lg font-bold text-navy mb-1">Maple Systems HMIs</h3>
      <p class="text-xs font-semibold text-gold mb-3">Dolphin Standard Operator Interface</p>
      <p class="text-sm text-text-light mb-3">
        Industrial touchscreen HMIs with alarm/event screens, data logging, and remote access capability. Broad PLC protocol support connects to virtually any controller platform.
      </p>
      <ul class="text-sm space-y-1 text-text-muted">
        <li>&#8226; Touchscreen operation with intuitive navigation</li>
        <li>&#8226; Alarm and event history screens</li>
        <li>&#8226; Built-in data logging and trending</li>
        <li>&#8226; Remote access for off-site monitoring</li>
        <li>&#8226; Free EBPro configuration software</li>
      </ul>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2">Allen-Bradley / Rockwell</h3>
      <p class="text-sm text-text-light mb-3">
        Available when a customer plant standard requires Rockwell hardware. Dolphin panels use CompactLogix or MicroLogix controllers with PanelView Plus HMIs.
      </p>
      <ul class="text-sm space-y-1 text-text-muted">
        <li>&#8226; CompactLogix L1/L2/L3 controllers</li>
        <li>&#8226; PanelView Plus 7&Prime; or 10&Prime; HMI</li>
        <li>&#8226; EtherNet/IP connectivity</li>
        <li>&#8226; Standard in oil &amp; gas, refining, chemical</li>
      </ul>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2">Siemens</h3>
      <p class="text-sm text-text-light mb-3">
        Available when a customer plant standard requires Siemens hardware. Dolphin panels use S7-1200 or S7-1500 controllers with Comfort Panel HMIs.
      </p>
      <ul class="text-sm space-y-1 text-text-muted">
        <li>&#8226; S7-1200 / S7-1500 controllers</li>
        <li>&#8226; KTP700 or TP900 Comfort HMI</li>
        <li>&#8226; PROFINET connectivity</li>
        <li>&#8226; Common in food, pharma, water treatment</li>
      </ul>
    </div>
  </div>

  <h2 id="decanter-controls">Decanter Centrifuge Controls</h2>
  <p>
    Dolphin Centrifuge builds dedicated control panels for decanter centrifuge systems with features specific to decanter operation. Decanter control panels offer:
  </p>
  <ul>
    <li>VFD Starters for Main and Back-drive Motors</li>
    <li>Motor Sequence Logic with Automatic Shut-down Sequence</li>
    <li>Braking Resistors for Quick Ramp-down</li>
    <li>Vibration Sensors with Feed Pump Interlock</li>
    <li>Bowl Speed Control</li>
    <li>Conveyor Torque Monitoring</li>
    <li>Bearing Temperature Monitoring and High-Temperature Alarm</li>
  </ul>

  <h2 id="explosion-proof">Explosion-Proof Centrifuge Controls</h2>
  <p>
    Dolphin Centrifuge has designed and assembled Explosion Proof Centrifuge Control System packages for all types of centrifuge applications. We build NEC Class 1 Div 1 and Class 1 Div 2 control systems to meet the most demanding hazardous-area requirements. Read more about our <a href="/explosion-proof-centrifuge/">explosion-proof centrifuges</a>.
  </p>
  <ul>
    <li>NEMA4X or NEMA7 enclosures</li>
    <li>UL or IEC / ATEX classifications</li>
    <li>Zone 1 &amp; 2 categories</li>
    <li>Field instrumentation compatibility</li>
    <li>Nitrogen-purged enclosures</li>
    <li>DCS control options</li>
  </ul>

  <h2 id="retrofit">New Controls for Your Old Centrifuge</h2>
  <p>
    Do you have old industrial centrifuges with outdated controls? We can retrofit our state-of-the-art centrifuge controls on your existing centrifuge systems. The customer can expect improved efficiency and lesser downtime with many extra functions. <a href="/contact-for-alfa-laval-centrifuges/">Contact Dolphin</a> today to discuss the possibilities.
  </p>
  <p>
    Dolphin Centrifuge can design and supply a drop-in replacement control panel. Retrofit panels are built to match the existing field wiring, motor specifications, and sensor inputs, minimizing installation time and cost. Benefits of a retrofit upgrade include:
  </p>
  <ul>
    <li>Automated operation replacing manual start/stop procedures</li>
    <li>Modern vibration and temperature protection preventing costly failures</li>
    <li>Touch screen HMI replacing push-button panels and analog gauges</li>
    <li>Data logging for process optimization and regulatory compliance</li>
    <li>Remote monitoring capability via Ethernet or cellular modem</li>
    <li>Reduced operator labor and training requirements</li>
  </ul>
  <p>
    Not sure which centrifuge model you need before specifying controls? Our <a href="/alfa-laval-centrifuge-selection-guide/">centrifuge selection guide</a> walks through capacity, separation requirements, and application matching. For process validation, Dolphin also offers <a href="/industrial-centrifuge-sample-testing/">sample testing</a> to verify separation performance before you commit to a full system.
  </p>

  <h2 id="turnkey">Turnkey System Integration</h2>
  <p>
    For new centrifuge installations, Dolphin Centrifuge designs the control panel as an integral part of the complete system. The panel manages not just the centrifuge but also the feed pump, heater, valves, and any auxiliary equipment on the skid. All systems are fully wired, programmed, and factory-tested before shipment so installation is limited to connecting utilities and process piping. For EPC centrifuge packages that require controls documentation, I/O lists, hazardous-area basis, FAT records, GA drawings, and P&amp;IDs, see our <a href="/epc-industrial-centrifuge-systems/">EPC industrial centrifuge systems</a> page.
  </p>
  <p>
    Turnkey control panels are available in NEMA 4, NEMA 4X (stainless), NEMA 7/9 (<a href="/explosion-proof-centrifuge/">explosion proof</a>), and NEMA 12 enclosure ratings to suit any installation environment.
  </p>

  <h2 id="specifications">Panel Specifications</h2>
  <table>
    <thead>
      <tr>
        <th>Specification</th>
        <th>Standard</th>
        <th>Optional</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Power Supply</td>
        <td>480V 3-phase, 60Hz</td>
        <td>208V, 380V, 575V, 50Hz</td>
      </tr>
      <tr>
        <td>Enclosure</td>
        <td>NEMA 4 painted steel</td>
        <td>NEMA 4X SS, NEMA 7/9 XP</td>
      </tr>
      <tr>
        <td>Motor Starter</td>
        <td>Across-the-line or soft starter</td>
        <td>VFD (variable frequency drive)</td>
      </tr>
      <tr>
        <td>PLC</td>
        <td>AutomationDirect CLICK PLUS</td>
        <td>Allen-Bradley, Siemens</td>
      </tr>
      <tr>
        <td>HMI</td>
        <td>Maple Systems touchscreen</td>
        <td>PanelView Plus, Siemens Comfort</td>
      </tr>
      <tr>
        <td>Communication</td>
        <td>Ethernet (local HMI)</td>
        <td>Modbus, EtherNet/IP, MQTT, cellular</td>
      </tr>
      <tr>
        <td>I/O Expansion</td>
        <td>Spare I/O for future sensors</td>
        <td>Remote I/O racks, SCADA integration</td>
      </tr>
    </tbody>
  </table>

  <FAQ items={faqItems} />

  <h2>Related Products &amp; Services</h2>
  <ul>
    <li><a href="/disc-stack-centrifuge/">Disc Stack Centrifuge Systems</a></li>
    <li><a href="/decanter-centrifuge/">Decanter Centrifuge Systems</a></li>
    <li><a href="/explosion-proof-centrifuge/">Explosion Proof Centrifuge Systems</a></li>
    <li><a href="/alfa-laval-centrifuge-parts/">Centrifuge Parts &amp; Spares</a></li>
    <li><a href="/industrial-centrifuge-design/">System Design &amp; Engineering</a></li>
    <li><a href="/industrial-centrifuge-sample-testing/">Sample Testing</a></li>
    <li><a href="/alfa-laval-centrifuge-selection-guide/">Centrifuge Selection Guide</a></li>
    <li><a href="/disc-stack-centrifuge-applications/">Application Directory</a></li>
  </ul>

</ApplicationLayout>
