  <!-- ── Features & Sizing ── -->
  <h2 id="features-and-sizing">Features and Sizing</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-[45%] shrink-0">
      <img
        src="/images/industrial-washer-fluid-centrifuge/Alfa-Laval-WSPX207-Stainless-Steel-Centrifuge-1.webp"
