              width="450" height="450"
              loading="lazy"
              class="rounded-lg w-full"
            />
            <p class="text-xs text-gray-500 mt-1 text-center">Alfa Laval MAB 206S Oil Separator</p>
          </div>
          <div>
            <img
              src="/images/alfa-laval-mab-centrifuge/Alfa-Laval-MAB-206-Disc-Stack-Centrifuge-Explosion-Proof-Class-1-Div-2.jpg"
