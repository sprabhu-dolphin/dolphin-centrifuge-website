---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval MAB Series Centrifuge",
  "description": "Alfa Laval MAB series solid-retaining disc-stack centrifuges for three-phase separation of diesel, biodiesel, turbine lube oil, and hydraulic oil. Models MAB 204, 205, 206, 207, 209.",
  "brand": {
    "@type": "Brand",
    "name": "Alfa Laval"
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "telephone": "(248) 522-2573",
    "email": "sales@dolphincentrifuge.com"
  },
  "offers": {
    "@type": "Offer",
    "seller": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    },
    "availability": "https://schema.org/InStock"
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the difference between the Alfa Laval MAB and MOPX centrifuge series?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Alfa Laval MAB series are solid-retaining (manual-clean) disc-stack centrifuges, meaning accumulated solids must be manually removed by stopping the centrifuge. The MOPX series are self-cleaning centrifuges that automatically eject separated solids during operation without stopping. MAB centrifuges are simpler and more economical for applications with lower solids loading."
      }
    },
    {
      "@type": "Question",
      "name": "What fluids can an Alfa Laval MAB centrifuge process?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Alfa Laval MAB centrifuges are designed for three-phase separation of mineral oils and fuels including diesel fuel, biodiesel, turbine lube oil, hydraulic oil, and engine oil. They purify these fluids by removing water and solid contaminants simultaneously. The solids level has to be zero or close to zero for these manual clean centrifuges to be effective."
      }
    },
    {
      "@type": "Question",
      "name": "How often does an Alfa Laval MAB centrifuge need to be cleaned?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cleaning frequency depends on the solids loading of the process fluid. For relatively clean fluids like turbine lube oil, cleaning intervals may be several days. For dirtier fluids with higher particulate content, the bowl may need manual cleaning every few hours. The sludge space capacity of each model (ranging from 0.40 gallons on the MAB 204 to 2.00 gallons on the MAB 209) also affects cleaning intervals."
      }
    },
    {
      "@type": "Question",
      "name": "Does Dolphin Centrifuge supply Alfa Laval MAB centrifuge parts?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Dolphin Centrifuge stocks and supplies Alfa Laval MAB centrifuge parts including bowl discs, gaskets, bearings, seals, gravity discs, and paring tubes for all MAB models (MAB 103, 104, 204, 205, 206, 207, 209). Contact Dolphin Centrifuge at (248) 522-2573 or visit /alfa-laval-centrifuge-parts/ for parts availability."
      }
    }
  ]
};

const jsonLd = [productJsonLd, faqJsonLd];

const toc = [
  { id: "overview", label: "Overview" },
  { id: "applications", label: "Applications" },
  { id: "operation", label: "Operation" },
  { id: "mab-204", label: "Alfa Laval MAB 204 Centrifuge" },
  { id: "mab-205", label: "Alfa Laval MAB 205 Centrifuge" },
  { id: "mab-206", label: "Alfa Laval MAB 206 Centrifuge" },
  { id: "mab-207", label: "Alfa Laval MAB 207 Centrifuge" },
  { id: "mab-209", label: "Alfa Laval MAB 209 Centrifuge" },
  { id: "faq", label: "Frequently Asked Questions" },
];
