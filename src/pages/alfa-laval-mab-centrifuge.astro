---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval MAB Series Centrifuge",
  "description": "Alfa Laval MAB series solid-retaining disc-stack centrifuges for continuous three-phase separation of diesel, biodiesel, turbine lube oil, and hydraulic oil. Models MAB 204, 205, 206, 207, 209.",
  "brand": {
    "@type": "Brand",
    "name": "Alfa Laval"
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "telephone": "(248) 522-2573",
    "email": "sales@dolphincentrifuge.com"
  },
  "offers": {
    "@type": "Offer",
    "seller": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    },
    "availability": "https://schema.org/InStock"
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the difference between the Alfa Laval MAB and MOPX centrifuge series?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Alfa Laval MAB series are solid-retaining (manual-clean) disc-stack centrifuges, meaning accumulated solids must be manually removed by stopping the centrifuge. The MOPX series are self-cleaning centrifuges that automatically eject separated solids during operation without stopping. MAB centrifuges are simpler and more economical for applications with lower solids loading."
      }
    },
    {
      "@type": "Question",
      "name": "What fluids can an Alfa Laval MAB centrifuge process?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Alfa Laval MAB centrifuges are designed for three-phase separation of mineral oils and fuels including diesel fuel, biodiesel, turbine lube oil, hydraulic oil, and engine oil. They purify these fluids by removing water and solid contaminants."
      }
    },
    {
      "@type": "Question",
      "name": "How often does an Alfa Laval MAB centrifuge need to be cleaned?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cleaning frequency depends on the solids loading of the process fluid. For relatively clean fluids like turbine lube oil, cleaning intervals may be several days. For dirtier fluids with higher particulate content, the bowl may need manual cleaning every few hours. The sludge space capacity of each model (ranging from 0.40 gallons on the MAB 204 to 2.00 gallons on the MAB 209) also affects cleaning intervals."
      }
    }
  ]
};
---

<BaseLayout
  title="Alfa Laval MAB Centrifuges for Diesel, Lube & Hydraulic Oil"
  description="Alfa Laval MAB series disc-stack centrifuges. Solid-bowl, three-phase separation of diesel, lube oil, and hydraulic oil. Models MAB 204–209. Specs and capacities."
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-mab-centrifuge/"
  breadcrumbs={[{label: 'Products', href: '/centrifuges/'}, {label: 'Alfa Laval MAB Centrifuge'}]}
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <section class="bg-[#1B3A5C] text-white py-14 md:py-20">
    <div class="container-dolphin max-w-5xl">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <div class="text-[#E8A317] text-sm font-semibold uppercase tracking-wider mb-3">Product Guide</div>
          <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-5">
            Alfa Laval MAB Centrifuges for Diesel, Lube &amp; Hydraulic Oil
          </h1>
          <p class="text-lg text-gray-200 mb-6">
            The Alfa Laval MAB Series — solid-retaining (manual-clean) disc-stack centrifuges for continuous three-phase separation of diesel fuel, turbine lube oil, biodiesel, and hydraulic oil. Available in five models from 15 GPM to 78 GPM capacity on diesel fuel.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] hover:bg-yellow-500 text-white font-semibold px-6 py-3 rounded-lg transition">Request Quote</a>
            <a href="tel:+12485222573" class="border border-white text-white hover:bg-white hover:text-[#1B3A5C] font-semibold px-6 py-3 rounded-lg transition">(248) 522-2573</a>
          </div>
        </div>
        <div>
          <img
            src="/images/alfa-laval-mab-centrifuge/Alfa-Laval-MAB-206-Diesel-Centrifuge-Package.jpg"
            alt="Alfa Laval MAB-206 Diesel Centrifuge Package"
            width="450" height="450"
            loading="eager"
            class="rounded-xl w-full shadow-lg"
          />
          <p class="text-sm text-gray-300 mt-2 text-center">Alfa Laval MAB 206S Oil Separator Package</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="bg-[#F5F5F0] py-12 md:py-16">
    <div class="container-dolphin max-w-4xl">

      <!-- Table of Contents -->
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-lg font-bold text-[#1B3A5C] mb-4">Table of Contents</h2>
        <nav>
          <ul class="space-y-1 text-sm">
            <li><a href="#overview" class="text-[#1B3A5C] hover:text-[#E8A317]">Overview</a></li>
            <li><a href="#applications" class="text-[#1B3A5C] hover:text-[#E8A317]">Applications</a></li>
            <li><a href="#operation" class="text-[#1B3A5C] hover:text-[#E8A317]">Operation</a></li>
            <li><a href="#mab-204" class="text-[#1B3A5C] hover:text-[#E8A317]">Alfa Laval MAB 204 Centrifuge</a></li>
            <li><a href="#mab-205" class="text-[#1B3A5C] hover:text-[#E8A317]">Alfa Laval MAB 205 Centrifuge</a></li>
            <li><a href="#mab-206" class="text-[#1B3A5C] hover:text-[#E8A317]">Alfa Laval MAB 206 Centrifuge</a></li>
            <li><a href="#mab-207" class="text-[#1B3A5C] hover:text-[#E8A317]">Alfa Laval MAB 207 Centrifuge</a></li>
            <li><a href="#mab-209" class="text-[#1B3A5C] hover:text-[#E8A317]">Alfa Laval MAB 209 Centrifuge</a></li>
            <li><a href="#comparison" class="text-[#1B3A5C] hover:text-[#E8A317]">MAB Series Model Comparison</a></li>
            <li><a href="#faq" class="text-[#1B3A5C] hover:text-[#E8A317]">Frequently Asked Questions</a></li>
          </ul>
        </nav>
      </div>

      <!-- Overview -->
      <div id="overview" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Overview</h2>
        <p class="text-[#2D2D2D] mb-4">
          Alfa Laval MAB series centrifuges are <a href="/disc-stack-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317]">disc-stack-type centrifuges</a> with a solid bowl. A solid-bowl centrifuge implies that the separated solids must be manually removed periodically.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          These are very simple centrifuges, with the main disadvantage of MAB-type centrifuges being the manual cleaning operation that requires the centrifuge to be stopped.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          The Alfa Laval MAB Series Centrifuges are solid-retaining (also known as solid bowl or manual-clean) disc centrifuges ideal for the continuous, three-phase separation of fuels, such as <a href="/diesel-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317]">diesel</a>, <a href="/biodiesel-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317]">biodiesel</a>, <a href="/lube-oil-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317]">turbine lube oil</a>, and hydraulic oil.
        </p>
        <p class="text-[#2D2D2D]">
          The MAB series is available in five models — MAB 204, MAB 205, MAB 206, MAB 207, and MAB 209 — with capacities ranging from 15 GPM to 78 GPM on diesel fuel. Motor sizes range from 4 HP on the smallest MAB 204 to 15 HP on the largest MAB 209. Each model operates on standard 230 or 460 volt power supply.
        </p>
      </div>

      <!-- Applications -->
      <div id="applications" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Applications</h2>
        <p class="text-[#2D2D2D] mb-4">
          The Alfa Laval MAB centrifuge is a purifier version of a disc-stack centrifuge. It is specifically designed to purify water from mineral oils and fuels such as diesel fuel, turbine lube oil, hydraulic oil, engine oil, etc.
        </p>
        <p class="text-[#2D2D2D]">
          Because of their three-phase separation capability, MAB centrifuges simultaneously remove both water and solid contaminants from the process fluid in a single pass. This makes them well-suited for applications where both water contamination and particulate removal are critical, including power generation facilities, marine vessels, industrial manufacturing plants, and fuel storage terminals.
        </p>
      </div>

      <!-- Operation -->
      <div id="operation" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Operation</h2>
        <div class="grid md:grid-cols-2 gap-6 items-start">
          <div>
            <p class="text-[#2D2D2D] mb-4">
              The process fluid is fed to the rotating centrifuge bowl from the top <strong>(1)</strong> and is sped up in the distributor <strong>(2)</strong>. It then enters the disc stack <strong>(3)</strong>, and it is between the discs that the separation occurs.
            </p>
            <p class="text-[#2D2D2D] mb-4">
              The high centrifugal force pushes the water and heavy solids to the bowl wall. The solids accumulate here, and the water fluid travels over the top disc <strong>(4)</strong> and exits the bowl through the open outlet <strong>(5)</strong>. The oil (light phase) is moved towards the bowl center and exits the bowl through the open outlet <strong>(6)</strong>.
            </p>
            <p class="text-[#2D2D2D]">
              The centrifuge needs to be periodically stopped for manual removal of separated solids. The rotating bowl assembly is mounted on a vertical bowl-spindle <strong>(7)</strong>. A horizontally mounted motor rotates the spindle via a worm gear.
            </p>
          </div>
          <div>
            <img
              src="/images/alfa-laval-mab-centrifuge/Alfa-Laval-WSB-203-Centrifuge-Bowl-251x300-1.jpg"
              alt="Alfa Laval WSB-203 Centrifuge Bowl Cross Section showing disc stack, distributor, and outlet configuration"
              width="251" height="300"
              loading="lazy"
              class="rounded-lg mx-auto w-full max-w-xs"
            />
            <p class="text-sm text-gray-500 mt-2 text-center">Alfa Laval Centrifuge Bowl Cross Section</p>
          </div>
        </div>
      </div>

      <!-- MAB 204 -->
      <div id="mab-204" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Alfa Laval MAB 204 Centrifuge</h2>
        <p class="text-[#2D2D2D] mb-4">
          The MAB 204 is the smallest model in the Alfa Laval MAB series, rated at 15 GPM on diesel fuel and equipped with a 4 HP motor. With a sludge space of 0.40 gallons, this compact centrifuge is well suited for lower-volume purification applications.
        </p>
        <h3 class="text-lg font-semibold text-[#2D2D2D] mb-3">Specifications</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <tbody>
              <tr class="border-b border-gray-200">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C] w-1/2">Model Type</td>
                <td class="py-3 font-mono">Alfa Laval MAB 204S-24-60</td>
              </tr>
              <tr class="border-b border-gray-200 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Rated Capacity</td>
                <td class="py-3 font-mono">15 GPM on Diesel Fuel<br/>13 GPM on Turbine Lube Oil<br/>8 GPM on Hydraulic Oil</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Sludge Space</td>
                <td class="py-3 font-mono">0.40 Gallons</td>
              </tr>
              <tr class="border-b border-gray-200 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Motor HP</td>
                <td class="py-3 font-mono">4 HP</td>
              </tr>
              <tr>
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Voltages</td>
                <td class="py-3 font-mono">230 / 460 V</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- MAB 205 -->
      <div id="mab-205" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Alfa Laval MAB 205 Centrifuge</h2>
        <p class="text-[#2D2D2D] mb-4">
          The MAB 205 offers increased capacity over the MAB 204, rated at 25 GPM on diesel fuel with a 5 HP motor. Its 0.48 gallon sludge space provides additional solids holding capacity for medium-volume oil purification applications.
        </p>
        <h3 class="text-lg font-semibold text-[#2D2D2D] mb-3">Specifications</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <tbody>
              <tr class="border-b border-gray-200">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C] w-1/2">Model Type</td>
                <td class="py-3 font-mono">Alfa Laval MAB 205S-24-60</td>
              </tr>
              <tr class="border-b border-gray-200 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Rated Capacity</td>
                <td class="py-3 font-mono">25 GPM on Diesel Fuel<br/>20 GPM on Turbine Lube Oil<br/>13 GPM on Hydraulic Oil</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Sludge Space</td>
                <td class="py-3 font-mono">0.48 Gallons</td>
              </tr>
              <tr class="border-b border-gray-200 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Motor HP</td>
                <td class="py-3 font-mono">5 HP</td>
              </tr>
              <tr>
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Voltages</td>
                <td class="py-3 font-mono">230 / 460 V</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- MAB 206 -->
      <div id="mab-206" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Alfa Laval MAB 206 Centrifuge</h2>
        <p class="text-[#2D2D2D] mb-4">
          The MAB 206 is one of the most popular models in the Alfa Laval MAB series, rated at 36 GPM on diesel fuel with a 7.5 HP motor. This model is frequently configured as an explosion-proof unit for Class 1, Division 2 hazardous area installations, making it ideal for fuel polishing and diesel purification in refineries, fuel terminals, and other classified environments.
        </p>

        <div class="grid md:grid-cols-3 gap-4 mb-6">
          <div>
            <img
              src="/images/alfa-laval-mab-centrifuge/Alfa-Laval-MAB-206-Diesel-Centrifuge-Package.jpg"
