            />
            <p class="text-xs text-gray-500 mt-1 text-center">Alfa Laval MAB-206 Diesel Centrifuge Skid</p>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-4 mb-6">
          <div>
            <img
              src="/images/alfa-laval-mab-centrifuge/Alfa-Laval-MAB-206-Disc-Centrifuge-for-Diesel-Fuel-Polishing-Class-1-Div-2.jpg"
