---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Disc Stack Centrifuge Performance - 8 External Factors",
  "description": "Understand the 8 external factors affecting disc stack centrifuge performance: ambient temperature, tank setup, pump selection, discharge piping, and more.",
  "author": { "@type": "Person", "name": "Sanjay Prabhu", "jobTitle": "Engineering Manager", "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" } },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "datePublished": "2021-03-01",
  "url": "https://dolphincentrifuge.com/disc-stack-centrifuge-performance/",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What external factors affect disc stack centrifuge performance?",
      "acceptedAnswer": { "@type": "Answer", "text": "The 8 main external factors affecting disc centrifuge performance are: (1) feed temperature — lower temperatures increase viscosity and reduce separation efficiency, (2) feed tank agitation — settled feed has variable sludge content that disrupts stable operation, (3) feed pump selection — incorrect pump type causes pulsation or cavitation, (4) pre-filtration — oversized particles bypass the disc stack and contaminate the centrate, (5) discharge piping back-pressure, (6) sludge ejection cycle timing, (7) operating water quality and pressure, (8) ambient temperature affecting gearbox oil viscosity and feed fluid properties." }
    },
    {
      "@type": "Question",
      "name": "How does feed temperature affect centrifuge separation performance?",
      "acceptedAnswer": { "@type": "Answer", "text": "Feed temperature directly determines the viscosity of the liquid being separated. Lower viscosity (higher temperature) allows centrifugal force to move particles more rapidly through the liquid. For every 10°C reduction in temperature, viscosity typically increases 10–20%, reducing separation efficiency proportionally. Heavy oils must be heated to 180–200°F to achieve acceptable viscosity. Even water-based coolants benefit from operating above 70°F for optimal sub-micron particle removal." }
    },
    {
      "@type": "Question",
      "name": "Why does feed tank agitation matter for centrifuge performance?",
      "acceptedAnswer": { "@type": "Answer", "text": "Without agitation, sludge settles to the bottom of the feed tank and the centrifuge receives alternating feeds of clean liquid (from the top) and highly concentrated sludge (from the bottom). These concentration spikes overload the bowl's sludge space and cause premature bowl filling, liquid seal instability, and inconsistent centrate quality. A properly sized agitator keeps sludge uniformly suspended, ensuring a consistent, manageable sludge load throughout operation." }
    },
    {
      "@type": "Question",
      "name": "What back-pressure is acceptable on a disc centrifuge centrate outlet?",
      "acceptedAnswer": { "@type": "Answer", "text": "Acceptable centrate back-pressure for most disc centrifuge models is 0–15 PSIG on the light phase outlet and 0–10 PSIG on the heavy phase outlet. Excessive back-pressure compresses the liquid seal ring and can cause liquid seal break. Back-pressure is created by long or undersized centrate piping, elevation changes, flow control valves, and downstream equipment resistance. Always minimize discharge piping length and elevation changes." }
    }
  ]
};
