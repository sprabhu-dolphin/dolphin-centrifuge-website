    { id: "solid-bowl", label: "Alfa Laval Solid Bowl aka Manual Clean Centrifuges" },
    { id: "self-cleaning", label: "Alfa Laval Auto-Desludging aka Self Cleaning Centrifuges" },
    { id: "stainless-steel", label: "Alfa Laval Stainless Steel Contact Centrifuges" },
    { id: "decanter", label: "Alfa Laval Decanter aka Horizontal Bowl Centrifuges" },
