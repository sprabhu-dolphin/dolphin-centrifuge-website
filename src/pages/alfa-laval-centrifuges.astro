---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval Centrifuges",
  "description": "Alfa Laval centrifuge product gallery — disc stack separators and decanter centrifuges for industrial processing. Sold and serviced by Dolphin Centrifuge.",
  "brand": { "@type": "Brand", "name": "Alfa Laval" },
  "manufacturer": { "@type": "Organization", "name": "Alfa Laval" },
  "category": "Industrial Centrifuges",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};
---

<BaseLayout
  title="Alfa Laval Centrifuges"
  description="Alfa Laval centrifuge product gallery — disc stack separators and decanter centrifuges for industrial processing. Sold and serviced by Dolphin Centrifuge."
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-centrifuges/"
  breadcrumbs={[{label: 'Products', href: '/alfa-laval-centrifuges/'}, {label: 'Alfa Laval Centrifuges'}]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">Products</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">Alfa Laval Centrifuges</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">Dolphin Centrifuge stocks, rebuilds, sells, and services Alfa Laval centrifuges &mdash; the world&rsquo;s leading brand of industrial disc stack separators and decanter centrifuges. From compact fuel purifiers to large-scale food-grade separators and high-capacity decanters, we maintain active inventory of reconditioned machines with full parts support from our Warren, Michigan facility.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Contact Us</a>
        <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-5xl">

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">About Alfa Laval Centrifuges</h2>
      <p class="text-text-light mb-4">
        Alfa Laval is the global standard in industrial centrifuge technology, with a history spanning more than 130 years. Their centrifuge product line covers virtually every industrial separation application &mdash; from high-speed disc stack separators for oil, fuel, food, and pharmaceutical processing to robust decanter centrifuges for sludge dewatering, oilfield waste management, and high-solids slurry treatment.
      </p>
      <p class="text-text-light mb-4">
        Dolphin Centrifuge has built its business around Alfa Laval centrifuge technology. We maintain deep expertise in these machines &mdash; understanding their engineering, their operating requirements, their wear patterns, and their applications &mdash; accumulated over 40+ years of hands-on work. Our facility is equipped to fully disassemble, inspect, recondition, and test these centrifuges to restore them to like-new performance.
      </p>
      <p class="text-text-light mb-8">
        We supply reconditioned Alfa Laval centrifuges either as standalone machines or as complete turnkey skid systems with feed pump, heat exchanger, controls, and piping. Parts from our inventory support machines already in service at customer facilities.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-6">Centrifuge Categories We Stock</h2>

      <!-- Category 1: Self-Cleaning Oil Purifiers -->
      <div class="bg-white rounded-xl p-6 border border-gray-200 mb-6">
        <h3 class="text-xl font-bold text-navy mb-3">Self-Cleaning Disc Stack &mdash; Oil Purifiers</h3>
        <div class="grid md:grid-cols-3 gap-4 mb-4">
          <div>
            <p class="text-xs font-bold text-gold uppercase mb-1">Typical Flow Rates</p>
            <p class="text-sm text-text-light">8 &ndash; 65 GPM (diesel; fluid-dependent)</p>
          </div>
          <div>
            <p class="text-xs font-bold text-gold uppercase mb-1">Construction</p>
            <p class="text-sm text-text-light">Carbon steel bowl; cast iron/steel frame</p>
          </div>
          <div>
            <p class="text-xs font-bold text-gold uppercase mb-1">Solids Handling</p>
            <p class="text-sm text-text-light">Hydraulic self-ejection; continuous operation</p>
          </div>
        </div>
        <p class="text-sm text-text-light mb-4">
          The self-cleaning oil purifier series is the workhorse of industrial liquid-liquid-solid separation. These three-phase disc stack centrifuges remove water and solid contaminants from petroleum products in continuous, unattended operation. They are the standard solution for diesel fuel polishing, fuel oil purification, lube oil treatment, waste oil reclamation, biodiesel glycerin separation, and crude oil dewatering. Dolphin supplies these as our DMPX-branded systems &mdash; purpose-modified for the application with our own drive systems, controls, and skid integration.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/disc-stack-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Disc Stack Centrifuge Overview &rarr;</a>
        </div>
      </div>

      <!-- Category 2: Manual-Clean (MAB Series) -->
      <div class="bg-white rounded-xl p-6 border border-gray-200 mb-6">
        <h3 class="text-xl font-bold text-navy mb-3">Manual-Clean Disc Stack &mdash; Diesel &amp; Lube Oil</h3>
        <div class="grid md:grid-cols-3 gap-4 mb-4">
          <div>
            <p class="text-xs font-bold text-gold uppercase mb-1">Typical Flow Rates</p>
            <p class="text-sm text-text-light">4 &ndash; 62 GPM (diesel; fluid-dependent)</p>
          </div>
          <div>
            <p class="text-xs font-bold text-gold uppercase mb-1">Construction</p>
            <p class="text-sm text-text-light">Carbon steel bowl; cast iron/steel frame</p>
          </div>
          <div>
            <p class="text-xs font-bold text-gold uppercase mb-1">Solids Handling</p>
            <p class="text-sm text-text-light">Manual bowl cleaning; ideal for low-solids feeds</p>
          </div>
        </div>
        <p class="text-sm text-text-light mb-4">
          Manual-clean disc stack centrifuges are simpler in design and lower in cost than self-cleaning machines. They accumulate solids inside the bowl until the machine is shut down, opened, and cleaned by hand. This design is well-suited to applications where the feed has very low solids content &mdash; allowing the bowl to run for many hours before cleaning is required. Common applications include diesel fuel polishing, marine lube oil purification, and light fuel oil treatment. Dolphin supplies these as DMB-branded systems.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/disc-stack-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Disc Stack Centrifuge Overview &rarr;</a>
          <a href="/diesel-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Diesel Centrifuge &rarr;</a>
        </div>
      </div>

      <!-- Category 3: Stainless Steel Food/Pharma -->
      <div class="bg-white rounded-xl p-6 border border-gray-200 mb-6">
        <h3 class="text-xl font-bold text-navy mb-3">Stainless Steel Disc Stack &mdash; Food, Pharma &amp; Biotech</h3>
        <div class="grid md:grid-cols-3 gap-4 mb-4">
          <div>
            <p class="text-xs font-bold text-gold uppercase mb-1">Typical Flow Rates</p>
            <p class="text-sm text-text-light">100 &ndash; 5,000+ LPH (product-dependent)</p>
          </div>
          <div>
            <p class="text-xs font-bold text-gold uppercase mb-1">Construction</p>
            <p class="text-sm text-text-light">316L stainless steel wetted parts; hygienic design</p>
          </div>
          <div>
            <p class="text-xs font-bold text-gold uppercase mb-1">Compliance</p>
            <p class="text-sm text-text-light">CIP/SIP capable; FDA material compliant</p>
          </div>
        </div>
        <p class="text-sm text-text-light mb-4">
          The stainless steel food and pharmaceutical disc centrifuge series is engineered for hygienic processing. All product-contact surfaces are 316L stainless steel, polished to minimize bacterial retention, and designed for clean-in-place (CIP) and steam-in-place (SIP) procedures without disassembly. Applications span fish oil clarification, vegetable and olive oil processing, pharmaceutical API separation, biotech fermentation harvest, and botanical extract clarification. Both two-phase (clarifier) and three-phase (separator) configurations are available.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/stainless-steel-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Stainless Steel Centrifuge &rarr;</a>
          <a href="/food-grade-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Food Grade Centrifuge &rarr;</a>
        </div>
      </div>

      <!-- Category 4: Decanter Centrifuges -->
      <div class="bg-white rounded-xl p-6 border border-gray-200 mb-8">
        <h3 class="text-xl font-bold text-navy mb-3">Decanter Centrifuges</h3>
        <div class="grid md:grid-cols-3 gap-4 mb-4">
          <div>
            <p class="text-xs font-bold text-gold uppercase mb-1">Available Models</p>
            <p class="text-sm text-text-light">NX-314, NX-418, G2-40, CHNX-418</p>
          </div>
          <div>
            <p class="text-xs font-bold text-gold uppercase mb-1">Construction</p>
            <p class="text-sm text-text-light">Carbon steel or duplex stainless; scroll conveyor</p>
          </div>
          <div>
            <p class="text-xs font-bold text-gold uppercase mb-1">Solids Handling</p>
            <p class="text-sm text-text-light">5 &ndash; 60% solids by volume; dry cake discharge</p>
          </div>
        </div>
        <p class="text-sm text-text-light mb-4">
          Decanter centrifuges handle high-solids-content feeds that disc stack centrifuges are not designed to process. A horizontal rotating bowl with an internal scroll conveyor continuously moves settled solids toward a discharge port while clarified liquid overflows at the opposite end. This enables continuous processing of sludges, slurries, and oily water with high suspended solids content. Dolphin stocks and services decanter centrifuges for crude oil tank bottom recovery, oilfield slop processing, wastewater sludge dewatering, and industrial slurry treatment. Explosion proof configurations are available for hazardous locations.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/decanter-centrifuge/" class="text-sm font-semibold text-navy hover:text-gold transition-colors">Decanter Centrifuge Overview &rarr;</a>
        </div>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Dolphin Centrifuge: Your Alfa Laval Centrifuge Source</h2>
      <p class="text-text-light mb-4">
        When you buy or service a centrifuge through Dolphin Centrifuge, you benefit from over 40 years of specialized expertise. We are not a general industrial equipment dealer &mdash; centrifuges are all we do. Our Warren, Michigan shop is set up specifically for centrifuge disassembly, inspection, parts replacement, reassembly, and dynamic testing.
      </p>
      <p class="text-text-light mb-4">
        Every reconditioned machine we sell is fully tested at our facility before shipment. We document all replaced components and provide a test report with each unit. Machines are shipped ready to install, with all required fluids, connection specifications, and operating instructions.
      </p>
      <p class="text-text-light mb-8">
        We also maintain parts inventory for most machines in our product range, supporting both machines we have sold and legacy units already in service at customer facilities. If you have an existing centrifuge that needs bowls, discs, seals, bearings, or wear parts, visit our <a href="/alfa-laval-centrifuge-parts/" class="text-navy font-semibold hover:text-gold transition-colors">centrifuge parts page</a> or contact us directly.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Finding the Right Centrifuge</h2>
      <p class="text-text-light mb-4">
        Not sure which centrifuge type or size is right for your application? Our selection process starts with your fluid: what you are separating, at what throughput, with what solids content, and under what site conditions (temperature, hazardous area classification, materials requirements). From that information we can identify the appropriate centrifuge type, size, and configuration.
      </p>
      <p class="text-text-light mb-8">
        For applications where separation performance is uncertain, we offer paid sample testing at our Warren facility. Send us a representative sample of your feed stream and we will run it through the centrifuge, measure separation efficiency, and provide a sizing recommendation in writing before you commit to equipment purchase.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Related Resources</h2>
      <ul class="text-text-light space-y-2 mb-8">
        <li>&#8226; <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Disc Stack Centrifuge Overview</a></li>
        <li>&#8226; <a href="/decanter-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Decanter Centrifuge Overview</a></li>
        <li>&#8226; <a href="/alfa-laval-centrifuge-parts/" class="text-navy font-semibold hover:text-gold transition-colors">Centrifuge Parts &amp; Spares</a></li>
        <li>&#8226; <a href="/industrial-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Industrial Centrifuge Guide</a></li>
        <li>&#8226; <a href="/contact-for-alfa-laval-centrifuges/" class="text-navy font-semibold hover:text-gold transition-colors">Contact Us for Centrifuge Inquiry</a></li>
        <li>&#8226; <a href="/disc-stack-centrifuge-applications/" class="text-navy font-semibold hover:text-gold transition-colors">View All Centrifuge Applications</a></li>
      </ul>

    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-navy">
    <div class="container-dolphin py-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Contact Dolphin Centrifuge</h2>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">Ready to discuss your centrifuge requirement? Our engineers are available to help you select, size, and configure the right system for your application and budget.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3.5 rounded-lg transition-colors">Contact Us</a>
        <a href="/industrial-centrifuge-sample-testing/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3.5 rounded-lg transition-colors">Sample Testing</a>
      </div>
    </div>
  </section>
</BaseLayout>
