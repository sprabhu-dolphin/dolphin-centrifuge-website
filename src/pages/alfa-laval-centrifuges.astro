  "headline": "Alfa Laval Centrifuges - Product Gallery",
  "description": "Alfa Laval centrifuges from Dolphin Centrifuge. Our product showcase showing the variety of Alfa Laval centrifuge systems manufactured by Dolphin Centrifuge.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
