  "datePublished": "2020-01-01",
  "dateModified": "2026-01-01",
  "mainEntityOfPage": "https://dolphincentrifuge.com/alfa-laval-centrifuges/"
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval Centrifuges",
  "description": "Alfa Laval centrifuges from Dolphin Centrifuge. Our product showcase showing the variety of Alfa Laval centrifuge systems manufactured by Dolphin Centrifuge.",
  "brand": { "@type": "Brand", "name": "Alfa Laval" },
  "manufacturer": { "@type": "Organization", "name": "Alfa Laval" },
  "category": "Industrial Centrifuges",
  "offers": {
