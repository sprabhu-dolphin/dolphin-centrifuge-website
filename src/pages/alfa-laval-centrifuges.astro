---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval Centrifuges",
  "description": "Alfa Laval disc stack separators and decanter centrifuges — 200+ units in stock. New DMPX/DMB systems and remanufactured units. 40+ years Alfa Laval expertise. Dolphin Centrifuge, Warren MI.",
  "brand": { "@type": "Brand", "name": "Alfa Laval" },
  "manufacturer": { "@type": "Organization", "name": "Alfa Laval" },
  "category": "Industrial Centrifuges",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Does Dolphin Centrifuge sell new or used Alfa Laval centrifuges?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dolphin Centrifuge supplies both new and remanufactured Alfa Laval centrifuge systems. New machines are available through our Dolphin DMPX (self-cleaning disc stack) and DMB (manual-clean) branded systems built on Alfa Laval platforms. Remanufactured units are fully rebuilt, tested, and backed by a Dolphin warranty. We maintain 200+ units in inventory at our Warren, Michigan facility."
      }
    },
    {
      "@type": "Question",
      "name": "What Alfa Laval centrifuge series does Dolphin Centrifuge stock?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dolphin Centrifuge stocks Alfa Laval disc stack centrifuges including MAB series (manual-clean, 3-phase), MOPX/MAPX series (self-cleaning, oil purifiers), WSPX/WHPX series (self-cleaning, water-based fluids), BTPX series (biotech/pharma), and decanter centrifuges NX-314, NX-418, G2-40, and CHNX-418."
      }
    },
    {
      "@type": "Question",
      "name": "Does Dolphin Centrifuge provide service and parts for Alfa Laval centrifuges?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Dolphin Centrifuge provides complete service and parts support for all Alfa Laval centrifuge models including bowl rebuilds, gasket kits, disc stacks, bearing sets, and complete overhaul services. Our Warren, Michigan facility has 50+ years of collective Alfa Laval rebuild experience."
      }
    }
  ]
};
---

<ApplicationLayout
  title="Alfa Laval Centrifuges — Disc Stack & Decanter | Dolphin Centrifuge"
  description="Alfa Laval disc stack separators and decanter centrifuges — 200+ units in stock. New DMPX/DMB systems and remanufactured units. 40+ years Alfa Laval expertise. Dolphin Centrifuge, Warren MI."
  heroImage="/images/alfa-laval-centrifuges/Alfa-Laval-Disc-Stack-Centrifuge-Stainless-Steel-Explosion-Proof.webp"
  heroImageAlt="Alfa Laval Disc Stack Centrifuge Stainless Steel Explosion Proof"
  category="products"
  categoryLabel="Products"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-centrifuges/"
  jsonLd={[jsonLd, faqJsonLd]}
  toc={[
    { id: "about", label: "About Alfa Laval Centrifuges" },
    { id: "categories", label: "Centrifuge Categories We Stock" },
    { id: "why-dolphin", label: "Why Dolphin Centrifuge" },
    { id: "selection", label: "Finding the Right Centrifuge" },
    { id: "faq", label: "Frequently Asked Questions" },
  ]}
  relatedProducts={[
    { label: "Disc Stack Centrifuge", href: "/disc-stack-centrifuge/", description: "Self-cleaning & manual-clean separators" },
    { label: "Decanter Centrifuge", href: "/decanter-centrifuge/", description: "High-solids sludge & slurry dewatering" },
    { label: "Stainless Steel Centrifuge", href: "/stainless-steel-centrifuge/", description: "Food, pharma & biotech separators" },
    { label: "Centrifuge Parts", href: "/alfa-laval-centrifuge-parts/", description: "Bowls, discs, seals & wear parts" },
  ]}
  relatedApplications={[
    { label: "Diesel Centrifuge", href: "/diesel-centrifuge/" },
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
    { label: "Food Grade Centrifuge", href: "/food-grade-centrifuge/" },
    { label: "Industrial Centrifuge", href: "/industrial-centrifuge/" },
    { label: "All Applications", href: "/disc-stack-centrifuge-applications/" },
  ]}
>

  <!-- AI Summary -->
  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge stocks 200+ Alfa Laval disc stack separators (8–65 GPM) and decanter centrifuges for oil, fuel, food, pharma, and wastewater separation. New DMPX/DMB systems and remanufactured units from our Warren, Michigan facility — 40+ years of Alfa Laval rebuild expertise.</p>
  </div>

  <h2 id="about">About Alfa Laval Centrifuges</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-1/2">
      <p>
        Alfa Laval is the global standard in industrial centrifuge technology, with a history spanning more than 130 years. Their centrifuge product line covers virtually every industrial separation application &mdash; from high-speed disc stack separators for oil, fuel, food, and pharmaceutical processing to robust decanter centrifuges for sludge dewatering, oilfield waste management, and high-solids slurry treatment.
      </p>
      <p>
        Dolphin Centrifuge has built its business around Alfa Laval centrifuge technology. We maintain deep expertise in these machines &mdash; understanding their engineering, their operating requirements, their wear patterns, and their applications &mdash; accumulated over 40+ years of hands-on work.
      </p>
    </div>
    <div class="md:w-1/2">
      <img src="/images/alfa-laval-centrifuges/Industrial-Waste-Oil-Self-Cleaning-Centrifuges-300x300-1.webp" width="300" height="300" alt="Industrial Waste Oil Self-Cleaning Centrifuges" loading="lazy" class="rounded-xl w-full" />
    </div>
  </div>

  <p>
    Our facility is equipped to fully disassemble, inspect, recondition, and test these centrifuges to restore them to like-new performance. We supply reconditioned Alfa Laval centrifuges either as standalone machines or as complete turnkey skid systems with feed pump, heat exchanger, controls, and piping. Parts from our inventory support machines already in service at customer facilities.
  </p>

  <h2 id="categories">Centrifuge Categories We Stock</h2>

  <!-- Category 1: Self-Cleaning Oil Purifiers -->
  <h3>Self-Cleaning Disc Stack &mdash; Oil Purifiers</h3>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-1/2">
      <div class="grid grid-cols-3 gap-3 mb-4">
        <div>
          <p class="text-xs font-bold text-gold uppercase mb-1">Typical Flow Rates</p>
          <p class="text-sm">8 &ndash; 65 GPM (diesel; fluid-dependent)</p>
        </div>
        <div>
          <p class="text-xs font-bold text-gold uppercase mb-1">Construction</p>
          <p class="text-sm">Carbon steel bowl; cast iron/steel frame</p>
        </div>
        <div>
          <p class="text-xs font-bold text-gold uppercase mb-1">Solids Handling</p>
          <p class="text-sm">Hydraulic self-ejection; continuous operation</p>
        </div>
      </div>
      <p>
        The self-cleaning oil purifier series is the workhorse of industrial liquid-liquid-solid separation. These three-phase disc stack centrifuges remove water and solid contaminants from petroleum products in continuous, unattended operation. They are the standard solution for diesel fuel polishing, fuel oil purification, lube oil treatment, waste oil reclamation, biodiesel glycerin separation, and crude oil dewatering. Dolphin supplies these as our DMPX-branded systems &mdash; purpose-modified for the application with our own drive systems, controls, and skid integration.
      </p>
      <p><a href="/disc-stack-centrifuge/">Disc Stack Centrifuge Overview &rarr;</a></p>
    </div>
    <div class="md:w-1/2">
      <img src="/images/alfa-laval-centrifuges/Alfa-Laval-MOPX205-Diesel-Centrifuge-Occidental-300x300-1.webp" width="300" height="300" alt="Alfa Laval MOPX205 Diesel Centrifuge Occidental" loading="lazy" class="rounded-xl w-full" />
    </div>
  </div>

  <!-- Category 2: Manual-Clean (MAB Series) -->
  <h3>Manual-Clean Disc Stack &mdash; Diesel &amp; Lube Oil</h3>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-1/2">
      <img src="/images/alfa-laval-centrifuges/diesel-centrifuge-industrial-scale-300x300-1.webp" width="300" height="300" alt="diesel centrifuge industrial scale" loading="lazy" class="rounded-xl w-full" />
    </div>
    <div class="md:w-1/2">
      <div class="grid grid-cols-3 gap-3 mb-4">
        <div>
          <p class="text-xs font-bold text-gold uppercase mb-1">Typical Flow Rates</p>
          <p class="text-sm">4 &ndash; 62 GPM (diesel; fluid-dependent)</p>
        </div>
        <div>
          <p class="text-xs font-bold text-gold uppercase mb-1">Construction</p>
          <p class="text-sm">Carbon steel bowl; cast iron/steel frame</p>
        </div>
        <div>
          <p class="text-xs font-bold text-gold uppercase mb-1">Solids Handling</p>
          <p class="text-sm">Manual bowl cleaning; ideal for low-solids feeds</p>
        </div>
      </div>
      <p>
        Manual-clean disc stack centrifuges are simpler in design and lower in cost than self-cleaning machines. They accumulate solids inside the bowl until the machine is shut down, opened, and cleaned by hand. This design is well-suited to applications where the feed has very low solids content &mdash; allowing the bowl to run for many hours before cleaning is required. Common applications include diesel fuel polishing, marine lube oil purification, and light fuel oil treatment. Dolphin supplies these as DMB-branded systems.
      </p>
      <p>
        <a href="/disc-stack-centrifuge/">Disc Stack Centrifuge Overview &rarr;</a> &nbsp;|&nbsp;
        <a href="/diesel-centrifuge/">Diesel Centrifuge &rarr;</a>
      </p>
    </div>
  </div>

  <!-- Category 3: Stainless Steel Food/Pharma -->
  <h3>Stainless Steel Disc Stack &mdash; Food, Pharma &amp; Biotech</h3>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-1/2">
      <div class="grid grid-cols-3 gap-3 mb-4">
        <div>
          <p class="text-xs font-bold text-gold uppercase mb-1">Typical Flow Rates</p>
          <p class="text-sm">100 &ndash; 5,000+ LPH (product-dependent)</p>
        </div>
        <div>
          <p class="text-xs font-bold text-gold uppercase mb-1">Construction</p>
          <p class="text-sm">316L stainless steel wetted parts; hygienic design</p>
        </div>
        <div>
          <p class="text-xs font-bold text-gold uppercase mb-1">Compliance</p>
          <p class="text-sm">CIP/SIP capable; FDA material compliant</p>
        </div>
      </div>
      <p>
        The stainless steel food and pharmaceutical disc centrifuge series is engineered for hygienic processing. All product-contact surfaces are 316L stainless steel, polished to minimize bacterial retention, and designed for clean-in-place (CIP) and steam-in-place (SIP) procedures without disassembly. Applications span fish oil clarification, vegetable and olive oil processing, pharmaceutical API separation, biotech fermentation harvest, and botanical extract clarification. Both two-phase (clarifier) and three-phase (separator) configurations are available.
      </p>
      <p>
        <a href="/stainless-steel-centrifuge/">Stainless Steel Centrifuge &rarr;</a> &nbsp;|&nbsp;
        <a href="/food-grade-centrifuge/">Food Grade Centrifuge &rarr;</a>
      </p>
    </div>
    <div class="md:w-1/2">
      <img src="/images/alfa-laval-centrifuges/Alfa-Laval-WSPX-307-Water-Based-Coolant-Centrifuge.webp" width="600" height="450" alt="Alfa Laval WSPX 307 Water Based Coolant Centrifuge" loading="lazy" class="rounded-xl w-full" />
    </div>
  </div>

  <!-- Category 4: Decanter Centrifuges -->
  <h3>Decanter Centrifuges</h3>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-1/2">
      <img src="/images/alfa-laval-centrifuges/Alfa-Laval-Decanter-Centrifuge-System-Class-1-Div-2-for-Herbal-Extraction-600.webp" width="600" height="450" alt="Alfa Laval Decanter Centrifuge System Class 1 Div 2 for Herbal Extraction" loading="lazy" class="rounded-xl w-full" />
    </div>
    <div class="md:w-1/2">
      <div class="grid grid-cols-3 gap-3 mb-4">
        <div>
          <p class="text-xs font-bold text-gold uppercase mb-1">Available Models</p>
          <p class="text-sm">NX-314, NX-418, G2-40, CHNX-418</p>
        </div>
        <div>
          <p class="text-xs font-bold text-gold uppercase mb-1">Construction</p>
          <p class="text-sm">Carbon steel or duplex stainless; scroll conveyor</p>
        </div>
        <div>
          <p class="text-xs font-bold text-gold uppercase mb-1">Solids Handling</p>
          <p class="text-sm">5 &ndash; 60% solids by volume; dry cake discharge</p>
        </div>
      </div>
      <p>
        Decanter centrifuges handle high-solids-content feeds that disc stack centrifuges are not designed to process. A horizontal rotating bowl with an internal scroll conveyor continuously moves settled solids toward a discharge port while clarified liquid overflows at the opposite end. This enables continuous processing of sludges, slurries, and oily water with high suspended solids content. Dolphin stocks and services decanter centrifuges for crude oil tank bottom recovery, oilfield slop processing, wastewater sludge dewatering, and industrial slurry treatment. Explosion proof configurations are available for hazardous locations.
      </p>
      <p><a href="/decanter-centrifuge/">Decanter Centrifuge Overview &rarr;</a></p>
    </div>
  </div>

  <h2 id="why-dolphin">Dolphin Centrifuge: Your Alfa Laval Centrifuge Source</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-1/2">
      <p>
        When you buy or service a centrifuge through Dolphin Centrifuge, you benefit from over 40 years of specialized expertise. We are not a general industrial equipment dealer &mdash; centrifuges are all we do. Our Warren, Michigan shop is set up specifically for centrifuge disassembly, inspection, parts replacement, reassembly, and dynamic testing.
      </p>
      <p>
        Every reconditioned machine we sell is fully tested at our facility before shipment. We document all replaced components and provide a test report with each unit. Machines are shipped ready to install, with all required fluids, connection specifications, and operating instructions.
      </p>
    </div>
    <div class="md:w-1/2">
      <img src="/images/alfa-laval-centrifuges/used-diesel-purification-system-300x300-1.webp" width="300" height="300" alt="used diesel purification system" loading="lazy" class="rounded-xl w-full" />
    </div>
  </div>

  <p>
    We also maintain parts inventory for most machines in our product range, supporting both machines we have sold and legacy units already in service at customer facilities. If you have an existing centrifuge that needs bowls, discs, seals, bearings, or wear parts, visit our <a href="/alfa-laval-centrifuge-parts/">centrifuge parts page</a> or <a href="/contact-for-alfa-laval-centrifuges/">contact us directly</a>.
  </p>

  <h2 id="selection">Finding the Right Centrifuge</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start">
    <div class="md:w-1/2">
      <p>
        Not sure which centrifuge type or size is right for your application? Our selection process starts with your fluid: what you are separating, at what throughput, with what solids content, and under what site conditions (temperature, hazardous area classification, materials requirements). From that information we can identify the appropriate centrifuge type, size, and configuration.
      </p>
      <p>
        For applications where separation performance is uncertain, we offer paid <a href="/industrial-centrifuge-sample-testing/">sample testing at our Warren facility</a>. Send us a representative sample of your feed stream and we will run it through the centrifuge, measure separation efficiency, and provide a sizing recommendation in writing before you commit to equipment purchase.
      </p>
    </div>
    <div class="md:w-1/2">
      <img src="/images/alfa-laval-centrifuges/Alfa-Laval-Diesel-Centrifuge-Calss-1-Div-2-Explosion-Proof-600.webp" width="600" height="450" alt="Alfa Laval Diesel Centrifuge Calss 1 Div 2 Explosion Proof" loading="lazy" class="rounded-xl w-full" />
    </div>
  </div>

  <!-- FAQ -->
  <div id="faq" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mt-8">
    <h2 class="text-xl font-bold text-navy mb-6 !mt-0 !border-0">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div>
        <h3 class="text-base font-semibold text-navy mb-2">Does Dolphin Centrifuge sell new or used Alfa Laval centrifuges?</h3>
        <p class="text-sm">Dolphin Centrifuge supplies both new and remanufactured Alfa Laval centrifuge systems. New machines are available as Dolphin DMPX and DMB branded systems. Remanufactured units are fully rebuilt, tested, and backed by a Dolphin warranty. We maintain 200+ units in inventory at our Warren, Michigan facility.</p>
      </div>
      <div>
        <h3 class="text-base font-semibold text-navy mb-2">What Alfa Laval centrifuge series does Dolphin Centrifuge stock?</h3>
        <p class="text-sm">Dolphin Centrifuge stocks Alfa Laval disc stack centrifuges including MAB series (manual-clean), MOPX/MAPX series (self-cleaning oil purifiers), WSPX/WHPX series (water-based fluids), BTPX series (biotech/pharma), and decanter centrifuges NX-314, NX-418, G2-40, and CHNX-418.</p>
      </div>
      <div>
        <h3 class="text-base font-semibold text-navy mb-2">Does Dolphin Centrifuge provide service and parts for Alfa Laval centrifuges?</h3>
        <p class="text-sm">Yes. Dolphin Centrifuge provides complete service and parts support for all Alfa Laval centrifuge models including bowl rebuilds, gasket kits, disc stacks, bearing sets, and complete overhaul services. Our Warren, Michigan facility has 50+ years of collective Alfa Laval rebuild experience.</p>
      </div>
    </div>
  </div>

</ApplicationLayout>
