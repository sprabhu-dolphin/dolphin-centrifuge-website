---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Difference Between Purifier and Clarifier Centrifuge",
  "description": "A purifier centrifuge separates two liquids plus solids (three-phase), while a clarifier separates solids from one liquid. Learn operational differences.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Engineering Manager",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "datePublished": "2021-01-01",
  "url": "https://dolphincentrifuge.com/disc-centrifuge-purifier-clarifier-difference/",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the difference between a purifier and clarifier centrifuge?",
      "acceptedAnswer": { "@type": "Answer", "text": "A purifier centrifuge performs three-phase separation — it simultaneously separates two immiscible liquids (such as oil and water) plus suspended solids. It has two liquid outlets (light phase and heavy phase) and requires a gravity disc to control the liquid interface position. A clarifier performs two-phase separation — it removes solids from a single liquid with one outlet. Clarifiers don't need a gravity disc and are used when only one liquid phase is present (e.g., removing metal fines from coolant)." }
    },
    {
      "@type": "Question",
      "name": "When should I use a purifier vs. clarifier centrifuge?",
      "acceptedAnswer": { "@type": "Answer", "text": "Use a purifier when your feed contains two immiscible liquid phases that need to be separated (oil + water, for example) along with solids. Use a clarifier when your feed is a single liquid phase contaminated only with solids. Common purifier applications: diesel purification, waste oil reclamation, lube oil treatment. Common clarifier applications: machining coolant recovery, parts washer fluid clarification, metalworking fluid recycling." }
    },
    {
      "@type": "Question",
      "name": "Can a purifier centrifuge work as a clarifier?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. A purifier centrifuge can be configured to operate as a clarifier by selecting the largest available gravity disc, which moves the liquid interface to the maximum radius and effectively closes off the heavy phase outlet. Both separated phases exit through the light phase outlet. This is useful when the application temporarily shifts from two-phase (oil + water) to single-phase (solids removal only). However, purpose-built clarifiers offer better efficiency for single-phase applications." }
    },
    {
      "@type": "Question",
      "name": "What is a gravity disc and why does a purifier need one?",
      "acceptedAnswer": { "@type": "Answer", "text": "The gravity disc (also called the regulating ring or interface disc) is a replaceable disc installed at the heavy phase outlet that controls the radial position of the liquid-liquid interface inside the rotating bowl. A larger gravity disc outer diameter pushes the interface outward (toward the bowl wall), increasing the light phase volume. A smaller diameter pulls the interface inward, increasing the heavy phase volume. Selecting the correct gravity disc size is critical to purifier performance — the wrong size causes liquid seal break or phase cross-contamination." }
    }
  ]
};
