    { id: "overview", label: "Overview of Decanter and Disc Centrifuge Operation" },
    { id: "physical", label: "Physical Characteristics (Orientation, Dimensions, Power, MOC)" },
    { id: "separation", label: "Separation Features and Capabilities" },
