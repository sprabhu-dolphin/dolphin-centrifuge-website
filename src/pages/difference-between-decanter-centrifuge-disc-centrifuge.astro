---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Difference Between Decanter and Disc Centrifuge: Technical Comparison",
  "description": "A comprehensive technical comparison of decanter centrifuges vs. disc centrifuges covering g-force, particle size, solids capacity, design complexity, and maintenance.",
  "author": { "@type": "Person", "name": "Sanjay Prabhu MSME", "jobTitle": "Centrifuge Applications Engineer", "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" } },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com", "logo": { "@type": "ImageObject", "url": "https://dolphincentrifuge.com/images/dolphin-centrifuge-logo.png" } },
  "datePublished": "2021-01-01",
  "url": "https://dolphincentrifuge.com/difference-between-decanter-centrifuge-disc-centrifuge/"
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the main difference between a decanter centrifuge and a disc stack centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The primary difference is particle size capability and solids handling capacity. Decanter centrifuges operate at 3,000+ Gs and can handle particles down to 100 microns and high solids volumes (up to 50% solids by volume) — they excel at sludge dewatering. Disc stack centrifuges operate at 7,000+ Gs and separate particles from 0.5 microns, but have much smaller solids-holding capacity and are better for liquid-liquid separation (oil-water) with low solids."
      }
    },
    {
      "@type": "Question",
      "name": "When should I choose a disc stack centrifuge vs. a decanter centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Choose a disc stack centrifuge when: separating liquids of different densities (oil and water), the solids content is low (<1-2%), very fine particle removal is required (0.5-10 microns), or three-phase separation (oil/water/solids simultaneously) is needed. Choose a decanter when: dewatering high-solids sludge, handling slurries with >5% solids, large solids (>100 microns), or continuous solids discharge is required without stopping."
      }
    },
    {
      "@type": "Question",
      "name": "Which centrifuge generates higher G-force — decanter or disc stack?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Disc stack centrifuges generate significantly higher G-force — typically 7,000 to 10,000 Gs — compared to decanter centrifuges which typically operate at 2,000 to 4,000 Gs. The higher G-force in disc stack centrifuges enables separation of much finer particles and tighter liquid-liquid separation."
      }
    },
    {
      "@type": "Question",
      "name": "Can a decanter centrifuge separate oil and water?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, decanters can perform three-phase separation (oil, water, solids) but are less efficient at liquid-liquid separation than disc stack centrifuges. Decanters require a larger density difference between the two liquid phases to achieve effective separation. They are commonly used for oily sludge and crude oil tank bottom recovery where high solids content makes disc stack centrifuges impractical."
      }
    },
    {
      "@type": "Question",
      "name": "Which centrifuge is easier to maintain — decanter or disc stack?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Decanter centrifuges have fewer components overall and simpler bowl design, but the auger wear liners and gearbox require periodic service. Disc stack centrifuges have more internal parts (disc stack, distributor, operating water system) but self-cleaning models require minimal operator intervention during normal operation. Both have similar maintenance intervals of 2,000–8,000 hours depending on application severity."
      }
    }
  ]
};
