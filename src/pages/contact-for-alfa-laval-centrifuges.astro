---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "How quickly will Dolphin Centrifuge respond to my inquiry?",
    answer: "Most inquiries receive a response within one business day. Providing complete application details — fluid type, flow rate, solids content, and whether you need new or remanufactured equipment — allows our engineers to prepare an accurate recommendation on the first response."
  },
  {
    question: "Does Dolphin Centrifuge offer paid sample testing before purchase?",
    answer: "Yes. Dolphin Centrifuge operates a fully equipped <a href='/industrial-centrifuge-sample-testing/'>sample testing lab</a> at our Warren, Michigan facility. Send us a sample of your fluid and we will run it through the appropriate centrifuge, document the results with before-and-after photos, and provide a detailed report with recommended equipment sizing."
  },
  {
    question: "What information should I include in my centrifuge quote request?",
    answer: "Include the type of fluid you need to process, the required flow rate or daily volume, estimated solids content by weight, whether you need new or remanufactured equipment, and any special requirements such as explosion-proof or food-grade construction. The more detail you provide, the faster and more precise our recommendation will be."
  },
  {
    question: "Does Dolphin Centrifuge ship internationally?",
    answer: "Yes. Dolphin Centrifuge ships centrifuge systems, parts, and accessories worldwide. We have supplied equipment to customers across North America, South America, Europe, the Middle East, Africa, and Asia. Contact us for freight estimates and export documentation."
  },
  {
    question: "Can I visit the Dolphin Centrifuge facility in Warren, Michigan?",
    answer: "Absolutely. We welcome visits from prospective customers who want to inspect our in-stock <a href='/disc-stack-centrifuge/'>disc stack centrifuges</a> and <a href='/decanter-centrifuge/'>decanter centrifuges</a>. Our warehouse at 24248 Gibson Dr, Warren MI 48089 maintains over 200 centrifuges available for inspection and immediate shipment. Call (248) 522-2573 to schedule a visit."
  }
];

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Contact Dolphin Centrifuge — Get a Quote for Industrial Centrifuges",
  "description": "Contact Dolphin Centrifuge in Warren, Michigan for industrial centrifuge quotes, parts, repair, and sample testing. 200+ units in stock, respond within one business day.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  },
  "url": "https://dolphincentrifuge.com/contact-for-alfa-laval-centrifuges/",
  "mainEntityOfPage": "https://dolphincentrifuge.com/contact-for-alfa-laval-centrifuges/"
};

const localBusinessJsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Dolphin Centrifuge",
  "url": "https://dolphincentrifuge.com",
  "telephone": "+1-248-522-2573",
  "email": "sales@dolphincentrifuge.com",
  "image": "https://dolphincentrifuge.com/images/about-dolphin-centrifuge/Dolphin-Centrifuge-Shop-Warren-1000.webp",
  "description": "Industrial centrifuge sales, service, and remanufacturing. Specializing in disc stack and decanter centrifuge systems for oil, wastewater, chemical, and marine applications.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "24248 Gibson Dr",
    "addressLocality": "Warren",
    "addressRegion": "MI",
    "postalCode": "48089",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 42.473361,
    "longitude": -83.00227
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "08:00",
    "closes": "17:00"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+1-248-522-2573",
    "contactType": "sales",
    "email": "sales@dolphincentrifuge.com",
    "availableLanguage": "English",
    "areaServed": "Worldwide"
  },
  "areaServed": {
    "@type": "Country",
    "name": "Worldwide"
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};
---

<ApplicationLayout
  title="Contact Dolphin Centrifuge — Get a Quote | Warren, MI"
  description="Contact Dolphin Centrifuge for industrial centrifuge quotes, parts, service, and sample testing. Call (248) 522-2573 or email sales@dolphincentrifuge.com."
  heroImage="/images/about-dolphin-centrifuge/Dolphin-Centrifuge-Shop-Warren-1000.webp"
  heroImageAlt="Dolphin Centrifuge facility in Warren, Michigan — industrial centrifuge manufacturing and service center"
  category="contact"
  categoryLabel="Contact"
  canonicalUrl="https://dolphincentrifuge.com/contact-for-alfa-laval-centrifuges/"
  jsonLd={[articleJsonLd, localBusinessJsonLd, faqJsonLd]}
  relatedProducts={[
    { label: "Disc Stack Centrifuges", href: "/disc-stack-centrifuge/", description: "Self-cleaning separator systems" },
    { label: "Decanter Centrifuges", href: "/decanter-centrifuge/", description: "High-solids dewatering systems" },
    { label: "Centrifuge Parts", href: "/alfa-laval-centrifuge-parts/", description: "OEM-equivalent replacement parts" }
  ]}
  relatedApplications={[
    { label: "All Applications", href: "/disc-stack-centrifuge-applications/" },
    { label: "Sample Testing", href: "/industrial-centrifuge-sample-testing/" },
    { label: "Centrifuge Repair & Service", href: "/industrial-disc-centrifuge-repair/" },
    { label: "About Dolphin Centrifuge", href: "/about-dolphin-centrifuge/" }
  ]}
>

  <!-- AI Summary -->
  <div class="not-prose bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8">
    <p class="text-sm text-text-light leading-relaxed italic">
      Dolphin Centrifuge supplies, services, and rebuilds industrial disc stack and decanter centrifuges from its 20,000 sq ft Warren, Michigan facility. Contact our team for new and remanufactured centrifuge systems, replacement parts, application engineering, and paid sample testing. Over 200 centrifuges in stock for immediate shipment.
    </p>
  </div>

  <!-- Contact Details + Form — Pattern A Side-by-Side -->
  <section id="contact-form" class="scroll-mt-20">
    <h2>Centrifuge Application Details Form</h2>
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 not-prose">

      <!-- Left Column: Direct Contact -->
      <div class="lg:col-span-2 space-y-6">

        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
          <h3 class="text-xl font-bold text-navy mb-4 font-heading">Reach Us Directly</h3>
          <p class="text-sm text-text mb-4">
            Whether you need a new or remanufactured industrial centrifuge, centrifuge parts, or expert service, our team is ready to help.
          </p>

          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 bg-navy rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-navy">Phone</p>
                <a href="tel:+12485222573" class="text-gold font-bold text-lg hover:underline">(248) 522-2573</a>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="w-8 h-8 bg-navy rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                  <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-navy">Email</p>
                <a href="mailto:sales@dolphincentrifuge.com" class="text-navy hover:text-gold break-all text-sm">sales@dolphincentrifuge.com</a>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="w-8 h-8 bg-navy rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-navy">Address</p>
                <address class="not-italic text-text text-sm leading-snug">
                  <a href="https://maps.google.com/maps?ll=42.473361,-83.00227&z=14&t=m&hl=en-US&gl=US&mapclient=embed&q=24248%20Gibson%20Dr%20Warren%2C%20MI%2048089" target="_blank" rel="noopener noreferrer" class="hover:text-gold">
                    24248 Gibson Dr<br />
                    Warren, MI 48089<br />
                    USA
                  </a>
                </address>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
          <h3 class="text-lg font-bold text-navy mb-3 font-heading">Preferred Contact Method</h3>
          <p class="text-sm text-text mb-3">When you submit the form, let us know how you would like us to reach you:</p>
          <ul class="space-y-2 text-text text-sm">
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-gold rounded-full flex-shrink-0"></span>
              <span>Phone: Dolphin calls you</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-gold rounded-full flex-shrink-0"></span>
              <span>Phone: You call us — <a href="tel:+12485222573" class="text-navy hover:text-gold font-semibold">(248) 522-2573</a></span>
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-gold rounded-full flex-shrink-0"></span>
              <span>Email</span>
            </li>
          </ul>
        </div>

        <div class="bg-navy rounded-xl p-6 text-white">
          <h3 class="text-lg font-bold mb-2 font-heading">Why Contact Dolphin Centrifuge?</h3>
          <p class="text-blue-100 text-sm mb-3">Your single source for industrial centrifuge equipment, parts, and service.</p>
          <ul class="space-y-2 text-blue-100 text-sm">
            <li class="flex items-start gap-2"><span class="text-gold mt-0.5">&#10003;</span> 100+ years combined centrifuge expertise</li>
            <li class="flex items-start gap-2"><span class="text-gold mt-0.5">&#10003;</span> 200+ centrifuges in stock — Warren, MI</li>
            <li class="flex items-start gap-2"><span class="text-gold mt-0.5">&#10003;</span> Complete <a href="/disc-stack-centrifuge-installation/" class="text-gold hover:underline">turnkey system design</a></li>
            <li class="flex items-start gap-2"><span class="text-gold mt-0.5">&#10003;</span> Warranty on all equipment</li>
            <li class="flex items-start gap-2"><span class="text-gold mt-0.5">&#10003;</span> Lifetime technical support</li>
            <li class="flex items-start gap-2"><span class="text-gold mt-0.5">&#10003;</span> New and <a href="/industrial-disc-centrifuge-repair/" class="text-gold hover:underline">remanufactured centrifuges</a> available</li>
          </ul>
        </div>

      </div>

      <!-- Right Column: Application Details Form -->
      <div class="lg:col-span-3">
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 md:p-8">
          <p class="text-text text-sm mb-6">
            Please fill in as many details as possible to allow us to help you find the most effective centrifuge for your process. Providing complete application details enables our engineers to evaluate your requirements and recommend the most suitable centrifuge configuration.
          </p>

          <form
            name="centrifuge-contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="space-y-6"
          >
            <input type="hidden" name="form-name" value="centrifuge-contact" />
            <p class="hidden">
              <label>Don't fill this out if you're human: <input name="bot-field" /></label>
            </p>

            <!-- Customer Details -->
            <fieldset>
              <legend class="text-lg font-bold text-navy mb-4 pb-2 border-b border-gray-200 w-full font-heading">
                Customer Details
                <span class="block text-sm font-normal text-gray-500 mt-1">Please fill in ALL your contact details below:</span>
              </legend>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                <div>
                  <label class="block text-sm font-semibold text-text mb-1">First Name <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    name="first_name"
                    required
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-text focus:outline-none focus:ring-2 focus:ring-navy"
                    placeholder="First"
                  />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-1">Last Name <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    name="last_name"
                    required
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-text focus:outline-none focus:ring-2 focus:ring-navy"
                    placeholder="Last"
                  />
                </div>
              </div>

              <div class="mb-4">
                <label class="block text-sm font-semibold text-text mb-1">Company Name <span class="text-red-500">*</span></label>
                <input
                  type="text"
                  name="company"
                  required
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-text focus:outline-none focus:ring-2 focus:ring-navy"
                />
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                <div>
                  <label class="block text-sm font-semibold text-text mb-1">Email <span class="text-red-500">*</span></label>
                  <input
                    type="email"
                    name="email"
                    required
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-text focus:outline-none focus:ring-2 focus:ring-navy"
                    placeholder="Enter Email"
                  />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-1">Confirm Email <span class="text-red-500">*</span></label>
                  <input
                    type="email"
                    name="email_confirm"
                    required
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-text focus:outline-none focus:ring-2 focus:ring-navy"
                    placeholder="Confirm Email"
                  />
                </div>
              </div>

              <div class="mb-4">
                <label class="block text-sm font-semibold text-text mb-1">Phone <span class="text-red-500">*</span></label>
                <input
                  type="tel"
                  name="phone"
                  required
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-text focus:outline-none focus:ring-2 focus:ring-navy"
                />
              </div>

              <div class="mb-4">
                <label class="block text-sm font-semibold text-text mb-2">Preferred method of contact: <span class="text-red-500">*</span></label>
                <div class="space-y-2">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="contact_method" value="phone_dolphin_calls" required class="text-navy" />
                    <span class="text-text text-sm">Phone (Dolphin calls you)</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="contact_method" value="phone_you_call" class="text-navy" />
                    <span class="text-text text-sm">Phone (You call us) — (248) 522-2573</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="contact_method" value="email" class="text-navy" />
                    <span class="text-text text-sm">Email</span>
                  </label>
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                <div>
                  <label class="block text-sm font-semibold text-text mb-1">Country <span class="text-red-500">*</span></label>
                  <select
                    name="country"
                    required
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-text focus:outline-none focus:ring-2 focus:ring-navy bg-white"
                  >
                    <option value="">Select Country</option>
                    <option value="US">United States</option>
                    <option value="CA">Canada</option>
                    <option value="MX">Mexico</option>
                    <option value="Other">Other</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-1">US State</label>
                  <p class="text-xs text-gray-500 mb-1">If you are located in the USA, please select your state within the United States.</p>
                  <select
                    name="us_state"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-text focus:outline-none focus:ring-2 focus:ring-navy bg-white"
                  >
                    <option value="">Select State (if USA)</option>
                    <option>Alabama</option><option>Alaska</option><option>American Samoa</option>
                    <option>Arizona</option><option>Arkansas</option><option>California</option>
                    <option>Colorado</option><option>Connecticut</option><option>Delaware</option>
                    <option>District of Columbia</option><option>Florida</option><option>Georgia</option>
                    <option>Guam</option><option>Hawaii</option><option>Idaho</option>
                    <option>Illinois</option><option>Indiana</option><option>Iowa</option>
                    <option>Kansas</option><option>Kentucky</option><option>Louisiana</option>
                    <option>Maine</option><option>Maryland</option><option>Massachusetts</option>
                    <option>Michigan</option><option>Minnesota</option><option>Mississippi</option>
                    <option>Missouri</option><option>Montana</option><option>Nebraska</option>
                    <option>Nevada</option><option>New Hampshire</option><option>New Jersey</option>
                    <option>New Mexico</option><option>New York</option><option>North Carolina</option>
                    <option>North Dakota</option><option>Northern Mariana Islands</option><option>Ohio</option>
                    <option>Oklahoma</option><option>Oregon</option><option>Pennsylvania</option>
                    <option>Puerto Rico</option><option>Rhode Island</option><option>South Carolina</option>
                    <option>South Dakota</option><option>Tennessee</option><option>Texas</option>
                    <option>Utah</option><option>U.S. Virgin Islands</option><option>Vermont</option>
                    <option>Virginia</option><option>Washington</option><option>West Virginia</option>
                    <option>Wisconsin</option><option>Wyoming</option>
                    <option>Armed Forces Americas</option><option>Armed Forces Europe</option><option>Armed Forces Pacific</option>
                  </select>
                </div>
              </div>
            </fieldset>

            <!-- Application Details -->
            <fieldset>
              <legend class="text-lg font-bold text-navy mb-4 pb-2 border-b border-gray-200 w-full font-heading">
                Application Details
                <span class="block text-sm font-normal text-gray-500 mt-1">Please provide as many details as you can to allow us to evaluate and respond to your request precisely:</span>
              </legend>

              <div class="mb-4">
                <label class="block text-sm font-semibold text-text mb-1">Type of Fluid <span class="text-red-500">*</span></label>
                <input
                  type="text"
                  name="fluid_type"
                  required
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-text focus:outline-none focus:ring-2 focus:ring-navy"
                  placeholder="e.g. Diesel Fuel, Pyrolysis Oil, Lube Oil, Waste Water"
                />
                <p class="text-xs text-gray-500 mt-1">Please describe the type of fluid you want to process through the centrifuge. For example: Diesel Fuel or Pyrolysis Oil or Lube Oil or Waste Water etc.</p>
              </div>

              <div class="mb-4">
                <label class="block text-sm font-semibold text-text mb-1">Capacity Required <span class="text-red-500">*</span></label>
                <input
                  type="text"
                  name="capacity"
                  required
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-text focus:outline-none focus:ring-2 focus:ring-navy"
                  placeholder="e.g. 50 GPM, or 10,000 gallons/day"
                />
                <p class="text-xs text-gray-500 mt-1">Please help us size the centrifuge by providing the expected processing capacity desired. If you do not know the exact capacity, provide an estimate based on your batch size and the number of batches you will process per day.</p>
              </div>

              <div class="mb-4">
                <label class="block text-sm font-semibold text-text mb-1">Percentage of Solids by Weight <span class="text-red-500">*</span></label>
                <input
                  type="text"
                  name="solids_percentage"
                  required
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-text focus:outline-none focus:ring-2 focus:ring-navy"
                  placeholder="e.g. 2%, or unknown"
                />
                <p class="text-xs text-gray-500 mt-1">The estimated or confirmed percentage of solids in the fluid stream are critical to identifying a suitable centrifuge.</p>
              </div>

              <div class="mb-4">
                <label class="block text-sm font-semibold text-text mb-2">
                  Do you require a New Centrifuge or is a Remanufactured centrifuge acceptable? <span class="text-red-500">*</span>
                </label>
                <p class="text-xs text-gray-500 mb-2">Would you consider a Re-Manufactured Centrifuge (w/ warranty) on a New Skid with all accessories being new? Or does the centrifuge also have to be new?</p>
                <div class="space-y-2">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="centrifuge_condition" value="new_required" required class="text-navy" />
                    <span class="text-text text-sm">New (Centrifuge has to be New)</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="centrifuge_condition" value="remanufactured_ok" class="text-navy" />
                    <span class="text-text text-sm">Remanufactured Acceptable</span>
                  </label>
                </div>
              </div>

              <div class="mb-6">
                <label class="block text-sm font-semibold text-text mb-1">Additional Details</label>
                <textarea
                  name="additional_details"
                  rows="5"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-text focus:outline-none focus:ring-2 focus:ring-navy"
                  placeholder="Please provide a detailed description of your application — temperature, pressure, any known contaminants, existing equipment, timeline, etc."
                ></textarea>
                <p class="text-xs text-gray-500 mt-1">Please provide a detailed description of your application.</p>
              </div>

              <button
                type="submit"
                class="w-full bg-gold text-navy font-bold py-4 px-8 rounded-lg hover:bg-gold-light transition-colors text-lg"
              >
                Submit Application Details
              </button>
            </fieldset>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Mid-page CTA -->
  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-5 my-10 not-prose">
    <p class="text-navy font-bold text-lg mb-1">Prefer to talk to an engineer directly?</p>
    <p class="text-text-light text-sm mb-3">Call us at <a href="tel:+12485222573" class="text-gold font-bold hover:underline">(248) 522-2573</a> or email <a href="mailto:sales@dolphincentrifuge.com" class="text-navy font-semibold hover:text-gold">sales@dolphincentrifuge.com</a> for immediate assistance with your centrifuge application.</p>
  </div>

  <!-- Map / Address Section — Pattern A Side-by-Side -->
