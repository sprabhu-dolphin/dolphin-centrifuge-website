  <!-- Form Submission Script -->
  <script>
    (function() {
      const WORKER_URL = 'https://dolphin-contact-form.dolphin-centrifuge.workers.dev';

      const form         = document.getElementById('centrifuge-contact-form');
      const errorMsg     = document.getElementById('form-error');
      const errorText    = document.getElementById('form-error-text');
      const submitBtn    = document.getElementById('submit-btn');
      const submitBtnText    = document.getElementById('submit-btn-text');
      const submitBtnLoading = document.getElementById('submit-btn-loading');

      if (!form) return;

      // ── Country → show/hide 'Other' field ────────────────────────────
      const countrySelect = document.getElementById('country');
      const countryOtherWrap = document.getElementById('country-other-wrap');
      const countryOtherInput = document.getElementById('country_other');
      const usStateSelect = document.getElementById('us_state');
      if (countrySelect) {
        countrySelect.addEventListener('change', function() {
          const isOther = this.value === 'Other';
          // Show / hide the free-text country field
          countryOtherWrap.style.display = isOther ? 'block' : 'none';
          if (!isOther) {
            countryOtherInput.value = '';
            clearFieldError(countryOtherInput);
          }
          // Disable + clear US State when Other is chosen
          if (usStateSelect) {
            usStateSelect.value = '';
            usStateSelect.disabled = isOther;
            usStateSelect.style.opacity = isOther ? '0.4' : '1';
            usStateSelect.style.cursor  = isOther ? 'not-allowed' : '';
          }
        });
      }

      // Required field IDs (must match name attributes)
      const REQUIRED_IDS = [
        'first_name', 'last_name', 'company',
        'email', 'email_confirm', 'phone',
        'country', 'fluid_type', 'capacity'
      ];

      // Clear red highlight when user starts typing / changing
      REQUIRED_IDS.forEach(id => {
        const el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('input', () => clearFieldError(el));
        el.addEventListener('change', () => clearFieldError(el));
      });

      function markFieldError(el) {
        el.classList.remove('border-gray-200', 'focus:border-navy');
        el.classList.add('border-red-500', 'bg-red-50');
      }

      function clearFieldError(el) {
        el.classList.remove('border-red-500', 'bg-red-50');
        el.classList.add('border-gray-200', 'focus:border-navy');
      }

      function validateRequired() {
        let firstInvalid = null;
        let anyEmpty = false;

        REQUIRED_IDS.forEach(id => {
          const el = document.getElementById(id);
          if (!el) return;
          const val = el.value.trim();
          if (!val) {
            markFieldError(el);
            anyEmpty = true;
            if (!firstInvalid) firstInvalid = el;
          } else {
            clearFieldError(el);
          }
        });

        return { anyEmpty, firstInvalid };
      }

      form.addEventListener('submit', async function(e) {
        e.preventDefault();

        // ── Client-side required field check ────────────────
        const { anyEmpty, firstInvalid } = validateRequired();
        if (anyEmpty) {
          errorText.textContent = 'Please fill in all required fields.';
          errorMsg.classList.remove('hidden');
          firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
          firstInvalid.focus();
          return;
        }

        // ── Email match check ────────────────────────────────
        const email        = form.querySelector('[name="email"]').value;
        const emailConfirm = form.querySelector('[name="email_confirm"]').value;
        if (email !== emailConfirm) {
          const el = document.getElementById('email_confirm');
          markFieldError(el);
          errorText.textContent = 'Email addresses do not match. Please check and try again.';
          errorMsg.classList.remove('hidden');
          errorMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }

        submitBtn.disabled = true;
        submitBtnText.classList.add('hidden');
        submitBtnLoading.classList.remove('hidden');
        errorMsg.classList.add('hidden');

        try {
          const formData = new FormData(form);
          const response = await fetch(WORKER_URL, { method: 'POST', body: formData });
          const result   = await response.json();

          if (result.success) {
            // Capture fluid type BEFORE reset
            const fluidType = (form.querySelector('[name="fluid_type"]')?.value || '').trim();
            const redirectUrl = getFluidRedirect(fluidType);
            // Reset form
            form.reset();
            REQUIRED_IDS.forEach(id => {
              const el = document.getElementById(id);
              if (el) clearFieldError(el);
            });
            // Show green toast (with optional redirect)
            showSuccessToast(redirectUrl);
          } else {
            throw new Error(result.error || 'Submission failed. Please try again.');
          }
        } catch (err) {
          errorText.textContent = err.message || 'An error occurred. Please call us at (248) 522-2573.';
          errorMsg.classList.remove('hidden');
          errorMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } finally {
          submitBtn.disabled = false;
          submitBtnText.classList.remove('hidden');
          submitBtnLoading.classList.add('hidden');
        }
      });
    })();

    // ── Fluid-type → redirect map ───────────────────────────
    function getFluidRedirect(fluidType) {
      if (!fluidType) return null;
      const f = fluidType.toLowerCase();
      const map = [
        { url: '/diesel-centrifuge/',                          k: ['diesel'] },
        { url: '/lube-oil-centrifuge/',                        k: ['lube oil','lubricant','lubrication oil','gear oil'] },
        { url: '/used-oil-centrifuge/',                        k: ['used oil','used motor','motor oil','engine oil','used lube'] },
        { url: '/waste-oil-centrifuge/',                       k: ['waste oil','waste lubric','waste lube'] },
        { url: '/hydraulic-oil-centrifuge/',                   k: ['hydraulic'] },
        { url: '/fuel-oil-centrifuge/',                        k: ['fuel oil','heavy fuel','bunker','hfo','mgo','marine fuel','fo ','ifо'] },
        { url: '/crude-oil-centrifuge/',                       k: ['crude oil','crude','petroleum'] },
        { url: '/quench-oil-centrifuge/',                      k: ['quench'] },
        { url: '/pyrolysis-oil-centrifuge/',                   k: ['pyrolysis','waste plastic','tire oil','tyre oil'] },
        { url: '/cutting-oil-centrifuge/',                     k: ['cutting oil','cutting fluid'] },
        { url: '/machine-coolant-centrifuge/',                 k: ['coolant','metalworking fluid','machining fluid'] },
        { url: '/tramp-oil-centrifuge/',                       k: ['tramp oil','tramp'] },
        { url: '/industrial-washer-fluid-centrifuge/',         k: ['washer fluid','parts washer','industrial washer'] },
        { url: '/yellow-grease-purification-centrifuge/',      k: ['yellow grease','used cooking oil','uco','fryer oil','restaurant grease'] },
        { url: '/wvo-centrifuge-separator/',                   k: ['wvo','waste vegetable','vegetable oil','cooking oil','svo'] },
        { url: '/fish-processing-centrifuge/',                 k: ['fish','fish oil','fish meal','seafood'] },
        { url: '/manure-centrifuge-separator/',                k: ['manure','animal waste','pig slurry','swine','livestock'] },
        { url: '/food-grade-centrifuge/',                      k: ['food grade','food process','edible','beverage'] },
        { url: '/wastewater-centrifuge/',                      k: ['wastewater','waste water','sewage','effluent','industrial water'] },
        { url: '/dewatering-centrifuge/',                      k: ['dewater','biosolid','sludge cake','slurry'] },
        { url: '/ethanol-extraction-centrifuges-technical-comparison/', k: ['ethanol','hemp','cbd','cannabis','extraction alcohol'] },
        { url: '/oil-centrifuge/',                             k: ['oil'] },
      ];
      for (const entry of map) {
        if (entry.k.some(kw => f.includes(kw))) return entry.url;
      }
      return '/picking-the-right-industrial-centrifuge/';
    }

    // ── Green toast logic ────────────────────────────────────
    (function() {
      window.showSuccessToast = function(redirectUrl) {
        const DISMISS_MS = redirectUrl ? 3000 : 6000;
        const toast     = document.getElementById('form-success');
        const bar       = document.getElementById('success-bar');
        const close     = document.getElementById('success-close');
        const rdMsg     = document.getElementById('redirect-msg');
        if (!toast) return;

        // Show redirect hint if applicable
        if (redirectUrl && rdMsg) {
          rdMsg.textContent = `→ Taking you to your relevant page in 3 seconds…`;
          rdMsg.style.display = 'block';
        } else if (rdMsg) {
          rdMsg.style.display = 'none';
        }

        toast.classList.remove('hidden');
        // Animate countdown bar
        bar.style.transition = 'none';
        bar.style.width = '100%';
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            bar.style.transition = `width ${DISMISS_MS}ms linear`;
            bar.style.width = '0%';
          });
        });

        const timer = setTimeout(() => {
          hideToast();
          if (redirectUrl) window.location.href = redirectUrl;
        }, DISMISS_MS);

        close.addEventListener('click', () => { clearTimeout(timer); hideToast(); }, { once: true });

        function hideToast() {
          toast.classList.add('hidden');
          bar.style.width = '100%';
        }
      };
    })();
  </script>




