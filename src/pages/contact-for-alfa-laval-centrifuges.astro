---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Dolphin Centrifuge",
  "url": "https://dolphincentrifuge.com",
  "telephone": "+1-248-522-2573",
  "email": "sales@dolphincentrifuge.com",
  "image": "https://dolphincentrifuge.com/images/dolphin-centrifuge-facility.webp",
  "description": "Industrial centrifuge sales, service, and remanufacturing. Specializing in disc stack and decanter centrifuge systems for oil, wastewater, chemical, and marine applications.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "24248 Gibson Dr",
    "addressLocality": "Warren",
    "addressRegion": "MI",
    "postalCode": "48089",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 42.473361,
    "longitude": -83.00227
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "08:00",
    "closes": "17:00"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+1-248-522-2573",
    "contactType": "sales",
    "email": "sales@dolphincentrifuge.com",
    "availableLanguage": "English",
    "areaServed": "Worldwide"
  },
  "areaServed": {
    "@type": "Country",
    "name": "Worldwide"
  }
};
---

<BaseLayout
  title="Contact Dolphin Centrifuge — Get a Quote"
  description="Contact Dolphin Centrifuge for industrial centrifuge systems, parts, and service. Call (248) 522-2573 or submit your application details for a fast, expert response."
  canonicalUrl="https://dolphincentrifuge.com/contact-for-alfa-laval-centrifuges/"
  breadcrumbs={[{label: 'Contact', href: '/contact-for-alfa-laval-centrifuges/'}]}
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <section class="bg-[#1B3A5C] text-white py-16 md:py-20">
    <div class="container-dolphin max-w-5xl">
      <h1 class="text-3xl md:text-5xl font-bold font-jakarta mb-4 leading-tight">
        Contact Dolphin Centrifuge
      </h1>
      <p class="text-lg md:text-xl text-blue-100 max-w-3xl">
        Tell us about your application and we will recommend the most effective centrifuge for your process. Please fill in as many details as possible to allow us to help you find the most effective centrifuge for your process. The more detail you provide, the faster and more precise our response will be.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="bg-[#F5F5F0]">
    <div class="container-dolphin py-12 md:py-16 max-w-5xl">

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Contact Details Sidebar -->
        <div class="lg:col-span-1 space-y-6">

          <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6">
            <h2 class="text-xl font-bold text-[#1B3A5C] mb-4">Reach Us Directly</h2>
            <p class="text-sm text-[#2D2D2D] mb-4">
              Whether you need a new or remanufactured industrial centrifuge, centrifuge parts, or expert service, our team is ready to help. Reach us by phone, email, or visit our facility in Warren, Michigan.
            </p>

            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-[#1B3A5C] rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-[#1B3A5C]">Phone</p>
                  <a href="tel:+12485222573" class="text-[#E8A317] font-bold text-lg hover:underline">(248) 522-2573</a>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-[#1B3A5C] rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                    <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-[#1B3A5C]">Email</p>
                  <a href="mailto:sales@dolphincentrifuge.com" class="text-[#1B3A5C] hover:text-[#E8A317] break-all">sales@dolphincentrifuge.com</a>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-[#1B3A5C] rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-[#1B3A5C]">Address</p>
                  <address class="not-italic text-[#2D2D2D] text-sm leading-snug">
                    <a href="https://maps.google.com/maps?ll=42.473361,-83.00227&z=14&t=m&hl=en-US&gl=US&mapclient=embed&q=24248%20Gibson%20Dr%20Warren%2C%20MI%2048089" target="_blank" rel="noopener noreferrer" class="hover:text-[#E8A317]">
                      24248 Gibson Dr<br />
                      Warren, MI 48089<br />
                      USA
                    </a>
                  </address>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6">
            <h3 class="text-lg font-bold text-[#1B3A5C] mb-3">Preferred Contact Method</h3>
            <p class="text-sm text-[#2D2D2D] mb-3">When you submit the form, let us know how you would like us to reach you:</p>
            <ul class="space-y-2 text-[#2D2D2D] text-sm">
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-[#E8A317] rounded-full flex-shrink-0"></span>
                <span>Phone: Dolphin calls you</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-[#E8A317] rounded-full flex-shrink-0"></span>
                <span>Phone: You call us — <a href="tel:+12485222573" class="text-[#1B3A5C] hover:text-[#E8A317]">(248) 522-2573</a></span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-[#E8A317] rounded-full flex-shrink-0"></span>
                <span>Email</span>
              </li>
            </ul>
          </div>

          <div class="bg-[#1B3A5C] rounded-xl p-6 text-white">
            <h3 class="text-lg font-bold mb-2">Why Contact Us?</h3>
            <p class="text-blue-100 text-sm mb-3">Dolphin Centrifuge is your single source for industrial centrifuge equipment, parts, and service.</p>
            <ul class="space-y-2 text-blue-100 text-sm">
              <li>• 100+ years combined centrifuge expertise</li>
              <li>• 200+ centrifuges in stock — Warren, MI</li>
              <li>• Complete turnkey system design</li>
              <li>• Warranty on all equipment</li>
              <li>• Lifetime technical support</li>
              <li>• New and remanufactured centrifuges available</li>
            </ul>
          </div>
        </div>

        <!-- Application Details Form -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8">
            <h2 class="text-2xl font-bold text-[#1B3A5C] mb-2">Centrifuge Application Details Form</h2>
            <p class="text-[#2D2D2D] text-sm mb-6">
              Please fill in as many details as possible to allow us to help you find the most effective centrifuge for your process. Providing complete application details enables our engineers to evaluate your requirements and recommend the most suitable centrifuge configuration.
            </p>

            <form
              name="centrifuge-contact"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              class="space-y-6"
            >
              <input type="hidden" name="form-name" value="centrifuge-contact" />
              <p class="hidden">
                <label>Don't fill this out if you're human: <input name="bot-field" /></label>
              </p>

              <!-- Customer Details -->
              <fieldset>
                <legend class="text-lg font-bold text-[#1B3A5C] mb-4 pb-2 border-b border-gray-200 w-full">
                  Customer Details
                  <span class="block text-sm font-normal text-gray-500 mt-1">Please fill in ALL your contact details below:</span>
                </legend>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                  <div>
                    <label class="block text-sm font-semibold text-[#2D2D2D] mb-1">First Name <span class="text-red-500">*</span></label>
                    <input
                      type="text"
                      name="first_name"
                      required
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 text-[#2D2D2D] focus:outline-none focus:ring-2 focus:ring-[#1B3A5C]"
                      placeholder="First"
                    />
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-[#2D2D2D] mb-1">Last Name <span class="text-red-500">*</span></label>
                    <input
                      type="text"
                      name="last_name"
                      required
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 text-[#2D2D2D] focus:outline-none focus:ring-2 focus:ring-[#1B3A5C]"
                      placeholder="Last"
                    />
                  </div>
                </div>

                <div class="mb-4">
                  <label class="block text-sm font-semibold text-[#2D2D2D] mb-1">Company Name <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    name="company"
                    required
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-[#2D2D2D] focus:outline-none focus:ring-2 focus:ring-[#1B3A5C]"
                  />
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                  <div>
                    <label class="block text-sm font-semibold text-[#2D2D2D] mb-1">Email <span class="text-red-500">*</span></label>
                    <input
                      type="email"
                      name="email"
                      required
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 text-[#2D2D2D] focus:outline-none focus:ring-2 focus:ring-[#1B3A5C]"
                      placeholder="Enter Email"
                    />
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-[#2D2D2D] mb-1">Confirm Email <span class="text-red-500">*</span></label>
                    <input
                      type="email"
                      name="email_confirm"
                      required
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 text-[#2D2D2D] focus:outline-none focus:ring-2 focus:ring-[#1B3A5C]"
                      placeholder="Confirm Email"
                    />
                  </div>
                </div>

                <div class="mb-4">
                  <label class="block text-sm font-semibold text-[#2D2D2D] mb-1">Phone <span class="text-red-500">*</span></label>
                  <input
                    type="tel"
                    name="phone"
                    required
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-[#2D2D2D] focus:outline-none focus:ring-2 focus:ring-[#1B3A5C]"
                  />
                </div>

                <div class="mb-4">
                  <label class="block text-sm font-semibold text-[#2D2D2D] mb-2">Preferred method of contact: <span class="text-red-500">*</span></label>
                  <div class="space-y-2">
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="radio" name="contact_method" value="phone_dolphin_calls" required class="text-[#1B3A5C]" />
                      <span class="text-[#2D2D2D] text-sm">Phone (Dolphin calls you)</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="radio" name="contact_method" value="phone_you_call" class="text-[#1B3A5C]" />
                      <span class="text-[#2D2D2D] text-sm">Phone (You call us) — (248) 522-2573</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="radio" name="contact_method" value="email" class="text-[#1B3A5C]" />
                      <span class="text-[#2D2D2D] text-sm">Email</span>
                    </label>
                  </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                  <div>
                    <label class="block text-sm font-semibold text-[#2D2D2D] mb-1">Country <span class="text-red-500">*</span></label>
                    <select
                      name="country"
                      required
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 text-[#2D2D2D] focus:outline-none focus:ring-2 focus:ring-[#1B3A5C] bg-white"
                    >
                      <option value="">Select Country</option>
                      <option value="US">United States</option>
                      <option value="CA">Canada</option>
                      <option value="MX">Mexico</option>
                      <option value="Other">Other</option>
                    </select>
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-[#2D2D2D] mb-1">US State</label>
                    <p class="text-xs text-gray-500 mb-1">If you are located in the USA, please select your state within the United States.</p>
                    <select
                      name="us_state"
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 text-[#2D2D2D] focus:outline-none focus:ring-2 focus:ring-[#1B3A5C] bg-white"
                    >
                      <option value="">Select State (if USA)</option>
                      <option>Alabama</option><option>Alaska</option><option>American Samoa</option>
                      <option>Arizona</option><option>Arkansas</option><option>California</option>
                      <option>Colorado</option><option>Connecticut</option><option>Delaware</option>
                      <option>District of Columbia</option><option>Florida</option><option>Georgia</option>
                      <option>Guam</option><option>Hawaii</option><option>Idaho</option>
                      <option>Illinois</option><option>Indiana</option><option>Iowa</option>
                      <option>Kansas</option><option>Kentucky</option><option>Louisiana</option>
                      <option>Maine</option><option>Maryland</option><option>Massachusetts</option>
                      <option>Michigan</option><option>Minnesota</option><option>Mississippi</option>
                      <option>Missouri</option><option>Montana</option><option>Nebraska</option>
                      <option>Nevada</option><option>New Hampshire</option><option>New Jersey</option>
                      <option>New Mexico</option><option>New York</option><option>North Carolina</option>
                      <option>North Dakota</option><option>Northern Mariana Islands</option><option>Ohio</option>
                      <option>Oklahoma</option><option>Oregon</option><option>Pennsylvania</option>
                      <option>Puerto Rico</option><option>Rhode Island</option><option>South Carolina</option>
                      <option>South Dakota</option><option>Tennessee</option><option>Texas</option>
                      <option>Utah</option><option>U.S. Virgin Islands</option><option>Vermont</option>
                      <option>Virginia</option><option>Washington</option><option>West Virginia</option>
                      <option>Wisconsin</option><option>Wyoming</option>
                      <option>Armed Forces Americas</option><option>Armed Forces Europe</option><option>Armed Forces Pacific</option>
                    </select>
                  </div>
                </div>
              </fieldset>

              <!-- Application Details -->
              <fieldset>
                <legend class="text-lg font-bold text-[#1B3A5C] mb-4 pb-2 border-b border-gray-200 w-full">
                  Application Details
                  <span class="block text-sm font-normal text-gray-500 mt-1">Please provide as many details as you can to allow us to evaluate and respond to your request precisely:</span>
                </legend>

                <div class="mb-4">
                  <label class="block text-sm font-semibold text-[#2D2D2D] mb-1">Type of Fluid <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    name="fluid_type"
                    required
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-[#2D2D2D] focus:outline-none focus:ring-2 focus:ring-[#1B3A5C]"
                    placeholder="e.g. Diesel Fuel, Pyrolysis Oil, Lube Oil, Waste Water"
                  />
                  <p class="text-xs text-gray-500 mt-1">Please describe the type of fluid you want to process through the centrifuge. For example: Diesel Fuel or Pyrolysis Oil or Lube Oil or Waste Water etc.</p>
                </div>

                <div class="mb-4">
                  <label class="block text-sm font-semibold text-[#2D2D2D] mb-1">Capacity Required <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    name="capacity"
                    required
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-[#2D2D2D] focus:outline-none focus:ring-2 focus:ring-[#1B3A5C]"
                    placeholder="e.g. 50 GPM, or 10,000 gallons/day"
                  />
                  <p class="text-xs text-gray-500 mt-1">Please help us size the centrifuge by providing the expected processing capacity desired. If you do not know the exact capacity, provide an estimate based on your batch size and the number of batches you will process per day.</p>
                </div>

                <div class="mb-4">
                  <label class="block text-sm font-semibold text-[#2D2D2D] mb-1">Percentage of Solids by Weight <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    name="solids_percentage"
                    required
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-[#2D2D2D] focus:outline-none focus:ring-2 focus:ring-[#1B3A5C]"
                    placeholder="e.g. 2%, or unknown"
                  />
                  <p class="text-xs text-gray-500 mt-1">The estimated or confirmed percentage of solids in the fluid stream are critical to identifying a suitable centrifuge.</p>
                </div>

                <div class="mb-4">
                  <label class="block text-sm font-semibold text-[#2D2D2D] mb-2">
                    Do you require a New Centrifuge or is a Remanufactured centrifuge acceptable? <span class="text-red-500">*</span>
                  </label>
                  <p class="text-xs text-gray-500 mb-2">Would you consider a Re-Manufactured Centrifuge (w/ warranty) on a New Skid with all accessories being new? Or does the centrifuge also have to be new?</p>
                  <div class="space-y-2">
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="radio" name="centrifuge_condition" value="new_required" required class="text-[#1B3A5C]" />
                      <span class="text-[#2D2D2D] text-sm">New (Centrifuge has to be New)</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="radio" name="centrifuge_condition" value="remanufactured_ok" class="text-[#1B3A5C]" />
                      <span class="text-[#2D2D2D] text-sm">Remanufactured Acceptable</span>
                    </label>
                  </div>
                </div>

                <div class="mb-6">
                  <label class="block text-sm font-semibold text-[#2D2D2D] mb-1">Additional Details</label>
                  <textarea
                    name="additional_details"
                    rows="5"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-[#2D2D2D] focus:outline-none focus:ring-2 focus:ring-[#1B3A5C]"
                    placeholder="Please provide a detailed description of your application — temperature, pressure, any known contaminants, existing equipment, timeline, etc."
                  ></textarea>
                  <p class="text-xs text-gray-500 mt-1">Please provide a detailed description of your application.</p>
                </div>

                <button
                  type="submit"
                  class="w-full bg-[#E8A317] text-white font-bold py-4 px-8 rounded-lg hover:bg-yellow-500 transition-colors text-lg"
                >
                  Submit Application Details
                </button>
              </fieldset>
            </form>
          </div>
        </div>
      </div>

      <!-- Map / Address Section -->
      <div class="mt-8 bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Find Us in Warren, Michigan</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
          <div>
            <p class="text-[#2D2D2D] mb-4">
              Dolphin Centrifuge is located in the heart of the Detroit Metro industrial district in Warren, Michigan. We welcome visits from prospective customers who want to see our facility and in-stock centrifuge inventory. Our warehouse maintains over 200 centrifuges ready for inspection, testing, and immediate shipment.
            </p>
            <p class="text-[#2D2D2D] mb-4">
              Whether you are looking for a complete turnkey centrifuge system, replacement parts, or expert centrifuge service and repair, our team of experienced engineers and technicians is available to assist you. Contact us today to discuss your centrifuge application requirements.
            </p>
            <address class="not-italic bg-[#F5F5F0] rounded-lg p-4 text-[#2D2D2D]">
              <strong class="block text-[#1B3A5C]">Dolphin Centrifuge</strong>
              <a href="https://maps.google.com/maps?ll=42.473361,-83.00227&z=14&t=m&hl=en-US&gl=US&mapclient=embed&q=24248%20Gibson%20Dr%20Warren%2C%20MI%2048089" target="_blank" rel="noopener noreferrer" class="hover:text-[#E8A317]">
                24248 Gibson Dr<br />
                Warren, MI 48089<br />
                USA
              </a><br /><br />
              <a href="tel:+12485222573" class="text-[#E8A317] font-bold">(248) 522-2573</a><br />
              <a href="mailto:sales@dolphincentrifuge.com" class="text-[#1B3A5C] hover:text-[#E8A317]">sales@dolphincentrifuge.com</a>
            </address>
          </div>
          <div>
            <iframe
              src="https://maps.google.com/maps?q=24248+Gibson+Dr+Warren+MI+48089&output=embed"
              width="100%"
              height="250"
              loading="lazy"
              class="rounded-lg border border-gray-200"
              title="Dolphin Centrifuge Location — 24248 Gibson Dr, Warren MI 48089"
            ></iframe>
          </div>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 md:p-8">
        <h2 class="text-xl font-bold text-[#1B3A5C] mb-4">Explore Our Solutions</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
          <a href="/disc-stack-centrifuge-applications/" class="block p-4 rounded-lg border border-gray-100 hover:border-[#E8A317] transition-colors">
            <h3 class="font-semibold text-[#1B3A5C] mb-1">Applications</h3>
            <p class="text-sm text-gray-600">Oil, wastewater, food, marine, and more.</p>
          </a>
          <a href="/disc-stack-centrifuge/" class="block p-4 rounded-lg border border-gray-100 hover:border-[#E8A317] transition-colors">
            <h3 class="font-semibold text-[#1B3A5C] mb-1">Disc Stack Centrifuges</h3>
            <p class="text-sm text-gray-600">Self-cleaning separator systems.</p>
          </a>
          <a href="/decanter-centrifuge/" class="block p-4 rounded-lg border border-gray-100 hover:border-[#E8A317] transition-colors">
            <h3 class="font-semibold text-[#1B3A5C] mb-1">Decanter Centrifuges</h3>
            <p class="text-sm text-gray-600">High-solids dewatering systems.</p>
