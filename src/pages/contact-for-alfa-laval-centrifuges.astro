---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqItems = [
  {
    question: "How quickly will Dolphin Centrifuge respond to my inquiry?",
    answer: "Most inquiries receive a response within a few business days. Providing complete application details - fluid type, flow rate, solids content, and whether you need new or remanufactured equipment - allows our engineers to prepare an accurate recommendation on the first response."
  },
  {
    question: "Does Dolphin Centrifuge offer sample testing before purchase?",
    answer: "Yes. Dolphin Centrifuge operates a fully equipped <a href='/industrial-centrifuge-sample-testing/'>sample testing lab</a> at our Warren, Michigan facility. Send us a sample of your fluid and we will run it through the appropriate centrifuge, document the results with before-and-after photos, and provide a detailed report with recommended equipment sizing and a brief testing video. This is a paid service - contact us for a quote."
  },
  {
    question: "What information should I include in my centrifuge quote request?",
    answer: "Include the type of fluid you need to process, the required flow rate or daily volume, estimated solids content by weight, whether you need new or remanufactured equipment, and any special requirements such as suitability for haz. areas, all stainless steel wetted parts, VITON gaskets. The more detail you provide, the faster and more precise our recommendation will be."
  },
  {
    question: "Does Dolphin Centrifuge ship internationally?",
    answer: "Yes. Dolphin Centrifuge ships centrifuge systems, parts, and accessories worldwide. We have supplied equipment to customers across North America, South America, Europe, the Middle East, Africa, and Asia. Contact us for freight estimates and export documentation."
  },
  {
    question: "Can I visit the Dolphin Centrifuge facility in Warren, Michigan?",
    answer: "Absolutely. We welcome visits from prospective customers who want to inspect our in-stock <a href='/disc-stack-centrifuge/'>disc stack centrifuges</a> and <a href='/decanter-centrifuge/'>decanter centrifuges</a>. Our warehouse at 24248 Gibson Dr, Warren MI 48089 maintains over 200 centrifuges available for rebuild and custom configuration. Call (248) 522-2573 to schedule a visit."
  }
];

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "headline": "Contact Dolphin Centrifuge - Industrial Centrifuge Quote",
  "description": "Contact Dolphin Centrifuge in Warren, Michigan for industrial centrifuge quotes, parts, repair, and sample testing. 200+ units in stock. Engineers respond within a few business days.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  },
  "url": "https://dolphincentrifuge.com/contact-for-alfa-laval-centrifuges/",
  "mainEntityOfPage": "https://dolphincentrifuge.com/contact-for-alfa-laval-centrifuges/"
};

const localBusinessJsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Dolphin Centrifuge",
  "url": "https://dolphincentrifuge.com",
  "telephone": "+1-248-522-2573",
  "email": "sales@dolphincentrifuge.com",
  "image": "https://dolphincentrifuge.com/images/about-dolphin-centrifuge/Dolphin-Centrifuge-Shop-Warren-1000.webp",
  "description": "Industrial centrifuge sales, service, and remanufacturing. Specializing in disc stack and decanter centrifuge systems for oil, wastewater, chemical, and marine applications.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "24248 Gibson Dr",
    "addressLocality": "Warren",
    "addressRegion": "MI",
    "postalCode": "48089",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 42.473361,
    "longitude": -83.00227
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "08:00",
    "closes": "17:00"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+1-248-522-2573",
    "contactType": "sales",
    "email": "sales@dolphincentrifuge.com",
    "availableLanguage": "English",
    "areaServed": "Worldwide"
  },
  "areaServed": {
    "@type": "Country",
    "name": "Worldwide"
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};
---

<ApplicationLayout
  title="Contact Dolphin Centrifuge - Industrial Centrifuge Quote | Warren, MI"
  description="Get a centrifuge quote from Dolphin Centrifuge in Warren, MI. 200+ disc stack and decanter centrifuges in stock. Same-day response. Call (248) 522-2573."
  heroImage="/images/about-dolphin-centrifuge/Dolphin-Centrifuge-Shop-Warren-1000.webp"
  heroImageAlt="Dolphin Centrifuge facility in Warren, Michigan - industrial centrifuge manufacturing and service center"
  category="contact"
  categoryLabel="Contact"
  canonicalUrl="https://dolphincentrifuge.com/contact-for-alfa-laval-centrifuges/"
  jsonLd={[articleJsonLd, localBusinessJsonLd, faqJsonLd]}
  relatedProducts={[
    { label: "Disc Stack Centrifuges", href: "/disc-stack-centrifuge/", description: "Self-cleaning separator systems" },
    { label: "Decanter Centrifuges", href: "/decanter-centrifuge/", description: "High-solids dewatering systems" },
    { label: "Centrifuge Parts", href: "/alfa-laval-centrifuge-parts/", description: "OEM-equivalent replacement parts" }
  ]}
  relatedApplications={[
    { label: "All Applications", href: "/disc-stack-centrifuge-applications/" },
    { label: "Sample Testing", href: "/industrial-centrifuge-sample-testing/" },
    { label: "Centrifuge Repair & Service", href: "/industrial-disc-centrifuge-repair/" },
    { label: "About Dolphin Centrifuge", href: "/about-dolphin-centrifuge/" }
  ]}
>

  <!-- H1 first — SEO requires H1 before any H2 -->
  <h1 class="text-3xl font-bold text-navy font-heading mb-2">Contact Dolphin Centrifuge - Industrial Centrifuge Quote</h1>

  <!-- Find Us in Warren, MI -->
  <h2>Find Us in Warren, Michigan</h2>
  <p class="text-text mb-4">
    Dolphin Centrifuge is located in the heart of the Detroit Metro industrial district in Warren, Michigan. We welcome visits from prospective customers who want to see our facility and in-stock <a href="/alfa-laval-centrifuges/" class="text-navy font-medium underline decoration-gold underline-offset-2 hover:text-gold-dark">centrifuge inventory</a>. Our warehouse maintains over 200 centrifuges ready for inspection, testing, and immediate shipment.
  </p>
  <p class="text-text mb-8">
    Whether you are looking for a complete <a href="/disc-stack-centrifuge/" class="text-navy font-medium underline decoration-gold underline-offset-2 hover:text-gold-dark">turnkey centrifuge system</a>, <a href="/alfa-laval-centrifuge-parts/" class="text-navy font-medium underline decoration-gold underline-offset-2 hover:text-gold-dark">replacement parts</a>, or expert centrifuge <a href="/industrial-disc-centrifuge-repair/" class="text-navy font-medium underline decoration-gold underline-offset-2 hover:text-gold-dark">service and repair</a>, our team of experienced engineers and technicians is available to assist you.
  </p>

  <!-- CONTACT HERO BANNER -->
  <div class="not-prose relative bg-navy rounded-2xl overflow-hidden mb-10 px-8 py-10 md:py-12">
    <!-- Subtle grid texture -->
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(0deg,#fff 0,#fff 1px,transparent 1px,transparent 40px),repeating-linear-gradient(90deg,#fff 0,#fff 1px,transparent 1px,transparent 40px);"></div>
    <div class="relative z-10 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div>
        <p class="text-gold text-sm font-bold uppercase tracking-widest mb-2">Get a Quote - Warren, Michigan</p>
        <p class="text-white text-3xl md:text-4xl font-bold font-heading mb-3 leading-tight">Contact Dolphin Centrifuge</p>
        <p class="text-white/70 text-base max-w-xl">Fill in your application details below and our centrifuge engineers will respond within a few business days.</p>
      </div>
      <div class="flex flex-col gap-3 shrink-0">
        <a href="tel:+12485222573" class="flex items-center gap-3 bg-gold text-navy font-bold px-6 py-3 rounded-xl hover:bg-gold/90 transition-all text-sm whitespace-nowrap shadow-lg">
          <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
          (248) 522-2573
        </a>
        <a href="mailto:sales@dolphincentrifuge.com" class="flex items-center gap-3 border-2 border-white/30 text-white font-semibold px-6 py-3 rounded-xl hover:bg-white/10 transition-all text-sm whitespace-nowrap">
          <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          sales@dolphincentrifuge.com
        </a>
      </div>
    </div>
  </div>

  <!-- MAIN SECTION - Full Width Form -->
  <section id="contact-form" class="scroll-mt-20">

    <!-- FORM: Full width -->
    <div class="not-prose">
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 md:p-8">

          <p class="text-text text-sm mb-6 leading-relaxed">
            Please fill in as many details as possible to allow us to help you find the most effective centrifuge for your process. Providing complete application details enables our engineers to recommend the most suitable centrifuge configuration.
          </p>

          <!-- Success Toast Popup (fixed, green, auto-dismiss) -->
          <div id="form-success" class="hidden fixed top-6 left-1/2 -translate-x-1/2 z-50 w-full max-w-lg px-4" role="alert" aria-live="assertive">
            <div class="bg-green-600 rounded-2xl shadow-2xl overflow-hidden">
              <div class="flex items-start gap-5 px-7 pt-6 pb-5">
                <!-- Checkmark circle -->
                <div class="shrink-0 w-12 h-12 bg-white/25 rounded-full flex items-center justify-center">
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <!-- Text -->
                <div class="flex-1">
                  <p class="text-white font-bold text-lg mb-1">Submission Received &#x2713;</p>
                  <p class="text-white/90 text-sm leading-relaxed mb-1">Our centrifuge engineers will review your application and respond within a few business days.</p>
                  <p class="text-white/80 text-xs mb-1">Need immediate help? Call <a href="tel:+12485222573" class="text-white font-bold underline">(248) 522-2573</a></p>
                  <p id="redirect-msg" class="hidden text-white/75 text-xs"></p>
                </div>
                <!-- Close button -->
                <button id="success-close" aria-label="Close" class="shrink-0 bg-transparent border-none cursor-pointer text-white/80 text-2xl leading-none pl-2">&times;</button>
              </div>
              <!-- Auto-dismiss countdown bar -->
              <div class="h-1 bg-white/20">
                <div id="success-bar" class="h-1 bg-white/70 w-full" style="transition:width linear;"></div>
              </div>
            </div>
          </div>

          <!-- Error Message -->
          <div id="form-error" class="hidden bg-red-50 border border-red-200 rounded-xl p-4 mb-5">
            <p class="text-red-700 text-sm font-semibold" id="form-error-text">An error occurred. Please try again or call (248) 522-2573.</p>
          </div>

          <form id="centrifuge-contact-form" class="space-y-8" novalidate>

            <!-- Honeypot trap -->
            <div style="display:none" aria-hidden="true">
              <label>Leave this empty: <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label>
            </div>

            <!-- SECTION 1: Customer Details -->
            <div>
              <div class="flex items-center gap-3 mb-5">
                <div class="w-7 h-7 bg-navy rounded-full flex items-center justify-center shrink-0">
                  <span class="text-gold text-xs font-bold">1</span>
                </div>
                <h3 class="text-base font-bold text-navy font-heading uppercase tracking-wide">Customer Details</h3>
              </div>

              <div class="space-y-4">

                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label for="first_name" class="block text-xs font-bold text-navy uppercase tracking-wide mb-1.5">First Name <span class="text-red-500">*</span></label>
                    <input type="text" id="first_name" name="first_name" required placeholder="First"
                      class="w-full border-2 border-gray-200 rounded-xl px-4 py-2.5 text-sm text-text focus:outline-none focus:border-navy transition-colors" />
                  </div>
                  <div>
                    <label for="last_name" class="block text-xs font-bold text-navy uppercase tracking-wide mb-1.5">Last Name <span class="text-red-500">*</span></label>
                    <input type="text" id="last_name" name="last_name" required placeholder="Last"
                      class="w-full border-2 border-gray-200 rounded-xl px-4 py-2.5 text-sm text-text focus:outline-none focus:border-navy transition-colors" />
                  </div>
                </div>

                <div>
                  <label for="company" class="block text-xs font-bold text-navy uppercase tracking-wide mb-1.5">Company Name <span class="text-red-500">*</span></label>
                  <input type="text" id="company" name="company" required
                    class="w-full border-2 border-gray-200 rounded-xl px-4 py-2.5 text-sm text-text focus:outline-none focus:border-navy transition-colors" />
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label for="email" class="block text-xs font-bold text-navy uppercase tracking-wide mb-1.5">Email <span class="text-red-500">*</span></label>
                    <input type="email" id="email" name="email" required placeholder="your@company.com"
                      class="w-full border-2 border-gray-200 rounded-xl px-4 py-2.5 text-sm text-text focus:outline-none focus:border-navy transition-colors" />
                  </div>
                  <div>
                    <label for="email_confirm" class="block text-xs font-bold text-navy uppercase tracking-wide mb-1.5">Confirm Email <span class="text-red-500">*</span></label>
                    <input type="email" id="email_confirm" name="email_confirm" required placeholder="Confirm email"
                      class="w-full border-2 border-gray-200 rounded-xl px-4 py-2.5 text-sm text-text focus:outline-none focus:border-navy transition-colors" />
                  </div>
                </div>

                <div>
                  <label for="phone" class="block text-xs font-bold text-navy uppercase tracking-wide mb-1.5">Phone <span class="text-red-500">*</span></label>
                  <input type="tel" id="phone" name="phone" required
                    class="w-full border-2 border-gray-200 rounded-xl px-4 py-2.5 text-sm text-text focus:outline-none focus:border-navy transition-colors" />
                </div>

                <!-- Preferred Contact Method - inside the form -->
                <div class="bg-gray-50 rounded-xl p-4 border-2 border-gray-200">
                  <label class="block text-xs font-bold text-navy uppercase tracking-wide mb-3">Preferred Method of Contact <span class="text-red-500">*</span></label>
                  <div class="space-y-2.5">
                    {[
                      { value: "phone_dolphin_calls", label: "Phone - Dolphin Centrifuge calls you" },
                      { value: "phone_you_call",      label: "Phone - You call us: (248) 522-2573" },
                      { value: "email",               label: "Email" },
                    ].map(opt => (
                      <label class="flex items-center gap-3 cursor-pointer group">
                        <input type="radio" name="contact_method" value={opt.value} required
                          class="w-4 h-4 accent-navy shrink-0" />
                        <span class="text-sm text-text group-hover:text-navy transition-colors">{opt.label}</span>
                      </label>
                    ))}
                  </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label for="country" class="block text-xs font-bold text-navy uppercase tracking-wide mb-1.5">Country <span class="text-red-500">*</span></label>
                    <select id="country" name="country" required
                      class="w-full border-2 border-gray-200 rounded-xl px-4 py-2.5 text-sm text-text focus:outline-none focus:border-navy transition-colors bg-white">
                      <option value="">Select...</option>
                      <option value="US">United States</option>
                      <option value="CA">Canada</option>
                      <option value="MX">Mexico</option>
                      <option value="Other">Other</option>
                    </select>
                  </div>
                  <div>
                    <label for="us_state" class="block text-xs font-bold text-navy uppercase tracking-wide mb-1.5">US State</label>
                    <select id="us_state" name="us_state"
                      class="w-full border-2 border-gray-200 rounded-xl px-4 py-2.5 text-sm text-text focus:outline-none focus:border-navy transition-colors bg-white">
                      <option value="">Select state...</option>
                      <option>Alabama</option><option>Alaska</option><option>Arizona</option>
                      <option>Arkansas</option><option>California</option><option>Colorado</option>
                      <option>Connecticut</option><option>Delaware</option><option>Florida</option>
                      <option>Georgia</option><option>Hawaii</option><option>Idaho</option>
                      <option>Illinois</option><option>Indiana</option><option>Iowa</option>
                      <option>Kansas</option><option>Kentucky</option><option>Louisiana</option>
                      <option>Maine</option><option>Maryland</option><option>Massachusetts</option>
                      <option>Michigan</option><option>Minnesota</option><option>Mississippi</option>
                      <option>Missouri</option><option>Montana</option><option>Nebraska</option>
                      <option>Nevada</option><option>New Hampshire</option><option>New Jersey</option>
                      <option>New Mexico</option><option>New York</option><option>North Carolina</option>
                      <option>North Dakota</option><option>Ohio</option><option>Oklahoma</option>
                      <option>Oregon</option><option>Pennsylvania</option><option>Rhode Island</option>
                      <option>South Carolina</option><option>South Dakota</option><option>Tennessee</option>
                      <option>Texas</option><option>Utah</option><option>Vermont</option>
                      <option>Virginia</option><option>Washington</option><option>West Virginia</option>
                      <option>Wisconsin</option><option>Wyoming</option>
                    </select>
                  </div>
                </div>

                <!-- Other country — shown only when 'Other' is selected -->
                <div id="country-other-wrap" style="display:none;">
                  <label for="country_other" class="block text-xs font-bold text-navy uppercase tracking-wide mb-1.5">Please specify your country <span class="text-red-500">*</span></label>
                  <input type="text" id="country_other" name="country_other"
                    placeholder="e.g. Germany, Brazil, India…"
                    class="w-full border-2 border-gray-200 rounded-xl px-4 py-2.5 text-sm text-text focus:outline-none focus:border-navy transition-colors" />
                </div>

              </div>
            </div>

            <!-- SECTION 2: Application Details -->
            <div>
              <div class="flex items-center gap-3 mb-5">
                <div class="w-7 h-7 bg-navy rounded-full flex items-center justify-center shrink-0">
                  <span class="text-gold text-xs font-bold">2</span>
                </div>
                <h3 class="text-base font-bold text-navy font-heading uppercase tracking-wide">Application Details</h3>
              </div>

              <div class="space-y-4">

                <div>
                  <label for="fluid_type" class="block text-xs font-bold text-navy uppercase tracking-wide mb-1.5">Type of Fluid <span class="text-red-500">*</span></label>
                  <input type="text" id="fluid_type" name="fluid_type" required autocomplete="off"
                    placeholder="e.g. Diesel Fuel, Pyrolysis Oil, Lube Oil, Waste Water"
                    class="w-full border-2 border-gray-200 rounded-xl px-4 py-2.5 text-sm text-text focus:outline-none focus:border-navy transition-colors" />
                  <p class="text-xs text-gray-400 mt-1">Describe the fluid you want to process through the centrifuge.</p>
                </div>

                <div>
                  <label for="capacity" class="block text-xs font-bold text-navy uppercase tracking-wide mb-1.5">Capacity Required <span class="text-red-500">*</span></label>
                  <input type="text" id="capacity" name="capacity" required autocomplete="off"
                    placeholder="e.g. 50 GPM, or 10,000 gallons/day"
                    class="w-full border-2 border-gray-200 rounded-xl px-4 py-2.5 text-sm text-text focus:outline-none focus:border-navy transition-colors" />
                  <p class="text-xs text-gray-400 mt-1">Provide the expected processing volume. Estimates are fine.</p>
                </div>

                <div>
                  <label for="solids_percentage" class="block text-xs font-bold text-navy uppercase tracking-wide mb-1.5">Percentage of Solids by Volume <span class="text-gray-400 font-normal normal-case">(optional)</span></label>
                  <input type="text" id="solids_percentage" name="solids_percentage" autocomplete="off"
                    placeholder="e.g. 2%, or unknown"
                    class="w-full border-2 border-gray-200 rounded-xl px-4 py-2.5 text-sm text-text focus:outline-none focus:border-navy transition-colors" />
                  <p class="text-xs text-gray-400 mt-1">Estimate if known — not required.</p>
                </div>

                <!-- New vs Reman -->
                <div class="bg-gray-50 rounded-xl p-4 border-2 border-gray-200">
                  <label class="block text-xs font-bold text-navy uppercase tracking-wide mb-1.5">Centrifuge Condition Required <span class="text-red-500">*</span></label>
                  <p class="text-xs text-gray-500 mb-3">Would you consider a remanufactured centrifuge with warranty on a new skid?</p>
                  <div class="space-y-2.5">
                    <label class="flex items-center gap-3 cursor-pointer group">
                      <input type="radio" name="centrifuge_condition" value="new_required" required class="w-4 h-4 accent-navy shrink-0" />
                      <span class="text-sm text-text group-hover:text-navy transition-colors">New - Centrifuge must be new</span>
                    </label>
                    <label class="flex items-center gap-3 cursor-pointer group">
                      <input type="radio" name="centrifuge_condition" value="remanufactured_ok" class="w-4 h-4 accent-navy shrink-0" />
                      <span class="text-sm text-text group-hover:text-navy transition-colors">Remanufactured Acceptable</span>
                    </label>
                  </div>
                </div>

                <div>
                  <label for="additional_details" class="block text-xs font-bold text-navy uppercase tracking-wide mb-1.5">Additional Details</label>
                  <textarea id="additional_details" name="additional_details" rows="5" autocomplete="off"
                    placeholder="Describe your application - temperature, pressure, contaminants, timeline, existing equipment, etc."
                    class="w-full border-2 border-gray-200 rounded-xl px-4 py-2.5 text-sm text-text focus:outline-none focus:border-navy transition-colors resize-none"
                  ></textarea>
                </div>

                <!-- Submit -->
                <button type="submit" id="submit-btn"
                  class="w-full bg-navy text-white font-bold py-4 px-8 rounded-xl text-base hover:bg-gold hover:text-navy transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2">
                  <span id="submit-btn-text">Submit Application Details</span>
                  <span id="submit-btn-loading" class="hidden">Sending your inquiry...</span>
                </button>

                <p class="text-xs text-center text-gray-400">We respond to all inquiries within a few business days.</p>

              </div>
            </div>

          </form>
      </div>
    </div>

    <!-- REACH US DIRECTLY: Full width below form -->
    <div class="not-prose mt-5">
      <div class="bg-navy rounded-2xl px-5 py-4 text-white">
        <h2 class="text-base font-bold font-heading mb-2 text-white uppercase tracking-wide">Reach Us Directly</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-2">
