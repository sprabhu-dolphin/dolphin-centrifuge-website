          alt="Decanter Centrifuge Cross Section Diagram showing feed zone, beach section, bowl, and scroll conveyor"
          width="600" height="223"
          loading="lazy"
          class="rounded-lg w-full"
        />
        <p class="text-sm text-gray-500 mt-2 text-center">Decanter Centrifuge Cross Section</p>
