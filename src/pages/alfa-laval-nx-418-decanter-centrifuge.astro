          <table class="w-full text-sm border-collapse">
            <tbody>
              <tr class="border-b border-gray-200">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C] w-1/2">Model Type</td>
                <td class="py-3 font-mono font-bold">Alfa Laval NX 418 B31-G Decanter Centrifuge</td>
              </tr>
              <tr class="border-b border-gray-200 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Rated Capacity</td>
                <td class="py-3 font-mono font-bold">110 GPM on Water Sludge Thickening</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Auger Differential Speed</td>
                <td class="py-3 font-mono">1 ~ 50 RPM</td>
              </tr>
              <tr class="border-b border-gray-200 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Drive Motor Power</td>
                <td class="py-3 font-mono">20 HP</td>
              </tr>
