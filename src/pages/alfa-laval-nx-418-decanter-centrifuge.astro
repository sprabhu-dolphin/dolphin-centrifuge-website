              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">GearBox Ratio</td>
                <td class="py-3 font-mono">1 : 159 (2.5 kN-M)</td>
              </tr>
              <tr class="border-b border-gray-200 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Bowl Speed</td>
