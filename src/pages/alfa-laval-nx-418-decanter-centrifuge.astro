    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" }
};

const jsonLd = [
  articleJsonLd,
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Alfa Laval NX-418 Decanter Centrifuge",
    "description": "Alfa Laval NX 418 B31-G two-phase decanter centrifuge for wastewater sludge thickening, crude oil tank bottoms, paint sludge, and industrial dewatering. 110 GPM capacity, 4,000 RPM bowl speed, 3,150 RCF G-Force, 20 HP drive motor. Also available as UVNX 418 B-11 three-phase tricanter for fish oil, olive oil, and animal fat rendering at 70 GPM.",
    "brand": {
      "@type": "Brand",
      "name": "Alfa Laval"
    },
    "manufacturer": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge",
      "telephone": "(248) 522-2573",
      "email": "sales@dolphincentrifuge.com"
    },
    "model": "NX 418 B31-G",
    "offers": {
      "@type": "Offer",
      "seller": {
        "@type": "Organization",
        "name": "Dolphin Centrifuge"
      },
      "availability": "https://schema.org/InStock"
    }
  }
];

const toc = [
  { id: "nx418-two-phase", label: "NX 418 Two-Phase Decanter Overview" },
  { id: "applications", label: "Applications" },
  { id: "cross-section", label: "Cross Section Diagram" },
  { id: "specifications-two-phase", label: "Two-Phase Specifications" },
