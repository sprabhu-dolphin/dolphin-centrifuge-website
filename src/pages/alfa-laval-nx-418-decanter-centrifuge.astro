            <span class="text-[#E8A317] font-bold mt-0.5">&#10003;</span>
            <span class="text-[#2D2D2D]">Paint Sludge Handling</span>
          </li>
        </ul>
      </div>

      <!-- Cross Section Diagram -->
      <div id="cross-section" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Cross Section Diagram</h2>
        <img
