---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval NX-418 Decanter Centrifuge",
  "description": "Alfa Laval NX 418 B31-G two-phase decanter centrifuge for wastewater sludge thickening, crude oil tank bottoms, paint sludge, and industrial dewatering. 110 GPM capacity, 4,000 RPM bowl speed, 3,150 RCF G-Force, 20 HP drive motor. Also available as UVNX 418 B-11 three-phase tricanter for fish oil, olive oil, and animal fat rendering at 70 GPM.",
  "brand": {
    "@type": "Brand",
    "name": "Alfa Laval"
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "telephone": "(248) 522-2573",
    "email": "sales@dolphincentrifuge.com"
  },
  "model": "NX 418 B31-G",
  "offers": {
    "@type": "Offer",
    "seller": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    },
    "availability": "https://schema.org/InStock"
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the rated capacity of the Alfa Laval NX 418 decanter centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Alfa Laval NX 418 B31-G two-phase decanter centrifuge has a rated capacity of 110 GPM on water sludge thickening. The three-phase UVNX 418 variant has a rated capacity of 70 GPM on fish stickwater and fishmeal separation."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between the NX 418 and UVNX 418 decanter centrifuges?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The NX 418 is a two-phase decanter centrifuge designed for liquid-solid separation such as sludge thickening and dewatering. The UVNX 418 is a three-phase decanter (tricanter) designed for liquid-liquid-solid separation applications such as fish oil, olive oil, and animal fat rendering."
      }
    }
  ]
};
---

<BaseLayout
  title="Alfa Laval NX-418 Decanter Centrifuge"
  description="Alfa Laval NX-418 decanter centrifuge specs, parts, and service. 110 GPM, 3,150 Gs. Dolphin Centrifuge: NX-418 sales, rebuilds, and spare parts."
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-nx-418-decanter-centrifuge/"
  breadcrumbs={[{label: 'Products', href: '/centrifuges/'}, {label: 'Alfa Laval NX-418 Decanter'}]}
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <section class="bg-[#1B3A5C] text-white py-14 md:py-20">
    <div class="container-dolphin max-w-5xl">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <div class="text-[#E8A317] text-sm font-semibold uppercase tracking-wider mb-3">Decanter Centrifuge</div>
          <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-5">
            Alfa Laval NX 418 Decanter | Sludge Thickening Centrifuge
          </h1>
          <p class="text-lg text-gray-200 mb-6">Dolphin Centrifuge provides expert service, genuine parts, and fully reconditioned units for this model. The Alfa Laval NX 418 is a horizontal de-sludging decanter centrifuge built for the two-phase separation of wastewater, crude oil tank bottoms, municipal sludge thickening, industrial sludge dewatering, and paint sludge handling. With a 20 HP motor, the NX 418 delivers a bowl RPM of 4,000 and can process 110 GPM of water with light sludge.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] hover:bg-yellow-500 text-white font-semibold px-6 py-3 rounded-lg transition">Request Quote</a>
            <a href="tel:+12485222573" class="border border-white text-white hover:bg-white hover:text-[#1B3A5C] font-semibold px-6 py-3 rounded-lg transition">(248) 522-2573</a>
          </div>
        </div>
        <div>
          <img
            src="/images/alfa-laval-nx-418-decanter-centrifuge/3-phase-rendering-decanter-centrifuge.webp"
            alt="Remanufactured Alfa Laval NX 418 Decanter Centrifuge"
            width="600" height="400"
            loading="eager"
            class="rounded-xl w-full shadow-lg"
          />
          <p class="text-sm text-gray-300 mt-2 text-center">Remanufactured Alfa Laval NX 418 Decanter Centrifuge</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="bg-[#F5F5F0] py-12 md:py-16">
    <div class="container-dolphin max-w-4xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
        <p class="text-sm text-text-light leading-relaxed italic">The Alfa Laval NX-418 is a two-phase horizontal decanter centrifuge rated at approximately 60 GPM, designed for separating solids from liquids in high-volume applications including crude oil tank bottoms, wastewater sludge, WVO processing, and botanical extraction. Dolphin Centrifuge supplies the NX-418 as a complete configured system with PLC controls and optional Class 1 Division 2 explosion-proof certification. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of decanter centrifuge experience.</p>
      </div>

      <!-- Table of Contents -->
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-lg font-bold text-[#1B3A5C] mb-4">Table of Contents</h2>
        <nav>
          <ul class="space-y-1 text-sm">
            <li><a href="#nx418-two-phase" class="text-[#1B3A5C] hover:text-[#E8A317]">Alfa Laval NX 418 B31-G Two-Phase Decanter Centrifuge</a></li>
            <li><a href="#applications" class="text-[#1B3A5C] hover:text-[#E8A317]">Applications</a></li>
            <li><a href="#cross-section" class="text-[#1B3A5C] hover:text-[#E8A317]">Cross Section Diagram</a></li>
            <li><a href="#specifications-two-phase" class="text-[#1B3A5C] hover:text-[#E8A317]">Specifications</a></li>
            <li><a href="#uvnx418" class="text-[#1B3A5C] hover:text-[#E8A317]">Alfa Laval UVNX 418 B-11 Three-Phase Decanter Centrifuge (Tricanter)</a></li>
            <li><a href="#specifications-three-phase" class="text-[#1B3A5C] hover:text-[#E8A317]">Specifications (Three-Phase)</a></li>
            <li><a href="#gallery" class="text-[#1B3A5C] hover:text-[#E8A317]">Used Alfa Laval NX 418 Photo Gallery</a></li>
            <li><a href="#faq" class="text-[#1B3A5C] hover:text-[#E8A317]">Frequently Asked Questions</a></li>
          </ul>
        </nav>
      </div>

      <!-- NX 418 Two-Phase Overview -->
      <div id="nx418-two-phase" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Alfa Laval NX 418 B31-G Two-Phase Decanter Centrifuge</h2>
        <p class="text-[#2D2D2D] mb-4">
          The Alfa Laval NX 418 <a href="/decanter-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317]">Decanter Centrifuge</a> is a horizontal de-sludging centrifuge built for the two-phase separation of <strong>wastewater</strong>, <strong>crude oil tank bottoms</strong>, municipal <strong>sludge-thickening</strong>, industrial sludge dewatering, <strong>paint sludge handling</strong>, etc.
        </p>
        <p class="text-[#2D2D2D]">
          With a 20 HP Motor, the NX 418 decanter has a <strong>bowl RPM of 4,000</strong> and can process <strong>110 GPM of water with light sludge</strong>.
        </p>
      </div>

      <!-- Applications -->
      <div id="applications" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Applications</h2>
        <p class="text-[#2D2D2D] mb-4">The Alfa Laval NX-418 Decanter is used for the following applications.</p>
        <ul class="grid md:grid-cols-2 gap-x-8 gap-y-2 text-sm">
          <li class="flex items-start gap-2">
            <span class="text-[#E8A317] font-bold mt-0.5">&#10003;</span>
            <a href="/ethanol-extraction-centrifuges-technical-comparison/" class="text-[#1B3A5C] hover:text-[#E8A317]">Ethanol Extraction Centrifuge</a>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#E8A317] font-bold mt-0.5">&#10003;</span>
            <a href="/waste-oil-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317]">Waste Oil De-sludging</a>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#E8A317] font-bold mt-0.5">&#10003;</span>
            <a href="/crude-oil-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317]">Crude Oil Tank Bottom Sludge</a>
