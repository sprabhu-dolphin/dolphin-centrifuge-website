          <li class="flex items-start gap-2">
            <span class="text-[#E8A317] font-bold mt-0.5">&#10003;</span>
            <a href="/wastewater-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317]">Municipal Wastewater</a>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#E8A317] font-bold mt-0.5">&#10003;</span>
            <a href="/pyrolysis-oil-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317]">Pyrolysis Sludge Separation</a>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#E8A317] font-bold mt-0.5">&#10003;</span>
            <a href="/liquid-humus-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317]">Liquid Humus Fertilizer</a>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#E8A317] font-bold mt-0.5">&#10003;</span>
