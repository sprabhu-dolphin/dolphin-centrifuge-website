          width="600" height="420"
          loading="lazy"
          class="rounded-lg w-full mb-3"
        />
        <p class="text-sm text-gray-500 mb-6 text-center">Decanter Centrifuge for Ethanol Extraction</p>
      </div>

      <!-- Specifications Three-Phase -->
      <div id="specifications-three-phase" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Specifications — UVNX 418 B-11 Three-Phase Decanter</h2>
        <p class="text-[#2D2D2D] mb-4">The following are the technical specifications for the Alfa Laval UVNX 418 B11-G three-phase decanter centrifuge (tricanter).</p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <tbody>
              <tr class="border-b border-gray-200">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C] w-1/2">Model Type</td>
                <td class="py-3 font-mono font-bold">Alfa Laval UVNX 418 B11-G (<a href="/three-phase-decanter/" class="text-[#1B3A5C] hover:text-[#E8A317]">Three-Phase Decanter</a>)</td>
              </tr>
              <tr class="border-b border-gray-200 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Rated Capacity</td>
                <td class="py-3 font-mono font-bold">70 GPM on Fish Stickwater &amp; Fishmeal Separation</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Auger Differential Speed</td>
