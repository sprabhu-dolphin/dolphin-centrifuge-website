      <!-- Specifications Two-Phase -->
      <div id="specifications-two-phase" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Specifications</h2>
        <p class="text-[#2D2D2D] mb-4">The following are the technical specifications for the Alfa Laval NX 418 B31-G two-phase decanter centrifuge.</p>
