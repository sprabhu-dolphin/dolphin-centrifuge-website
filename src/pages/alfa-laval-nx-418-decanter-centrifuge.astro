    "name": "Alfa Laval NX-418 Decanter Centrifuge",
    "description": "Alfa Laval NX 418 B31-G two-phase decanter centrifuge for wastewater sludge thickening, crude oil tank bottoms, paint sludge, and industrial dewatering. 110 GPM capacity, 4,000 RPM bowl speed, 3,150 RCF G-Force, 20 HP drive motor. Also available as UVNX 418 B-11 three-phase tricanter for fish oil, olive oil, and animal fat rendering at 70 GPM.",
    "brand": {
      "@type": "Brand",
      "name": "Alfa Laval"
    },
    "manufacturer": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge",
      "telephone": "(248) 522-2573",
      "email": "sales@dolphincentrifuge.com"
    },
    "model": "NX 418 B31-G",
    "offers": {
      "@type": "Offer",
      "seller": {
        "@type": "Organization",
        "name": "Dolphin Centrifuge"
      },
      "availability": "https://schema.org/InStock"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the rated capacity of the Alfa Laval NX 418 decanter centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Alfa Laval NX 418 B31-G two-phase decanter centrifuge has a rated capacity of 110 GPM on water sludge thickening. The three-phase UVNX 418 variant has a rated capacity of 70 GPM on fish stickwater and fishmeal separation."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between the NX 418 and UVNX 418 decanter centrifuges?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The NX 418 is a two-phase decanter centrifuge designed for liquid-solid separation such as sludge thickening and dewatering. The UVNX 418 is a three-phase decanter (tricanter) designed for liquid-liquid-solid separation applications such as fish oil, olive oil, and animal fat rendering."
        }
