                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">GearBox Ratio</td>
                <td class="py-3 font-mono">1 : 159 (2.5 kN-M)</td>
              </tr>
              <tr class="border-b border-gray-200 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">AE (Area Equivalent)</td>
                <td class="py-3 font-mono">1,565</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Bowl Speed</td>
                <td class="py-3 font-mono">4,000 RPM</td>
              </tr>
              <tr class="border-b border-gray-200 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">G-Force</td>
                <td class="py-3 font-mono font-bold">3,150 RCF</td>
              </tr>
              <tr class="bg-[#1B3A5C] text-white">
                <td class="py-3 pr-4 font-semibold">Conveyor Protection</td>
                <td class="py-3 font-mono">Carbide Tile or Tungsten Carbide Hard-Surfacing</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- UVNX 418 Three-Phase -->
      <div id="uvnx418" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Alfa Laval UVNX 418 B-11 Three-Phase Decanter Centrifuge (Tricanter)</h2>
