const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are the main wear parts in a disc stack centrifuge?",
      "acceptedAnswer": { "@type": "Answer", "text": "The primary wear parts are the disc stack (separation discs), gravity disc, paring disc, neck bearing, hood ring, operating water valve, and bowl seals. The disc stack and seals are the most frequently replaced items in routine maintenance." }
    },
    {
      "@type": "Question",
      "name": "Does Dolphin Centrifuge supply OEM or aftermarket parts?",
      "acceptedAnswer": { "@type": "Answer", "text": "Dolphin Centrifuge supplies both OEM and high-quality aftermarket replacement parts for disc stack centrifuges, including Alfa Laval models. Aftermarket parts are manufactured to OEM dimensions and meet the same performance specifications at a lower cost." }
    },
    {
      "@type": "Question",
      "name": "How do I know when to replace the gravity disc?",
      "acceptedAnswer": { "@type": "Answer", "text": "Replace the gravity disc when it shows visible wear, corrosion, or dimensional changes that alter the separation radius. If the centrifuge produces excessive liquid carryover or poor separation despite correct feed conditions, a worn or incorrectly sized gravity disc is often the cause." }
