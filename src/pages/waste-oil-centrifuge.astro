---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';
import DolphinChart from '../components/DolphinChart.astro';
import ProductCard from '../components/ProductCard.astro';

// FAQ items - TO BE POPULATED with real content from RankMath recovery data
// This is a legitimate FAQ page (one of 9). Do NOT use AI-generated questions.
const faqItems: { question: string; answer: string }[] = [];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Waste Oil Centrifuge Systems",
  "url": "https://dolphincentrifuge.com/waste-oil-centrifuge/",
  "description": "Industrial waste oil centrifuges: 3-phase separation up to 12,000 Gs, removes water & solids to 1 micron. Complete turnkey systems from 3 GPM to 100+ GPM.",
