    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

// FAQPage schema - will be re-added when real FAQ content is populated
// const faqJsonLd = {};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "url": "https://dolphincentrifuge.com/waste-oil-centrifuge/",
  "headline": "Waste Oil Centrifuge | Industrial Waste Oil Separation Systems",
  "description": "Industrial waste oil centrifuges: 3-phase separation up to 12,000 Gs, removes water and solids to 1 micron. Complete turnkey systems from 3 GPM to 100+ GPM.",
  "author": {
    "@type": "Person",
