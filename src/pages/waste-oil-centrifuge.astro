---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';
import DolphinChart from '../components/DolphinChart.astro';

const faqItems = [
  {
    question: "What is a waste oil centrifuge?",
    answer: "A waste oil centrifuge is a high-speed industrial separator that uses centrifugal force (up to 12,000 Gs) to remove water, sediment, and fine solid particles from used or contaminated oil. It performs continuous three-phase separation — separating light phase (oil), heavy phase (water), and sludge simultaneously without filter media."
  },
  {
    question: "How does a waste oil centrifuge work?",
    answer: "Waste oil enters the spinning centrifuge bowl, where centrifugal force up to 12,000 Gs causes immediate separation. Heavier water and solids migrate to the outer bowl wall. Clean oil moves to the center and exits under pressure through a built-in pump. Solids are intermittently ejected from the bowl automatically, enabling continuous operation."
  },
  {
    question: "What size waste oil centrifuge do I need?",
    answer: "Waste oil centrifuge sizing depends on daily processing volume, oil viscosity, temperature, and solids content. Centrifuges range from 3 GPM to 100+ GPM. For commercial processors, Dolphin Centrifuge offers turnkey systems from 500 Gal/Day to 10,000+ Gal/Day. Contact us with your application details for accurate sizing."
  },
  {
    question: "Can a centrifuge remove water from waste oil?",
    answer: "Yes. A three-phase disc stack centrifuge simultaneously removes all free water and solids from waste oil. In real-world testing, water content was reduced from 38% by volume to 1.2% by volume in a single pass through an industrial disc centrifuge. A centrifuge is far more effective at water removal than settling tanks or filters."
  },
  {
    question: "What is the difference between a waste oil centrifuge and a filter?",
    answer: "A waste oil centrifuge uses mechanical centrifugal force to continuously separate solids and water without any filter media. A filter accumulates solids until plugged, then requires manual media replacement — adding labor and disposal costs. Centrifuges operate 24/7 with automatic solids ejection, no consumable media, and separate all free water, which filters cannot do."
  },
  {
    question: "What is black diesel and can a centrifuge clean it?",
    answer: "Black diesel refers to used engine oil and other used mineral oils repurposed as fuel for diesel engines and generators. A disc stack centrifuge effectively purifies black diesel by removing all solids and water to produce usable fuel. Dolphin Centrifuge offers dedicated <a href='/black-diesel-centrifuge/'>black diesel centrifuge systems</a>."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Waste Oil Centrifuge Systems",
  "url": "https://dolphincentrifuge.com/waste-oil-centrifuge/",
  "description": "Industrial waste oil centrifuges: 3-phase separation up to 12,000 Gs, removes water & solids to 1 micron. Complete turnkey systems from 3 GPM to 100+ GPM.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "image": "https://dolphincentrifuge.com/images/waste-oil-centrifuge/waste-motor-oil-centrifuge-system.webp",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const jsonLd = [productJsonLd, faqJsonLd];

const toc = [
  { id: 'operation', label: 'Operation' },
  { id: 'performance', label: 'Performance Results' },
  { id: 'factors', label: 'Factors Affecting Performance' },
  { id: 'sizing', label: 'Sizing' },
  { id: 'advantages', label: 'Advantages Over Filters' },
  { id: 'faq', label: 'Waste Oil Centrifuge FAQ' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'black-diesel', label: 'Black Diesel' },
  { id: 'installation', label: 'Installation' },
  { id: 'industrial-scale', label: 'Industrial Scale Processing' },
  { id: 'decanters', label: 'Decanters for High Sludge' },
  { id: 'filter-vs-centrifuge', label: 'Filter vs Centrifuge' },
  { id: 'process-flow', label: 'Process Flow Diagram' },
  { id: 'models', label: 'Centrifuges for Sale' },
];

const relatedApplications = [
  { label: 'Used Oil Centrifuge', href: '/used-oil-centrifuge/' },
  { label: 'Black Diesel Centrifuge', href: '/black-diesel-centrifuge/' },
  { label: 'WVO Centrifuge Separator', href: '/wvo-centrifuge-separator/' },
  { label: 'Waste Oil Emulsion Centrifuge', href: '/waste-oil-emulsion-centrifuge/' },
];

const relatedProducts = [
  { label: 'Alfa Laval WHPX 405', href: '/alfa-laval-whpx-405/', description: '3-phase self-cleaning — 5 GPM @ 180°F' },
  { label: 'Alfa Laval WHPX 513', href: '/alfa-laval-whpx-513/', description: '3-phase self-cleaning — 60 GPM @ 180°F' },
  { label: 'Alfa Laval MOPX 213', href: '/alfa-laval-mopx-209-centrifuge/', description: '3-phase self-cleaning — 40 GPM @ 180°F' },
];
---

<ApplicationLayout
  title="Waste Oil Centrifuge"
  description="Industrial waste oil centrifuges: 3-phase separation up to 12,000 Gs, removes water and solids to 1 micron. Specs, sizing, and systems — Dolphin Centrifuge."
  heroImage="/images/waste-oil-centrifuge/waste-motor-oil-centrifuge-system.webp"
  heroImageAlt="Waste motor oil centrifuge system — industrial disc stack centrifuge for waste oil recovery"
  category="applications"
  categoryLabel="Oil & Fuel"
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
  canonicalUrl="https://dolphincentrifuge.com/waste-oil-centrifuge/"
  jsonLd={jsonLd}
>

  <!-- AI Summary -->
  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies three-phase industrial waste oil centrifuge systems — disc stack separators that continuously remove oil, water, and solids from contaminated waste oil at up to 12,000 Gs. These systems separate particles to 1 micron and all free water, processing 3 to 100+ GPM without filter media. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in industrial oil recovery and waste oil purification.</p>
  </div>

  <!-- ═══ Operation ═══ Pattern A: Image + Text side by side -->
  <div id="operation" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Operation</h2>
    <div class="flex flex-col md:flex-row gap-6 items-start">
      <div class="md:w-[45%] shrink-0">
        <img
          src="/images/waste-oil-centrifuge/Alfa-Laval-Waste-Oil-Centrifuge-P-615-300.webp"
          alt="Alfa Laval Waste Oil Centrifuge P-615 — 10 GPM three-phase disc stack unit"
          width="400"
          height="350"
          loading="lazy"
          class="rounded-lg shadow-sm w-full h-auto object-contain"
        />
        <p class="text-gray-500 text-sm mt-1 text-center">Alfa Laval Waste Oil Centrifuge (10 GPM)</p>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-text text-lg font-semibold mb-4">
          A waste oil centrifuge works by exerting gravitational forces up to 12,000 Gs to separate sediment and water from waste oil. This force separates particles as small as 1 micron from the waste oil. The centrifuge has a flow-through design that enables the continuous flow of the separated contaminants through separate outlets.
        </p>
        <p class="text-text mb-4">
          Three-phase separation means the separation of the three phases in contaminated oil:
        </p>
        <ul class="list-disc pl-6 text-text space-y-2 mb-4">
          <li><strong>Light phase</strong> &mdash; oil (the clean, recovered product)</li>
          <li><strong>Heavy phase</strong> &mdash; water (separated and discharged continuously)</li>
          <li><strong>Sludge</strong> &mdash; solid contaminants (intermittently ejected from the bowl)</li>
        </ul>
        <p class="text-text mb-4">
          A waste oil centrifuge is a heavy-duty, industrial-grade machine. It has the added capacity to <em>self-eject</em> the separated solids. It also discharges the separated water continuously through a discrete heavy-phase outlet.
        </p>
        <p class="text-text">
          <a href="/waste-oil-centrifuge-case-study-marine-and-industrial-waste-oil-recovery/" class="text-navy underline hover:text-gold font-semibold">Waste Oil Recovery Case Study with Ash Removal &rarr;</a>
        </p>
      </div>
    </div>
  </div>

  <!-- ═══ Performance Results ═══ Pattern A: Before/After + Table side by side -->
  <div id="performance" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Performance Results</h2>
    <p class="text-text mb-4">
      Centrifuge performance refers to the cleaning ability of the centrifuge on waste oil. In this section, we answer the question:
    </p>

    <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
      <div class="md:w-[40%] shrink-0">
        <a href="/images/waste-oil-centrifuge/Waste-Oil-Before-and-After-Disc-Stack-Centrifuge.webp" target="_blank" rel="noopener">
          <img
            src="/images/waste-oil-centrifuge/Waste-Oil-Before-and-After-Disc-Stack-Centrifuge.webp"
            alt="Waste Oil Before and After Disc Stack Centrifuge — visible separation showing contaminated oil transformed to clean oil"
            width="400"
            height="300"
            loading="lazy"
            class="rounded-lg shadow-sm w-full h-auto object-contain"
          />
        </a>
        <p class="text-gray-500 text-sm mt-2 text-center">Waste Oil Before and After Disc Stack Centrifuge</p>
      </div>
      <div class="flex-1 min-w-0">
        <h3 class="text-xl font-bold text-navy mb-3">How well does a disc centrifuge clean waste oil?</h3>
        <p class="text-text mb-4">
          The following is a <em>real-world example</em> of our centrifuge performance results on waste oil. The table shows the contaminant levels in waste oil before and after an Alfa Laval MOPX 207 Centrifuge.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-navy text-white">
                <th class="text-left p-2.5 rounded-tl-lg text-xs" colspan="3">Alfa Laval MOPX-207 — 3-Phase, Self-Cleaning</th>
              </tr>
              <tr class="bg-blue-900 text-white">
                <th class="text-left p-2.5 text-xs">Contaminant</th>
                <th class="text-left p-2.5 text-xs">Before</th>
                <th class="text-left p-2.5 text-xs rounded-tr-lg">After</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-white border-b border-gray-100">
                <td class="p-2.5 text-xs">Sediment</td>
                <td class="p-2.5 text-red-600 font-semibold text-xs">0.42% Wt.</td>
                <td class="p-2.5 text-green-700 font-semibold text-xs">0.06% Wt.</td>
              </tr>
              <tr class="bg-light-bg border-b border-gray-100">
                <td class="p-2.5 text-xs">Water</td>
                <td class="p-2.5 text-red-600 font-semibold text-xs">38.0% Vol.</td>
                <td class="p-2.5 text-green-700 font-semibold text-xs">1.2% Vol.</td>
              </tr>
              <tr class="bg-white border-b border-gray-100">
                <td class="p-2.5 text-xs">Aluminum</td>
                <td class="p-2.5 text-red-600 font-semibold text-xs">495 ppm</td>
                <td class="p-2.5 text-green-700 font-semibold text-xs">85 ppm</td>
              </tr>
              <tr class="bg-light-bg border-b border-gray-100">
                <td class="p-2.5 text-xs">Silicon</td>
                <td class="p-2.5 text-red-600 font-semibold text-xs">386 ppm</td>
                <td class="p-2.5 text-green-700 font-semibold text-xs">132 ppm</td>
              </tr>
              <tr class="bg-white">
                <td class="p-2.5 text-xs">Ash Content</td>
                <td class="p-2.5 text-red-600 font-semibold text-xs">1.17% Wt.</td>
                <td class="p-2.5 text-green-700 font-semibold text-xs">0.09% Wt.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ Factors ═══ Two charts side by side using DolphinChart -->
  <div id="factors" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">
      Factors Affecting <a href="/disc-stack-centrifuge-efficiency/" class="hover:text-gold underline">Centrifuge Performance</a>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div>
        <h3 class="text-lg font-bold text-navy mb-2">Temperature</h3>
        <p class="text-text mb-4">
          Processing temperature is a key consideration while sizing waste oil centrifuges. Higher process temperature reduces the oil viscosity, which enables higher throughput.
        </p>
        <DolphinChart
          title="Oil Viscosity vs Temperature"
          xLabel="Temperature (°F)"
          yLabel="Viscosity (cSt)"
          series={[{
            data: [
              { x: 70, y: 480 },
              { x: 100, y: 200 },
              { x: 130, y: 85 },
              { x: 160, y: 38 },
              { x: 190, y: 18 },
              { x: 210, y: 12 },
            ]
          }]}
          altText="Oil Viscosity versus Temperature Graph — showing how higher temperature reduces viscosity and increases centrifuge throughput"
          caption="Oil Viscosity versus Temperature Graph"
        />
        <p class="text-text mt-3 text-sm">
          Conversely, lower-temperature oil leads to lower capacity through the same centrifuge.
        </p>
      </div>
      <div>
        <h3 class="text-lg font-bold text-navy mb-2">Flow Rate</h3>
        <p class="text-text mb-4">
          Lower flow rates give higher retention time in the centrifuge bowl. This time enables longer exposure to the high centrifugal forces leading to better separation.
        </p>
        <DolphinChart
          title="Flow Rate vs Solids Separation"
          xLabel="Flow Rate (GPM)"
          yLabel="% Solids Remaining"
          series={[{
            data: [
              { x: 2, y: 0.62 },
              { x: 4, y: 0.72 },
              { x: 6, y: 0.79 },
              { x: 8, y: 0.85 },
              { x: 10, y: 0.90 },
              { x: 12, y: 0.93 },
              { x: 14, y: 0.98 },
            ]
          }]}
          altText="Flow Rate vs Particle Size Separation Efficiency Chart — lower flow rates improve separation quality"
          caption="Flow Rate vs Particle Size Separation"
        />
        <p class="text-text mt-3 text-sm">
          Inversely, higher flow rates lead to less effective separation.
        </p>
      </div>
    </div>
  </div>

  <!-- ═══ Sizing ═══ Pattern A: Image (45%) + Text (55%) side by side -->
  <div id="sizing" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Sizing</h2>
    <div class="flex flex-col md:flex-row gap-6 items-start">
      <div class="md:w-[45%] shrink-0">
        <img
          src="/images/waste-oil-centrifuge/Industrial-Centrifuge-Systems-for-Waste-Oil.webp"
          alt="Industrial Centrifuge Systems for Waste Oil — complete skid-mounted waste oil purification system"
          width="500"
          height="375"
          loading="lazy"
          class="rounded-lg shadow-sm w-full h-auto object-contain"
        />
        <p class="text-gray-500 text-sm mt-1 text-center">Industrial Centrifuge Systems for Waste Oil</p>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-text mb-4">
          Industrial centrifuges used for waste oil purification are sized based on their throughput or processing capacity. Centrifuges with processing capacities from <strong>3 Gallons per Minute to over 100 Gallons per Minute</strong> are available for sale.
        </p>
        <p class="text-text mb-4">
          Due to the higher sludge levels in waste oil than in lube or hydraulic oil, <strong>self-cleaning centrifuges are required</strong> for waste oil processing.
        </p>
        <p class="text-text">
          For example, consider our medium capacity, self-cleaning Alfa Laval centrifuge, widely used for waste oil recovery. Notice the reduction in capacity at reduced oil temperature in the specifications below.
        </p>
      </div>
    </div>
  </div>

  <!-- ═══ Advantages ═══ Pattern B: Bullets (55%) + Illustration (45%) side by side -->
  <div id="advantages" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Advantages of Centrifuges Over Filters</h2>
    <div class="flex flex-col md:flex-row gap-6 items-start">
      <div class="flex-1 min-w-0">
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="w-2 h-2 bg-gold rounded-full flex-shrink-0 mt-2"></span>
            <span class="text-text">Total mechanical separation eliminates the need for filter media</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-2 h-2 bg-gold rounded-full flex-shrink-0 mt-2"></span>
            <span class="text-text"><a href="/industrial-centrifuge-controls/" class="text-navy underline hover:text-gold">Automatic operation</a> eliminates labor costs</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-2 h-2 bg-gold rounded-full flex-shrink-0 mt-2"></span>
            <span class="text-text">Continuous separation without the downtime/labor associated with filter replacement</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-2 h-2 bg-gold rounded-full flex-shrink-0 mt-2"></span>
            <span class="text-text">High g-force allows the centrifuge to separate particles down to <strong>0.5 micron level</strong></span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-2 h-2 bg-gold rounded-full flex-shrink-0 mt-2"></span>
            <span class="text-text">A waste oil centrifuge will also <strong>separate all free water</strong></span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-2 h-2 bg-gold rounded-full flex-shrink-0 mt-2"></span>
            <span class="text-text"><a href="/waste-oil-emulsion-centrifuge/" class="text-navy underline hover:text-gold">Breaking of waste oil emulsion</a></span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-2 h-2 bg-gold rounded-full flex-shrink-0 mt-2"></span>
            <span class="text-text"><a href="/disc-stack-centrifuge-remove-metals-ash-used-oil/" class="text-navy underline hover:text-gold">Removing ash and fine metal particles from used engine oil</a></span>
          </li>
        </ul>
      </div>
      <div class="md:w-[40%] shrink-0">
        <img
          src="/images/waste-oil-centrifuge/filter-vs-centrifuge-comparison.webp"
          alt="Filter versus Centrifuge comparison — industrial oil filtration vs disc stack centrifuge separation"
          width="500"
          height="373"
          loading="lazy"
          class="rounded-lg shadow-sm w-full h-auto object-contain"
        />
        <p class="text-gray-500 text-sm mt-1 text-center">Filter vs Centrifuge Comparison</p>
      </div>
    </div>
  </div>

  <!-- ═══ FAQ ═══ -->
  <FAQ items={faqItems} heading="Waste Oil Centrifuge FAQ" />

  <!-- Mid-page CTA -->
  <div class="bg-navy rounded-xl p-6 md:p-8 text-white text-center my-8">
    <h2 class="text-xl font-bold mb-2">Need Help Sizing a Waste Oil Centrifuge?</h2>
    <p class="text-blue-100 mb-4 max-w-xl mx-auto text-sm">
      Tell us your daily volume, oil type, and processing temperature. Our engineers will recommend the right centrifuge system for your waste oil application.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold text-navy font-bold px-5 py-2.5 rounded-lg hover:bg-gold-light transition-colors text-sm">
        Get a Free Quote
      </a>
      <a href="/industrial-centrifuge-sample-testing/" class="border border-white text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-white hover:text-navy transition-colors text-sm">
        Sample Testing
      </a>
      <a href="tel:+12485222573" class="border border-white text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-white hover:text-navy transition-colors text-sm">
        (248) 522-2573
      </a>
    </div>
  </div>

  <!-- ═══ Specifications ═══ Pattern C: Table (60%) + Product Photo (40%) -->
  <div id="specifications" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Specifications</h2>
    <p class="text-text mb-4">
      The following table highlights the specifications of our most popular large-scale waste oil processing disc-stack centrifuges.
    </p>
    <div class="flex flex-col lg:flex-row gap-6 items-start">
      <div class="flex-1 min-w-0 overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-navy text-white">
              <th class="text-left p-3 rounded-tl-lg">Specification</th>
              <th class="text-left p-3">MOPX207<br /><span class="font-normal text-xs">Self-Cleaning</span></th>
              <th class="text-left p-3 rounded-tr-lg">MOPX 210<br /><span class="font-normal text-xs">Self-Cleaning</span></th>
            </tr>
          </thead>
          <tbody>
            <tr class="bg-white border-b border-gray-100">
              <td class="p-3 font-semibold">Separation @ 200&deg;F</td>
              <td class="p-3">1&micro;; All Free Water</td>
              <td class="p-3">1&micro;; All Free Water</td>
            </tr>
            <tr class="bg-light-bg border-b border-gray-100">
              <td class="p-3 font-semibold">Rated Capacity</td>
              <td class="p-3 font-mono">32 GPM</td>
              <td class="p-3 font-mono">72 GPM</td>
            </tr>
            <tr class="bg-white border-b border-gray-100">
              <td class="p-3 font-semibold">@ 70&deg;F (Ambient)</td>
              <td class="p-3 font-mono">5–7 GPM</td>
              <td class="p-3 font-mono">12–15 GPM</td>
            </tr>
            <tr class="bg-light-bg border-b border-gray-100">
              <td class="p-3 font-semibold">@ 140&deg;F</td>
              <td class="p-3 font-mono">10–12 GPM</td>
              <td class="p-3 font-mono">20–24 GPM</td>
            </tr>
            <tr class="bg-white border-b border-gray-100">
              <td class="p-3 font-semibold">@ 200&deg;F</td>
              <td class="p-3 font-mono font-bold text-green-700">20+ GPM</td>
              <td class="p-3 font-mono font-bold text-green-700">45+ GPM</td>
            </tr>
            <tr class="bg-light-bg border-b border-gray-100">
              <td class="p-3 font-semibold">Drive Motor</td>
              <td class="p-3">7.5 HP</td>
              <td class="p-3">15 HP</td>
            </tr>
            <tr class="bg-white border-b border-gray-100">
              <td class="p-3 font-semibold">Voltage</td>
              <td class="p-3 font-mono">230/460V 3-Phase</td>
              <td class="p-3 font-mono">230/460V 3-Phase</td>
            </tr>
            <tr class="bg-light-bg border-b border-gray-100">
              <td class="p-3 font-semibold">Bowl Speed</td>
              <td class="p-3 font-mono">7,200 RPM</td>
              <td class="p-3 font-mono">5,100 RPM</td>
            </tr>
            <tr class="bg-white border-b border-gray-100">
              <td class="p-3 font-semibold">G-Force</td>
              <td class="p-3 font-mono font-bold">7,200 Gs</td>
