---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqItems = [
  {
    question: "What is a waste oil centrifuge?",
    answer: "A waste oil centrifuge is a high-speed industrial separator that uses centrifugal force (up to 12,000 Gs) to remove water, sediment, and fine solid particles from used or contaminated oil. It performs continuous three-phase separation — separating light phase (oil), heavy phase (water), and sludge simultaneously without filter media."
  },
  {
    question: "How does a waste oil centrifuge work?",
    answer: "Waste oil enters the spinning centrifuge bowl, where centrifugal force up to 12,000 Gs causes immediate separation. Heavier water and solids migrate to the outer bowl wall. Clean oil moves to the center and exits under pressure through a built-in pump. Solids are intermittently ejected from the bowl automatically, enabling continuous operation."
  },
  {
    question: "What size waste oil centrifuge do I need?",
    answer: "Waste oil centrifuge sizing depends on daily processing volume, oil viscosity, temperature, and solids content. Centrifuges range from 3 GPM to 100+ GPM. For commercial processors, Dolphin Centrifuge offers turnkey systems from 500 Gal/Day to 10,000+ Gal/Day. Contact us with your application details for accurate sizing."
  },
  {
    question: "Can a centrifuge remove water from waste oil?",
    answer: "Yes. A three-phase disc stack centrifuge simultaneously removes all free water and solids from waste oil. In real-world testing, water content was reduced from 38% by volume to 1.2% by volume in a single pass through an industrial disc centrifuge. A centrifuge is far more effective at water removal than settling tanks or filters."
  },
  {
    question: "What is the difference between a waste oil centrifuge and a filter?",
    answer: "A waste oil centrifuge uses mechanical centrifugal force to continuously separate solids and water without any filter media. A filter accumulates solids until plugged, then requires manual media replacement — adding labor and disposal costs. Centrifuges operate 24/7 with automatic solids ejection, no consumable media, and separate all free water, which filters cannot do."
  },
  {
    question: "What is black diesel and can a centrifuge clean it?",
    answer: "Black diesel refers to used engine oil and other used mineral oils repurposed as fuel for diesel engines and generators. A disc stack centrifuge effectively purifies black diesel by removing all solids and water to produce usable fuel. Dolphin Centrifuge offers dedicated black diesel centrifuge systems."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Waste Oil Centrifuge Systems",
  "url": "https://dolphincentrifuge.com/waste-oil-centrifuge/",
  "description": "Industrial waste oil centrifuges: 3-phase separation up to 12,000 Gs, removes water & solids to 1 micron. Complete turnkey systems from 3 GPM to 100+ GPM.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const jsonLd = [productJsonLd, faqJsonLd];
---

<BaseLayout
  title="Waste Oil Centrifuge Systems"
  description="Industrial waste oil centrifuges: 3-phase separation up to 12,000 Gs, removes water and solids to 1 micron. Specs, sizing, and systems — Dolphin Centrifuge."
  canonicalUrl="https://dolphincentrifuge.com/waste-oil-centrifuge/"
  breadcrumbs={[{label: 'Applications', href: '/applications/'}, {label: 'Waste Oil Centrifuge'}]}
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <section class="bg-[#1B3A5C] text-white py-16 md:py-20">
    <div class="container-dolphin max-w-5xl">
      <h1 class="text-3xl md:text-5xl font-bold font-jakarta mb-4 leading-tight">
        Waste Oil Centrifuge
      </h1>
      <p class="text-xl text-[#E8A317] font-semibold mb-3">Operation, Benefits, Specifications, Cost &amp; Installation</p>
      <p class="text-lg text-blue-100 max-w-3xl mb-8">
        Dolphin Centrifuge supplies purpose-modified industrial disc stack centrifuges for waste oil purification. Operating at up to 12,000 Gs with separation down to 1 micron, these systems process 3 GPM to over 100 GPM continuously. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in centrifugal separation for waste oil recovery, used engine oil processing, and commercial-scale oil recycling operations.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] text-white font-bold px-6 py-3 rounded-lg hover:bg-yellow-500 transition-colors">
          Contact Us
        </a>
        <a href="#specifications" class="border border-white text-white font-semibold px-6 py-3 rounded-lg hover:bg-white hover:text-[#1B3A5C] transition-colors">
          View Specifications
        </a>
      </div>
    </div>
  </section>

  <!-- Hero Image -->
  <section class="bg-[#F5F5F0]">
    <div class="container-dolphin max-w-5xl py-8">
      <img
        src="/images/waste-oil-centrifuge/Alfa-Laval-WHPX-410-Waste-Oil-Centrifuge-600.jpg"
        alt="Alfa Laval WHPX 410 Waste Oil Centrifuge — three-phase self-cleaning disc stack centrifuge system by Dolphin Centrifuge"
        width="600"
        height="600"
        loading="eager"
        class="rounded-xl shadow-md mx-auto block"
      />
      <p class="text-center text-gray-500 text-sm mt-3">Alfa Laval WHPX 410 Waste Oil Centrifuge</p>
    </div>
  </section>

  <!-- TOC -->
  <section class="bg-white border-b border-gray-200">
    <div class="container-dolphin max-w-4xl py-8">
      <h2 class="text-lg font-bold text-[#1B3A5C] mb-4">Table of Contents</h2>
      <nav class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2 text-sm">
        <a href="#operation" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Operation</a>
        <a href="#performance" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Performance Results</a>
        <a href="#factors" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Factors Affecting Performance</a>
        <a href="#sizing" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Sizing</a>
        <a href="#advantages" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Advantages Over Filters</a>
        <a href="#faq" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Waste Oil Centrifuge FAQ</a>
        <a href="#specifications" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Specifications</a>
        <a href="#black-diesel" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Black Diesel</a>
        <a href="#installation" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Installation</a>
        <a href="#industrial-scale" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Industrial Scale Processing</a>
        <a href="#decanters" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Decanters for High Sludge</a>
        <a href="#filter-vs-centrifuge" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Filter vs Centrifuge</a>
        <a href="#process-flow" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Process Flow Diagram</a>
        <a href="#models" class="text-[#1B3A5C] hover:text-[#E8A317] underline">Centrifuges for Sale</a>
      </nav>
    </div>
  </section>

  <!-- Main Content -->
  <section class="bg-[#F5F5F0]">
    <div class="container-dolphin py-12 md:py-16 max-w-4xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies three-phase industrial waste oil centrifuge systems — disc stack separators that continuously remove oil, water, and solids from contaminated waste oil at up to 12,000 Gs. These systems separate particles to 1 micron and all free water, processing 3 to 100+ GPM without filter media. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in industrial oil recovery and waste oil purification.</p>
      </div>

      <!-- Operation -->
      <div id="operation" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1B3A5C] mb-4">Operation</h2>
        <p class="text-[#2D2D2D] text-lg font-semibold mb-4">
          A waste oil centrifuge works by exerting gravitational forces up to 12,000 Gs to separate sediment and water from waste oil. This force separates particles as small as 1 micron from the waste oil. The centrifuge has a flow-through design that enables the continuous flow of the separated contaminants through separate outlets.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          <a href="/waste-oil-centrifuge-case-study-marine-and-industrial-waste-oil-recovery/" class="text-[#1B3A5C] underline hover:text-[#E8A317] font-semibold">Waste Oil Recovery Case Study with Ash Removal &rarr;</a>
        </p>
        <p class="text-[#2D2D2D] mb-4">
          Industrial waste oil centrifuges offer a large processing capacity. Continuous three-phase separation is the key to the efficient separation of waste oils.
        </p>

        <div class="flex flex-col md:flex-row gap-6 items-start mb-4">
          <div class="flex-shrink-0">
            <img
              src="/images/waste-oil-centrifuge/Alfa-Laval-Waste-Oil-Centrifuge-P-615-300.jpg"
              alt="Alfa Laval Waste Oil Centrifuge P-615 — 10 GPM three-phase disc stack unit"
              width="300"
              height="339"
              loading="lazy"
              class="rounded-lg shadow-sm"
            />
            <p class="text-gray-500 text-sm mt-1 text-center">Alfa Laval Waste Oil Centrifuge (10 GPM)</p>
          </div>
          <div>
            <p class="text-[#2D2D2D] mb-4">
              Three-phase separation means the separation of the three phases in contaminated oil. The 3 phases are:
            </p>
            <ul class="list-disc pl-6 text-[#2D2D2D] space-y-2 mb-4">
              <li><strong>Light phase</strong> &mdash; oil (the clean, recovered product)</li>
              <li><strong>Heavy phase</strong> &mdash; water (separated and discharged continuously)</li>
              <li><strong>Sludge</strong> &mdash; solid contaminants (intermittently ejected from the bowl)</li>
            </ul>
            <p class="text-[#2D2D2D] mb-4">
              A waste oil centrifuge is a heavy-duty, industrial-grade machine. It has the added capacity to <em>self-eject</em> the separated solids. It also discharges the separated water continuously through a discrete heavy-phase outlet.
            </p>
          </div>
        </div>

        <p class="text-[#2D2D2D]">
          <a href="/waste-oil-centrifuges-lp/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">See our Waste Oil Centrifuge Technical Specs &rarr;</a>
        </p>
      </div>

      <!-- Performance Results -->
      <div id="performance" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1B3A5C] mb-4">Performance Results</h2>
        <p class="text-[#2D2D2D] mb-4">
          Centrifuge performance refers to the cleaning ability of the centrifuge on waste oil. In this section, we answer the question:
        </p>

        <div class="text-center mb-6">
          <a href="/images/waste-oil-centrifuge/Waste-Oil-Before-and-After-Disc-Stack-Centrifuge.jpg" target="_blank" rel="noopener">
            <img
              src="/images/waste-oil-centrifuge/Waste-Oil-Before-and-After-Disc-Stack-Centrifuge.jpg"
              alt="Waste Oil Before and After Disc Stack Centrifuge — visible separation showing contaminated oil transformed to clean oil"
              width="600"
              height="515"
              loading="lazy"
              class="rounded-lg shadow-sm mx-auto"
            />
          </a>
          <p class="text-gray-500 text-sm mt-2">Waste Oil Before and After Disc Stack Centrifuge</p>
        </div>

        <h3 class="text-xl font-bold text-[#1B3A5C] mb-3">How well does a disc centrifuge clean waste oil?</h3>
        <p class="text-[#2D2D2D] mb-4">
          The following is a <em>real-world example</em> of our centrifuge performance results on waste oil. The table shows the contaminant levels in waste oil before and after an Alfa Laval MOPX 207 Centrifuge.
        </p>

        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-[#1B3A5C] text-white">
                <th class="text-left p-3 rounded-tl-lg" colspan="3">Centrifuge Type: Alfa Laval MOPX-207 &mdash; 3-Phase, Self-Cleaning, Disc Stack Centrifuge</th>
              </tr>
              <tr class="bg-blue-900 text-white">
                <th class="text-left p-3">Contaminant</th>
                <th class="text-left p-3">Before Centrifuge</th>
                <th class="text-left p-3 rounded-tr-lg">After Centrifuge</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-white border-b border-gray-100">
                <td class="p-3">Sediment by Extraction</td>
                <td class="p-3 text-red-600 font-semibold">0.42 % Wt.</td>
                <td class="p-3 text-green-700 font-semibold">0.06 % Wt.</td>
              </tr>
              <tr class="bg-blue-50 border-b border-gray-100">
                <td class="p-3">Water by Distillation</td>
                <td class="p-3 text-red-600 font-semibold">38.0 % Vol.</td>
                <td class="p-3 text-green-700 font-semibold">1.2 % Vol.</td>
              </tr>
              <tr class="bg-white border-b border-gray-100">
                <td class="p-3 font-semibold text-[#1B3A5C]" colspan="3">Metals:</td>
              </tr>
              <tr class="bg-white border-b border-gray-100">
                <td class="p-3 pl-6">Vanadium</td>
                <td class="p-3">28 ppm</td>
                <td class="p-3">31 ppm</td>
              </tr>
              <tr class="bg-blue-50 border-b border-gray-100">
                <td class="p-3 pl-6">Aluminum</td>
                <td class="p-3 text-red-600 font-semibold">495 ppm</td>
                <td class="p-3 text-green-700 font-semibold">85 ppm</td>
              </tr>
              <tr class="bg-white border-b border-gray-100">
                <td class="p-3 pl-6">Silicon</td>
                <td class="p-3 text-red-600 font-semibold">386 ppm</td>
                <td class="p-3 text-green-700 font-semibold">132 ppm</td>
              </tr>
              <tr class="bg-blue-50">
                <td class="p-3">Ash Content</td>
                <td class="p-3 text-red-600 font-semibold">1.17 % Wt.</td>
                <td class="p-3 text-green-700 font-semibold">0.09 % Wt.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Factors Affecting Performance -->
      <div id="factors" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1B3A5C] mb-4">
          Factors Affecting <a href="/disc-stack-centrifuge-efficiency/" class="hover:text-[#E8A317] underline">Centrifuge Performance</a>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <h3 class="text-lg font-bold text-[#1B3A5C] mb-2">Temperature</h3>
            <p class="text-[#2D2D2D] mb-3">
              Processing temperature is a key consideration while sizing waste oil centrifuges. Higher process temperature reduces the oil viscosity, which enables higher throughput.
            </p>
            <a href="/images/waste-oil-centrifuge/oil-viscosity-vs-temperature-400.jpg" target="_blank" rel="noopener">
              <img
                src="/images/waste-oil-centrifuge/oil-viscosity-vs-temperature-400.jpg"
                alt="Oil Viscosity versus Temperature Graph — showing how higher temperature reduces viscosity and increases centrifuge throughput"
                width="400"
                height="256"
                loading="lazy"
                class="rounded-lg shadow-sm w-full object-cover"
              />
            </a>
            <p class="text-gray-500 text-sm mt-1 text-center">Oil Viscosity versus Temperature Graph</p>
            <p class="text-[#2D2D2D] mt-3 text-sm">
              Conversely, lower-temperature oil leads to lower capacity through the same centrifuge.
            </p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-[#1B3A5C] mb-2">Flow Rate</h3>
            <p class="text-[#2D2D2D] mb-3">
              Lower flow rates give higher retention time in the centrifuge bowl. This time enables longer exposure to the high centrifugal forces leading to better separation.
            </p>
            <a href="/images/waste-oil-centrifuge/Flow-Rate-vs-Particle-Separation-Efficiency-400.jpg" target="_blank" rel="noopener">
              <img
                src="/images/waste-oil-centrifuge/Flow-Rate-vs-Particle-Separation-Efficiency-400.jpg"
                alt="Flow Rate vs Particle Size Separation Efficiency Chart — lower flow rates improve separation quality"
                width="400"
                height="136"
                loading="lazy"
                class="rounded-lg shadow-sm w-full object-cover"
              />
            </a>
            <p class="text-gray-500 text-sm mt-1 text-center">Flow Rate vs Particle Size Separation</p>
            <p class="text-[#2D2D2D] mt-3 text-sm">
              Inversely, higher flow rates lead to less effective separation.
            </p>
          </div>
        </div>
      </div>

      <!-- Sizing -->
      <div id="sizing" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1B3A5C] mb-4">Sizing</h2>
        <img
          src="/images/waste-oil-centrifuge/Industrial-Centrifuge-Systems-for-Waste-Oil.jpg"
          alt="Industrial Centrifuge Systems for Waste Oil — complete skid-mounted waste oil purification system"
          width="600"
          height="300"
          loading="lazy"
          class="rounded-lg shadow-sm w-full object-cover mb-4"
        />
        <p class="text-gray-500 text-sm mb-4 text-center">Industrial Centrifuge Systems for Waste Oil</p>
        <p class="text-[#2D2D2D] mb-4">
          Industrial centrifuges used for waste oil purification are sized based on their throughput or processing capacity. Centrifuges with processing capacities from <strong>3 Gallons per Minute to over 100 Gallons per Minute</strong> are available for sale.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          Due to the higher sludge levels in waste oil than in lube or hydraulic oil, <strong>self-cleaning centrifuges are required</strong> for waste oil processing.
        </p>
        <p class="text-[#2D2D2D]">
          For example, consider our medium capacity, self-cleaning Alfa Laval centrifuge, widely used for waste oil recovery. Notice the reduction in capacity at reduced oil temperature in the specifications below.
        </p>
      </div>

      <!-- Advantages -->
      <div id="advantages" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1B3A5C] mb-4">Advantages of Centrifuges Over Filters</h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="w-2 h-2 bg-[#E8A317] rounded-full flex-shrink-0 mt-2"></span>
            <span class="text-[#2D2D2D]">Total mechanical separation eliminates the need for filter media</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-2 h-2 bg-[#E8A317] rounded-full flex-shrink-0 mt-2"></span>
            <span class="text-[#2D2D2D]"><a href="/industrial-centrifuge-controls/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">Automatic operation</a> eliminates labor costs</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-2 h-2 bg-[#E8A317] rounded-full flex-shrink-0 mt-2"></span>
            <span class="text-[#2D2D2D]">Continuous separation without the downtime/labor associated with filter replacement</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-2 h-2 bg-[#E8A317] rounded-full flex-shrink-0 mt-2"></span>
            <span class="text-[#2D2D2D]">High g-force allows the centrifuge to separate particles down to <strong>0.5 micron level</strong></span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-2 h-2 bg-[#E8A317] rounded-full flex-shrink-0 mt-2"></span>
            <span class="text-[#2D2D2D]">A waste oil centrifuge will also <strong>separate all free water</strong></span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-2 h-2 bg-[#E8A317] rounded-full flex-shrink-0 mt-2"></span>
            <span class="text-[#2D2D2D]"><a href="/waste-oil-emulsion-centrifuge/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">Breaking of waste oil emulsion</a></span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-2 h-2 bg-[#E8A317] rounded-full flex-shrink-0 mt-2"></span>
            <span class="text-[#2D2D2D]"><a href="/disc-stack-centrifuge-remove-metals-ash-used-oil/" class="text-[#1B3A5C] underline hover:text-[#E8A317]">Removing ash and fine metal particles from used engine oil</a></span>
          </li>
        </ul>
      </div>

      <!-- FAQ -->
      <div id="faq" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1B3A5C] mb-6">Waste Oil Centrifuge FAQ</h2>
        <div class="space-y-4">
          {faqItems.map((item) => (
            <details class="border border-gray-200 rounded-lg overflow-hidden">
              <summary class="flex items-center justify-between p-4 cursor-pointer bg-[#F5F5F0] hover:bg-blue-50 font-semibold text-[#1B3A5C]">
                <span>{item.question}</span>
                <span class="text-[#E8A317] text-xl ml-4 flex-shrink-0">+</span>
              </summary>
              <div class="p-4 text-[#2D2D2D] text-sm leading-relaxed">{item.answer}</div>
            </details>
          ))}
        </div>
      </div>

      <!-- Mid-page CTA -->
      <div class="bg-[#1B3A5C] rounded-xl p-6 md:p-8 text-white text-center mb-8">
        <h2 class="text-xl font-bold mb-2">Need Help Sizing a Waste Oil Centrifuge?</h2>
        <p class="text-blue-100 mb-4 max-w-xl mx-auto text-sm">
          Tell us your daily volume, oil type, and processing temperature. Our engineers will recommend the right centrifuge system for your waste oil application.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] text-white font-bold px-5 py-2.5 rounded-lg hover:bg-yellow-500 transition-colors text-sm">
            Get a Free Quote
          </a>
          <a href="/industrial-centrifuge-sample-testing/" class="border border-white text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-white hover:text-[#1B3A5C] transition-colors text-sm">
            Sample Testing
          </a>
          <a href="tel:+12485222573" class="border border-white text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-white hover:text-[#1B3A5C] transition-colors text-sm">
            (248) 522-2573
          </a>
        </div>
      </div>

      <!-- Specifications -->
      <div id="specifications" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1B3A5C] mb-4">Specifications</h2>
        <p class="text-[#2D2D2D] mb-4">
          The following table highlights the specifications of our most popular large-scale waste oil processing disc-stack centrifuges.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
