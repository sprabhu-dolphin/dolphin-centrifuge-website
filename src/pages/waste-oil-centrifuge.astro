const toc = [
  { id: 'operation', label: 'Operation' },
  { id: 'video', label: 'Pilot-scale Testing Video' },
  { id: 'performance', label: 'Performance Results' },
  { id: 'factors', label: 'Factors Affecting Performance' },
  { id: 'sizing', label: 'Sizing' },
  { id: 'advantages', label: 'Advantages Over Filters' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'black-diesel', label: 'Black Diesel' },
  { id: 'installation', label: 'Installation' },
  { id: 'industrial-scale', label: 'Industrial Scale Processing' },
  { id: 'decanters', label: 'Decanters for High Sludge' },
  { id: 'filter-vs-centrifuge', label: 'Filter vs Centrifuge' },
  { id: 'process-flow', label: 'Process Flow Diagram' },
  { id: 'models', label: 'Centrifuges for Sale' },
];

const relatedApplications = [
  { label: 'Used Oil Centrifuge', href: '/used-oil-centrifuge/' },
  { label: 'Black Diesel Centrifuge', href: '/black-diesel-centrifuge/' },
  { label: 'WVO Centrifuge Separator', href: '/wvo-centrifuge-separator/' },
  { label: 'Waste Oil Emulsion Centrifuge', href: '/waste-oil-emulsion-centrifuge/' },
];

const relatedProducts = [
  { label: 'Alfa Laval WHPX 405', href: '/alfa-laval-whpx-405/', description: '3-phase self-cleaning — 5 GPM @ 180°F' },
  { label: 'Alfa Laval WHPX 513', href: '/alfa-laval-whpx-513/', description: '3-phase self-cleaning — 60 GPM @ 180°F' },
  { label: 'Alfa Laval MOPX 213', href: '/alfa-laval-mopx-209-centrifuge/', description: '3-phase self-cleaning — 40 GPM @ 180°F' },
];
---

<ApplicationLayout
  title="Waste Oil Centrifuge | Large Scale | Operation, Benefits & Specs"
  pageTitle="Waste Oil Centrifuge | Large Scale | Operation, Benefits & Specs"
  description="Recover and purify waste oil with an industrial waste oil centrifuge. Separates water and sediment using 10,000 Gs. High capacity, self-cleaning units."
  heroImage="/images/waste-oil-centrifuge/waste-oil-centrifuge-hero-nb.webp"
  heroImageAlt="Waste oil centrifuge system in industrial waste oil processing facility — Dolphin Centrifuge"
  category="applications"
  categoryLabel="Oil & Fuel"
  overlay="frost"
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
  canonicalUrl="https://dolphincentrifuge.com/waste-oil-centrifuge/"
  ogImage="/images/waste-oil-centrifuge/waste-motor-oil-centrifuge-system.webp"
  jsonLd={jsonLd}
>

  {/* ── 1. Operation ── */}
  <div id="operation" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4 !mt-0 !border-0">Operation</h2>
    <div class="prose-dolphin mb-6">
      <p class="text-lg font-semibold text-navy/90 leading-snug">
        A waste oil centrifuge works by exerting gravitational forces up to 12,000 Gs to separate sediment and water from waste oil.
      </p>
      <p>
        This force separates particles as small as 1 micron from the waste oil. The centrifuge has a flow-through design that enables the continuous flow of the separated contaminants through separate outlets.
      </p>
      <p>
        Industrial waste oil centrifuges offer a large processing capacity. Continuous three-phase separation is the key to the efficient separation of waste oils.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 items-start">
      <div class="not-prose flex justify-center">
        <img
          src="/images/waste-oil-centrifuge/Alfa-Laval-Waste-Oil-Centrifuge-P-615-300.webp"
          alt="Alfa Laval Waste Oil Centrifuge P-615 — 10 GPM three-phase disc stack unit"
          width="300"
          height="280"
          loading="lazy"
          class="rounded-lg shadow-sm w-full max-h-64 object-contain bg-gray-50 border border-gray-100"
        />
      </div>
      <div class="md:col-span-2 prose-dolphin">
        <p class="!mt-0">Three-phase separation means the separation of the three phases in contaminated oil:</p>
        <ul class="space-y-1">
          <li><strong>Light phase</strong> &mdash; oil (the clean, recovered product)</li>
          <li><strong>Heavy phase</strong> &mdash; water (separated and discharged continuously)</li>
          <li><strong>Sludge</strong> &mdash; solid contaminants (intermittently ejected from the bowl)</li>
        </ul>
        <p class="mt-4">
          A waste oil centrifuge is a heavy-duty, industrial-grade machine. It has the added capacity to <em>self-eject</em> the separated solids and discharge separated water continuously.
        </p>
        <p class="mt-4">
          <a href="/waste-oil-centrifuge-case-study-marine-and-industrial-waste-oil-recovery/" class="inline-flex items-center gap-1.5 font-bold text-gold-dark hover:text-gold transition-colors">
            Waste Oil Recovery Case Study with Ash Removal <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
        </p>
      </div>
    </div>
  </div>

  <!-- ═══ Pilot-scale Video ═══ -->
  <div id="video" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Pilot-scale Waste Oil Centrifuge Testing Video</h2>
    <div class="aspect-video w-full max-w-3xl mx-auto rounded-lg overflow-hidden shadow-md">
      <iframe
        width="100%"
        height="100%"
        src="https://www.youtube.com/embed/y7Rc9SVFbMo"
        title="Alfa Laval Centrifuge Waste Oil Processing Pilot Scale Test"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  </div>

  {/* ── 3. Performance Results ── */}
  <div id="performance" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-2 !mt-0 !border-0">Performance Results</h2>
    <div class="prose-dolphin mb-6">
      <h3 class="text-xl font-bold text-gold-dark mb-4">How well does a disc centrifuge clean waste oil?</h3>
      <p>
        The following is a <strong>real-world example</strong> of our centrifuge performance results on waste oil. The table shows the contaminant levels in waste oil before and after an Alfa Laval MOPX 207 Centrifuge.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 items-start">
      <div class="not-prose flex justify-center">
        <a href="/images/waste-oil-centrifuge/Waste-Oil-Before-and-After-Disc-Stack-Centrifuge.webp" class="block rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-gray-100">
          <img
            src="/images/waste-oil-centrifuge/Waste-Oil-Before-and-After-Disc-Stack-Centrifuge.webp"
            alt="Waste Oil Before and After Disc Stack Centrifuge"
            width="400"
            height="500"
            loading="lazy"
            class="w-full h-auto object-contain bg-gray-50"
          />
        </a>
      </div>
      <div class="md:col-span-2">
        <div class="not-prose overflow-x-auto border border-gray-100 rounded-lg shadow-sm">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-navy text-white text-xs uppercase tracking-wider">
                <th class="p-3 text-left" colspan="3">Alfa Laval MOPX-207 Performance Data</th>
              </tr>
              <tr class="bg-navy/90 text-white text-[10px] uppercase tracking-widest">
                <th class="p-3 text-left">Contaminant</th>
                <th class="p-3 text-left">Before</th>
                <th class="p-3 text-left">After</th>
              </tr>
            </thead>
            <tbody class="text-xs">
              <tr class="bg-white border-b border-gray-50">
                <td class="p-3 font-semibold text-navy">Sediment</td>
                <td class="p-3 text-red-600 font-bold">0.42% Wt.</td>
                <td class="p-3 text-green-700 font-bold">0.06% Wt.</td>
              </tr>
              <tr class="bg-gray-50/50 border-b border-gray-50">
                <td class="p-3 font-semibold text-navy">Water</td>
                <td class="p-3 text-red-600 font-bold">38.0% Vol.</td>
                <td class="p-3 text-green-700 font-bold">1.2% Vol.</td>
              </tr>
              <tr class="bg-white border-b border-gray-50 font-bold tracking-tight text-navy/70">
                <td class="px-3 py-2 bg-gray-100/30" colspan="3">Trace Metals Removed:</td>
              </tr>
              <tr class="bg-white border-b border-gray-50">
                <td class="p-3 text-navy/80">Vanadium</td>
                <td class="p-3">28 ppm</td>
                <td class="p-3">31 ppm</td>
              </tr>
              <tr class="bg-gray-50/50 border-b border-gray-50">
                <td class="p-3 text-navy/80">Aluminum</td>
                <td class="p-3 text-red-600">495 ppm</td>
                <td class="p-3 text-green-700 font-bold">85 ppm</td>
              </tr>
              <tr class="bg-white border-b border-gray-50">
                <td class="p-3 text-navy/80">Silicon</td>
                <td class="p-3 text-red-600">386 ppm</td>
                <td class="p-3 text-green-700 font-bold">132 ppm</td>
              </tr>
              <tr class="bg-gray-50/50">
                <td class="p-3 font-bold text-navy">Ash Content</td>
                <td class="p-3 text-red-600 font-bold">1.17% Wt.</td>
                <td class="p-3 text-green-700 font-bold text-sm">0.09% Wt.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  {/* ── 4. Factors Affecting Performance ── */}
  <div id="factors" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4 !mt-0">
      Factors Affecting <a href="/disc-stack-centrifuge-efficiency/" class="hover:text-gold transition-colors">Centrifuge Performance</a>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
      <div class="prose-dolphin">
        <h3 class="text-lg font-bold text-navy mb-2">Temperature</h3>
        <p>
          Processing temperature is a key consideration while sizing waste oil centrifuges. Higher process temperature reduces the oil viscosity, which enables higher throughput.
        </p>
        <div class="not-prose mt-4">
          <DolphinChart
            title="Oil Viscosity vs Temperature"
            xLabel="Temperature (°F)"
            yLabel="Viscosity (cSt)"
            series={[{
              data: [
                { x: 70, y: 480 },
                { x: 100, y: 200 },
                { x: 130, y: 85 },
                { x: 160, y: 38 },
                { x: 190, y: 18 },
                { x: 210, y: 12 },
              ]
            }]}
            altText="Oil Viscosity versus Temperature Graph — showing how higher temperature reduces viscosity and increases centrifuge throughput"
            caption="Oil Viscosity vs. Temperature"
          />
        </div>
        <p class="text-[13px] text-text-muted mt-4 italic">
          Conversely, lower-temperature oil leads to lower capacity through the same centrifuge.
        </p>
      </div>
      <div class="prose-dolphin">
        <h3 class="text-lg font-bold text-navy mb-2">Flow Rate</h3>
        <p>
          Lower flow rates give higher retention time in the centrifuge bowl. This time enables longer exposure to the high centrifugal forces leading to better separation.
        </p>
        <div class="not-prose mt-4">
          <DolphinChart
            title="Flow Rate vs Solids Separation"
            xLabel="Flow Rate (GPM)"
            yLabel="% Solids Remaining"
            series={[{
              data: [
                { x: 2, y: 0.62 },
                { x: 4, y: 0.72 },
                { x: 6, y: 0.79 },
                { x: 8, y: 0.85 },
                { x: 10, y: 0.90 },
                { x: 12, y: 0.93 },
                { x: 14, y: 0.98 },
              ]
            }]}
            altText="Flow Rate vs Particle Size Separation Efficiency Chart — lower flow rates improve separation quality"
            caption="Flow Rate vs. Solids Separation"
          />
        </div>
        <p class="text-[13px] text-text-muted mt-4 italic">
          Inversely, higher flow rates lead to less effective separation.
        </p>
      </div>
    </div>
  </div>

  {/* ── 5. Sizing ── */}
  <div id="sizing" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-6 !mt-0">Sizing</h2>
    <div class="not-prose mb-8 flex justify-center">
      <div class="w-full max-w-4xl">
        <img
          src="/images/waste-oil-centrifuge/Industrial-Centrifuge-Systems-for-Waste-Oil.webp"
          alt="Industrial Centrifuge Systems for Waste Oil"
          width="800"
          height="450"
          loading="lazy"
          class="rounded-xl shadow-lg border border-gray-200 w-full h-auto object-cover"
        />
        <p class="text-gray-500 text-xs mt-3 text-center italic">Industrial Centrifuge Systems for Waste Oil &ndash; Multi-Module Skid</p>
      </div>
    </div>
    <div class="prose-dolphin max-w-none">
      <p class="text-lg font-semibold text-navy/90">
        Industrial centrifuges used for waste oil purification are sized based on their throughput or processing capacity.
      </p>
      <p>
        Centrifuges with processing capacities from <strong>3 Gallons per Minute to over 100 Gallons per Minute</strong> are available for sale.
      </p>
      <p>
        Due to the higher sludge levels in waste oil than in lube or hydraulic oil, <strong>self-cleaning centrifuges are required</strong> for waste oil processing.
      </p>
      <p>
        For example, consider our medium capacity, self-cleaning Alfa Laval centrifuge, widely used for waste oil recovery. Notice the reduction in capacity at reduced oil temperature in the specifications below.
      </p>
    </div>
  </div>

  {/* ── 6. Advantages Over Filters ── */}
  <div id="advantages" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-6 md:gap-10 items-start">
      <div class="md:col-span-3">
        <h2 class="text-2xl md:text-3xl font-bold text-navy mb-6 !mt-0 !border-0">Advantages of Centrifuges Over Filters</h2>
        <div class="prose-dolphin">
          <ul class="space-y-4 !pl-0 !list-none">
            {[
              { text: 'Total mechanical separation eliminates the need for filter media', bold: true },
              { text: 'Automatic operation eliminates labor costs', link: '/industrial-centrifuge-controls/' },
              { text: 'Continuous separation without downtime Associated with filter replacement', bold: false },
              { text: 'High g-force allows separation down to 0.5 micron level', bold: true },
              { text: 'Complete removal of all free water from waste oil', bold: false },
              { text: 'Mechanical breaking of waste oil emulsions', link: '/waste-oil-emulsion-centrifuge/' },
              { text: 'Removal of ash and fine metal particles from used engine oil', link: '/disc-stack-centrifuge-remove-metals-ash-used-oil/' },
            ].map((item) => (
              <li class="flex items-start gap-4 group">
                <div class="w-2 h-2 rounded-full bg-gold mt-2.5 group-hover:scale-125 transition-transform shrink-0"></div>
                <div>
                  {item.link ? (
                    <a href={item.link} class="!no-underline hover:!underline font-semibold leading-tight">{item.text}</a>
                  ) : (
                    <span class={item.bold ? "font-semibold leading-tight" : "leading-tight"}>{item.text}</span>
                  )}
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <div class="md:col-span-2 not-prose">
        <div class="rounded-xl overflow-hidden shadow-md border border-gray-100">
          <img
            src="/images/waste-oil-centrifuge/filter-vs-centrifuge-comparison.webp"
            alt="Filter versus Centrifuge comparison — industrial oil filtration vs disc stack centrifuge separation"
            width="500"
            height="373"
            loading="lazy"
            class="w-full h-auto object-cover"
          />
        </div>
        <div class="bg-light-bg p-4 rounded-b-xl border-x border-b border-gray-100">
           <p class="text-gray-600 text-[11px] leading-relaxed italic text-center">Centrifuges provide continuous separation without the ongoing cost of media or manual labor.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ FAQ ═══ Legitimate FAQ page - content pending from RankMath recovery -->
  {faqItems.length > 0 && <FAQ items={faqItems} heading="Waste Oil Centrifuge FAQ" />}

  <!-- Mid-page CTA -->
  <div class="bg-navy rounded-xl p-6 md:p-8 text-white text-center my-8">
    <h2 class="text-xl font-bold mb-2">Need Help Sizing a Waste Oil Centrifuge?</h2>
    <p class="text-blue-100 mb-4 max-w-xl mx-auto text-sm">
      Tell us your daily volume, oil type, and processing temperature. Our engineers will recommend the right centrifuge system for your waste oil application.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold text-navy font-bold px-5 py-2.5 rounded-lg hover:bg-gold-light transition-colors text-sm">
        Get a Quote
      </a>
      <a href="/industrial-centrifuge-sample-testing/" class="border border-white text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-white hover:text-navy transition-colors text-sm">
        Sample Testing
      </a>
      <a href="tel:+12485222573" class="border border-white text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-white hover:text-navy transition-colors text-sm">
        (248) 522-2573
      </a>
    </div>
  </div>

  {/* ── 7. Specifications ── */}
  <div id="specifications" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4 !mt-0 !border-0">Specifications</h2>
    <p class="text-text-light mb-8 max-w-3xl">
      The following table highlights the specifications of our most popular large-scale waste oil processing disc-stack centrifuges.
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12 items-start">
      <div class="lg:col-span-3">
        <div class="not-prose overflow-x-auto border border-gray-100 rounded-lg shadow-sm">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-navy text-white text-[10px] uppercase tracking-widest">
                <th class="p-3 text-left">Feature</th>
                <th class="p-3 text-left">MOPX 207</th>
                <th class="p-3 text-left">MOPX 210</th>
              </tr>
            </thead>
            <tbody class="text-xs">
              <tr class="bg-white border-b border-gray-50">
                <td class="p-3 font-bold text-navy">Separation Quality</td>
                <td class="p-3">1&micro;; Total Water Removal</td>
                <td class="p-3">1&micro;; Total Water Removal</td>
              </tr>
              <tr class="bg-gray-50/50 border-b border-gray-50">
                <td class="p-3 font-bold text-navy">Rated Capacity</td>
                <td class="p-3 font-mono">32 GPM</td>
                <td class="p-3 font-mono">72 GPM</td>
              </tr>
              <tr class="bg-white border-b border-gray-50">
                <td class="p-3 font-bold text-navy italic">Actual Capacity at Temp:</td>
                <td class="p-3"></td>
                <td class="p-3"></td>
              </tr>
              <tr class="bg-white border-b border-gray-50">
                <td class="p-3 pl-6 text-navy/70">@ 70&deg;F (Ambient)</td>
                <td class="p-3 font-mono">5&ndash;7 GPM</td>
                <td class="p-3 font-mono">12&ndash;15 GPM</td>
              </tr>
              <tr class="bg-gray-50/50 border-b border-gray-50">
                <td class="p-3 pl-6 text-navy/70">@ 140&deg;F</td>
                <td class="p-3 font-mono">10&ndash;12 GPM</td>
                <td class="p-3 font-mono">20&ndash;24 GPM</td>
              </tr>
              <tr class="bg-white border-b border-gray-50">
                <td class="p-3 pl-6 font-bold text-green-700 bg-green-50/30">@ 200&deg;F</td>
                <td class="p-3 font-mono font-bold text-green-700 bg-green-50/30">20+ GPM</td>
                <td class="p-3 font-mono font-bold text-green-700 bg-green-50/30">45+ GPM</td>
              </tr>
              <tr class="bg-gray-50/50 border-b border-gray-50">
                <td class="p-3 font-bold text-navy">Drive Motor</td>
                <td class="p-3">7.5 HP</td>
                <td class="p-3">15 HP</td>
              </tr>
              <tr class="bg-white border-b border-gray-50">
                <td class="p-3 font-bold text-navy">Centrifugal Force</td>
                <td class="p-3 font-bold">7,200 Gs</td>
                <td class="p-3 font-bold">6,800 Gs</td>
              </tr>
              <tr class="bg-gray-50/50">
                <td class="p-3 font-bold text-navy">System Weight</td>
                <td class="p-3 font-mono">2,800 Lbs</td>
                <td class="p-3 font-mono">4,000 Lbs</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="lg:col-span-2 not-prose">
