---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Disc Centrifuge Liquid Seal Break or Breakover | Causes, Detection, Fixes",
    "description": "What causes liquid seal break or breakover in disc stack centrifuges, how to detect it mechanically and electronically, and corrective measures for each cause. Technical guide by Dolphin Centrifuge.",
    "author": { "@type": "Person", "name": "Sanjay Prabhu MSME", "jobTitle": "Centrifuge Applications Engineer", "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" } },
    "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
    "datePublished": "2021-02-01",
    "url": "https://dolphincentrifuge.com/disc-stack-centrifuge-liquid-seal-break/"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is liquid seal break in a disc stack centrifuge?",
        "acceptedAnswer": { "@type": "Answer", "text": "Liquid seal break (also called breakover or loss of liquid seal) is when the rotating liquid ring that seals the centrifuge bowl collapses, allowing air to enter the bowl. This causes the separated light phase (oil or clean liquid) to be lost from the centrate outlet, process liquid to flood out of the machine, and immediate separation failure. The liquid seal is maintained by the balance between feed flow rate, gravity disc size, and back-pressure — any disruption can trigger a break." }
      },
      {
        "@type": "Question",
        "name": "What causes liquid seal break in a centrifuge?",
        "acceptedAnswer": { "@type": "Answer", "text": "Common causes of liquid seal break include: (1) incorrect gravity disc size — too large a disc diameter reduces the seal, (2) low feed flow rate — insufficient liquid to maintain the seal ring, (3) high centrate back-pressure — excessive downstream resistance, (4) feed interruption or pump cavitation, (5) incorrect operating water volume during startup. Density changes in the process fluid (due to temperature swings or batch variation) can also destabilize the seal." }
      },
      {
        "@type": "Question",
        "name": "How do I detect liquid seal break?",
        "acceptedAnswer": { "@type": "Answer", "text": "Mechanical signs of liquid seal break include: liquid flooding from the centrate outlet and bowl hood, a sudden drop in centrate flow, and process fluid mixing between phases. Electronic detection methods include centrate conductivity probes (detects heavy phase in light phase outlet), flow meters on each outlet, and pressure sensors monitoring centrate back-pressure. Some installations use a turbidity probe to detect liquid loss in the centrate." }
      },
      {
        "@type": "Question",
        "name": "How do I fix a liquid seal break?",
        "acceptedAnswer": { "@type": "Answer", "text": "To recover from a liquid seal break: (1) immediately stop feed flow, (2) maintain operating water supply to re-establish the liquid ring, (3) check that the gravity disc size is correct for the current fluid density, (4) reduce centrate back-pressure by checking downstream valves and piping for restrictions, (5) confirm feed flow rate is within the rated range. If the break recurs consistently, re-evaluate the gravity disc selection using the density difference calculation for your specific light and heavy phases." }
      },
      {
        "@type": "Question",
        "name": "How do I select the correct gravity disc to prevent liquid seal break?",
        "acceptedAnswer": { "@type": "Answer", "text": "Gravity disc selection is based on the density of the light phase (oil) and heavy phase (water) being separated. The OEM provides a nomogram or formula using the density difference to calculate the correct disc inner diameter. A larger disc diameter raises the liquid interface (reducing seal margin), while a smaller diameter lowers it (increasing seal margin but risking heavy-phase carryover into the oil). When in doubt, select a smaller disc diameter for a more stable seal, then widen to optimize separation quality." }
      }
    ]
  }
];
---

<ApplicationLayout
  title="Disc Centrifuge Liquid Seal Break | Dolphin"
  description="What causes liquid seal break in disc centrifuges and how to fix it: gravity disc size, temperature, flow rate, priming, worn seals, and bowl speed explained."
  heroImage="/images/disc-stack-centrifuge-liquid-seal-break/disc-bowl-cross-section-seal-break-600.webp"
  heroImageAlt="Disc centrifuge bowl cross section showing liquid seal break pathway"
  category="knowledge"
  categoryLabel="Knowledge Base"
  canonicalUrl="https://dolphincentrifuge.com/disc-stack-centrifuge-liquid-seal-break/"
  jsonLd={jsonLd}
  relatedApplications={[
    { label: "Disc Centrifuge Backpressure Guide", href: "/disc-centrifuge-backpressure/" },
    { label: "Disc Stack Centrifuge Mechanical Issues & Fixes", href: "/disc-stack-centrifuge-mechanical-issues-fixes/" },
    { label: "9 Steps to Selecting the Right Industrial Centrifuge", href: "/picking-the-right-industrial-centrifuge/" },
    { label: "Centrifuge RCF and RPM Calculation", href: "/centrifuge-rcf-rpm-difference-calculation/" },
    { label: "Disadvantages of a Disc-Stack Centrifuge", href: "/disadvantages-disc-stack-centrifuge/" },
  ]}
>

  <div class="not-prose bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge provides expert troubleshooting for disc stack centrifuge liquid seal break — a failure mode where the heavy-phase water seal (maintained at 5,000-10,000 G) collapses, discharging oil through the water outlet. This guide covers 10 root causes, mechanical and electronic detection methods, and corrective measures for each.</p>
  </div>

  <!-- What is Liquid Seal Break -->
  <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">What is Liquid Seal Break or Breakover in Disc Centrifuges?</h2>
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <div class="space-y-3 text-text-light">
      <p>During the normal 3-phase separation process in a disc-stack centrifuge, the heavy phase (typically water) forms a liquid seal around the periphery of the bowl.</p>
      <p>Under certain conditions, the light phase pushes out the heavy phase and escapes through the heavy phase outlet. This operating condition is known as <strong>Liquid Seal Break</strong> or <strong>Break-Over</strong>.</p>
      <p>This article discusses the common causes of liquid seal breaking and the respective corrective measure for each of these causes.</p>
    </div>
  </div>

  <!-- Is it the same as Breakover? -->
  <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Is Liquid Seal Break the Same as Breakover?</h2>
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <p class="text-text-light">A liquid seal break and breakover are the same condition in disc-stack centrifuge operation. These terms refer to the condition during which the light phase of the separating liquid 'breakover' or 'breaks the heavy phase liquid seal' and comes out through the heavy phase outlet.</p>
  </div>

  <!-- Main Causes -->
  <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Main Causes of Liquid Seal Break</h2>
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <p class="text-text-light">The following is a list of causes of a 'liquid seal break' or breakover condition during the operation of disc-stack centrifuges. Corrective measures to fix the breakover for each cause are also included.</p>
  </div>

  <!-- Cause 1: Incorrect Gravity Disc -->
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">1</span>
      <h3 class="text-xl font-bold text-navy">Incorrect Gravity Disc (Hole Too Big)</h3>
    </div>
    <div class="space-y-3 text-text-light">
      <p>The gravity disc in the centrifuge bowl regulates the oil-water interface within the centrifuge. For best separation results, the oil-water interface should be closest to the bowl periphery without breaking the water seal.</p>
      <p>This interface positioning allows maximum g-force exerted by the rotation to act on the separation interface (shown below).</p>

      <img
        src="/images/disc-stack-centrifuge-liquid-seal-break/disc-centrifuge-oil-water-interface-400.webp"
        alt="Disc Centrifuge Oil Water Interface Effects showing interface positioning inside bowl"
        width="400" height="133"
        loading="lazy"
        class="rounded-lg w-full my-4"
      />
      <p class="text-sm text-center text-gray-500 -mt-2 mb-4 italic">Disc Centrifuge Oil Water Interface Effects</p>

      <p>A gravity disc with a larger hole diameter than the correct size (as determined by the nomogram) pushes the oil-water interface radially outwards. This incorrect interface positioning causes the light phase (oil) to be outside the top disc.</p>
      <p>The light phase can now exit the centrifuge bowl through the heavy phase passage and out through the heavy phase outlet. This, by definition, is a broken liquid seal.</p>
      <p>In this case, the process fluid (oil) comes out of the heavy phase (water) side causing fluid loss, which is highly undesirable.</p>
      <p><strong>Fix:</strong> The correct gravity disc with a smaller diameter hole (as indicated by the nomogram) will prevent the liquid seal from breaking. Using the gravity disc with a smaller hole diameter will remedy this cause of liquid seal breaking or breakover.</p>
    </div>
  </div>

  <!-- Cause 2: Process Fluid Temperature -->
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">2</span>
      <h3 class="text-xl font-bold text-navy">Process Fluid Temperature</h3>
    </div>
    <div class="space-y-3 text-text-light">
      <p>The nomogram defines the correct gravity disc based on the specific gravity of the process fluid at a specific temperature. If the process fluid is not at the appropriate temperature, the gravity disc installed in the centrifuge bowl may cause the fluid interface to move radially outward beyond the top disc.</p>
      <p>Under this condition, the light phase will exit the bowl through the heavy phase outlet (as explained above), causing a liquid seal break.</p>
      <p><strong>Fix:</strong> Maintaining the process fluid at the correct operating temperature throughout the process will prevent the liquid seal from breaking.</p>
    </div>
  </div>

  <!-- Cause 3: High Fluid Flow-Rate -->
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">3</span>
      <h3 class="text-xl font-bold text-navy">High Fluid Flow-Rate</h3>
    </div>
    <div class="space-y-3 text-text-light">
      <p>The centrifuge bowl size limits the amount of fluid of a given viscosity to pass through the disc stack. If the process fluid flow rate exceeds the bowl's capacity, the process fluid will push the liquid seal out of the bowl. Subsequently, the light phase will escape the bowl through the heavy phase outlet causing a liquid seal to break.</p>
      <p><strong>Fix:</strong> Reducing the process fluid flow rate will allow the light phase through the disc stack and ensure proper separation.</p>
    </div>
  </div>

  <!-- Cause 4: Light Phase Outlet Valve Closed -->
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">4</span>
      <h3 class="text-xl font-bold text-navy">Light Phase Outlet Valve Closed</h3>
    </div>
    <div class="space-y-3 text-text-light">
      <p>In most centrifuge systems, a regulating valve is provided on the light phase outlet pipe to apply back pressure for optimum separation. If the light phase outlet valve is accidentally closed, the light phase fluid cannot exit the bowl through its designed outlet.</p>
      <p>The light phase fluid will then push out the heavy phase liquid seal and exit the bowl through the heavy phase outlet. This causes a breakover.</p>
      <p><strong>Fix:</strong> The light phase outlet valve should be checked and opened if it is closed. A pressure sensor on the light phase outlet can be installed to detect excessive pressure on the light phase outlet to activate an alarm and prevent this from causing a breakover.</p>
    </div>
  </div>

  <!-- Cause 5: Priming Liquid Volume -->
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">5</span>
      <h3 class="text-xl font-bold text-navy">Priming Liquid Volume</h3>
    </div>
    <div class="space-y-3 text-text-light">
      <p>The first step during the startup of a disc-stack centrifuge is the bowl's priming with the heavy phase liquid, which is often water. The centrifuge bowl should be fed with priming liquid till the heavy phase liquid comes out through the heavy phase outlet.</p>
      <p>This heavy fluid exiting the centrifuge bowl indicates that the bowl's heavy phase space is filled with the priming liquid.</p>
      <p>In an automated centrifuge system, the priming liquid is supplied to the bowl through a solenoid valve operated by a timer. If the water pressure or flow changes, the allocated time may not be sufficient to fill the bowl with an adequate amount of heavy-phase liquid.</p>
      <p>In such cases, the light phase liquid will displace the heavy phase liquid and break the liquid seal.</p>
      <p><strong>Fix:</strong> Ensure the priming timer is set appropriately for the actual water pressure and flow. Verify that the bowl's heavy phase space is fully primed before introducing the process fluid.</p>
    </div>
  </div>

  <!-- Cause 6: Gasket Defective -->
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">6</span>
      <h3 class="text-xl font-bold text-navy">Gasket at Gravity Disc or Small Lock Ring Defective</h3>
    </div>
    <div class="space-y-3 text-text-light">

      <img
        src="/images/disc-stack-centrifuge-liquid-seal-break/disc-bowl-cross-section-seal-break-400.webp"
        alt="Disc Centrifuge Breakover caused by leaking gasket at gravity disc"
        width="400" height="199"
        loading="lazy"
        class="rounded-lg w-full my-4"
      />
      <p class="text-sm text-center text-gray-500 -mt-2 mb-4 italic">Disc Centrifuge Breakover — Leaking Gasket</p>

      <p>The heavy phase's flow path goes from the outer bowl periphery, above the top disc, then under the gravity disc, then into the heavy phase chamber, and finally out of the bowl. A couple of sealing parts (gasket and O-Ring) prevent the heavy phase from leaking out of the bowl.</p>
      <p>An O-ring situated under the gravity disc seals the interface between the gravity disc and the bowl hood. If this o-ring is damaged, the heavy phase will escape through this interface due to the extremely high pressure generated by centrifugal force.</p>
      <p>This unintentional reduction in the heavy phase will cause the liquid seal to break.</p>
      <p>Similarly, a flat gasket above the gravity disc seals the interface between the gravity disc and the small lock ring. If this gasket is damaged or torn, it will allow the liquid seal to escape causing a liquid seal to break.</p>
      <p><strong>Fix:</strong> These seals should be routinely checked and replaced (if damaged) to prevent breakover during operation.</p>
    </div>
  </div>

  <!-- Cause 7: Nylon Seal Ring -->
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">7</span>
      <h3 class="text-xl font-bold text-navy">Nylon Seal Ring is Worn, or Sliding Piston Lip Is Damaged</h3>
    </div>
    <div class="space-y-3 text-text-light">
      <p>The nylon seal ring embedded in the bowl hood presses against the lip of the sliding piston to form the main bowl seal that prevents the process fluid from escaping the bowl during separation. The priming liquid (heavy phase) is adjacent to this seal between the nylon seal ring and the sliding piston.</p>
      <p>If the nylon seal ring is worn out, it will allow the heavy phase (prime liquid) to escape the bowl. Similarly, if the mating lip seal on the sliding piston is damaged, gouged, or worn, it will have a similar effect. In either case, the unintentional exit of the prime liquid will cause the liquid seal to break.</p>
      <p><strong>Fix:</strong> The nylon seal ring is a sacrificial part and should be replaced periodically before it wears and causes breakovers and other operating problems. The sliding piston sealing lip should also be checked regularly to avoid such issues.</p>
      <p>Please read our article about <a href="/disc-stack-centrifuge-mechanical-issues-fixes/" class="text-navy font-semibold hover:text-gold transition-colors">top mechanical issues and fixes related to disc centrifuges</a>.</p>
    </div>
  </div>

  <!-- Cause 8: Disc Stack Clogged -->
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">8</span>
      <h3 class="text-xl font-bold text-navy">Disc Stack is Clogged with Sludge</h3>
    </div>
    <div class="space-y-3 text-text-light">
      <p>In rare cases, if the process sludge builds up and enters the gap between the discs, it will block the light phase's passage towards the center of the bowl. This disc blockage will cause the light phase to displace the heavy phase and, as a result, cause a breakover.</p>
      <p><strong>Fix:</strong> Under clogged disc stack conditions, the centrifuge should be stopped immediately and the disc stack thoroughly cleaned to remedy this cause of liquid seal break (breakover).</p>
    </div>
  </div>

  <!-- Cause 9: Low Bowl Speed -->
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">9</span>
      <h3 class="text-xl font-bold text-navy">Low Bowl Speed</h3>
    </div>
    <div class="space-y-3 text-text-light">
      <p>The centrifuge bowl speed generates the centrifugal force, which helps close the bowl through the operating water pressure under the sliding piston.</p>
      <p>If the centrifuge bowl speed is low due to a mechanical or electrical fault, the operating water pressure is insufficient to close the bowl properly. An improperly closed bowl allows the priming water to exit the bowl, which causes the liquid seal to break or breakover.</p>
      <p>The revolution counter on the centrifuge frame indicates the bowl speed to the operator. This speed should be periodically monitored to identify lower bowl speed.</p>
      <p><strong>Fix:</strong> Ensuring the centrifuge bowl is rotating at the designed speed will prevent low bowl speed from causing the liquid seal to break or breakover.</p>
    </div>
  </div>

  <!-- Cause 10: Bowl Not Assembled Properly -->
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">10</span>
      <h3 class="text-xl font-bold text-navy">Bowl Not Assembled Properly</h3>
    </div>
    <div class="space-y-3 text-text-light">
      <p>The disc centrifuge bowl is designed and manufactured very precisely. It is quite easy for an untrained operator to assemble the bowl incorrectly, which can cause some seals not to compress and seal adequately. For example, if the small lock ring is not tightened properly, the priming liquid (heavy phase) will escape the bowl through this inadequate seal causing the liquid seal to break.</p>
      <p>If the bowl hood is not positioned correctly on the sliding piston, the resulting uneven seal between the nylon seal ring and sliding piston will cause the heavy phase to escape, causing the liquid seal to break.</p>
      <p><strong>Fix:</strong> Proper bowl assembly is critical to prevent breakover from occurring and for the safe and reliable operation of the disc-stack centrifuge.</p>
    </div>
  </div>

  <!-- Detecting Liquid Seal Break -->
  <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Detecting Liquid Seal Break</h2>
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <div class="space-y-3 text-text-light">
      <p>A liquid seal break is detected by monitoring the fluid flowing out of the centrifuge. When the liquid seal breaks, it interrupts the fluid flow in the light phase outlet.</p>
      <p>It also causes a sudden excess fluid flow through the heavy phase outlet. Mechanical or electronic devices can detect either of these indicators.</p>

      <h3 class="text-lg font-bold text-navy mt-6 mb-3">Mechanical Detection</h3>
      <p>The routing of the heavy phase outlet of the centrifuge is through a collection tank. This tank has a bottom drain with an adjustable valve. The valve allows the typical volume of heavy phase to drain through it.</p>
      <p>But, in case of a liquid seal break, the excessive light phase volume accumulates in this tank. This accumulation of the light phase causes the tank level to rise and activates a level switch mounted in the tank.</p>
      <p>The change of state of the level switch triggers an alarm in the centrifuge control system, which activates corrective action.</p>

      <h3 class="text-lg font-bold text-navy mt-6 mb-3">Electronic Detection</h3>
      <p>As mentioned above, the liquid seal break stops the flow in the centrifuge's light phase outlet. During normal operation, a <a href="/disc-centrifuge-backpressure/" class="text-navy font-semibold hover:text-gold transition-colors">back-pressure</a> valve maintains pressure in this line.</p>
      <p>When a liquid seal break occurs, this pressure in the outlet line drops. A pressure sensor installed on this line senses the loss of pressure and thus detects the liquid seal break.</p>
      <p>Based on this trigger, the centrifuge control system stops the flow and activates an alarm.</p>
    </div>
  </div>

  <!-- Summary -->
  <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Summary</h2>
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <div class="space-y-3 text-text-light">
      <p>The liquid seal breaking is a common problem most disc centrifuge operators are familiar with. The primary causes and remedies mentioned above should help correct the vast majority of liquid seal breaks occurring in disc centrifuges.</p>
      <p>As seen above, most of these causes can be eliminated by periodic centrifuge maintenance and replacement of critical gaskets on the first sign of wear or damage.</p>
      <p class="text-sm italic">by <strong>Sanjay Prabhu MSME</strong>, Engineering Manager, Dolphin Centrifuge</p>
    </div>
  </div>

  <!-- CTA -->
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2 class="text-xl font-bold text-navy mb-3">Liquid Seal or Separation Problems?</h2>
    <p class="text-text-light mb-4">Recurring liquid seal break problems despite correct settings and flow rates indicate a machine configuration issue that requires professional diagnosis. Dolphin Centrifuge provides technical support, gravity disc selection, and <a href="/industrial-disc-centrifuge-repair/" class="text-navy font-semibold hover:text-gold transition-colors">centrifuge repair and audit services</a> to resolve persistent separation and liquid seal issues.</p>
    <p class="text-text-light mb-4">Contact us at <a href="tel:+12485222573" class="text-navy font-semibold hover:text-gold transition-colors">(248) 522-2573</a> or <a href="mailto:sales@dolphincentrifuge.com" class="text-navy font-semibold hover:text-gold transition-colors">sales@dolphincentrifuge.com</a>.</p>
    <div class="flex flex-wrap gap-3 mt-4">
      <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-6 py-3 rounded-lg transition-colors">Contact for Support</a>
      <a href="/industrial-centrifuge-sample-testing/" class="border border-navy text-navy font-semibold px-6 py-3 rounded-lg hover:bg-navy hover:text-white transition-colors">Sample Testing</a>
    </div>
  </div>

  <!-- FAQ -->
  <h2 id="faq" class="text-2xl font-bold text-navy mb-4">Frequently Asked Questions</h2>
  <div class="space-y-3 not-prose mb-8">
    <details class="border-l-4 border-gold/40 bg-gray-50 rounded-r-lg p-4 group">
      <summary class="font-semibold text-navy cursor-pointer flex items-center justify-between">
        What is liquid seal break in a disc stack centrifuge?
        <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#8964;</span>
      </summary>
      <p class="text-text-light text-sm mt-3">Liquid seal break occurs when the rotating liquid ring that seals the centrifuge bowl collapses, allowing air to enter. This causes the separated light phase to be lost from the centrate outlet, process liquid to flood out of the machine, and immediate separation failure. The seal is maintained by the balance between feed flow rate, gravity disc size, and back-pressure.</p>
    </details>
    <details class="border-l-4 border-gold/40 bg-gray-50 rounded-r-lg p-4 group">
      <summary class="font-semibold text-navy cursor-pointer flex items-center justify-between">
        What causes liquid seal break in a centrifuge?
        <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#8964;</span>
      </summary>
      <p class="text-text-light text-sm mt-3">Common causes: incorrect gravity disc size (too large reduces the seal), low feed flow rate (insufficient liquid to maintain the ring), high centrate back-pressure, feed interruption or pump cavitation, or incorrect operating water volume during startup. Density changes in the process fluid due to temperature swings can also destabilize the seal.</p>
    </details>
    <details class="border-l-4 border-gold/40 bg-gray-50 rounded-r-lg p-4 group">
      <summary class="font-semibold text-navy cursor-pointer flex items-center justify-between">
        How do I detect liquid seal break?
        <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#8964;</span>
      </summary>
      <p class="text-text-light text-sm mt-3">Mechanical signs include: liquid flooding from the centrate outlet and bowl hood, a sudden drop in centrate flow, and phase mixing. Electronic detection uses centrate conductivity probes, flow meters on each outlet, and centrate back-pressure sensors. Turbidity probes can also detect liquid loss in the centrate stream.</p>
    </details>
    <details class="border-l-4 border-gold/40 bg-gray-50 rounded-r-lg p-4 group">
      <summary class="font-semibold text-navy cursor-pointer flex items-center justify-between">
        How do I fix a liquid seal break?
        <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#8964;</span>
      </summary>
      <p class="text-text-light text-sm mt-3">To recover: (1) immediately stop feed flow, (2) maintain operating water supply to re-establish the liquid ring, (3) check that the gravity disc size is correct for current fluid density, (4) reduce centrate back-pressure by checking downstream valves and piping, (5) confirm feed flow rate is within rated range. If the break recurs consistently, re-evaluate gravity disc selection using the density difference calculation for your specific fluid phases.</p>
    </details>
    <details class="border-l-4 border-gold/40 bg-gray-50 rounded-r-lg p-4 group">
      <summary class="font-semibold text-navy cursor-pointer flex items-center justify-between">
        How do I select the correct gravity disc to prevent liquid seal break?
        <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#8964;</span>
      </summary>
      <p class="text-text-light text-sm mt-3">Gravity disc selection is based on the density of the light phase (oil) and heavy phase (water) being separated. The OEM provides a nomogram or formula using the density difference to calculate the correct disc inner diameter. A larger disc diameter raises the liquid interface (reducing seal margin), while a smaller diameter lowers it (increasing seal margin but risking heavy-phase carryover into the oil). When in doubt, select a smaller disc diameter for a more stable seal, then widen to optimize separation quality.</p>
    </details>
