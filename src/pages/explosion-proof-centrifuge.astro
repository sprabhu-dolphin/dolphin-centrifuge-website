---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqItems = [
  {
    question: "What is an explosion-proof centrifuge?",
    answer: "An explosion-proof centrifuge is a specially designed and manufactured industrial centrifuge for operating in hazardous locations. The possibility of the presence of explosive gases or particles designates specific environments as unsafe. A centrifuge that can safely process under such conditions is classified as explosion-proof. These centrifuges feature certified electrical enclosures, sparkless drive mechanisms, and specialized sensors and wiring to prevent ignition of flammable materials."
  },
  {
    question: "What is the difference between Class 1 Div 1 and Class 1 Div 2 centrifuges?",
    answer: "Class 1 Division 1 areas are locations where explosion or fire hazards exist due to the continuous presence of flammable gases, combustible liquid-produced vapors, combustible dust, or ignitable fibers. Class 1 Division 2 areas are locations where volatile flammable liquids or flammable gases exist but are generally confined within closed containers. Class 1 Div 1 centrifuges require more stringent modifications including cast metal housings and fully sealed enclosures, while Class 1 Div 2 centrifuges may use nitrogen-purged enclosures."
  },
  {
    question: "What electrical modifications are needed for a hazardous area centrifuge?",
    answer: "Hazardous area centrifuges require several electrical modifications: upgraded enclosures with inert gas purging or cast metal containment housings, rigid conduit routing with specialized fittings and sealed glands for both sensor and power wiring, and certified field instruments including temperature, pressure, level, and flow sensors rated for the applicable classification. Solenoid valves must also be certified for hazardous area use."
  },
  {
    question: "How are centrifuge drives modified for explosion-proof applications?",
    answer: "Two primary mechanical modifications address spark risk in centrifuge drives. First, standard steel friction clutch shoes can be replaced with brass or other non-ferrous metals to prevent sparking during contact. Second, and preferred, the friction clutch can be eliminated entirely through direct coupling using a coupling disc bolted to the horizontal shaft drum. Direct coupling requires a power inverter (VFD) to allow the motor to ramp up to operating speed over a defined time window without drawing excessive current."
  },
  {
    question: "What hazardous area certifications are available for industrial centrifuges?",
    answer: "Industrial centrifuges can be certified under three primary classification systems: NEC/CEC (North America) with Class and Division designations, ATEX (European Union) with Zone designations for explosive atmospheres, and IECEx (International) maintained by the International Electrotechnical Commission. Dolphin Centrifuge provides centrifuge systems certified to all three standards depending on the installation region and requirements."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Explosion Proof Centrifuge",
  "description": "Industrial explosion-proof centrifuges certified for Class 1 Div 1, Class 1 Div 2, ATEX Zone 1/2, and IECEx hazardous area installations. Electrical and mechanical modifications for safe operation in petroleum refineries, offshore platforms, and solvent extraction facilities.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "(248) 522-2573",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "24248 Gibson Dr",
      "addressLocality": "Warren",
      "addressRegion": "MI",
      "postalCode": "48089",
      "addressCountry": "US"
    }
  },
  "category": "Industrial Centrifuges",
  "url": "https://dolphincentrifuge.com/explosion-proof-centrifuge/",
  "image": "https://dolphincentrifuge.com/images/explosion-proof-centrifuge/Alfa-Laval-Explosion-Proof-Centrifuge-600.webp"
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "url": "https://dolphincentrifuge.com/explosion-proof-centrifuge/",
  "headline": "Explosion Proof Centrifuge | Hazardous Area Certified",
  "description": "Industrial explosion-proof centrifuges for Class 1 Div 1/2, ATEX, and IECEx certified hazardous locations including petroleum refineries and offshore platforms.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" }
};

const jsonLd = [productJsonLd, faqJsonLd, articleJsonLd];

const toc = [
  { id: 'synopsis', label: 'Synopsis' },
  { id: 'explosion-proof-centrifuge', label: 'Explosion Proof Centrifuge' },
  { id: 'applications', label: 'Applications Requiring Area Classified Centrifuges' },
  { id: 'class1-div1', label: 'Class 1 Division 1 Centrifuge Applications' },
  { id: 'petroleum-refineries', label: 'Centrifuge for Petroleum Refineries' },
  { id: 'class1-div2', label: 'Class 1 Division 2 Hazardous Area Applications' },
  { id: 'hemp-ethanol-extraction', label: 'Hemp Ethanol Extraction Centrifuge' },
  { id: 'purged-centrifuges', label: 'Uses for Purged Centrifuges' },
  { id: 'electrical-standards', label: 'Electrical Standards (NEC / ATEX / IECEx)' },
  { id: 'electrical-modifications', label: 'Electrical Modifications' },
  { id: 'enclosure-upgrades', label: 'Electrical Enclosures Upgrades' },
  { id: 'wiring', label: 'Power and Field Sensor Wiring' },
  { id: 'field-instruments', label: 'Field Instruments & Gages' },
  { id: 'mechanical-modifications', label: 'Mechanical Modifications' },
  { id: 'spark-less-clutches', label: 'Spark-less Clutches' },
  { id: 'direct-coupling', label: 'Direct Coupling of Centrifuge Drive' },
  { id: 'other-upgrades', label: 'Other Upgrades' },
  { id: 'summary', label: 'Summary' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedApplications = [
  { label: 'Crude Oil Tank Bottom Recovery', href: '/crude-oil-tank-bottom-recovery-centrifuge/' },
  { label: 'Diesel Fuel Centrifuge', href: '/diesel-centrifuge/' },
  { label: 'Stainless Steel Centrifuge', href: '/stainless-steel-centrifuge/' },
  { label: 'XP Stainless Steel Centrifuge', href: '/explosion-proof-stainless-steel-centrifuge/' },
];

const relatedProducts = [
  { label: 'Disc Stack Centrifuge Overview', href: '/disc-stack-centrifuge/', description: 'Full line of disc stack separators' },
  { label: 'Centrifuge Rental Services', href: '/disc-stack-centrifuge-rental/', description: 'Short & long-term rental programs' },
  { label: 'Centrifuge Selection Guide', href: '/alfa-laval-centrifuge-selection-guide/', description: 'Choose the right centrifuge for your application' },
];
---

<ApplicationLayout
  title="Explosion Proof Centrifuge | Hazardous Area Certified | Dolphin"
  description="Industrial explosion-proof centrifuges certified for Class 1 Div 1 &amp; Div 2, ATEX, and IECEx hazardous areas. Dolphin Centrifuge — 40+ years, fast delivery."
  heroImage="/images/explosion-proof-centrifuge/explosion-proof-centrifuge-hero-nb.webp"
  heroImageAlt="Explosion-proof centrifuge certified for Class 1 Div 1 hazardous area installation"
  category="applications"
  categoryLabel="Hazardous Area"
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
  canonicalUrl="https://dolphincentrifuge.com/explosion-proof-centrifuge/"
  jsonLd={jsonLd}
>

  <!-- AI Summary -->
  <div class="not-prose bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies explosion-proof disc stack centrifuge systems certified for Class 1 Div 1, Class 1 Div 2, ATEX Zone 1/2, and IECEx hazardous areas. Featuring sparkless direct-drive transmissions and nitrogen-purged enclosures for petroleum refineries, offshore platforms, and solvent extraction facilities.</p>
  </div>

  <!-- ══ Synopsis ══ -->
  <div id="synopsis" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2>Synopsis</h2>
    <p>
      Industrial centrifuge applications need not be limited by the location or environment being unacceptable for standard machinery. Specially designed centrifuges are safe to install in potentially hazardous environments. In this article, we discuss various considerations and solutions for applying centrifuges in dangerous locations.
    </p>
  </div>

  <!-- ══ What Is an XP Centrifuge ══ Pattern A: side-by-side -->
  <div id="explosion-proof-centrifuge" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2>Explosion Proof Centrifuge</h2>
    <div class="flex flex-col md:flex-row gap-6 items-start">
      <div class="md:w-[55%]">
        <p>
          An explosion-proof centrifuge is a specially designed and manufactured industrial centrifuge for operating in hazardous locations. The possibility of the presence of explosive gases or particles designates specific environments as unsafe. A centrifuge that can safely process under such conditions is classified as explosion-proof.
        </p>
        <p>
          Many industrial applications process fluids that have a low flash point and are flammable. In other words, liquids that can easily ignite need specially designed equipment to operate safely. Sub-classifications within this category of hazardous environments depend on the type and presence of such flammable materials.
        </p>
        <p>
          Authorized governing bodies define specific details on area classifications. This UL documentation provides detailed hazardous area classification criteria.
        </p>
      </div>
      <div class="md:w-[45%] shrink-0">
        <img
          src="/images/explosion-proof-centrifuge/Alfa-Laval-Explosion-Proof-Centrifuge-600-2.webp"
          alt="Class 1 Div 1 explosion-proof centrifuge for hazardous area installation"
          width="600"
          height="707"
          loading="lazy"
          class="rounded-lg shadow-sm w-full h-auto object-cover"
        />
        <p class="text-gray-500 text-sm mt-1 text-center">Class 1 Div 1 — Explosion Proof Centrifuge</p>
      </div>
    </div>
  </div>

  <!-- ══ Applications — Class 1 Div 1 ══ -->
  <div id="applications" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2>Applications Requiring Area Classified Centrifuges</h2>

    <div id="class1-div1" class="mb-8">
      <h3>Class 1 Division 1 Centrifuge Applications</h3>

      <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
        <p>
          <strong>Class 1 Division 1</strong> areas are classified as locations where explosion or fire hazards exist due to the presence of flammable gases, flammable or combustible liquid-produced vapors, combustible dust, or ignitable fibers or flyings.
        </p>
      </div>

      <p>
        The following are typical examples of such explosion-proof centrifuge applications. We briefly describe the considerations for centrifuge execution for petroleum refineries.
      </p>

      <!-- Petroleum Refineries — Pattern A -->
      <div id="petroleum-refineries" class="bg-gray-50 rounded-lg p-6 mb-6">
        <h4 class="text-lg font-bold text-navy mb-4">Centrifuge for Petroleum Refineries</h4>
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <div class="md:w-[55%]">
            <p>
              Crude oil refineries process crude oil feedstock to produce final products such as solvents, condensate, gasoline, diesel, naphtha, kerosene, etc. All of these petroleum components are flammable and therefore require safe processing by using explosion-proof centrifuges.
            </p>
            <p>
              The hazardous area classification of the centrifuge depends on the actual location of the centrifuge. If the centrifuge is in an area in the presence of flammable liquids, vapors, or gases, it needs to be suitable for the Class 1 Div 1 environment.
            </p>
            <p>
              The photograph shown here illustrates an <a href="/alfa-laval-mab-103-centrifuge/">Alfa Laval MAB-103B24-60</a> Centrifuge suitable for NEC Class 1 Division 1 Groups C &amp; D hazardous area installation.
            </p>
            <p>
              On the other hand, if the centrifuge application is in a relatively safer area where such flammable material is not usually present, a Class I Div 2 certified centrifuge may be adequate, like the one shown below.
            </p>
          </div>
          <div class="md:w-[45%] shrink-0">
            <img
              src="/images/explosion-proof-centrifuge/Alfa-Laval-Diesel-Centrifuge-Class-1-Div-2-Explosion-Proof-600-1.webp"
              alt="Diesel centrifuge Class 1 Div 2 explosion-proof for petroleum refinery application"
              width="600"
              height="496"
              loading="lazy"
              class="rounded-lg shadow-sm w-full h-auto object-cover"
            />
            <p class="text-gray-500 text-sm mt-1 text-center">Diesel Centrifuge — Class 1 Div 2 Explosion Proof</p>
          </div>
        </div>
      </div>

      <!-- Offshore Gas Platform — Pattern A -->
      <div class="mb-4">
        <h4 class="text-lg font-bold text-navy mb-3">Class 1 Div 1 Explosion Proof Centrifuge — Offshore Gas Platform</h4>
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <div class="md:w-[55%]">
            <p>
              Similarly, an Offshore Oil and Gas Platform centrifuge system could require a specific hazardous area classification based on the final installation location.
            </p>
          </div>
          <div class="md:w-[45%] shrink-0">
            <img
              src="/images/explosion-proof-centrifuge/alfa-laval-class1-div2-hazardous-area-centrifuge-offshore-400.webp"
              alt="Class 1 Div 2 diesel centrifuge installed on offshore oil and gas platform"
              width="400"
              height="400"
              loading="lazy"
              class="rounded-lg shadow-sm w-full h-auto object-cover"
            />
            <p class="text-gray-500 text-sm mt-1 text-center">Class 1 Div 2 Diesel Centrifuge — Offshore Platform</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ══ Class 1 Div 2 ══ -->
    <div id="class1-div2" class="mb-8">
      <h3>Class 1 Division 2 (C1D2) Hazardous Area Centrifuge Applications</h3>

      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
        <p>
          <strong>Class 1 Division 2</strong> areas are classified as locations where volatile flammable liquids or flammable gases or vapors exist but are generally confined within closed containers.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <div>
          <img
            src="/images/explosion-proof-centrifuge/DMPX-028-Class-1-Div-2-Duplex-Diesel-Centrifuge-Module-600.webp"
            alt="DMPX-028 Class 1 Div 2 duplex diesel centrifuge module"
            width="600"
            height="578"
            loading="lazy"
            class="rounded-lg w-full object-cover"
          />
          <p class="text-gray-500 text-xs mt-1 text-center">DMPX-028 Class 1 Div 2 Duplex Diesel Centrifuge Module</p>
        </div>
        <div>
          <img
            src="/images/explosion-proof-centrifuge/Alfa-Laval-3-Phase-Centrifuge-Class-1-Div-2-Crude-Oil-Hawaii-300.webp"
            alt="3-phase centrifuge Class 1 Div 2 for crude oil processing"
            width="300"
            height="401"
            loading="lazy"
            class="rounded-lg w-full object-cover"
          />
          <p class="text-gray-500 text-xs mt-1 text-center">Centrifuge Class 1 Div 2 — Crude Oil</p>
        </div>
        <div>
          <img
            src="/images/explosion-proof-centrifuge/SS-Food-Grade-Decanter-C1D2-Alcohol-Processing-600-1.webp"
            alt="Stainless steel food-grade decanter centrifuge Class 1 Div 2 for alcohol slurry processing"
            width="600"
            height="630"
            loading="lazy"
            class="rounded-lg w-full object-cover"
          />
          <p class="text-gray-500 text-xs mt-1 text-center">Stainless Steel (Food Grade) Decanter — C1D2 Alcohol Processing</p>
        </div>
      </div>

      <p>
        The following example illustrates the explosion-proof equipment considerations for the Hemp CBD Oil industry.
      </p>

      <!-- Hemp Ethanol Extraction — Pattern A -->
      <div id="hemp-ethanol-extraction" class="bg-gray-50 rounded-lg p-6 mt-6">
        <h4 class="text-lg font-bold text-navy mb-3">Hemp Ethanol Extraction Centrifuge</h4>
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <div class="md:w-[55%]">
            <p>
              Alcohol is the solvent of choice for <a href="/disc-stack-centrifuge-applications/">CBD Oil extraction from hemp plants</a>. Ethanol alcohol has a low flash point and is considered a hazardous fluid. Therefore, decanter centrifuges used for hemp biomass separation from ethanol must meet hazardous area certification.
            </p>
            <p>
              The image shown here is that of an Alfa Laval <strong>Class 1 Div 2 Hemp Extraction Centrifuge.</strong>
            </p>
            <p>
              Since the hemp solvent extraction is a closed (isolated from the environment) system, Class 1 Div 2 certified components are adequate for such locations. Suppose the hemp producer uses a hydrocarbon-based solvent as the extraction medium. In that case, careful consideration and professional consultation are recommended to identify and implement the right hazardous area classification.
            </p>
            <p>
              Another very similar application is for <a href="/disc-stack-centrifuge-applications/">THC extraction from cannabis using solvents or ethanol.</a>
            </p>
          </div>
          <div class="md:w-[45%] shrink-0">
            <img
              src="/images/explosion-proof-centrifuge/hemp-centrifuge-explosion-proof-300x300.webp"
              alt="Large volume hemp centrifuge explosion-proof Class 1 Div 2 rated at 40 GPM"
              width="300"
              height="300"
              loading="lazy"
              class="rounded-lg shadow-sm w-full h-auto object-cover"
            />
            <p class="text-gray-500 text-sm mt-1 text-center">Large Volume Hemp Centrifuge — Explosion Proof — 40 GPM</p>
          </div>
        </div>
      </div>

      <!-- Stainless Steel Disc Stack XP -->
      <div class="mt-6">
        <img
          src="/images/explosion-proof-centrifuge/Alfa-Laval-Disc-Stack-Centrifuge-Stainless-Steel-Explosion-Proof.webp"
          alt="Stainless steel disc stack centrifuge in explosion-proof configuration"
          width="600"
          height="664"
          loading="lazy"
          class="rounded-lg w-full max-w-lg mx-auto block"
        />
        <p class="text-gray-500 text-xs mt-2 text-center">Disc Stack Centrifuge — Stainless Steel Explosion Proof</p>
      </div>
    </div>

    <!-- Purged Centrifuges — Pattern A -->
    <div id="purged-centrifuges">
      <h3>Uses for Purged Centrifuges</h3>
      <div class="flex flex-col md:flex-row gap-6 items-start">
        <div class="md:w-[55%]">
          <p>
            In specific applications, the centrifuges may be purged with an inert gas to blanket the internals. This constant purging prevents the buildup of vapors from the process fluid. This purging is an added safety measure. This methodology also helps in cases where the gases or odors are a potential health hazard for the local operators.
          </p>
          <p>
            An inert gas purging system coupled with a low vacuum venting system helps prevent the operating area from being free of such gases and odors.
          </p>
          <p>
            For example, centrifuges operating on <a href="/crude-oil-tank-bottom-recovery-centrifuge/">crude oil tank bottoms</a> could potentially be inert gas purged and vented to alleviate the presence of hydrogen sulfide gas in the operating area.
          </p>
          <p>
            Inert gas blanketing isolates the process fluid from the atmosphere to prevent oxidation and related chemical deterioration. <a href="/beer-wine-centrifuge/">Centrifuges used to process wine and beer</a> must keep the process fluid away from the air to prevent oxidation. This application is an example of purging for a non-hazardous centrifuge application.
          </p>
        </div>
        <div class="md:w-[45%] shrink-0">
          <img
            src="/images/explosion-proof-centrifuge/Alfa-Laval-MAB-206-Disc-Stack-Centrifuge-Explosion-Proof-Class-1-Div-2.webp"
            alt="Disc stack centrifuge explosion-proof Class 1 Div 2 configuration"
            width="600"
            height="801"
            loading="lazy"
            class="rounded-lg shadow-sm w-full h-auto object-cover"
          />
          <p class="text-gray-500 text-sm mt-1 text-center">Disc Stack Centrifuge — Explosion Proof Class 1 Div 2</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ Electrical Standards ══ -->
  <div id="electrical-standards" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2>Electrical Standards for Explosion-Proof &amp; Hazardous Areas</h2>

    <p class="mb-6">
      Depending on the region, different types of hazardous area classifications apply to specific area locations. We have broadly summarized the three primary systems of classification in use worldwide. Again, specific details on each guideline are on the included links under each heading.
    </p>

    <div class="grid md:grid-cols-3 gap-6">
      <!-- N. America -->
      <div class="bg-gray-50 rounded-lg p-5 border border-gray-200">
        <h4 class="text-lg font-bold text-navy mb-3">N. America (NEC / CEC)</h4>
        <p class="text-sm leading-relaxed mb-3">
          Permissible components for use in hazardous areas in N. America must comply with requirements issued by <strong>NEC (National Electrical Code)</strong> and <strong>CEC (Canadian Electrical Code)</strong> standards.
        </p>
        <p class="text-sm leading-relaxed mb-3">
          The UL system designates Classes and Divisions within each Class. In comparison, the new Canadian system sets zones within each Class. There are significant differences between the division and zone classifications.
        </p>
        <p class="text-sm leading-relaxed">
          UL (Underwriters Laboratories) provides certification and marking for equipment intended for use in classified hazardous locations.
        </p>
        <div class="mt-3 bg-blue-50 rounded p-2 text-xs font-mono text-navy">
          Class 1 Div 1 / Div 2<br/>
          Groups A, B, C, D
        </div>
      </div>

      <!-- European Union -->
      <div class="bg-gray-50 rounded-lg p-5 border border-gray-200">
        <h4 class="text-lg font-bold text-navy mb-3">European Union (ATEX)</h4>
        <p class="text-sm leading-relaxed mb-3">
          The European electrical and protective equipment certification system in Europe is commonly known as the <strong>ATEX directive</strong>. Per the official document, "Equipment and protective systems intended for use in potentially explosive atmospheres (ATEX) cover a range of products, including those used on fixed offshore platforms, petrochemical plants, mines, and flour mills, amongst others."
        </p>
        <p class="text-sm leading-relaxed">
          A typical example of an Alfa Laval centrifuge suitable for hazardous locations would be marked as <strong>ATEX II 3 G (Zone 2) II B T3.</strong> The reader can reference specific zone details in the official ATEX summary documentation.
        </p>
        <div class="mt-3 bg-blue-50 rounded p-2 text-xs font-mono text-navy">
          Zone 1 / Zone 2<br/>
          ATEX II 3G, IIB T3
        </div>
      </div>

      <!-- International -->
      <div class="bg-gray-50 rounded-lg p-5 border border-gray-200">
        <h4 class="text-lg font-bold text-navy mb-3">International (IECEx)</h4>
        <p class="text-sm leading-relaxed mb-3">
          IS (International Standard) has guidelines for hazardous area designation and compliance, similar to the ATEX guidelines. The <strong>IEC (International Electrotechnical Commission)</strong> maintains these standards.
        </p>
        <div class="mt-3 bg-blue-50 rounded p-2 text-xs font-mono text-navy">
          IECEx Zone 1 / Zone 2<br/>
          IEC 60079 Series
        </div>
      </div>
    </div>

    <!-- ATEX image -->
    <div class="mt-6">
      <img
        src="/images/explosion-proof-centrifuge/DMPX-014-Duplex-Disc-Stack-Centrifuge-Skid-for-HFO-and-Diesel-ATEX-Zone-2-600.webp"
        alt="DMPX-014 duplex disc stack centrifuge skid for HFO and diesel fuel - ATEX Zone 2 certified"
        width="600"
        height="458"
        loading="lazy"
        class="rounded-lg w-full max-w-xl mx-auto block"
      />
      <p class="text-gray-500 text-xs mt-2 text-center">DMPX-014 Duplex Disc Stack Centrifuge Skid for HFO and Diesel — ATEX Zone 2</p>
    </div>
  </div>

  <!-- ══ Electrical Modifications ══ -->
  <div id="electrical-modifications" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
    <h2>Electrical Modifications for Hazardous Area Centrifuges</h2>

    <p class="mb-6">
      Electrical components used on industrial centrifuges designed for hazardous areas must meet the designated classification and be certified to the same standard. These parts fall into the following categories.
    </p>

    <!-- Enclosures — Pattern A -->
    <div id="enclosure-upgrades" class="mb-8">
      <h3>Electrical Enclosures Upgrades</h3>
      <div class="flex flex-col md:flex-row gap-6 items-start">
        <div class="md:w-[55%]">
          <p>
            Industrial electrical enclosures house various electrical components, which can cause sparking during routine operations. These sparks can cause flammable gases or vapors to ignite if they are present in high concentrations. Therefore centrifuge control system enclosures need to be appropriately isolated from the surrounding environment through proper sealing.
          </p>
          <p>
            Depending on the classification level, an inert gas purging system may be installed on the enclosure, as shown in the adjacent photograph. This device creates and maintains an inert gas atmosphere within the enclosure that prevents the ignition of flammable gases or vapors by replacing oxygen.
          </p>
          <p>
            The next level of enclosure classification to Class I Div 1 specification involves cast metal housing designed to contain thermal events within the enclosures. Specially rated electrical fittings and joint seals isolate these containment enclosures from the surrounding environment.
          </p>
        </div>
        <div class="md:w-[45%] shrink-0">
          <img
            src="/images/explosion-proof-centrifuge/Class-1-Div-2-Nitrogen-Purge-Centrifuge-System-300.webp"
            alt="Nitrogen purge device for Class 1 Div 2 centrifuge control enclosure"
            width="300"
            height="395"
            loading="lazy"
            class="rounded-lg shadow-sm w-full h-auto max-w-xs"
