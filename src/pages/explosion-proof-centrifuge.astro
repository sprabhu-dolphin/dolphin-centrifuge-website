---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Explosion Proof Centrifuge",
  "description": "Industrial explosion-proof centrifuges certified for Class 1 Div 1, Class 1 Div 2, ATEX Zone 1/2, and IECEx hazardous area installations. Electrical and mechanical modifications for safe operation in petroleum refineries, offshore platforms, and solvent extraction facilities.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "(248) 522-2573",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "24248 Gibson Dr",
      "addressLocality": "Warren",
      "addressRegion": "MI",
      "postalCode": "48089",
      "addressCountry": "US"
    }
  },
  "category": "Industrial Centrifuges",
  "url": "https://dolphincentrifuge.com/explosion-proof-centrifuge/",
  "image": "https://dolphincentrifuge.com/images/explosion-proof-centrifuge/Alfa-Laval-Explosion-Proof-Centrifuge-600.jpg"
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is an explosion-proof centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An explosion-proof centrifuge is a specially designed and manufactured industrial centrifuge for operating in hazardous locations. The possibility of the presence of explosive gases or particles designates specific environments as unsafe. A centrifuge that can safely process under such conditions is classified as explosion-proof. These centrifuges feature certified electrical enclosures, spark-free drive mechanisms, and specialized sensors and wiring to prevent ignition of flammable materials."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between Class 1 Div 1 and Class 1 Div 2 centrifuges?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Class 1 Division 1 areas are locations where explosion or fire hazards exist due to the continuous presence of flammable gases, combustible liquid-produced vapors, combustible dust, or ignitable fibers. Class 1 Division 2 areas are locations where volatile flammable liquids or flammable gases exist but are generally confined within closed containers. Class 1 Div 1 centrifuges require more stringent modifications including cast metal housings and fully sealed enclosures, while Class 1 Div 2 centrifuges may use nitrogen-purged enclosures."
      }
    },
    {
      "@type": "Question",
      "name": "What electrical modifications are needed for a hazardous area centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Hazardous area centrifuges require several electrical modifications: upgraded enclosures with inert gas purging or cast metal containment housings, rigid conduit routing with specialized fittings and sealed glands for both sensor and power wiring, and certified field instruments including temperature, pressure, level, and flow sensors rated for the applicable classification. Solenoid valves must also be certified for hazardous area use."
      }
    },
    {
      "@type": "Question",
      "name": "How are centrifuge drives modified for explosion-proof applications?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Two primary mechanical modifications address spark risk in centrifuge drives. First, standard steel friction clutch shoes can be replaced with brass or other non-ferrous metals to prevent sparking during contact. Second, and preferred, the friction clutch can be eliminated entirely through direct coupling using a coupling disc bolted to the horizontal shaft drum. Direct coupling requires a power inverter (VFD) to allow the motor to ramp up to operating speed over a defined time window without drawing excessive current."
      }
    },
    {
      "@type": "Question",
      "name": "What hazardous area certifications are available for industrial centrifuges?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Industrial centrifuges can be certified under three primary classification systems: NEC/CEC (North America) with Class and Division designations, ATEX (European Union) with Zone designations for explosive atmospheres, and IECEx (International) maintained by the International Electrotechnical Commission. Dolphin Centrifuge provides centrifuge systems certified to all three standards depending on the installation region and requirements."
      }
    }
  ]
};
---

<BaseLayout
  title="Explosion Proof Centrifuge Guide"
  description="UL-listed explosion-proof disc centrifuges for Class I Div 1 & Div 2 hazardous locations. Dolphin Centrifuge — certified units, fast delivery, expert support."
  canonicalUrl="https://dolphincentrifuge.com/explosion-proof-centrifuge/"
  breadcrumbs={[{label: 'Products', href: '/centrifuges/'}, {label: 'Explosion-Proof Centrifuge'}]}
  jsonLd={jsonLd}
>

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Hero -->
  <section class="bg-[#1B3A5C] text-white py-14 md:py-20">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <nav class="text-sm text-blue-200 mb-4" aria-label="Breadcrumb">
            <a href="/centrifuges/" class="hover:text-white transition-colors">Products</a>
            <span class="mx-2">›</span>
            <span class="text-white">Explosion-Proof Centrifuge</span>
          </nav>
          <h1 class="text-3xl md:text-4xl font-bold font-['Plus_Jakarta_Sans'] mb-4 leading-tight">
            Explosion Proof Centrifuge
          </h1>
          <p class="text-lg text-blue-100 mb-6 font-['Source_Sans_3']">
            Hazardous Area Certified — Class 1 Div 1 / Div 2, ATEX, IECEx
          </p>
          <p class="text-blue-100 mb-4 font-['Source_Sans_3']">
            Industrial centrifuge applications need not be limited by a hazardous or explosive environment. Specially designed and certified centrifuges operate safely in Class 1 Division 1, Class 1 Division 2, ATEX Zone 1/2, and IECEx classified locations.
          </p>
          <p class="text-blue-100 mb-8 font-['Source_Sans_3']">
            Dolphin Centrifuge supplies purpose-modified industrial disc stack and decanter centrifuges for hazardous area installations. With over 40 years of experience in centrifugal separation, we provide fully certified explosion-proof centrifuge systems for petroleum refineries, offshore platforms, solvent extraction, and chemical processing facilities across North America and worldwide.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] hover:bg-yellow-500 text-black font-bold py-3 px-6 rounded-lg transition-colors text-center">
              Request a Quote
            </a>
            <a href="tel:+12485222573" class="border border-white text-white hover:bg-white hover:text-[#1B3A5C] font-semibold py-3 px-6 rounded-lg transition-colors text-center">
              (248) 522-2573
            </a>
          </div>
        </div>
        <div class="flex justify-center">
          <img
