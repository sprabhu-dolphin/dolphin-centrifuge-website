      class="rounded-lg shadow-md img-cap-700"
      data-lightbox-caption="Typical execution timeline: RFQ review, bid package, approval documents, procurement, fabrication, FAT, and shipment."
    />
  </figure>

  <div class="grid md:grid-cols-2 gap-5 not-prose mb-8 items-stretch">

    <div class="relative overflow-hidden rounded-xl border border-gray-200 bg-white p-5 shadow-sm ring-1 ring-gray-100 flex flex-col">
