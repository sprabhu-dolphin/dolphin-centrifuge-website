  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question.replace(/&amp;/g, '&'),
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/&amp;/g, '&')
