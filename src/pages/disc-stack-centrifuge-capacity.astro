  { label: 'Disc Stack Centrifuge Troubleshooting', href: '/disc-stack-centrifuge-mechanical-issues-fixes/' },
  { label: 'Disc Stack Centrifuge Overview', href: '/disc-stack-centrifuge/' },
];

const relatedProducts = [
  { label: 'DMPX Series — Self-Cleaning', href: '/centrifuges/', description: '4 to 108 GPM rated capacity' },
  { label: 'Oil Centrifuge Systems', href: '/oil-centrifuge/', description: 'Fuel & lube oil purification' },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Disc Stack Centrifuge Capacity Guide | Dolphin Centrifuge",
    "description": "Understand disc stack centrifuge capacity: the difference between swallowing, rated, and actual capacity, plus all factors affecting real-world throughput including viscosity, temperature, particle size, and centrifuge design.",
    "author": { "@type": "Person", "name": "Sanjay Prabhu MSME", "jobTitle": "Centrifuge Applications Engineer", "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" } },
    "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
    "datePublished": "2021-08-01",
    "url": "https://dolphincentrifuge.com/disc-stack-centrifuge-capacity/",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the difference between swallowing capacity and rated capacity of a disc stack centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Swallowing capacity is the maximum volumetric flow rate the centrifuge pump and piping can handle physically — it is not the separation-effective rate. Rated capacity is the manufacturer's specified throughput for a given fluid at standard conditions (typically diesel at 13 cSt). Actual capacity in real-world operation may be lower due to fluid viscosity, temperature, solids content, and the required separation quality."
        }
      },
      {
        "@type": "Question",
        "name": "How does fluid viscosity affect disc stack centrifuge capacity?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Higher viscosity directly reduces centrifuge throughput. As a rule of thumb: doubling the viscosity roughly halves the effective capacity. For example, a DMPX-028 rated at 25 GPM on diesel (13 cSt) drops to approximately 10-12 GPM on 100 cSt lube oil, and as low as 3-4 GPM on 700 cSt heavy fuel oil (HFO 380)."
        }
      },
      {
        "@type": "Question",
        "name": "Does temperature affect disc stack centrifuge capacity?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Higher temperature reduces fluid viscosity, which increases centrifuge capacity. Most heavy oils are preheated to 190-210 degrees F before centrifuge processing to bring viscosity down to the 30-100 cSt range where the centrifuge operates efficiently. Heating is often the most effective way to recover capacity on viscous fluids."
        }
      },
      {
        "@type": "Question",
        "name": "How do I select the right disc stack centrifuge capacity for my application?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Start with your required throughput in GPM, then identify your fluid viscosity at operating temperature. Apply the viscosity de-rating factor (from manufacturer tables) to the rated capacity to get effective capacity for your fluid. Add 20-30% buffer for flow surges and future expansion. Dolphin Centrifuge engineers can size the right DMPX model for your application — call (248) 522-2573."
        }
      },
      {
        "@type": "Question",
        "name": "Does solids content affect disc stack centrifuge capacity?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Higher solids content fills the sludge space faster, requiring more frequent bowl ejection cycles (for self-cleaning centrifuges) or more frequent manual cleaning (for solid-bowl types). In practical terms, high solids reduce effective throughput because the centrifuge must spend more time on cleaning cycles and less time on separation."
        }
      }
    ]
  }
];
