---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqItems = [
  {
    question: "What do Dolphin Centrifuge customers say about their support experience?",
    answer: "Customers consistently note Dolphin Centrifuge's rapid response time, deep technical knowledge, and long-term relationship focus. Multiple customers report relationships spanning 15+ years, with engineers available after hours for urgent troubleshooting. Technical support is included at no charge for all centrifuges supplied."
  },
  {
    question: "Does Dolphin Centrifuge provide references for specific applications?",
    answer: "Yes. Dolphin Centrifuge can provide customer references for most centrifuge applications including waste oil recovery, food processing, pharmaceutical, metalworking coolant, wastewater treatment, and marine applications. Contact us at (248) 522-2573 or sales@dolphincentrifuge.com to request application-specific references."
  },
  {
    question: "How long has Dolphin Centrifuge been in business?",
    answer: "Dolphin Centrifuge was founded in 1981 — over 40 years serving industrial customers with disc stack and decanter centrifuge systems, parts, and service. The company began as an Alfa Laval aftermarket parts supplier and grew into a full-service centrifuge systems manufacturer based in Warren, Michigan."
  },
  {
    question: "Does Dolphin Centrifuge offer free sample testing before purchase?",
    answer: "Yes. Dolphin Centrifuge operates a fully equipped sample testing lab in Warren, Michigan. Send us a fluid sample and we run it through the centrifuge, document before-and-after results with photos, and provide a detailed report with recommended equipment sizing. This service allows customers to verify separation performance before committing to a purchase."
  },
  {
    question: "What warranty does Dolphin Centrifuge provide on its centrifuge systems?",
    answer: "All Dolphin Centrifuge centrifuge systems include a mechanical warranty covering workmanship and components. Beyond the warranty period, Dolphin provides lifetime technical support at no charge — covering operational questions, troubleshooting assistance, and parts identification for as long as the equipment is in service."
  }
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer.replace(/<[^>]*>/g, '') }
  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Dolphin Centrifuge Customer Testimonials — Real Reviews from Industrial Users",
  "description": "Read what real Dolphin Centrifuge customers say about our engineering expertise, centrifuge systems, and lifetime support across biodiesel, oilfield, and industrial applications.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/dolphin-centrifuge-customer-testimonials/",
  "mainEntityOfPage": "https://dolphincentrifuge.com/dolphin-centrifuge-customer-testimonials/"
};

const testimonials = [
  {
    id: 1,
    quote: "You've been there, you get it …I pass this along because it is precisely the type of customer service we appreciate and respect. Many don't understand the importance of getting us back on line quickly and we need to have an equipment vendor who understands the equipment they sell. You do understand how important it is to have us up and running… and you clearly understand your equipment. We all thank you for your professionalism. Finally, from your email back to David, it is also abundantly clear that you realize we are not Exxon Mobil or Chevron. We are a start-up in every sense of the word and at this point need an equipment supplier who realizes our concern over every dollar. You've been there, you get it, and for that, too, I thank you! When the time comes, I look forward to talking with you about another Dolphin purchase.",
    company: "N.E. Biofuel Co.",
    contact: "T. G.",
    title: "President & CEO",
    highlight: "You've been there, you get it",
    industry: "Biodiesel / Biofuel"
  },
  {
    id: 2,
    quote: "For the ongoing reservoir side centrifuge filtration you are looking for I would suggest you contact Sanjay at Dolphin Centrifuge. I have been dealing with Sanjay for over 15 years now and he is by far the best at what he does. Aside from the fact he can provide a custom solution for you at the best price, his service is excellent. He has even answered my call in the middle of the night before when he was in Japan on a startup.",
    company: "D.O.C.",
    contact: "J. E.",
    title: "Manager",
    highlight: "over 15 years",
    industry: "Industrial / Reservoir"
  },
  {
    id: 3,
    quote: "Thank you! for your continued support. Both machines are ripping through the stream – good separation. We'll be calling you shortly for 2 more.. stay tuned.",
    company: "J.H Prod. / Gulf Oilfield Products",
    contact: "Gulf Oilfield Products",
    title: null,
    highlight: "good separation",
    industry: "Oilfield"
  },
  {
    id: 4,
    quote: "By the way Jim (Kraft) is very good. He really knows his centrifuges and the process. I am so glad that we brought him in.",
    company: "NJ BioDiesel Co.",
    contact: "M. Z.",
    title: "President / COO",
    highlight: "knows his centrifuges",
    industry: "Biodiesel"
  },
  {
    id: 5,
    quote: "Dolphin Centrifuge did an excellent job of building our MOPX207 separator skid to build it as a compact setup with an easy plug and play operation. Everything that went into the unit as far as the automation from controls for the computer system is very user-friendly. It was very noticeable how far they go to make sure their Centrifuge builds are user-friendly through the computer system, giving the operator the ability only to type in few parameter settings such as % solids and GPM. Hands down, you could tell these guys were very experienced at running these units and processing through these units. They had excellent communication, and if we hit a hiccup along the way, they could clearly explain what was happening and how to correct it.",
    company: "Alaskan Oil Processor",
    contact: "C. F.",
    title: "Facility Supervisor",
    highlight: "these guys were very experienced at running these units",
    industry: "Oil Processing / Alaska"
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Dolphin Centrifuge Customer Testimonials",
  "description": "Real testimonials from Dolphin Centrifuge customers across biodiesel, oilfield, industrial, and oil processing industries.",
  "numberOfItems": testimonials.length,
  "itemListElement": testimonials.map((t, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Review",
      "reviewBody": t.quote,
      "author": {
        "@type": "Person",
        "name": t.contact,
        "jobTitle": t.title || undefined
      },
      "itemReviewed": {
        "@type": "LocalBusiness",
        "name": "Dolphin Centrifuge",
        "url": "https://dolphincentrifuge.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "24248 Gibson Dr",
          "addressLocality": "Warren",
          "addressRegion": "MI",
          "postalCode": "48089",
          "addressCountry": "US"
        }
      },
      "publisher": {
        "@type": "Organization",
        "name": t.company
      }
    }
  }))
};
---

<ApplicationLayout
  title="Customer Testimonials | Dolphin Centrifuge"
  description="Real Dolphin Centrifuge customer reviews — biodiesel, oilfield, and industrial operators share their experience with our centrifuge systems and support."
  heroImage="/images/about-dolphin-centrifuge/Dolphin-Centrifuge-Shop-600.webp"
  heroImageAlt="Dolphin Centrifuge facility — Warren, Michigan industrial centrifuge service center"
  canonicalUrl="https://dolphincentrifuge.com/dolphin-centrifuge-customer-testimonials/"
  category="about"
  categoryLabel="About Us"
  toc={[
    { id: "customer-testimonials", label: "Customer Testimonials" },
    { id: "why-customers-stay", label: "Why Customers Stay With Dolphin" },
    { id: "what-sets-dolphin-apart", label: "What Sets Dolphin Apart" },
    { id: "faq", label: "Frequently Asked Questions" }
  ]}
  relatedApplications={[
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
    { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
    { label: "Lube Oil Centrifuge", href: "/lube-oil-centrifuge/" },
    { label: "Centrifuge Applications Overview", href: "/disc-stack-centrifuge-applications/" }
  ]}
  relatedProducts={[
    { label: "DMPX-042 Disc Centrifuge", href: "/centrifuges/dmpx-042/" },
    { label: "DMPX-028 Disc Centrifuge", href: "/centrifuges/dmpx-028/" },
    { label: "DMPX-070 Disc Centrifuge", href: "/centrifuges/dmpx-070/" }
  ]}
  jsonLd={[jsonLd, articleJsonLd, faqJsonLd]}
>

  <article class="prose-dolphin max-w-none">

    <div class="not-prose bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
      <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge customer testimonials from biodiesel producers, oilfield operators, marine fuel treatment facilities, lube oil processors, and metalworking coolant users. Customers report extended fluid life, reduced disposal costs, eliminated filter costs, and rapid ROI from Dolphin Centrifuge <a href="/disc-stack-centrifuge/">disc stack</a> and <a href="/decanter-centrifuge/">decanter centrifuge</a> systems. Contact us for <a href="/industrial-centrifuge-sample-testing/">free sample testing</a> or a <a href="/contact-for-alfa-laval-centrifuges/">custom quote</a>.</p>
    </div>

    <!-- Intro -->
    <p>
      The following testimonials are from real Dolphin Centrifuge customers — biodiesel producers,
      oilfield operators, lube oil processors, and industrial engineers who have put our equipment and
      expertise to work in demanding environments. We let their words speak for our reputation.
    </p>
    <p>
      We are happy to provide additional customer references on request. Call us at
      <a href="tel:+12485222573">(248) 522-2573</a>
      or email <a href="mailto:sales@dolphincentrifuge.com">sales@dolphincentrifuge.com</a>.
    </p>

    <!-- Testimonials -->
    <h2 id="customer-testimonials">Customer Testimonials</h2>

    {testimonials.map((t, i) => (
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8 relative">

        <!-- Quote mark decoration -->
        <div class="absolute top-4 right-6 text-6xl text-gold/20 font-serif leading-none select-none" aria-hidden="true">&ldquo;</div>

        <!-- Highlight badge -->
        <div class="inline-block bg-gold/10 border border-gold/30 text-navy text-xs font-semibold px-3 py-1 rounded-full mb-4">
          &ldquo;{t.highlight}&rdquo;
        </div>

        <!-- Full quote -->
        <blockquote class="text-text leading-relaxed text-base md:text-[1.05rem] italic border-l-4 border-gold pl-5">
          {t.quote}
        </blockquote>

        <!-- Attribution -->
        <div class="mt-5 flex items-start gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-navy flex items-center justify-center text-white font-bold text-sm">
            {t.contact.charAt(0)}
          </div>
          <div>
            <div class="font-semibold text-navy">{t.contact}{t.title ? `, ${t.title}` : ''}</div>
            <div class="text-sm text-gray-600">{t.company}</div>
            <div class="text-xs text-gray-400 mt-0.5">{t.industry}</div>
          </div>
        </div>
      </div>
    ))}

    <!-- Mid-page CTA -->
    <div class="bg-gold/10 border-l-4 border-gold rounded-r-lg p-5 mb-8 not-prose">
      <p class="text-navy font-bold text-lg mb-1">Ready to Experience Dolphin Service?</p>
      <p class="text-text-light text-sm mb-3">Join hundreds of satisfied customers across biodiesel, oilfield, marine, and industrial applications. Get a quote or send us your fluid sample for free testing.</p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold text-navy font-bold px-5 py-2.5 rounded-lg hover:bg-yellow-500 transition-colors text-sm">Get a Free Quote</a>
        <a href="/industrial-centrifuge-sample-testing/" class="inline-block border border-navy text-navy font-semibold px-5 py-2.5 rounded-lg hover:bg-navy/5 transition-colors text-sm">Free Sample Testing</a>
      </div>
    </div>

    <!-- Why Customers Stay -->
    <h2 id="why-customers-stay">Why Customers Stay With Dolphin</h2>
    <p>
      The testimonials above share common themes: engineers who genuinely know the equipment, responsive
      support at unusual hours, transparent pricing that respects smaller budgets, and systems that just work.
      These are not marketing promises — they are observations from customers who bought equipment, put it
      into service, and came back for more.
    </p>
    <p>
      Dolphin Centrifuge is not a used equipment dealer that happens to sell centrifuges on the side.
      <strong>Industrial centrifuges are all we do.</strong> That focus translates directly into deeper
      technical knowledge, better application guidance, and more reliable after-sale support than you
      will typically receive from a generalist equipment dealer. Learn more on our
      <a href="/about-dolphin-centrifuge/">About Dolphin Centrifuge</a> page.
    </p>
    <p>
      Our <strong>free lifetime technical support</strong> — no subscription, no expiration — reflects our
      confidence in the equipment we build and our commitment to the customers who buy it. When you call
      us five years after your centrifuge ships with a question about bowl cleaning intervals or a
      troubleshooting puzzle, we pick up the phone.
    </p>

    <!-- What Sets Dolphin Apart -->
    <h2 id="what-sets-dolphin-apart">What Sets Dolphin Apart</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div class="flex items-start gap-3">
        <span class="text-gold text-xl font-bold mt-0.5 flex-shrink-0">&rsaquo;</span>
        <div>
          <div class="font-semibold text-navy mb-1">40+ Years of Specialization</div>
          <p class="text-sm text-text">Industrial centrifuges exclusively since 1981 — not a side business or afterthought. Every staff member is focused on centrifuge applications, selection, and support.</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <span class="text-gold text-xl font-bold mt-0.5 flex-shrink-0">&rsaquo;</span>
        <div>
          <div class="font-semibold text-navy mb-1">Engineering-Led Company</div>
          <p class="text-sm text-text">We design and build complete <a href="/disc-stack-centrifuge/">centrifuge systems</a> in-house at our Warren, MI factory — not just resell off-the-shelf equipment.</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <span class="text-gold text-xl font-bold mt-0.5 flex-shrink-0">&rsaquo;</span>
        <div>
          <div class="font-semibold text-navy mb-1">300+ Unit Inventory</div>
          <p class="text-sm text-text">Over 300 reconditioned and new centrifuges on hand in Warren, MI. What you see on our site is equipment we actually own and can ship.</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <span class="text-gold text-xl font-bold mt-0.5 flex-shrink-0">&rsaquo;</span>
        <div>
          <div class="font-semibold text-navy mb-1">Factory Visit Welcome</div>
          <p class="text-sm text-text">All prospective customers are invited to our Warren, MI facility to inspect equipment, witness factory acceptance testing, and meet the team.</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <span class="text-gold text-xl font-bold mt-0.5 flex-shrink-0">&rsaquo;</span>
        <div>
          <div class="font-semibold text-navy mb-1">~50% vs New OEM Pricing</div>
          <p class="text-sm text-text">Reconditioned systems with new skid, new pump, new controls, and all accessories — typically at half the cost of a comparable new installation.</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <span class="text-gold text-xl font-bold mt-0.5 flex-shrink-0">&rsaquo;</span>
        <div>
          <div class="font-semibold text-navy mb-1">Free Lifetime Tech Support</div>
          <p class="text-sm text-text">No expiration, no subscription fee. Our engineers support every centrifuge we deliver for as long as it operates — even years after purchase.</p>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <h2 id="faq">Frequently Asked Questions</h2>
    <div class="space-y-3 not-prose">
      {faqItems.map(item => (
        <details class="border-l-4 border-gold bg-white rounded-r-xl shadow-sm p-5">
          <summary class="font-semibold text-navy cursor-pointer list-none flex items-center gap-2">
            <span class="text-gold font-bold">+</span> {item.question}
          </summary>
          <p class="text-text-light mt-3 text-sm leading-relaxed">{item.answer}</p>
        </details>
      ))}
    </div>
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

    <!-- Bottom CTA Bar -->
    <div class="bg-navy rounded-xl p-6 md:p-8 mt-10 text-center not-prose">
      <p class="text-white text-lg font-bold mb-2">Let Us Prove It — Request a Reference or Quote</p>
      <p class="text-blue-100 text-sm mb-4">We are happy to provide customer references for your specific application. Call, email, or request a quote online.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold hover:bg-yellow-500 text-navy font-bold px-6 py-3 rounded-lg transition-colors">Get a Free Quote</a>
        <a href="/industrial-centrifuge-sample-testing/" class="inline-block border border-white/40 hover:border-white text-white font-semibold px-6 py-3 rounded-lg transition-colors">Free Sample Testing</a>
      </div>
    </div>

  </article>

</ApplicationLayout>
