---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What disc stack centrifuge applications are common on offshore platforms?",
      "acceptedAnswer": { "@type": "Answer", "text": "Offshore platforms use disc stack centrifuges for diesel fuel purification, lube oil cleaning, hydraulic oil purification, bilge water treatment (oil-water separation), and ballast water treatment. These applications require explosion-proof (ATEX) designs suited for hazardous area zones on drilling rigs and production platforms." }
    },
    {
      "@type": "Question",
      "name": "What explosion-proof certification should an offshore centrifuge have?",
      "acceptedAnswer": { "@type": "Answer", "text": "Offshore centrifuges in hydrocarbon-handling areas require ATEX (Directive 2014/34/EU) and/or IECEx certification for Zone 1 or Zone 2 hazardous locations. Equipment must be certified for the specific gas group and temperature class relevant to the platform's hazardous area classification." }
    },
    {
      "@type": "Question",
      "name": "Why is compact footprint important for offshore centrifuge selection?",
      "acceptedAnswer": { "@type": "Answer", "text": "Offshore platforms have severe space and weight constraints. Centrifuge packages must fit within designated equipment rooms while meeting structural weight limits. Dolphin Centrifuge designs compact skid-mounted centrifuge packages with integral pipework, heating systems, and controls optimized for offshore installations." }
    }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Disc Stack Centrifuge for Offshore Applications: Uses, Specifications & Capacities",
  "description": "Disc stack centrifuges for offshore oil and gas platforms: diesel purification, lube oil cleaning, bilge water treatment, explosion-proof specs, and capacities.",
  "author": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "datePublished": "2022-02-01",
  "url": "https://dolphincentrifuge.com/disc-stack-centrifuge-offshore-applications/",
};
