import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "What role does a centrifuge play in biodiesel production?",
    answer: "A centrifuge performs multiple critical separation steps in biodiesel production: separating glycerin from biodiesel after the transesterification reaction, removing wash water during the purification stage, and final polishing to meet ASTM D6751 quality standards. It replaces hours of gravity settling with seconds of continuous processing."
  },
  {
    question: "Does a biodiesel centrifuge need special modifications?",
    answer: "Yes. Biodiesel production involves methanol and corrosive chemicals that damage standard centrifuge components. Dolphin Centrifuge offers a complete Biodiesel Kit that includes VITON seals (resistant to methanol), direct-drive motor (eliminates ignition sources), corrosion-resistant coatings, and Class 1, Division 2 (C1D2) rated electrical components for hazardous-area compliance."
  },
  {
    question: "What is the capacity of a biodiesel centrifuge?",
    answer: "Biodiesel centrifuge capacity ranges from 3 GPM for small-scale WVO purification up to 60 GPM for glycerin separation in large commercial operations. Capacity varies by process step — glycerin separation runs at higher flow rates than WVO purification or wash water removal due to lower viscosity. <a href='/contact-for-alfa-laval-centrifuges/'>Contact us</a> for sizing based on your production volume."
  },
  {
    question: "Can a centrifuge help biodiesel meet ASTM D6751 standards?",
    answer: "Yes. A final centrifuge polishing pass removes trace contaminants including residual glycerin, soaps, catalyst, and fine particles — producing biodiesel that meets ASTM D6751 fuel quality specifications. This polishing step is essential for commercial producers selling into regulated fuel markets."
  },
  {
    question: "What is the Biodiesel Kit and why is it necessary?",
    answer: "The Biodiesel Kit is a set of purpose-built modifications applied to the centrifuge for biodiesel production. It includes VITON seals (resistant to methanol), Teflon-coated collecting covers, a direct-drive frictionless motor to eliminate ignition sources, and Class 1, Division 2 (C1D2) electrical components. These modifications are required because standard centrifuge components are incompatible with methanol and the flammable vapors present in biodiesel environments."
  }
];

