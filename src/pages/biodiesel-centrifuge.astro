  <h2 id="biodiesel-kit">Biodiesel Kit Design Features</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-[40%] shrink-0">
      <img
        src="/images/biodiesel-centrifuge/Alfa-Laval-MAB205-Teflon-Coated-Biodiesel-Centrifuge-300.webp"
