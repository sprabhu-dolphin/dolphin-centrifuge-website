import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "Does a biodiesel centrifuge need to be rated for hazardous areas? Why?",
    answer: "A biodiesel centrifuge needs to be rated for operating in hazardous areas. This rating is essential because methanol (flammable liquid) is often present in biodiesel production facilities. It is a requirement to use hazardous area certified equipment in area with flammable fluids present."
  },
  {
    question: "What is the smallest biodiesel centrifuge?",
    answer: "The smallest biodiesel centrifuge is an Alfa Laval MAB 103 that can process approximately 1 gallon per minute of a biodiesel glycerol mix."
  },
  {
    question: "Do biodiesel centrifuge need special modifications?",
    answer: "Biodiesel centrifuges are standard centrifuges that are specially modified to process biodiesel. Some of the modifications include the use of special elastomers (instead of nitrile), electrical components suitable for hazardous areas, protective coating for parts affected by biodiesel, etc."
  },
  {
    question: "Why do I need a centrifuge when biodiesel easily separates from glycerin?",
    answer: "Biodiesel and glycerin separate quickly under gravity. However, the complete separation to produce 100% pure biodiesel can take a long period. A biodiesel centrifuge speeds up the separation by exerting up to 10,000 times the force for gravity to quickly produce 100% pure biodiesel without the need for decanting."
  },
  {
    question: "What is the largest biodiesel centrifuge?",
    answer: "The largest biodiesel centrifuge processes over 200 gallons per minute of a biodiesel glycerin mix. This centrifuge is an Alfa Laval, 3-phase, disc stack type centrifuge."
  },
  {
    question: "Does a biodiesel centrifuge have other applications in biodiesel production?",
    answer: "A biodiesel centrifuge of the self-cleaning type is useful to separate water and sludge from WVO. The same centrifuge is also suitable to separate wash water from biodiesel in the wash process. Glycerin purification is another application for biodiesel centrifuges."
  },
  {
    question: "Can a biodiesel centrifuge produce ASTM grade biodiesel?",
    answer: "A properly set up and tuned biodiesel centrifuge can produce biodiesel to meet or exceed ASTM biodiesel standards."
  },
  {
    question: "Is a biodiesel centrifuge expensive to operate?",
    answer: "The only operation-related expense of a biodiesel centrifuge is the cost of electricity. As an example, the cost to produce 1,200 gallons of biodiesel with a centrifuge is less than $1.00 based on electricity cost."
  }
];

