  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "datePublished": "2021-01-01",
  "dateModified": "2026-01-01",
  "url": "https://dolphincentrifuge.com/alfa-laval-mopx-207-centrifuge/",
  "mainEntityOfPage": "https://dolphincentrifuge.com/alfa-laval-mopx-207-centrifuge/"
};

const jsonLd = [
  articleJsonLd,
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Alfa Laval MOPX 207 Centrifuge",
    "description": "The Alfa Laval MOPX 207 is a self-cleaning disc-stack centrifuge with 7.5 HP motor, 6,325 RPM bowl speed, and 28 GPM diesel capacity. Ideal for fuel, lube oil, waste oil, and biodiesel separation.",
    "brand": {
      "@type": "Brand",
      "name": "Alfa Laval"
    },
    "manufacturer": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge",
      "url": "https://dolphincentrifuge.com"
    },
    "offers": {
      "@type": "Offer",
      "seller": {
        "@type": "Organization",
        "name": "Dolphin Centrifuge"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://dolphincentrifuge.com/alfa-laval-mopx-207-centrifuge/"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the capacity of the Alfa Laval MOPX 207 centrifuge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Alfa Laval MOPX 207 can process 28 GPM of 13 cSt diesel fuel, 22 GPM of turbine lube oil, and 20 GPM of hydraulic oil. It can also process over 30 GPM of distillate and condensate."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between the MOPX 207, WHPX 407, and WSPX 207?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The MOPX 207 is a full-discharge purifier designed for fuel and mineral oil separation. The WHPX 407 is a partial-discharge centrifuge with a 10 HP motor designed for fuel oils like light fuel oil (LFO). The WSPX 207 is a concentrator designed for water-based liquids such as machine coolants and washer fluids."
        }
      },
      {
        "@type": "Question",
        "name": "What materials is the MOPX 207 bowl made from?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The MOPX 207 bowl body and bowl hood are constructed from 316L Duplex Stainless Steel. The disc stack is also 316L Duplex Stainless Steel. The distributor and top disc are Marine Grade Bronze, with 316 Stainless Steel available as a special order option."
        }
      },
      {
        "@type": "Question",
        "name": "Is the Alfa Laval MOPX 207 available in an explosion-proof configuration?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, the Alfa Laval MOPX 207 is available in a Class 1 Division 2 explosion-proof configuration, making it suitable for hazardous environments where flammable fuels and solvents are processed."
        }
      },
      {
        "@type": "Question",
        "name": "What is the Dolphin Centrifuge equivalent of the Alfa Laval MOPX 207?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Dolphin DMPX-028 is the complete system module equivalent of the Alfa Laval MOPX 207 centrifuge bowl. The DMPX-028 adds a full system frame, PLC controls, electric heaters, feed pump, and piping to the MOPX 207 bowl to create a turnkey centrifuge module rated at 20–28 GPM on diesel depending on configuration. Contact Dolphin Centrifuge at (248) 522-2573 for pricing."
        }
      }
    ]
  }
];

const toc = [
  { id: 'operation', label: 'Operation — Alfa Laval MOPX 207' },
  { id: 'applications-mopx', label: 'Applications — MOPX-207' },
  { id: 'specifications-mopx', label: 'Specifications — MOPX-207' },
  { id: 'material', label: 'Material of Construction' },
  { id: 'whpx-407', label: 'Alfa Laval WHPX 407' },
  { id: 'applications-whpx', label: 'WHPX-407 Applications' },
  { id: 'specifications-whpx', label: 'WHPX-407 Specifications' },
  { id: 'wspx-207', label: 'Alfa Laval WSPX 207' },
  { id: 'applications-wspx', label: 'WSPX-207 Applications' },
  { id: 'specifications-wspx', label: 'WSPX-207 Specifications' },
  { id: 'gallery', label: 'MOPX 207 Modules & Gallery' },
  { id: 'faq', label: 'Frequently Asked Questions' },
