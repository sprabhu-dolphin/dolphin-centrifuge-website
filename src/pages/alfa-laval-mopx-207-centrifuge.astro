---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const title = "Alfa Laval MOPX 207 Centrifuge";
const description = "Alfa Laval MOPX 207 self-cleaning disc centrifuge: 28 GPM, 7.5 HP, 6,325 RPM. Full specs, applications, WHPX-407/WSPX-207 comparisons. Dolphin Centrifuge.";

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Alfa Laval MOPX 207 Centrifuge — Parts, Service & Specifications",
  "description": "Dolphin Centrifuge supplies parts, repairs, and remanufactured Alfa Laval MOPX 207 self-cleaning disc-stack centrifuges. 7.5 HP, 6,325 RPM, 28 GPM on diesel. DMPX-028 system equivalent.",
