  { label: 'Alfa Laval MOPX 209 Centrifuge', href: '/alfa-laval-mopx-209-centrifuge/', description: 'Larger capacity MOPX-series model' },
  { label: 'Diesel Fuel Purifier', href: '/diesel-fuel-purifier/', description: 'Diesel purification systems' },
  { label: 'Waste Oil Centrifuge', href: '/waste-oil-centrifuge/', description: 'Used oil recovery systems' },
];

const relatedApplications = [
  { label: 'Biodiesel Centrifuge', href: '/biodiesel-centrifuge/' },
  { label: 'Fuel Oil Centrifuge', href: '/fuel-oil-centrifuge/' },
  { label: 'Machine Coolant Centrifuge', href: '/machine-coolant-centrifuge/' },
  { label: 'Quench Oil Centrifuge', href: '/quench-oil-centrifuge/' },
  { label: 'Black Diesel Centrifuge', href: '/black-diesel-centrifuge/' },
];
---

<ApplicationLayout
  title={title}
  description={description}
  heroImage="/images/alfa-laval-mopx-207-centrifuge/Alfa-Laval-Diesel-Centrifuge-Skid-for-Diesel-Dewatering.webp"
  heroImageAlt="Alfa Laval MOPX-207 Self-Cleaning Disc Stack Centrifuge Class 1 Div 2 — diesel centrifuge skid for dewatering"
  category="products"
  categoryLabel="Products"
  toc={toc}
  relatedProducts={relatedProducts}
  relatedApplications={relatedApplications}
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-mopx-207-centrifuge/"
  jsonLd={jsonLd}
>

  <!-- AI Summary -->
  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8">
    <p class="text-sm font-semibold text-navy mb-1">AI Summary</p>
    <p class="text-sm text-text-light leading-relaxed italic">
      The Alfa Laval MOPX 207 is a self-cleaning disc-stack centrifuge processing up to 28 GPM of diesel fuel at 6,325 RPM. Dolphin Centrifuge supplies it as the DMPX-028 complete module for fuel oil, lube oil, and waste oil purification.
    </p>
  </div>

  <!-- MOPX 207 Operation -->
  <h2 id="operation">Alfa Laval MOPX 207 — Operation</h2>
  <p>
    The <a href="https://www.alfalaval.com/" target="_blank" rel="noopener noreferrer">Alfa Laval</a> MOPX 207 Centrifuge is a self-cleaning, <a href="/disc-stack-centrifuge/">disc-stack centrifuge</a> ideal for the continuous, three-phase separation of fuels and mineral oils.
  </p>
  <p>
    With a <strong>7.5 HP Motor</strong>, the MOPX 207 centrifuge has a bowl RPM of <strong>6,325</strong> and can process <strong>32 GPM of Distillate</strong>.
  </p>
  <p>
    The Alfa Laval MOPX-207 is a versatile, 'self-cleaning' centrifuge that is small enough to be manually serviced without the need for lifting devices (cranes, hoists, etc.)
  </p>
  <p>
    However, it can process over 30 Gallons per Minute of condensate.
  </p>

  <div class="flex flex-col md:flex-row gap-6 items-center not-prose">
    <figure class="flex-shrink-0">
      <img
        src="/images/alfa-laval-mopx-207-centrifuge/Alfa-Laval-MOPX207-Used-Oil-Centrifuge-600.webp"
        alt="Alfa Laval MOPX207 Used Oil Centrifuge — self-cleaning disc stack separator for fuel and mineral oil separation"
        width="450"
        height="450"
        loading="lazy"
        class="rounded-lg"
      />
      <figcaption class="text-center text-sm text-gray-500 mt-2">Alfa Laval MOPX207 Used Oil Centrifuge</figcaption>
    </figure>
    <div class="flex-1">
      <h3 class="text-lg font-semibold text-navy mb-3">Key Operational Highlights</h3>
      <ul class="space-y-2 text-text text-sm">
        <li class="flex gap-2"><span class="text-gold">&#x2713;</span> Continuous three-phase separation (oil / water / solids)</li>
        <li class="flex gap-2"><span class="text-gold">&#x2713;</span> Self-cleaning bowl — automatic sludge ejection without stopping</li>
        <li class="flex gap-2"><span class="text-gold">&#x2713;</span> Small enough for manual service — no lifting equipment needed</li>
        <li class="flex gap-2"><span class="text-gold">&#x2713;</span> 316L duplex stainless steel bowl construction</li>
        <li class="flex gap-2"><span class="text-gold">&#x2713;</span> Available in standard and explosion-proof (Class 1 Div 2) configurations</li>
        <li class="flex gap-2"><span class="text-gold">&#x2713;</span> Processes diesel, lube oil, waste oil, biodiesel, and more</li>
      </ul>
    </div>
  </div>

  <!-- MOPX Applications -->
  <h2 id="applications-mopx">Alfa Laval MOPX-207 — Applications</h2>
  <p>
    The MOPX-207 finds a variety of applications in fuel and lubrication purification applications. Some of the popular applications are:
  </p>

  <div class="flex flex-col md:flex-row gap-6 items-start not-prose">
    <ul class="grid grid-cols-1 gap-2 flex-1 text-sm text-text">
      <li><a href="/diesel-centrifuge/" class="flex items-center gap-2 text-navy hover:text-gold p-2 rounded hover:bg-gray-50"><span class="text-gold">&#x279C;</span> Diesel Fuel</a></li>
      <li><a href="/waste-oil-centrifuge/" class="flex items-center gap-2 text-navy hover:text-gold p-2 rounded hover:bg-gray-50"><span class="text-gold">&#x279C;</span> Waste Oil</a></li>
      <li><a href="/black-diesel-centrifuge/" class="flex items-center gap-2 text-navy hover:text-gold p-2 rounded hover:bg-gray-50"><span class="text-gold">&#x279C;</span> Black Diesel</a></li>
      <li><a href="/wvo-centrifuge-separator/" class="flex items-center gap-2 text-navy hover:text-gold p-2 rounded hover:bg-gray-50"><span class="text-gold">&#x279C;</span> WVO or Yellow Grease</a></li>
      <li><a href="/biodiesel-centrifuge/" class="flex items-center gap-2 text-navy hover:text-gold p-2 rounded hover:bg-gray-50"><span class="text-gold">&#x279C;</span> Biodiesel Glycerol</a></li>
      <li><a href="/fuel-oil-centrifuge/" class="flex items-center gap-2 text-navy hover:text-gold p-2 rounded hover:bg-gray-50"><span class="text-gold">&#x279C;</span> Heavy Fuel Oil</a></li>
      <li><a href="/machine-coolant-centrifuge/" class="flex items-center gap-2 text-navy hover:text-gold p-2 rounded hover:bg-gray-50"><span class="text-gold">&#x279C;</span> Machining Coolant</a></li>
      <li><a href="/quench-oil-centrifuge/" class="flex items-center gap-2 text-navy hover:text-gold p-2 rounded hover:bg-gray-50"><span class="text-gold">&#x279C;</span> Quenching Oil</a></li>
      <li><a href="/crude-oil-centrifuge/" class="flex items-center gap-2 text-navy hover:text-gold p-2 rounded hover:bg-gray-50"><span class="text-gold">&#x279C;</span> Light Crude Oil</a></li>
    </ul>
    <figure class="flex-shrink-0">
      <img
        src="/images/alfa-laval-mopx-207-centrifuge/Alfa-Laval-Explosion-Proof-Centrifuge-600.webp"
        alt="Alfa Laval MAPX-207 Explosion-Proof Centrifuge — Class 1 Div 2 configuration for hazardous environments"
        width="360"
        height="450"
        loading="lazy"
        class="rounded-lg"
      />
      <figcaption class="text-center text-sm text-gray-500 mt-2">Alfa Laval MAPX-207 — Explosion-Proof Centrifuge</figcaption>
    </figure>
  </div>

  <!-- MOPX Specifications -->
  <h2 id="specifications-mopx">Alfa Laval MOPX 207 — Specifications</h2>
  <div class="overflow-x-auto not-prose">
    <table class="w-full text-sm text-text border-collapse">
      <thead>
        <tr class="bg-navy text-white">
          <th class="px-4 py-3 text-left font-semibold w-1/2">Parameter</th>
          <th class="px-4 py-3 text-left font-semibold">Value</th>
        </tr>
      </thead>
      <tbody>
        <tr class="border-b border-gray-100 hover:bg-gray-50">
          <td class="px-4 py-3 font-semibold">Centrifuge Model</td>
          <td class="px-4 py-3 font-mono">Alfa Laval MOPX 207 TGT</td>
        </tr>
        <tr class="border-b border-gray-100 hover:bg-gray-50">
          <td class="px-4 py-3 font-semibold">Capacity — Diesel</td>
          <td class="px-4 py-3 font-mono">28 GPM on 13 cSt Diesel Fuel</td>
        </tr>
        <tr class="border-b border-gray-100 hover:bg-gray-50">
          <td class="px-4 py-3 font-semibold">Capacity — Turbine Lube Oil</td>
          <td class="px-4 py-3 font-mono">22 GPM</td>
        </tr>
        <tr class="border-b border-gray-100 hover:bg-gray-50">
          <td class="px-4 py-3 font-semibold">Capacity — Hydraulic Oil</td>
          <td class="px-4 py-3 font-mono">20 GPM</td>
        </tr>
        <tr class="border-b border-gray-100 hover:bg-gray-50">
          <td class="px-4 py-3 font-semibold">Sludge Space</td>
          <td class="px-4 py-3 font-mono">1.00 Gallons</td>
        </tr>
        <tr class="border-b border-gray-100 hover:bg-gray-50">
          <td class="px-4 py-3 font-semibold">Bowl Speed</td>
          <td class="px-4 py-3 font-mono">6,325 RPM</td>
        </tr>
        <tr class="border-b border-gray-100 hover:bg-gray-50">
          <td class="px-4 py-3 font-semibold">Net Weight</td>
