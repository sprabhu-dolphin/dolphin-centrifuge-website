---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval MOPX 207 Self-Cleaning Centrifuge",
  "description": "The Alfa Laval MOPX 207 is a self-cleaning disc-stack centrifuge with 7.5 HP motor, 6,325 RPM bowl speed, and 28 GPM diesel capacity. Ideal for fuel, lube oil, waste oil, and biodiesel separation.",
  "brand": {
    "@type": "Brand",
    "name": "Alfa Laval"
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  },
  "offers": {
    "@type": "Offer",
    "seller": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://dolphincentrifuge.com/alfa-laval-mopx-207-centrifuge/"
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the capacity of the Alfa Laval MOPX 207 centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Alfa Laval MOPX 207 can process 28 GPM of 13 cSt diesel fuel, 22 GPM of turbine lube oil, and 20 GPM of hydraulic oil. It can also process over 30 GPM of distillate and condensate."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between the MOPX 207, WHPX 407, and WSPX 207?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The MOPX 207 is a full-discharge purifier designed for fuel and mineral oil separation. The WHPX 407 is a partial-discharge centrifuge with a 10 HP motor designed for fuel oils like light fuel oil (LFO). The WSPX 207 is a concentrator designed for water-based liquids such as machine coolants and washer fluids."
      }
    },
    {
      "@type": "Question",
      "name": "What materials is the MOPX 207 bowl made from?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The MOPX 207 bowl body and bowl hood are constructed from 316L Duplex Stainless Steel. The disc stack is also 316L Duplex Stainless Steel. The distributor and top disc are Marine Grade Bronze, with 316 Stainless Steel available as a special order option."
      }
    },
    {
      "@type": "Question",
      "name": "Is the Alfa Laval MOPX 207 available in an explosion-proof configuration?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, the Alfa Laval MOPX 207 is available in a Class 1 Division 2 explosion-proof configuration, making it suitable for hazardous environments where flammable fuels and solvents are processed."
      }
    }
  ]
};
---

<BaseLayout
  title="Alfa Laval MOPX 207 Centrifuge | Specs, Uses, Capacity"
  description="Alfa Laval MOPX 207 self-cleaning disc-stack centrifuge: 28 GPM diesel capacity, 7.5 HP motor, 6,325 RPM. Full specs, material of construction, applications, WHPX-407 and WSPX-207 data."
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-mopx-207-centrifuge/"
  breadcrumbs={[{label: 'Products', href: '/centrifuges/'}, {label: 'Alfa Laval MOPX-207'}]}
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <section class="bg-[#1B3A5C] text-white py-16 md:py-20">
    <div class="container mx-auto px-4 max-w-5xl">
      <nav class="text-sm text-blue-300 mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white">Home</a>
        <span class="mx-2">/</span>
        <a href="/centrifuges/" class="hover:text-white">Products</a>
        <span class="mx-2">/</span>
