---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "What topics are covered in Dolphin Centrifuge operator training?",
    answer: "Dolphin Centrifuge training programs cover centrifuge operating principles, startup and shutdown procedures, sludge discharge timing adjustment, bowl disassembly and cleaning (for manual-clean machines), bearing and lubrication maintenance, vibration monitoring, troubleshooting common operational problems, and safety procedures for high-speed rotating equipment."
  },
  {
    question: "Is centrifuge training available on-site at my facility?",
    answer: "Yes. Dolphin Centrifuge provides on-site training at your facility, training at our Warren, Michigan facility, and virtual/remote training options. On-site training is particularly valuable for new centrifuge installations — we can train your operators during commissioning so they are fully capable from day one."
  },
  {
    question: "What centrifuge brands and models does Dolphin Centrifuge training cover?",
    answer: "Dolphin Centrifuge training covers all Alfa Laval disc stack centrifuges (MAB, MOPX, MAPX, WSPX, WHPX series) and Alfa Laval decanter centrifuges (NX-314, NX-418, G2-40). We also provide training for Westfalia, Sharples, and other brands on a case-by-case basis. Contact us to discuss your specific equipment."
  },
  {
    question: "Is centrifuge operator training included with a new system purchase?",
    answer: "Yes. Dolphin Centrifuge includes in-house operator training with every new centrifuge system purchase. Customer operators come to our Warren, Michigan facility during final testing to receive hands-on training on their specific system, including startup procedures, control panel operation, bowl disassembly, and preventive maintenance routines."
  },
  {
    question: "How do I schedule centrifuge training for my team?",
    answer: "Contact Dolphin Centrifuge by phone at (248) 522-2573 or by email at sales@dolphincentrifuge.com to schedule a training session. Provide the centrifuge model(s) your team operates, the number of attendees, and your preferred format (on-site, in-house, or virtual). We will confirm availability and prepare a customized training program for your equipment and application."
  }
];

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Industrial Centrifuge Operator Training",
  "description": "Industrial centrifuge operator training programs by Dolphin Centrifuge. On-site and in-house training for operation, maintenance, troubleshooting, and bowl assembly.",
  "provider": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "address": { "@type": "PostalAddress", "streetAddress": "24248 Gibson Dr.", "addressLocality": "Warren", "addressRegion": "MI", "postalCode": "48089", "addressCountry": "US" },
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "url": "https://dolphincentrifuge.com/industrial-centrifuge-training/",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, '')
    }
  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Industrial Centrifuge Operator Training",
  "description": "On-site and in-house industrial centrifuge operator training by Dolphin Centrifuge. Programs cover startup, operation, maintenance, troubleshooting, and bowl assembly for disc stack and decanter centrifuges.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/industrial-centrifuge-training/",
  "mainEntityOfPage": "https://dolphincentrifuge.com/industrial-centrifuge-training/"
};

const jsonLd = [serviceJsonLd, faqJsonLd, articleJsonLd];

const toc = [
  { id: 'on-site-training', label: 'On-Site Startup Training' },
  { id: 'in-house-training', label: 'In-House Training' },
  { id: 'why-training', label: 'Why Training Matters' },
  { id: 'programs', label: 'Training Programs' },
  { id: 'delivery', label: 'Training Delivery Options' },
  { id: 'attendees', label: 'Who Should Attend?' },
  { id: 'materials', label: 'Training Materials' },
  { id: 'faq', label: 'FAQ' },
];

const relatedApplications = [
  { label: 'Centrifuge Service & Repair', href: '/industrial-disc-centrifuge-repair/' },
  { label: 'Centrifuge Installation', href: '/disc-stack-centrifuge-installation/' },
  { label: 'Parts Glossary', href: '/disc-centrifuge-parts-glossary/' },
  { label: 'Centrifuge Lubrication', href: '/disc-stack-centrifuge-lubrication/' },
];

const relatedProducts = [
  { label: 'System Design & Engineering', href: '/industrial-centrifuge-design/', description: 'Custom turnkey systems' },
  { label: 'Top 10 Mechanical Issues', href: '/disc-stack-centrifuge-mechanical-issues-fixes/', description: 'Troubleshooting guide' },
];
---

<ApplicationLayout
  title="Industrial Centrifuge Training | Dolphin Centrifuge"
  description="Centrifuge operator training by Dolphin Centrifuge. On-site, in-house, and virtual programs covering startup, operation, maintenance, and troubleshooting."
  category="services"
  categoryLabel="Services"
  heroImage="/images/industrial-centrifuge-training/Centrifuge-Training.webp"
  heroImageAlt="Centrifuge Training"
  canonicalUrl="https://dolphincentrifuge.com/industrial-centrifuge-training/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge provides comprehensive operator training for Alfa Laval industrial centrifuges. Programs cover centrifuge startup, daily operation, sludge ejection adjustment, bowl assembly, troubleshooting, and preventive maintenance. Training is available on-site at your facility, in-house at our Warren, Michigan workshop, or via virtual sessions. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of hands-on experience with disc stack and decanter centrifuges across all major industries.</p>
  </div>

  <h2 id="on-site-training">Startup Assistance and Centrifuge Training at Customer Site</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start not-prose mb-6">
    <div class="md:w-1/2">
      <p class="text-text-light mb-4">
        Dolphin Centrifuge provides comprehensive operational training for Alfa Laval industrial centrifuges. We offer this training on-site or in-house at our facility in Warren, MI.
      </p>
      <p class="text-text-light mb-4">
        The on-site industrial centrifuge service and training are integral to our services. This training assures the customer of the best use of the centrifuge safely and efficiently.
      </p>
      <p class="text-text-light mb-4">
        After delivery and site installation, our technicians check the entire centrifuge system. We involve the customer's operating staff in this inspection. This step familiarizes the operators with every aspect of the mechanical and electrical sub-systems.
      </p>
      <p class="text-text-light">Our industrial centrifuge startup and training include:</p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/industrial-centrifuge-training/disc-stack-centrifuge-repair-600.webp"
        alt="disc stack centrifuge repair"
        width="600"
        height="274"
        loading="lazy"
        class="rounded-lg shadow-md w-full"
      />
    </div>
  </div>

  <ul>
    <li>Complete mechanical &amp; electrical check of the <a href="/disc-stack-centrifuge-installation/">centrifuge installation</a>.</li>
    <li>Bowl Installation by site personnel under our technical supervision.</li>
    <li>Initial startup of the centrifuge and test run to check operating parameters.</li>
    <li>Process customer products through a centrifuge.</li>
    <li><a href="/disc-stack-centrifuge-performance/">Optimize centrifuge</a> to customers' fluid characteristics for optimum efficiency.</li>
    <li>Monitor and record operating parameters for future reference.</li>
    <li>Comprehensive <a href="/industrial-centrifuge-controls/">Dolphin Control System</a> operation training.</li>
    <li>Test sub-system components (pumps, heaters, sludge handling system, etc.) and adjust as needed.</li>
    <li>Trigger various system alarms and train personnel on centrifuge troubleshooting.</li>
    <li>System shut-down sequence by site personnel under our tech's supervision.</li>
    <li>Bowl disassembly and re-assembly by site personnel under our tech's supervision.</li>
  </ul>
  <p>Dolphin Centrifuge also provides on-site <a href="/industrial-disc-centrifuge-repair/">centrifuge service</a> options as part of a PM schedule or on an as-needed basis.</p>

  <h2 id="in-house-training">Industrial Centrifuge Operational Training (In-House)</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start not-prose mb-6">
    <div class="md:w-1/2">
      <p class="text-text-light mb-4">
        Dolphin offers free operator training when you buy a centrifuge system from us. Customer operator(s) sent to our workshop get hands-on training on the centrifuge system.
      </p>
      <p class="text-text-light mb-4">
        The testing phase of our manufacturing process is the best time for this training. Due to licensing limitations, water is the testing fluid.
      </p>
      <p class="text-text-light mb-4">
        Our in-house training covers above listed operational aspects of the centrifuge system. We encourage your personnel to operate the centrifuge and control system during training.
      </p>
      <p class="text-text-light mb-4">
        We also train them to tear down &amp; rebuild the centrifuge bowl. This exercise familiarizes the operators with the inner mechanical details of the centrifuge system.
      </p>
      <p class="text-text-light">
        <a href="/contact-for-alfa-laval-centrifuges/" class="text-navy underline decoration-gold underline-offset-3 hover:text-gold-dark transition-colors font-medium">Contact Dolphin Centrifuge</a> for more information and to set up a centrifuge training session.
      </p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/industrial-disc-centrifuge-repair/Electropolished-Bowl-Discs-400.webp"
        alt="Electropolished disc stack bowl discs ready for centrifuge reassembly during in-house operator training"
        width="400"
        height="491"
        loading="lazy"
        class="rounded-lg shadow-md w-full"
      />
    </div>
  </div>

  <h2 id="why-training">Why Training Matters</h2>
  <p>
    An industrial centrifuge is a precision machine operating at extreme speeds. Proper operator training directly impacts separation performance, equipment lifespan, and workplace safety. A trained operator can identify developing problems before they become expensive failures, optimize separation parameters for changing feed conditions, and perform routine maintenance — including proper <a href="/disc-stack-centrifuge-lubrication/">centrifuge lubrication</a> — that prevents unplanned downtime.
  </p>
  <p>
    Our training programs draw on over 40 years of field experience. Our instructors are the same technicians who <a href="/industrial-disc-centrifuge-repair/">rebuild centrifuges</a> in our Warren, Michigan facility and commission <a href="/industrial-centrifuge-design/">turnkey systems</a> at customer sites worldwide. They teach what actually matters in real-world operation, not textbook theory.
  </p>

  <div class="bg-navy/5 border border-navy/20 rounded-xl p-6 my-8 not-prose text-center">
    <p class="text-lg font-semibold text-navy mb-2">Schedule Centrifuge Training for Your Team</p>
    <p class="text-sm text-text-light mb-4">On-site, in-house, or virtual sessions tailored to your equipment and process.</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-navy text-white px-6 py-2.5 rounded-lg font-medium hover:bg-navy/90 transition-colors">Request Training</a>
      <a href="tel:+12485222573" class="inline-block border border-navy text-navy px-6 py-2.5 rounded-lg font-medium hover:bg-navy/5 transition-colors">(248) 522-2573</a>
    </div>
  </div>

  <h2 id="programs">Training Programs</h2>

  <h3>New System Commissioning Training</h3>
  <p>
    Included with every new centrifuge system purchase from Dolphin Centrifuge. Conducted on-site during system startup, this training covers your specific equipment, process, and control system. Operators leave the session fully qualified to run the equipment independently.
  </p>

  <h3>Operator Fundamentals</h3>
  <p>
    A comprehensive 1&ndash;2 day program covering the principles and hands-on skills needed to operate an industrial centrifuge safely and effectively. Topics include:
  </p>
  <ul>
    <li>Centrifuge operating principles (disc stack and/or decanter)</li>
    <li>Pre-start inspection and startup procedures</li>
    <li>Normal operating parameter monitoring</li>
    <li>Shutdown and cleaning procedures</li>
    <li>Safety hazards and lockout/tagout requirements</li>
    <li>Control panel operation and alarm response</li>
    <li>Feed preparation and temperature management</li>
  </ul>

  <h3>Maintenance &amp; Bowl Assembly</h3>
  <p>
    An advanced 1&ndash;2 day program for maintenance technicians who will perform routine service and preventive maintenance. This is a hands-on course that involves working with actual centrifuge components. Topics include:
  </p>
  <ul>
    <li>Complete bowl disassembly and reassembly</li>
    <li>Disc stack inspection, cleaning, and reinstallation</li>
    <li>Seal and O-ring replacement</li>
    <li>Bearing inspection and replacement criteria</li>
    <li>Vibration monitoring and interpretation</li>
    <li>Operating water system adjustment and testing (self-cleaning models)</li>
    <li>Preventive maintenance schedules and checklists</li>
    <li>Lubrication procedures and specifications</li>
  </ul>

  <h3>Troubleshooting &amp; Optimization</h3>
  <p>
    An advanced course for experienced operators and process engineers who want to maximize centrifuge performance and diagnose problems efficiently. Topics include:
  </p>
  <ul>
    <li>Interpreting separation quality (effluent clarity, moisture content, solids dryness)</li>
    <li>Adjusting gravity disc sizing and back-pressure for disc stack separators</li>
    <li>Scroll differential speed and pond depth adjustment for decanters</li>
    <li>Diagnosing common faults: vibration, foaming, poor separation, high motor current</li>
    <li>Optimizing feed temperature, flow rate, and chemical dosing</li>
    <li>Reading and acting on vibration analysis data</li>
  </ul>

  <h2 id="delivery">Training Delivery Options</h2>
  <table>
    <thead>
      <tr>
        <th>Format</th>
        <th>Duration</th>
        <th>Best For</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><strong>On-Site at Your Facility</strong></td>
        <td>1&ndash;3 days</td>
        <td>Hands-on training with your specific equipment and process</td>
      </tr>
      <tr>
        <td><strong>At Our Warren, MI Facility</strong></td>
        <td>1&ndash;2 days</td>
        <td>Bowl assembly training with access to our full shop and parts inventory</td>
      </tr>
      <tr>
        <td><strong>Virtual / Remote</strong></td>
        <td>Half-day sessions</td>
        <td>Refresher training, theory, control system operation, troubleshooting review</td>
      </tr>
    </tbody>
  </table>

  <h2 id="attendees">Who Should Attend?</h2>
  <ul>
    <li><strong>Operators:</strong> Personnel responsible for daily centrifuge operation and monitoring</li>
    <li><strong>Maintenance Technicians:</strong> Staff performing preventive maintenance and repairs</li>
    <li><strong>Process Engineers:</strong> Engineers responsible for optimizing separation performance</li>
    <li><strong>Supervisors:</strong> Plant managers and shift leaders who oversee centrifuge operations</li>
    <li><strong>New Hires:</strong> Replacement staff or new team members joining an existing centrifuge operation</li>
  </ul>

  <h2 id="materials">Training Materials</h2>
  <p>All training participants receive:</p>
  <ul>
    <li>Printed training manual specific to your centrifuge model and application</li>
    <li>Preventive maintenance checklists and schedules</li>
    <li>Troubleshooting guide with <a href="/disc-stack-centrifuge-mechanical-issues-fixes/">common fault diagnosis</a></li>
    <li>Certificate of completion for each attendee</li>
  </ul>

  <p>
    To schedule training or request a customized training program, contact us at <a href="mailto:sales@dolphincentrifuge.com">sales@dolphincentrifuge.com</a> or call <a href="tel:+12485222573">(248) 522-2573</a>.
  </p>

  <FAQ items={faqItems} />

</ApplicationLayout>
