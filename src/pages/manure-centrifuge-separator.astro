---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "How does a decanter centrifuge compare to a screw press for manure separation?",
    answer: "A decanter centrifuge captures particles down to 25–50 microns and produces solids at up to 50% dryness, compared to 100–200 micron capture and 25–35% dryness from a typical screw press. The centrifuge also requires no filter screens or media replacement and runs fully automated with minimal labor. This finer separation captures significantly more phosphorus bound to small particles."
  },
  {
    question: "What capacity manure centrifuge systems are available?",
    answer: "Dolphin Centrifuge manure dewatering systems range from 25 GPM compact decanters for smaller dairy and swine operations to 50+ GPM high-capacity systems for large commercial livestock facilities. Sizing depends on manure volume, solids concentration, and desired cake dryness. <a href='/contact-for-alfa-laval-centrifuges/'>Contact us</a> for sizing recommendations based on your herd size and manure handling setup."
  },
  {
    question: "Does a manure centrifuge remove phosphorus from the liquid fraction?",
    answer: "Yes. The majority of phosphorus in manure is bound to solid particles. A decanter centrifuge captures these fine solids — including colloidal particles that gravity separators and screw presses miss — concentrating phosphorus in the solid fraction. This helps livestock operations meet nutrient management plan requirements by reducing phosphorus levels in the liquid applied to fields."
  },
  {
    question: "What are the end products from centrifugal manure separation?",
    answer: "A manure centrifuge produces two streams: dewatered solids (cake) and clarified liquid (centrate). The solids can be composted for premium bedding, sold as organic fertilizer, or used as soil amendment. The liquid centrate retains approximately 50% of the nitrogen content, making it a valuable fertigation resource that reduces commercial fertilizer purchases."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "url": "https://dolphincentrifuge.com/manure-centrifuge-separator/",
  "name": "Manure Centrifuge Separator System",
  "description": "Industrial manure centrifuge separator for livestock operations. Decanter centrifuge technology produces dry solids and nutrient-rich liquid at 3,000+ Gs with continuous, automated operation.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const jsonLd = [productJsonLd, faqJsonLd];

const toc = [
  { id: 'why-separate-manure', label: 'Why Separate Manure?' },
  { id: 'separation-process', label: 'Separation Process' },
  { id: 'operation', label: 'Centrifuge Operation' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'benefits', label: 'Benefits' },
  { id: 'advantages-over-filter-press', label: 'Advantages over Filter Press' },
];

const relatedApplications = [
  { label: 'Wastewater Centrifuge', href: '/wastewater-centrifuge/' },
  { label: 'Dewatering Centrifuge', href: '/dewatering-centrifuge/' },
  { label: 'Liquid Humus Centrifuge', href: '/liquid-humus-centrifuge/' },
  { label: 'Algae Centrifuge', href: '/algae-centrifuge/' },
];

const relatedProducts = [
  { label: 'NX-314 Decanter', href: '/alfa-laval-nx-314-decanter-centrifuge/', description: 'Compact manure dewatering &mdash; 25 GPM' },
  { label: 'NX-418 Decanter', href: '/alfa-laval-nx-418-decanter-centrifuge/', description: 'High-capacity manure processing &mdash; 50+ GPM' },
];
