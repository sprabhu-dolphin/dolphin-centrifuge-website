---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the Alfa Laval BTPX 205 used for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Alfa Laval BTPX-205 is a self-cleaning disc stack centrifuge used for biotech cell harvesting, pharmaceutical recovery, and fine chemical separation. Typical applications include fermentation broth clarification, organic cell harvesting, inclusion body recovery, plasma fraction recovery, vaccine production, and catalyst separation. It handles solids content up to 10% by volume and particle sizes from 0.5 to 500 microns."
      }
    },
    {
      "@type": "Question",
      "name": "What G-force does the Alfa Laval BTPX-205 generate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Alfa Laval BTPX-205 generates 12,800 Gs of centrifugal force at its rated bowl speed of 9,650 RPM. This extreme G-force enables separation of particles as small as 0.5 microns, making it suitable for sub-micron pharmaceutical precipitates, cell debris, and fine biotech solids."
      }
    },
    {
      "@type": "Question",
      "name": "What is partial discharge on the BTPX-205 and why does it matter?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Partial discharge means the BTPX-205 ejects only the accumulated solid fraction during its self-cleaning cycle — not the liquid process fluid. This dramatically reduces product loss compared to full-discharge centrifuges, which is critical in pharmaceutical and biotech applications where the process liquid is the high-value product. Discharge intervals can be set by timer or by volume processed."
      }
    },
    {
      "@type": "Question",
      "name": "Is the BTPX-205 CIP and SIP compatible?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The BTPX-205 features clean-in-place (CIP) and steam-in-place (SIP) compatible hygienic design with closed-loop hermetic operation. The product path is fully sealed from the atmosphere, preventing contamination and foaming. This makes it suitable for GMP-compliant pharmaceutical and biotech environments requiring documented cleanability."
      }
    }
  ]
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Alfa Laval BTPX 205 Biotech Centrifuge",
    "description": "Alfa Laval BTPX-205 self-cleaning disc stack centrifuge for biotech cell harvesting, pharmaceutical separation, and chemical processing. 5 GPM, 12,800 Gs.",
    "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
    "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
    "url": "https://dolphincentrifuge.com/alfa-laval-btpx-205-biotech-centrifuge/",
  },
  faqJsonLd,
];

const toc = [
  { id: 'overview', label: 'Overview' },
  { id: 'technical-specifications', label: 'Technical Specifications' },
  { id: 'applications', label: 'Applications' },
  { id: 'how-it-works', label: 'How It Works' },
  { id: 'why-choose', label: 'Why Choose the BTPX-205' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedProducts = [
  { label: 'Disc Stack Centrifuge Overview', href: '/disc-stack-centrifuge/', description: 'Complete disc stack centrifuge systems' },
  { label: 'Stainless Steel Centrifuges', href: '/alfa-laval-stainless-steel-centrifuge/', description: 'Hygienic stainless steel models' },
];

const relatedApplications = [
  { label: 'Food Grade Centrifuge Systems', href: '/food-grade-centrifuge/' },
  { label: 'All Centrifuge Applications', href: '/disc-stack-centrifuge-applications/' },
  { label: 'Pilot Sample Testing', href: '/industrial-centrifuge-sample-testing/' },
];
---

<ApplicationLayout
  title="Alfa Laval BTPX 205 Biotech Centrifuge | Dolphin Centrifuge"
  description="Alfa Laval BTPX-205 self-cleaning disc stack centrifuge for biotech cell harvesting, pharmaceutical separation, and chemical processing. 5 GPM, 12,800 Gs."
  heroImage="/images/alfa-laval-btpx-205-biotech-centrifuge/Alfa-Laval-BTPX-205-SGD-34-CDP.webp"
  heroImageAlt="Alfa Laval BTPX 205 SGD 34 CDP Biotech Centrifuge"
  category="products"
  categoryLabel="Products"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-btpx-205-biotech-centrifuge/"
  jsonLd={jsonLd}
  toc={toc}
  relatedProducts={relatedProducts}
  relatedApplications={relatedApplications}
>

  <!-- AI Summary — 30-50 words -->
  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">The Alfa Laval BTPX-205 is a self-cleaning hermetic disc stack centrifuge generating 12,800 Gs for biotech cell harvesting, pharmaceutical recovery, and fine chemical separation at up to 5 GPM. Dolphin Centrifuge supplies reconditioned and serviced BTPX-205 units from Warren, Michigan.</p>
  </div>

  <!-- Overview -->
  <h2 id="overview">Overview</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-1/2">
      <p>
        The Alfa Laval BTPX-205 is a self-cleaning centrifuge of the <a href="/disc-stack-centrifuge/">disc stack type</a>, engineered for the continuous separation of solids from liquids in demanding biotech and pharmaceutical environments. The machine can be configured as a purifier (liquid-liquid-solid separation) or as a clarifier (liquid-solid separation), giving operators flexibility across a wide range of process requirements. When set up as a purifier, the BTPX-205 separates solids and intermixed, immiscible liquid phases.
      </p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/alfa-laval-btpx-205-biotech-centrifuge/Alfa-Laval-BTPX-205-SGD34-CDP-1.webp"
        alt="Alfa Laval BTPX 205 SGD34 CDP Biotech Disc Stack Centrifuge"
        loading="lazy"
        width="750"
        height="976"
        class="rounded-xl shadow-md w-full"
      />
    </div>
  </div>

  <p>
    A key feature of the BTPX-205 is its partial solids ejection capability. Unlike full-discharge centrifuges that expel both solids and a significant volume of process fluid during each cycle, the BTPX-205 purges only the accumulated solids. This partial discharge dramatically reduces <a href="/centrifuge-product-loss-during-discharge/">fluid losses during discharge</a>, which is critical in pharmaceutical and biotech applications where the process fluid itself is the valuable product.
  </p>
  <p>
    The sludge ejection cycle can be triggered by a timer or based on the volume of fluid processed, allowing precise control over the discharge frequency. The centrifuge handles solids content up to 10% by volume in the feed stream. Dolphin Centrifuge offers <a href="/industrial-centrifuge-sample-testing/">pilot sample testing</a> to confirm the BTPX-205 is the right fit before purchase.
  </p>

  <!-- Technical Specifications -->
  <h2 id="technical-specifications">Technical Specifications</h2>
  <div class="overflow-x-auto mb-8 not-prose">
    <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
      <tbody>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Model Type</td>
          <td class="px-4 py-3 font-mono text-text-light">Alfa Laval BTPX-205-SGD34-CDP</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Rated Capacity</td>
          <td class="px-4 py-3 font-mono text-text-light">5 GPM on Pharma Cell Broth</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Sludge Space</td>
          <td class="px-4 py-3 font-mono text-text-light">0.25 Gallons</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Bowl RPM</td>
          <td class="px-4 py-3 font-mono text-text-light">9,650</td>
        </tr>
        <tr class="bg-white border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">G-Force</td>
          <td class="px-4 py-3 font-mono text-text-light">12,800 Gs</td>
        </tr>
        <tr class="bg-gray-50 border-b border-gray-200">
          <td class="px-4 py-3 font-semibold text-navy">Motor HP</td>
          <td class="px-4 py-3 font-mono text-text-light">7.5 HP</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3 font-semibold text-navy">Voltages</td>
          <td class="px-4 py-3 font-mono text-text-light">230 / 460 V</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Applications -->
  <h2 id="applications">Applications</h2>
  <p>
    The BTPX-205 is designed for removing suspended solids with particle sizes ranging from 0.5 to 500 &micro;m. The liquid centrate has a lower density than the separated solids, and total solids content can range from 0.1% to 10% by volume. The maximum process capacity of the machine is 5 gallons per minute.
  </p>

  <div class="grid md:grid-cols-3 gap-6 mb-8 not-prose">
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-3">Biotechnology</h3>
      <ul class="text-sm text-text-light space-y-2">
        <li>&#8226; Organic cell harvesting</li>
        <li>&#8226; Cell growth media clarification</li>
        <li>&#8226; Fermentation broth clarification</li>
        <li>&#8226; Cell debris removal</li>
        <li>&#8226; Inclusion body recovery</li>
      </ul>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-3">Pharmaceutical</h3>
      <ul class="text-sm text-text-light space-y-2">
        <li>&#8226; Plasma fraction recovery</li>
        <li>&#8226; Precipitate recovery</li>
        <li>&#8226; Vaccines and serums production</li>
      </ul>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-3">Chemical</h3>
      <ul class="text-sm text-text-light space-y-2">
        <li>&#8226; Catalyst separation</li>
        <li>&#8226; Sub-micron particle separation</li>
        <li>&#8226; Pigments, dyes, and toners</li>
      </ul>
    </div>
  </div>

  <!-- How It Works -->
  <h2 id="how-it-works">How It Works</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-1/2">
      <p>
        The bio-culture fluid enters the rotating bowl of the BTPX-205 centrifuge. The bowl exerts a high centrifugal force of 12,800 Gs on the process fluid, causing rapid sedimentation of the cells. The process fluid enters through a stationary inlet pipe (1) and is accelerated by a distributor (2) before entering the disc stack (3).
      </p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/alfa-laval-btpx-205-biotech-centrifuge/BTPX-205-Bowl-Cross-Section-300.webp"
        alt="BTPX 205 Bowl Cross Section"
        loading="lazy"
        width="300"
        height="341"
        class="rounded-xl shadow-md w-full"
      />
    </div>
  </div>

  <p>
    The separation of the solids from the liquid happens in the inter-disc spaces. The clear liquid moves towards the center of the bowl. A <a href="/disc-centrifuge-parts-glossary/">paring disc</a> (4) pumps out the clear centrate.
  </p>
  <p>
    The denser solids move towards the bowl periphery. A hydraulic mechanism located under the bowl separation space causes the sludge ejection by forcing a sliding piston (5) downward, opening the solids ejection ports (6) at the bowl periphery. The cyclone reduces the high ejection velocity of the solids.
  </p>
  <p>
    The separated cells and solids are auto-ejected while the liquid phase (broth) exits through a separate outlet, enabling continuous, unattended operation. For applications requiring <a href="/food-grade-centrifuge/">food-grade or hygienic centrifuge systems</a>, the BTPX-205's CIP/SIP compatibility makes it a strong candidate.
  </p>

  <!-- Why Choose -->
  <h2 id="why-choose">Why Choose the BTPX-205?</h2>
  <div class="grid md:grid-cols-2 gap-6 mb-8 not-prose">
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2">Minimal Product Loss</h3>
      <p class="text-sm text-text-light">Partial discharge technology ejects only solids, dramatically reducing the loss of valuable process fluid compared to full-discharge centrifuges. Dolphin Centrifuge provides full <a href="/industrial-disc-centrifuge-repair/">disc centrifuge repair and reconditioning</a> for BTPX-205 units.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2">Extreme G-Force</h3>
      <p class="text-sm text-text-light">At 12,800 Gs, the BTPX-205 separates particles as small as 0.5 microns, making it ideal for cell harvesting and fine precipitate recovery.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2">Continuous Operation</h3>
      <p class="text-sm text-text-light">Self-cleaning design with programmable discharge intervals allows uninterrupted processing without manual intervention.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2">Versatile Configuration</h3>
      <p class="text-sm text-text-light">Can be set up as a clarifier or purifier to match specific process requirements in biotech, pharma, and chemical applications.</p>
    </div>
  </div>

  <!-- CTA -->
  <div class="bg-[#1B3A5C] rounded-xl p-6 md:p-8 text-white text-center my-8 not-prose">
    <h2 class="text-2xl md:text-3xl font-bold mb-4" style="font-family: 'Plus Jakarta Sans', sans-serif;">Ready to Get Started?</h2>
    <p class="text-blue-100 mb-6 max-w-2xl mx-auto">Dolphin Centrifuge supplies reconditioned BTPX-205 centrifuges for biotech cell harvesting, pharmaceutical recovery, and fine chemical separation. Contact us for pricing, availability, and pilot testing.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] text-white font-semibold px-8 py-3 rounded-lg hover:bg-yellow-600 transition-colors">Get a Free Quote</a>
      <a href="tel:+12485222573" class="border border-white text-white px-8 py-3 rounded-lg hover:bg-white/10 transition-colors">(248) 522-2573</a>
    </div>
  </div>

  <!-- FAQ Section -->
  <h2 id="faq">Frequently Asked Questions</h2>
  <div class="space-y-4 not-prose">
    <details class="bg-gray-50 rounded-xl border border-gray-200 p-5">
      <summary class="font-semibold text-navy cursor-pointer">What is the Alfa Laval BTPX 205 used for?</summary>
      <p class="text-text-light mt-3 text-sm">The Alfa Laval BTPX-205 is a self-cleaning disc stack centrifuge used for biotech cell harvesting, pharmaceutical recovery, and fine chemical separation. Typical applications include fermentation broth clarification, organic cell harvesting, inclusion body recovery, plasma fraction recovery, vaccine production, and catalyst separation. It handles solids content up to 10% by volume and particle sizes from 0.5 to 500 microns.</p>
    </details>
    <details class="bg-gray-50 rounded-xl border border-gray-200 p-5">
      <summary class="font-semibold text-navy cursor-pointer">What G-force does the Alfa Laval BTPX-205 generate?</summary>
      <p class="text-text-light mt-3 text-sm">The Alfa Laval BTPX-205 generates 12,800 Gs of centrifugal force at its rated bowl speed of 9,650 RPM. This extreme G-force enables separation of particles as small as 0.5 microns, making it suitable for sub-micron pharmaceutical precipitates, cell debris, and fine biotech solids.</p>
    </details>
    <details class="bg-gray-50 rounded-xl border border-gray-200 p-5">
      <summary class="font-semibold text-navy cursor-pointer">What is partial discharge on the BTPX-205 and why does it matter?</summary>
      <p class="text-text-light mt-3 text-sm">Partial discharge means the BTPX-205 ejects only the accumulated solid fraction during its self-cleaning cycle — not the liquid process fluid. This dramatically reduces product loss compared to full-discharge centrifuges, which is critical in pharmaceutical and biotech applications where the process liquid is the high-value product. Discharge intervals can be set by timer or by volume processed.</p>
    </details>
    <details class="bg-gray-50 rounded-xl border border-gray-200 p-5">
      <summary class="font-semibold text-navy cursor-pointer">Is the BTPX-205 CIP and SIP compatible?</summary>
      <p class="text-text-light mt-3 text-sm">Yes. The BTPX-205 features clean-in-place (CIP) and steam-in-place (SIP) compatible hygienic design with closed-loop hermetic operation. The product path is fully sealed from the atmosphere, preventing contamination and foaming. This makes it suitable for GMP-compliant pharmaceutical and biotech environments requiring documented cleanability.</p>
    </details>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

</ApplicationLayout>
