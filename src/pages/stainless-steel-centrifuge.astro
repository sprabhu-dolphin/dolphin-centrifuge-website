              <tr class="border-t border-gray-100"><td class="px-4 py-2 font-medium text-navy">Drive Motor</td><td class="px-4 py-2 text-text-light">15 HP</td></tr>
              <tr class="border-t border-gray-100"><td class="px-4 py-2 font-medium text-navy">Voltages</td><td class="px-4 py-2 text-text-light">230 / 460 V</td></tr>
              <tr class="border-t border-gray-100"><td class="px-4 py-2 font-medium text-navy">Size</td><td class="px-4 py-2 text-text-light">5' x 7' x 7' (H)</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- BRPX 313 Stainless Steel Disc Stack Centrifuge -->
      <h2 class="text-2xl md:text-3xl font-bold text-navy mt-10 mb-4">BRPX 313 Stainless Steel Disc Stack Centrifuge</h2>
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 md:p-8 mb-4">
        <h3 class="text-lg font-bold text-navy mb-3">Applications</h3>
        <ul class="text-text-light space-y-1 mb-6">
          <li>&#8226; CBD Oil from Hemp Water</li>
          <li>&#8226; Fish Oil Separation from Stick-water</li>
