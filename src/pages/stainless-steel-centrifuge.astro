        <h3 class="text-lg font-bold text-navy mb-3">Specifications</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
            <thead>
              <tr class="bg-navy text-white">
                <th class="text-left px-4 py-3 font-semibold">Spec</th>
                <th class="text-left px-4 py-3 font-semibold">Value</th>
              </tr>
            </thead>
            <tbody class="bg-white">
              <tr class="border-t border-gray-100"><td class="px-4 py-2 font-medium text-navy">Model Type</td><td class="px-4 py-2 text-text-light">BRPX 313 SGT 24-60</td></tr>
              <tr class="border-t border-gray-100"><td class="px-4 py-2 font-medium text-navy">Rated Capacity</td><td class="px-4 py-2 text-text-light">50 GPM on CBD Ethanol Clarification</td></tr>
              <tr class="border-t border-gray-100"><td class="px-4 py-2 font-medium text-navy">Sludge Space</td><td class="px-4 py-2 text-text-light">3.87 Gallons</td></tr>
