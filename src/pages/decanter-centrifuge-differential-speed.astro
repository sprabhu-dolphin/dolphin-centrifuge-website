          (<span id="calc-display-bowl">4,000</span> &minus; <span id="calc-display-sun">2,460</span>) &divide; <span id="calc-display-ratio">159</span>
        </p>
      </div>
      <div class="text-center">
        <p id="calc-result-diff" class="text-4xl font-bold font-mono text-gold leading-none">10</p>
        <p class="text-xs text-navy font-semibold mt-1 uppercase tracking-wide">Differential RPM</p>
      </div>
      <div class="text-center">
        <p id="calc-result-scroll" class="text-4xl font-bold font-mono text-navy leading-none">3,990</p>
        <p class="text-xs text-navy font-semibold mt-1 uppercase tracking-wide">Scroll Speed RPM</p>
      </div>
    </div>

    <p class="text-xs text-gray-400 text-center pb-4">Results based on the data entered above. &copy; Dolphin Centrifuge</p>
  </div>

  <script is:inline>
    function calcDiffSpeed() {
      const bowl = parseFloat(document.getElementById('calc-bowl-speed').value) || 0;
      const ratio = parseFloat(document.getElementById('calc-gear-ratio').value) || 1;
      const sun = parseFloat(document.getElementById('calc-sun-speed').value) || 0;

      const diff = (bowl - sun) / ratio;
      const scrollSpeed = bowl - diff;

      document.getElementById('calc-display-bowl').textContent = bowl.toLocaleString();
      document.getElementById('calc-display-sun').textContent = sun.toLocaleString();
      document.getElementById('calc-display-ratio').textContent = ratio.toLocaleString();

      if (isNaN(diff) || ratio === 0) {
        document.getElementById('calc-result-diff').textContent = '—';
        document.getElementById('calc-result-scroll').textContent = '—';
        return;
      }

      document.getElementById('calc-result-diff').textContent = Math.round(diff * 10) / 10;
      document.getElementById('calc-result-scroll').textContent = Math.round(scrollSpeed).toLocaleString();
    }
    calcDiffSpeed();
  </script>

