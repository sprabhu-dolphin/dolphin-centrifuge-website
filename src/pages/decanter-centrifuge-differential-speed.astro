        />
        <p class="text-xs text-gray-400 mt-1">Use a positive number if the GearBox rotates in the same direction as the bowl. Use a negative number if in the opposite direction.</p>
      </div>
    </div>

    <!-- Result -->
    <div class="mx-6 mb-6 rounded-xl bg-navy/5 border border-navy/10 px-6 py-5 flex flex-col md:flex-row items-center gap-4">
