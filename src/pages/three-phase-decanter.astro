  <!-- Working Principle -->
  <h2 id="working-principle">Working Principle</h2>

  <figure>
    <img
      src="/images/three-phase-decanter/Three-Phase-Decanter-Diagram-400.webp"
      alt="Three Phase Decanter Diagram"
      width="400"
      height="165"
