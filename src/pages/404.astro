---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Page Not Found';
const description = 'The page you requested could not be found. Browse our centrifuge knowledge base or contact us for help.';

// Astro emits 404 status when this page handles an unmatched route.
Astro.response.status = 404;
Astro.response.headers.set('Cache-Control', 'no-store');
---

<BaseLayout
  title={title}
  description={description}
  disableTitleSuffix={false}
>
  <main class="min-h-[60vh] flex items-center justify-center px-4 py-16 bg-light-bg">
    <div class="max-w-2xl text-center">
      <p class="text-sm font-mono uppercase tracking-wider text-gold mb-2">Error 404</p>
      <h1 class="text-4xl md:text-5xl font-bold text-navy mb-4 font-heading">
        Page Not Found
      </h1>
      <p class="text-lg text-gray-700 mb-8">
        The page you're looking for doesn't exist or has been moved. Try one of these instead:
      </p>
      <div class="grid sm:grid-cols-2 gap-4 mb-8 text-left">
        <a href="/" class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-gold hover:shadow-md transition no-underline">
          <p class="font-bold text-navy mb-1">Home</p>
          <p class="text-sm text-gray-600 m-0">Industrial centrifuge solutions</p>
        </a>
        <a href="/knowledge-center/" class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-gold hover:shadow-md transition no-underline">
          <p class="font-bold text-navy mb-1">Knowledge Center</p>
          <p class="text-sm text-gray-600 m-0">Technical articles and guides</p>
        </a>
        <a href="/alfa-laval-centrifuges/" class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-gold hover:shadow-md transition no-underline">
          <p class="font-bold text-navy mb-1">Alfa Laval Centrifuges</p>
          <p class="text-sm text-gray-600 m-0">Product gallery</p>
        </a>
        <a href="/contact-for-alfa-laval-centrifuges/" class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-gold hover:shadow-md transition no-underline">
          <p class="font-bold text-navy mb-1">Contact Us</p>
          <p class="text-sm text-gray-600 m-0">Talk to an engineer</p>
        </a>
      </div>
      <p class="text-sm text-text-muted m-0">
        Or call <a href="tel:+12485222573" class="text-navy underline font-bold hover:text-gold">(248) 522-2573</a>
      </p>
    </div>
  </main>
</BaseLayout>
