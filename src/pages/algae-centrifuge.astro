---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "What is an algae centrifuge?",
    answer: "An algae centrifuge is a flow-through disc-stack centrifuge used for harvesting algae cells from water. It uses centrifugal force generated by fast rotation to spin out the algae cells and separate them from the water. Industrial models exert up to 12,000 g's and can process 5 to over 100 gallons per minute."
  },
  {
    question: "How does an industrial algae centrifuge work?",
    answer: "The algae water is fed continuously into the rotating centrifuge bowl. The high g-force (up to 12,000 g's) spins the algae cells toward the bowl wall. Separated clear water discharges continuously through the water outlet. The self-cleaning bowl automatically ejects the concentrated algae biomass as a slurry or thick paste without stopping the centrifuge."
  },
  {
    question: "What flow rates are available for algae harvesting centrifuges?",
    answer: "Dolphin Centrifuge offers self-cleaning disc-stack centrifuge models ranging from 5 GPM up to over 100 GPM for algae harvesting. A typical 25 GPM unit has a 7.5 HP motor and a compact footprint. Larger models are available for higher throughput requirements."
  },
  {
    question: "Does high g-force damage algae cells?",
    answer: "No. The high g-force does not damage the algae cell structure. Industrial disc-stack centrifuges routinely harvest algae cells intact using forces exceeding 7,000 g's."
  },
  {
    question: "What material is used in algae harvesting centrifuges?",
    answer: "Industrial algae centrifuges primarily use all stainless steel for fluid contact surfaces. This corrosion-resistant material allows harvesting of saltwater algae on a commercial scale. An all-stainless steel (food grade) centrifuge is recommended for algae cultivated in seawater."
  },
  {
    question: "Can algae centrifuges process seaweed or kelp?",
    answer: "Yes. Kelp or seaweed separation, humic fertilizer separation, and other similar biomass extraction processes are well suited for the stainless steel disc-stack centrifuge. Dolphin Centrifuge has supplied stainless steel disc-stack centrifuges for processing kelp for organic fertilizer production."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "url": "https://dolphincentrifuge.com/algae-centrifuge/",
  "name": "Algae Centrifuge System",
  "description": "Industrial disc-stack algae centrifuges for large-scale algae cell harvesting. Self-cleaning, 7,000+ Gs, 5-100+ GPM, stainless steel construction for saltwater algae.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
