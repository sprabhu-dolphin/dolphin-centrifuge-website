const jsonLd = [productJsonLd, faqJsonLd];

const toc = [
  { id: 'algae-centrifuge-overview', label: 'Algae Centrifuge — What Is It?' },
  { id: 'operation', label: 'Operation' },
  { id: 'benefits', label: 'Benefits' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'manufacturer', label: 'Manufacturer' },
  { id: 'other-applications', label: 'Other Applications' },
  { id: 'lab-scale', label: 'Lab Scale Algae Harvesting' },
  { id: 'algae-oil-separation', label: 'Algae Oil Separation' },
  { id: 'faq', label: 'FAQ' },
];

const relatedApplications = [
  { label: 'Liquid Humus Fertilizer Centrifuge', href: '/liquid-humus-centrifuge/' },
  { label: 'Food Grade Centrifuge', href: '/food-grade-centrifuge/' },
  { label: 'Stainless Steel Centrifuge', href: '/stainless-steel-centrifuge/' },
  { label: 'Oil Centrifuge', href: '/oil-centrifuge/' },
