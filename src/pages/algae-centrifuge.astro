const relatedProducts = [
  { label: 'DMPX-042 Self-Cleaning System', href: '/centrifuges/dmpx-042/', description: 'Mid-range self-cleaning, 20–35 GPM' },
  { label: 'DMPX-070 Self-Cleaning System', href: '/centrifuges/dmpx-070/', description: 'High-capacity self-cleaning, 40–100+ GPM' },
