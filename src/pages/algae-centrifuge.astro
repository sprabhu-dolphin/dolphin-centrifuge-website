---
import BaseLayout from '../layouts/BaseLayout.astro';

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "url": "https://dolphincentrifuge.com/algae-centrifuge/",
  "name": "Algae Centrifuge System",
  "description": "Industrial disc-stack algae centrifuges for large-scale algae cell harvesting. Self-cleaning, 7,000+ Gs, 5-100+ GPM, stainless steel construction for saltwater algae.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is an algae centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An algae centrifuge is a flow-through disc-stack centrifuge used for harvesting algae cells from water. It uses centrifugal force generated by fast rotation to spin out the algae cells and separate them from the water. Industrial models exert up to 12,000 g's and can process 5 to over 100 gallons per minute."
      }
    },
    {
      "@type": "Question",
      "name": "How does an industrial algae centrifuge work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The algae water is fed continuously into the rotating centrifuge bowl. The high g-force (up to 12,000 g's) spins the algae cells toward the bowl wall. Separated clear water discharges continuously through the water outlet. The self-cleaning bowl automatically ejects the concentrated algae biomass as a slurry or thick paste without stopping the centrifuge."
      }
    },
    {
      "@type": "Question",
      "name": "What flow rates are available for algae harvesting centrifuges?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dolphin Centrifuge offers self-cleaning disc-stack centrifuge models ranging from 5 GPM up to over 100 GPM for algae harvesting. A typical 25 GPM unit has a 7.5 HP motor and a compact footprint. Larger models are available for higher throughput requirements."
      }
    },
    {
      "@type": "Question",
      "name": "Does high g-force damage algae cells?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. The high g-force does not damage the algae cell structure. Industrial disc-stack centrifuges routinely harvest algae cells intact using forces exceeding 7,000 g's."
      }
    },
    {
      "@type": "Question",
      "name": "What material is used in algae harvesting centrifuges?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Industrial algae centrifuges primarily use all stainless steel for fluid contact surfaces. This corrosion-resistant material allows harvesting of saltwater algae on a commercial scale. An all-stainless steel (food grade) centrifuge is recommended for algae cultivated in seawater."
      }
    },
    {
      "@type": "Question",
      "name": "Can algae centrifuges process seaweed or kelp?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Kelp or seaweed separation, humic fertilizer separation, and other similar biomass extraction processes are well suited for the stainless steel disc-stack centrifuge. Dolphin Centrifuge has supplied stainless steel disc-stack centrifuges for processing kelp for organic fertilizer production."
      }
    }
  ]
};
---

<BaseLayout
  title="Algae Centrifuge Systems"
  description="Disc stack centrifuges for algae harvesting and dewatering. 7,000 Gs, 32 GPM throughput. Dolphin Centrifuge: algae centrifuge sales, parts, and service."
  canonicalUrl="https://dolphincentrifuge.com/algae-centrifuge/"
  breadcrumbs={[{label: 'Applications', href: '/applications/'}, {label: 'Algae Centrifuge'}]}
  jsonLd={[productJsonLd, faqJsonLd]}
>

  <!-- Hero -->
  <section class="bg-[#1B3A5C] text-white py-14 md:py-20">
    <div class="container-dolphin max-w-5xl">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <div class="text-[#E8A317] text-sm font-semibold uppercase tracking-wider mb-3">Application Guide</div>
          <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-5">
            Algae Centrifuge | Large-Scale Algae Cell Harvesting
          </h1>
          <p class="text-lg text-gray-200 mb-6">
            Industrial disc-stack centrifuges for continuous, high-efficiency harvesting of algae cells from water. Self-cleaning design, up to 12,000 g's, 5 to over 100 GPM. All stainless steel construction for saltwater and food-grade algae processing.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] hover:bg-yellow-500 text-white font-semibold px-6 py-3 rounded-lg transition">Request Quote</a>
            <a href="tel:+12485222573" class="border border-white text-white hover:bg-white hover:text-[#1B3A5C] font-semibold px-6 py-3 rounded-lg transition">(248) 522-2573</a>
          </div>
        </div>
        <div>
          <img
            src="/images/algae-centrifuge/Alfa-Laval-CRPX-207-Stainless-Steel-Kelp-Seaweed-Centrifuge-600.jpg"
            alt="Alfa Laval CRPX-207 Stainless Steel Kelp Seaweed Centrifuge"
            width="600" height="400"
            loading="eager"
            class="rounded-xl w-full shadow-lg"
          />
          <p class="text-sm text-gray-300 mt-2 text-center">Alfa Laval Stainless Steel Algae — Seaweed Centrifuge</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="bg-[#F5F5F0] py-12 md:py-16">
    <div class="container-dolphin max-w-4xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies industrial disc stack centrifuge systems for large-scale algae harvesting. Operating at 7,000–12,000 Gs, these self-cleaning centrifuges process 5 to 100+ GPM of algae culture continuously, harvesting biomass without damaging cell structure. Stainless steel bowl construction is standard for marine and saltwater algae applications. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of centrifugal separation experience across industrial and biotechnology sectors.</p>
      </div>

      <!-- Table of Contents -->
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-lg font-bold text-[#1B3A5C] mb-4">Table of Contents</h2>
        <nav>
          <ul class="space-y-1 text-sm">
            <li><a href="#algae-centrifuge-overview" class="text-[#1B3A5C] hover:text-[#E8A317]">Algae Centrifuge — What Is It?</a></li>
            <li><a href="#operation" class="text-[#1B3A5C] hover:text-[#E8A317]">Operation</a></li>
            <li><a href="#benefits" class="text-[#1B3A5C] hover:text-[#E8A317]">Benefits</a></li>
            <li><a href="#specifications" class="text-[#1B3A5C] hover:text-[#E8A317]">Specifications</a></li>
            <li><a href="#manufacturer" class="text-[#1B3A5C] hover:text-[#E8A317]">Manufacturer</a></li>
            <li><a href="#other-applications" class="text-[#1B3A5C] hover:text-[#E8A317]">Other Applications</a></li>
            <li><a href="#lab-scale" class="text-[#1B3A5C] hover:text-[#E8A317]">Lab Scale Algae Harvesting — Disc Stack Centrifuge</a></li>
            <li><a href="#algae-oil-separation" class="text-[#1B3A5C] hover:text-[#E8A317]">Algae Oil Separation</a></li>
            <li><a href="#faq" class="text-[#1B3A5C] hover:text-[#E8A317]">FAQ</a></li>
          </ul>
        </nav>
      </div>

      <!-- Algae Centrifuge Overview -->
      <div id="algae-centrifuge-overview" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Algae Centrifuge</h2>
        <p class="text-[#2D2D2D] mb-4">
          An algae centrifuge is a flow-through centrifuge used for <a href="https://energyeducation.ca/encyclopedia/Harvesting_algae" class="text-[#1B3A5C] underline" target="_blank" rel="noopener">harvesting algae cells</a> from water. It uses the centrifugal force generated by the fast rotation of the algae water to spin out the algae cells and separate them.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          There are small-scale, commercial grade centrifuges for algae available for sale. These centrifuges process 1 to 5 GPM and exert centrifugal forces in the 1,000–2,000 g's range.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          The low flow rate is due to the low g-force generated by these centrifuges, which require a higher retention time. This, in turn, means low flow rates.
        </p>
        <p class="text-[#2D2D2D]">
          These centrifuges are suitable for small-scale algae cell separation in labs. For industrial-scale algae harvesting, you need an industrial disc stack centrifuge, as described below.
        </p>
      </div>

      <!-- Operation -->
      <div id="operation" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Operation</h2>
        <p class="text-[#2D2D2D] mb-4">
          An <a href="/industrial-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317]">industrial algae centrifuge</a> is an effective way of harvesting algae cells from water. The high g-force (up to 12,000 g's) spins the algae cells toward the centrifuge bowl wall. The centrifuge discharges the clear, separated water continuously.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          The self-cleaning type bowl auto-ejects the concentrated algae cells. This discharge comes as a slurry or a thick paste ready for algae oil extraction or drying.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          A flow-through centrifuge allows large-scale, continuous separation of algae. This constant separation eliminates filters or other separation machines, such as filter presses or screw presses.
        </p>
        <p class="text-[#2D2D2D] mb-4">
          Our self-cleaning centrifuge models have different capacities. They can process from 5 gallons per minute to <strong>over 100 gallons per minute</strong> of algae water.
        </p>
        <p class="text-[#2D2D2D] mb-6 italic font-medium">
          The high g-force does not damage the algae cell structure.
        </p>
        <p class="text-[#2D2D2D] mb-6">
          Industrial algae centrifuges primarily have all stainless steel fluid contact. This corrosion-resistant material allows the harvesting of saltwater algae on a commercial scale. An all-stainless steel centrifuge (food grade) is recommended for algae cultivated in seawater.
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <img
              src="/images/algae-centrifuge/algae-biomass-concentrate-600.jpg"
              alt="Algae Cell Concentrate from Disc Stack Centrifuge Test"
              width="600" height="315"
              loading="lazy"
              class="rounded-lg w-full"
            />
            <p class="text-sm text-gray-500 mt-2 text-center">Algae Cell Concentrate from Disc Stack Centrifuge Test</p>
          </div>
          <div>
            <img
              src="/images/algae-centrifuge/Algae-Harveting-Results.jpg"
              alt="Algae Harvesting Results from Alfa Laval Disc Stack Centrifuge"
              width="600" height="314"
              loading="lazy"
              class="rounded-lg w-full"
            />
            <p class="text-sm text-gray-500 mt-2 text-center">Algae harvesting results from the Alfa Laval centrifuge</p>
          </div>
        </div>
      </div>

      <!-- Benefits -->
      <div id="benefits" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Benefits</h2>
        <p class="text-[#2D2D2D] mb-4">
          Algae Centrifuges offer multiple advantages over conventional filters or open-bowl centrifuges. Following is a list of some of these benefits.
        </p>
        <ul class="space-y-4">
          <li class="flex gap-3">
            <span class="text-[#E8A317] font-bold mt-0.5">&#10003;</span>
            <div>
              <strong class="text-[#1B3A5C]">Continuous Process:</strong>
              <span class="text-[#2D2D2D]"> Algae centrifuges have a flow-through design that allows the algae cells to be harvested continuously. The centrifuge continuously discharges the clear centrate (water) through a designated water outlet.</span>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-[#E8A317] font-bold mt-0.5">&#10003;</span>
            <div>
              <strong class="text-[#1B3A5C]">High Centrifuge Efficiency:</strong>
              <span class="text-[#2D2D2D]"> A disc-stack centrifuge with high centrifugal force has an equivalent settling area the size of several football fields. An open bowl centrifuge with a low RPM centrifuge cannot affect such centrifuge efficiency.</span>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-[#E8A317] font-bold mt-0.5">&#10003;</span>
            <div>
              <strong class="text-[#1B3A5C]">7,000+ G-Force:</strong>
              <span class="text-[#2D2D2D]"> With a high rotation speed, the disc-stack centrifuge exerts a centrifugal force over 7,000 times that of gravity. Separating the smallest algae cells under this tremendous force is quick and efficient.</span>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-[#E8A317] font-bold mt-0.5">&#10003;</span>
            <div>
              <strong class="text-[#1B3A5C]">Self-Cleaning Design:</strong>
              <span class="text-[#2D2D2D]"> The self-cleaning disc-stack centrifuge automatically ejects the separated algae biomass without stopping the centrifuge.</span>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-[#E8A317] font-bold mt-0.5">&#10003;</span>
            <div>
              <strong class="text-[#1B3A5C]">Compact Size:</strong>
              <span class="text-[#2D2D2D]"> Disc-stack centrifuges are compact and can fit into small spaces. For example, a 20-GPM Algae Harvesting Centrifuge has a 3' x 3' x 4' (H) footprint.</span>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-[#E8A317] font-bold mt-0.5">&#10003;</span>
            <div>
              <strong class="text-[#1B3A5C]">Low Operating Cost:</strong>
              <span class="text-[#2D2D2D]"> The only operating cost of an algae centrifuge is electricity for the drive motor. Given that the centrifuge is self-cleaning and fully automatic, there is no recurring material (filter, media, etc.) or manual labor costs.</span>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-[#E8A317] font-bold mt-0.5">&#10003;</span>
            <div>
              <strong class="text-[#1B3A5C]">Durability:</strong>
              <span class="text-[#2D2D2D]"> <a href="/alfa-laval-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317]">Alfa Laval centrifuges</a> are highly durable machines with primary bowl parts made of 316 Stainless Steel. The centrifuge frame is also very robust, and it is not unusual for these centrifuges to provide decades of service life.</span>
            </div>
          </li>
        </ul>

        <div class="mt-6 border-t border-gray-100 pt-5">
          <p class="text-[#2D2D2D] italic text-sm">
            If you have simple, routine questions: We have condensed our 40+ years of disc-stack centrifuge experience into <a href="/disc-stack-centrifuge-faq/" class="text-[#1B3A5C] hover:text-[#E8A317] font-medium">101 Frequently Asked Questions about Disc Stack Centrifuges!</a>
          </p>
        </div>
      </div>

      <!-- Mid-Page CTA -->
      <div class="bg-gradient-to-r from-[#1B3A5C] to-[#2a4f7a] rounded-xl p-6 md:p-8 text-white mb-8">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div>
            <h3 class="text-xl font-bold mb-2">Need an Algae Harvesting Centrifuge?</h3>
            <p class="text-blue-100">Our engineers will evaluate your algae strain and recommend the optimal system for your throughput requirements.</p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] hover:bg-yellow-500 text-white font-semibold px-6 py-3 rounded-lg transition whitespace-nowrap">Get a Quote</a>
            <a href="tel:+12485222573" class="border border-white text-white hover:bg-white hover:text-[#1B3A5C] font-semibold px-6 py-3 rounded-lg transition whitespace-nowrap">(248) 522-2573</a>
          </div>
        </div>
      </div>

      <!-- Specifications -->
      <div id="specifications" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Specifications</h2>
        <p class="text-[#2D2D2D] mb-4">
          The following are the specifications for a typical Alfa Laval disc-stack centrifuge when used for algae cell harvesting.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <tbody>
              <tr class="border-b border-gray-200">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C] w-1/2">Processing Capacity</td>
                <td class="py-3 font-mono font-bold">25 GPM on Algae Dewatering (32 GPM Max.)</td>
              </tr>
              <tr class="border-b border-gray-200 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Centrifuge Type</td>
                <td class="py-3">Self-Cleaning, Disc-Stack Centrifuge (Auto Ejects Concentrated Cells)</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Bowl Speed</td>
                <td class="py-3 font-mono">6,300 RPM</td>
              </tr>
              <tr class="border-b border-gray-200 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Centrifugal Force (RCF)</td>
                <td class="py-3 font-mono font-bold">7,000 Gs</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Cell Volume</td>
                <td class="py-3 font-mono">1.0 Gallons</td>
              </tr>
              <tr class="border-b border-gray-200 bg-gray-50">
                <td class="py-3 pr-4 font-semibold text-[#1B3A5C]">Motor Power</td>
                <td class="py-3 font-mono">7.5 HP (5 kW)</td>
              </tr>
              <tr class="bg-[#1B3A5C] text-white">
                <td class="py-3 pr-4 font-semibold">Dimensions &amp; Weight</td>
                <td class="py-3 font-mono">4' x 6' x 5' (H) · 2,500 Lbs</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Manufacturer -->
      <div id="manufacturer" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Manufacturer</h2>
        <p class="text-[#2D2D2D]">
          Dolphin Centrifuge manufactures Algae Centrifuges — specially modified Alfa Laval centrifuges to separate or harvest algae cells from water. We also manufacture three-phase centrifuges that work as algae oil separators to extract the separated algae oil from the water.
        </p>
      </div>

      <!-- Other Applications -->
      <div id="other-applications" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Other Applications</h2>
        <p class="text-[#2D2D2D] mb-4">
          Kelp or seaweed separation, humic fertilizer separation, and other similar biomass extraction processes are well suited for this type of stainless steel centrifuge.
        </p>
        <p class="text-[#2D2D2D] mb-6">
          The Alfa Laval stainless steel disc-stack centrifuge shown below is for processing kelp (seaweed) for organic fertilizer production.
        </p>
        <img
          src="/images/algae-centrifuge/Alfa-Laval-CRPX-207-Stainless-Steel-Kelp-Seaweed-Centrifuge-600.jpg"
          alt="Stainless Steel Kelp Seaweed Self-Cleaning Centrifuge"
          width="600" height="400"
          loading="lazy"
          class="rounded-lg w-full"
        />
        <p class="text-sm text-gray-500 mt-2 text-center">Stainless Steel Kelp Seaweed Self-Cleaning Centrifuge</p>
      </div>

      <!-- Lab Scale -->
      <div id="lab-scale" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Lab Scale Algae Harvesting — Disc Stack Centrifuge</h2>
        <p class="text-[#2D2D2D] mb-6">
          The following are results from the process of a small (1 gallon) sample of commercial algae through our lab scale disc stack centrifuge. The results are self-explanatory.
        </p>
        <div class="text-center">
          <img
            src="/images/algae-centrifuge/Industrial-Centrifuge-Pilot-Testing-Results.jpg"
            alt="Before and After Samples of Algae — Industrial Centrifuge Pilot Testing Results"
            width="244" height="400"
            loading="lazy"
            class="rounded-lg mx-auto"
          />
          <p class="text-sm text-gray-500 mt-2">Before and After samples of Algae</p>
        </div>
      </div>

      <!-- Algae Oil Separation -->
      <div id="algae-oil-separation" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-4">Algae Oil Separation</h2>
        <p class="text-[#2D2D2D] mb-4">
          An algae <a href="/oil-centrifuge/" class="text-[#1B3A5C] hover:text-[#E8A317]">oil separation centrifuge</a> separates the algae oil from water. This centrifuge is a disc-stack industrial centrifuge that continuously exerts high force to separate the light oil from the water.
        </p>
        <p class="text-[#2D2D2D]">
          A self-cleaning centrifuge also separates the algae cell debris from the oil and self-ejects this separated biomass intermittently.
        </p>
      </div>

      <!-- FAQ -->
      <div id="faq" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#1B3A5C] mb-6">Algae Centrifuge FAQ</h2>
        <div class="space-y-5">
          <details class="border border-gray-200 rounded-lg">
            <summary class="px-5 py-4 font-semibold text-[#1B3A5C] cursor-pointer hover:bg-gray-50 rounded-lg list-none flex justify-between items-center">
              What is an algae centrifuge?
              <span class="text-[#E8A317] font-bold text-lg ml-2">+</span>
            </summary>
            <div class="px-5 pb-4 pt-2 text-[#2D2D2D] text-sm leading-relaxed">
              An algae centrifuge is a flow-through disc-stack centrifuge used for harvesting algae cells from water. It uses centrifugal force generated by fast rotation to spin out the algae cells and separate them from the water. Industrial models exert up to 12,000 g's and can process 5 to over 100 gallons per minute.
            </div>
          </details>
          <details class="border border-gray-200 rounded-lg">
            <summary class="px-5 py-4 font-semibold text-[#1B3A5C] cursor-pointer hover:bg-gray-50 rounded-lg list-none flex justify-between items-center">
              How does an industrial algae centrifuge work?
              <span class="text-[#E8A317] font-bold text-lg ml-2">+</span>
            </summary>
            <div class="px-5 pb-4 pt-2 text-[#2D2D2D] text-sm leading-relaxed">
              The algae water is fed continuously into the rotating centrifuge bowl. The high g-force (up to 12,000 g's) spins the algae cells toward the bowl wall. Separated clear water discharges continuously through the water outlet. The self-cleaning bowl automatically ejects the concentrated algae biomass as a slurry or thick paste without stopping the centrifuge.
            </div>
          </details>
          <details class="border border-gray-200 rounded-lg">
            <summary class="px-5 py-4 font-semibold text-[#1B3A5C] cursor-pointer hover:bg-gray-50 rounded-lg list-none flex justify-between items-center">
              What flow rates are available for algae harvesting centrifuges?
              <span class="text-[#E8A317] font-bold text-lg ml-2">+</span>
            </summary>
            <div class="px-5 pb-4 pt-2 text-[#2D2D2D] text-sm leading-relaxed">
              Dolphin Centrifuge offers self-cleaning disc-stack centrifuge models ranging from 5 GPM up to over 100 GPM for algae harvesting. A typical 25 GPM unit has a 7.5 HP motor and a 3' x 3' x 4'(H) footprint. Larger models are available for higher throughput requirements.
            </div>
          </details>
          <details class="border border-gray-200 rounded-lg">
            <summary class="px-5 py-4 font-semibold text-[#1B3A5C] cursor-pointer hover:bg-gray-50 rounded-lg list-none flex justify-between items-center">
              Does high g-force damage algae cells?
              <span class="text-[#E8A317] font-bold text-lg ml-2">+</span>
            </summary>
            <div class="px-5 pb-4 pt-2 text-[#2D2D2D] text-sm leading-relaxed">
              No. The high g-force does not damage the algae cell structure. Industrial disc-stack centrifuges routinely harvest algae cells intact using forces exceeding 7,000 g's.
            </div>
          </details>
          <details class="border border-gray-200 rounded-lg">
            <summary class="px-5 py-4 font-semibold text-[#1B3A5C] cursor-pointer hover:bg-gray-50 rounded-lg list-none flex justify-between items-center">
              What material is used in algae harvesting centrifuges?
              <span class="text-[#E8A317] font-bold text-lg ml-2">+</span>
            </summary>
            <div class="px-5 pb-4 pt-2 text-[#2D2D2D] text-sm leading-relaxed">
              Industrial algae centrifuges primarily use all stainless steel for fluid contact surfaces. This corrosion-resistant material allows harvesting of saltwater algae on a commercial scale. An all-stainless steel (food grade) centrifuge is recommended for algae cultivated in seawater.
            </div>
          </details>
          <details class="border border-gray-200 rounded-lg">
            <summary class="px-5 py-4 font-semibold text-[#1B3A5C] cursor-pointer hover:bg-gray-50 rounded-lg list-none flex justify-between items-center">
              Can algae centrifuges process seaweed or kelp?
              <span class="text-[#E8A317] font-bold text-lg ml-2">+</span>
            </summary>
            <div class="px-5 pb-4 pt-2 text-[#2D2D2D] text-sm leading-relaxed">
              Yes. Kelp or seaweed separation, humic fertilizer separation, and other similar biomass extraction processes are well suited for the stainless steel disc-stack centrifuge. Dolphin Centrifuge has supplied Alfa Laval stainless steel disc-stack centrifuges for processing kelp for organic fertilizer production.
            </div>
          </details>
