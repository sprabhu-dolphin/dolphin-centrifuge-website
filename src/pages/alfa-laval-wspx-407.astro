---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const faqItems = [
  {
    question: "What is the rated capacity of the Alfa Laval WSPX 407?",
    answer: "The WSPX 407 TGD is rated at 25 GPM. The centrifuge bowl spins at 8,500 RPM generating over 7,000 G-Force, enabling efficient separation of tramp oil and sub-micron metal fines from water-based machining coolants and wash liquids."
  },
  {
    question: "What is the DMPX-042C module that Dolphin Centrifuge supplies?",
    answer: "The DMPX-042C is Dolphin Centrifuge's complete coolant centrifuge module built around the Alfa Laval WSPX 407. It includes the centrifuge, controls, pump, and skid — configured for continuous coolant processing at 25 GPM. Dolphin Centrifuge supplies, services, and rebuilds the DMPX-042C for industrial customers across North America."
  },
  {
    question: "What applications is the WSPX 407 used for?",
    answer: "The WSPX 407 is a 3-phase separator used for cleaning water-based machining coolants, wash liquids, and de-oiling of washer fluids. Common applications include automotive machining, aerospace part manufacturing, and precision grinding facilities where continuous tramp oil and particle removal is required."
  },
  {
    question: "How does the WSPX 407 differ from the WSPX 307?",
    answer: "The WSPX 407 (25 GPM, 8,500 RPM) is the upgraded successor to the WSPX 307 (22 GPM, 8,600 RPM). The WSPX 407 offers slightly higher capacity while maintaining the same compact form factor and all stainless steel wetted surface design suited for corrosive coolant applications."
  },
  {
    question: "Can Dolphin Centrifuge supply parts or rebuild the WSPX 407?",
    answer: "Yes. Dolphin Centrifuge supplies genuine and compatible replacement parts for the WSPX 407, including disc stacks, seals, bearings, and discharge valve components. Complete bowl rebuilds and remanufactured WSPX 407 centrifuges are available. Contact us for parts availability and service scheduling."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval WSPX 407 TGD Self-Cleaning Coolant Centrifuge",
  "description": "Alfa Laval WSPX 407 TGD 3-phase self-cleaning disc centrifuge rated at 25 GPM for industrial coolant, wash liquid, and cutting oil recovery. 8,500 RPM, 7,000+ G-Force.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/alfa-laval-wspx-407/",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Alfa Laval WSPX 407 Self-Cleaning Coolant Centrifuge",
  "description": "Technical overview of the Alfa Laval WSPX 407 TGD self-cleaning 3-phase disc centrifuge for machine coolant recovery, wash liquid purification, and washer fluid deoiling.",
  "author": {
    "@type": "Person",
    "name": "Dolphin Centrifuge Engineering",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  },
  "url": "https://dolphincentrifuge.com/alfa-laval-wspx-407/"
};

const jsonLd = [productJsonLd, faqJsonLd, articleJsonLd];

const toc = [
  { id: 'overview', label: 'WSPX 407 Operation' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'applications', label: 'Applications' },
  { id: 'wspx-series', label: 'WSPX Series Overview' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedApplications = [
  { label: 'Machine Coolant Centrifuge', href: '/machine-coolant-centrifuge/' },
  { label: 'Cutting Oil Centrifuge', href: '/cutting-oil-centrifuge/' },
];

const relatedProducts = [
  { label: 'WSPX 207 Centrifuge', href: '/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/', description: 'Entry-level WSPX coolant centrifuge' },
  { label: 'WSPX 303 Centrifuge', href: '/alfa-laval-wspx-303-centrifuge/', description: 'Mid-range WSPX coolant centrifuge' },
  { label: 'WSPX 307 Centrifuge', href: '/alfa-laval-wspx-307/', description: 'Higher-capacity WSPX model' },
];
---

<ApplicationLayout
  title="Alfa Laval WSPX 407 Coolant Centrifuge | Dolphin"
  description="Alfa Laval WSPX 407 TGD 3-phase self-cleaning disc centrifuge rated at 25 GPM, 8,500 RPM, 7,000+ G-Force for coolant and wash fluid recovery. Parts, repairs, and remanufactured units from Dolphin Centrifuge."
  category="products"
  categoryLabel="Products"
  heroImage="/images/alfa-laval-wspx-407/Alfa-Laval-WSPX-407-machine-coolant-centrifuge.webp"
  heroImageAlt="Alfa Laval WSPX 407 machine coolant centrifuge for tramp oil removal"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-wspx-407/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="bg-navy/5 border-l-4 border-gold/40 rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies parts, repairs, and remanufactured Alfa Laval WSPX 407 TGD 3-phase self-cleaning disc stack centrifuges rated at 25 GPM, spinning at 8,500 RPM with over 7,000 G-Force. Available as the DMPX-042C module for continuous tramp oil and particle removal from machining coolants, wash liquids, and washer fluids. Warren, Michigan — over 40 years of experience.</p>
  </div>

  <h2 id="overview">WSPX 407 Operation</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-1/2">
      <p>
        The Alfa Laval WSPX 407 TGD is a 3-phase <a href="/disc-stack-centrifuge/">disc stack centrifuge</a> designed to separate tramp oil and small particles from machine coolant. The centrifuge bowl rotates at 8,500 RPM, exerting over 7,000 G-Force for efficient separation of contaminants from <a href="/machine-coolant-centrifuge/">water-based machining coolants</a> and wash liquids.
      </p>
      <p>
        Rated at 25 GPM, the WSPX 407 is ideal for cleaning wash liquids, water-based machining coolants, and de-oiling of washer fluids in automotive, aerospace, and precision machining facilities. The self-cleaning bowl has 0.87 gallons of sludge space.
      </p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/alfa-laval-wspx-407/Alfa-Laval-WSPX-407-machine-coolant-centrifuge.webp"
        alt="Alfa Laval WSPX 407 machine coolant centrifuge"
        width="350"
        height="350"
        loading="lazy"
        class="rounded-lg w-full"
      />
    </div>
  </div>

  <p>
    Its automatic sludge discharge cycle ejects solids on a programmable timer without stopping fluid flow, making it compatible with 24/7 production schedules. The 10 HP motor drives the bowl at full separation speed continuously. For ongoing maintenance, Dolphin Centrifuge offers full <a href="/industrial-disc-centrifuge-repair/">centrifuge repair and rebuild services</a> for the WSPX series.
  </p>

  <div class="bg-gold/10 border-l-4 border-gold rounded-r-xl p-5 my-8 not-prose">
    <p class="text-base font-semibold text-navy mb-1">Need parts, repairs, or a remanufactured WSPX 407?</p>
    <p class="text-sm text-text-light mb-3">Dolphin Centrifuge can model your coolant system flow requirements to confirm the right WSPX selection. We offer <a href="/industrial-centrifuge-sample-testing/" class="text-navy font-semibold hover:text-gold">free sample testing</a> to validate separation performance before purchase, plus complete rebuild services to keep your WSPX at peak efficiency.</p>
    <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold hover:bg-gold/80 text-navy font-bold px-6 py-2 rounded-lg transition-colors text-sm">Request a Quote &rarr;</a>
  </div>

  <h2 id="specifications">WSPX 407 Specifications</h2>

  <table>
    <tbody>
      <tr><td><strong>Model Type</strong></td><td>Alfa Laval WSPX 407 TGD</td></tr>
      <tr><td><strong>Rated Capacity</strong></td><td>25 GPM</td></tr>
      <tr><td><strong>Bowl Speed</strong></td><td>8,500 RPM</td></tr>
      <tr><td><strong>G-Force</strong></td><td>7,000+</td></tr>
      <tr><td><strong>Sludge Space</strong></td><td>0.87 Gallons</td></tr>
      <tr><td><strong>Motor HP</strong></td><td>10 HP</td></tr>
      <tr><td><strong>Bowl Type</strong></td><td>Self-Cleaning (Automatic Discharge)</td></tr>
      <tr><td><strong>Separation Type</strong></td><td>3-Phase (Liquid-Liquid-Solid)</td></tr>
      <tr><td><strong>Voltages</strong></td><td>230 / 460 V</td></tr>
    </tbody>
  </table>

  <h2 id="applications">Applications</h2>

  <div class="grid md:grid-cols-2 gap-x-8 gap-y-2 mb-8 not-prose">
    <ul class="text-text-light space-y-2">
      <li>&#8226; <a href="/machine-coolant-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Water-based machining coolant cleaning</a></li>
      <li>&#8226; Wash liquid purification and recovery</li>
      <li>&#8226; De-oiling of washer fluids</li>
      <li>&#8226; Automotive engine and transmission machining</li>
    </ul>
    <ul class="text-text-light space-y-2">
      <li>&#8226; <a href="/cutting-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Cutting fluid purification</a></li>
      <li>&#8226; Aerospace structural part machining</li>
      <li>&#8226; Tramp oil removal — continuous duty</li>
      <li>&#8226; Metal fines and particle separation</li>
    </ul>
  </div>

  <h2 id="wspx-series">WSPX Series Overview</h2>

  <p>
    The WSPX series includes models for a range of coolant system capacities. The <a href="/alfa-laval-wspx-307/">WSPX 307</a> is the next model down in the series. For smaller installations, see the <a href="/alfa-laval-wspx-303-centrifuge/">WSPX 303</a> and <a href="/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/">WSPX 207</a>. Dolphin Centrifuge can model your system flow requirements to confirm the right WSPX selection. For ongoing maintenance, our <a href="/industrial-disc-centrifuge-repair/">centrifuge repair and rebuild services</a> keep WSPX units running at peak efficiency.
  </p>

  <div class="grid md:grid-cols-4 gap-4 mb-8 not-prose">
    <div class="bg-white rounded-xl p-5 border border-gray-200">
      <h3 class="text-base font-bold text-navy mb-1"><a href="/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/" class="text-navy hover:text-gold transition-colors">WSPX 207</a></h3>
      <p class="text-sm text-text-light">Entry-level WSPX — 20 GPM</p>
    </div>
    <div class="bg-white rounded-xl p-5 border border-gray-200">
      <h3 class="text-base font-bold text-navy mb-1"><a href="/alfa-laval-wspx-303-centrifuge/" class="text-navy hover:text-gold transition-colors">WSPX 303</a></h3>
      <p class="text-sm text-text-light">Mid-range WSPX — 8 GPM</p>
    </div>
    <div class="bg-white rounded-xl p-5 border border-gray-200">
      <h3 class="text-base font-bold text-navy mb-1"><a href="/alfa-laval-wspx-307/" class="text-navy hover:text-gold transition-colors">WSPX 307</a></h3>
      <p class="text-sm text-text-light">Higher-capacity — 22 GPM</p>
    </div>
    <div class="bg-white rounded-xl p-5 border-2 border-gold">
      <h3 class="text-base font-bold text-navy mb-1">WSPX 407</h3>
      <p class="text-sm text-text-light">Highest capacity — 25 GPM</p>
    </div>
  </div>

  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What is the rated capacity of the Alfa Laval WSPX 407?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The WSPX 407 TGD is rated at 25 GPM. The centrifuge bowl spins at 8,500 RPM generating over 7,000 G-Force, enabling efficient separation of tramp oil and sub-micron metal fines from water-based machining coolants and wash liquids.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What is the DMPX-042C module that Dolphin Centrifuge supplies?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The DMPX-042C is Dolphin Centrifuge's complete coolant centrifuge module built around the Alfa Laval WSPX 407. It includes the centrifuge, controls, pump, and skid — configured for continuous coolant processing at 25 GPM. Dolphin Centrifuge supplies, services, and rebuilds the DMPX-042C for industrial customers across North America.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What applications is the WSPX 407 used for?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The WSPX 407 is a 3-phase separator used for cleaning water-based machining coolants, wash liquids, and de-oiling of washer fluids. Common applications include automotive machining, aerospace part manufacturing, and precision grinding facilities where continuous tramp oil and particle removal is required.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      How does the WSPX 407 differ from the WSPX 307?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The WSPX 407 (25 GPM, 8,500 RPM) is the upgraded successor to the WSPX 307 (22 GPM, 8,600 RPM). The WSPX 407 offers slightly higher capacity while maintaining the same compact form factor and all stainless steel wetted surface design suited for corrosive coolant applications.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      Can Dolphin Centrifuge supply parts or rebuild the WSPX 407?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">Yes. Dolphin Centrifuge supplies genuine and compatible replacement parts for the WSPX 407, including disc stacks, seals, bearings, and discharge valve components. Complete bowl rebuilds and remanufactured WSPX 407 centrifuges are available. Contact us for parts availability and service scheduling.</p>
  </details>

  <div class="bg-navy rounded-xl p-8 text-center mt-12 not-prose">
    <h2 class="text-2xl font-bold text-white mb-3">Parts, Repairs &amp; Remanufactured WSPX 407</h2>
    <p class="text-gray-300 mb-6 max-w-lg mx-auto">Contact Dolphin Centrifuge for pricing, system design, and application review. Free sample testing available for qualifying applications.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold/80 text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Quote</a>
      <a href="/industrial-centrifuge-sample-testing/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">Free Sample Testing</a>
      <a href="tel:2485222573" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">(248) 522-2573</a>
    </div>
  </div>

</ApplicationLayout>
