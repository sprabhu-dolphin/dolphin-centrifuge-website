const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Disc Centrifuge Bad Separation: 6 Causes & Diagnosis Guide",
  "description": "6 causes of disc centrifuge poor separation: wrong gravity disc, low temperature, excess feed rate, fouled discs, ejection timing, and emulsification.",
  "author": { "@type": "Person", "name": "Sanjay Prabhu MSME", "jobTitle": "Engineering Manager", "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" } },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "datePublished": "2021-01-01",
  "url": "https://dolphincentrifuge.com/disc-stack-centrifuge-bad-separation/",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Why is my disc stack centrifuge not separating properly?",
      "acceptedAnswer": { "@type": "Answer", "text": "Poor separation in a disc stack centrifuge is typically caused by one or more of: wrong gravity disc size (incorrect back pressure), process fluid temperature too low (high viscosity), feed flow rate exceeding rated capacity, fouled or clogged disc stack, incorrect sludge ejection timing causing sludge carryover, or the presence of emulsifying agents in the fluid." }
    },
    {
      "@type": "Question",
      "name": "How does temperature affect disc centrifuge separation quality?",
      "acceptedAnswer": { "@type": "Answer", "text": "Higher temperature reduces fluid viscosity, which improves separation efficiency. Most industrial oils and hydrocarbons separate best at 60–90°C. Operating below the recommended temperature significantly reduces separation quality and throughput. Always verify the centrifuge feed temperature matches the application requirements." }
    },
    {
      "@type": "Question",
      "name": "Can the gravity disc cause bad separation in a disc centrifuge?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — the gravity disc is one of the most common causes of poor separation. If the gravity disc is undersized, back pressure is too low and the liquid interface moves outward, flooding the light phase outlet with heavy phase. If oversized, back pressure is too high and light phase spills into the heavy phase outlet. Select the gravity disc based on the density difference between the phases." }
    }
  ]
};
---

<BaseLayout
  title="Disc Centrifuge Bad Separation: Causes & Fixes | Dolphin Centrifuge"
  description="6 causes of disc centrifuge poor separation: wrong gravity disc, low temperature, excess feed rate, fouled discs, ejection timing, and emulsification."
  canonicalUrl="https://dolphincentrifuge.com/disc-stack-centrifuge-bad-separation/"
  breadcrumbs={[{label: 'Knowledge', href: '/disc-stack-centrifuge-faq/'}, {label: 'Poor Separation Quality'}]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">Knowledge Base</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">Disc Centrifuge Bad Separation: 6 Causes &amp; How to Fix Them</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">Poor separation quality from a disc stack centrifuge is almost always traceable to one of six root causes. This guide walks through each cause with practical diagnosis steps and corrective actions.</p>
      <div class="flex flex-wrap gap-3 mt-6">
            <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] hover:bg-yellow-500 text-white font-semibold px-6 py-3 rounded-lg transition">Request a Quote</a>
            <a href="tel:+12485222573" class="border border-white/70 text-white hover:bg-white hover:text-[#1B3A5C] font-semibold px-6 py-3 rounded-lg transition">(248) 522-2573</a>
          </div>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-4xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge specializes in diagnosing and correcting disc stack centrifuge separation problems — including poor oil-water separation, solids carryover, water in the oil phase, and emulsion formation. Operating at up to 8,000 Gs, disc stack centrifuges will consistently produce clean output when operating parameters match design specifications. When separation degrades, it is almost always a correctable operating condition. Dolphin Centrifuge provides troubleshooting support, parts, and service for all Alfa Laval and industrial disc centrifuge models. Based in Warren, Michigan, with over 40 years of centrifuge experience.</p>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 p-6 mb-10 shadow-sm">
        <img src="/images/disc-stack-centrifuge-bad-separation/disc-centrifuge-oil-water-interface-800.jpg" alt="Disc centrifuge oil-water interface diagram showing separation zones" width="800" height="266" loading="eager" class="rounded-lg w-full mb-4" />
        <p class="text-text-light leading-relaxed"><strong>Summary:</strong> A disc stack centrifuge operating correctly under the right conditions will consistently produce clean, well-separated output. When separation quality deteriorates &mdash; oil in the water phase, water or solids in the oil phase, or generally cloudy discharge &mdash; the cause is almost never a spontaneous machine failure. Instead, it is a change in one or more operating parameters that has moved the centrifuge outside its design envelope. This guide addresses all <a href="/disc-stack-centrifuge-applications/" class="text-navy font-semibold hover:text-gold transition-colors">major industrial centrifuge applications</a> including marine fuel cleaning, industrial oil purification, food-grade oil processing, and wastewater treatment.</p>
      </div>

      <!-- Flowchart intro -->
      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Diagnosis Flowchart Approach</h2>
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-8">
        <p class="text-text-light mb-3">Before investigating individual causes, answer these three questions to direct your diagnosis:</p>
        <ol class="space-y-2 text-text-light list-decimal list-inside ml-2">
          <li><strong class="text-navy">When did separation quality change?</strong> Sudden change suggests a process or settings change. Gradual decline over weeks suggests wear or buildup.</li>
          <li><strong class="text-navy">What changed recently?</strong> New product batch, different oil viscosity or density, changed feed rate, maintenance performed, or ambient temperature change — any of these can shift separation quality significantly.</li>
          <li><strong class="text-navy">Which phase is contaminated?</strong> Water/heavy phase contaminated with oil points to a different cause than oil/light phase contaminated with water or solids.</li>
        </ol>
      </div>

      <!-- Cause 1 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">1</span>
          <h2 class="text-xl font-bold text-navy">Incorrect Gravity Disc (Interface Control)</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p><strong class="text-navy">What a gravity disc does:</strong> In purifier-type disc centrifuges (which separate oil from water), the gravity disc (also called the interface ring or regulating ring) sets the radial position of the liquid interface inside the bowl. Its inner diameter is selected based on the specific gravity of the oil being processed. If the gravity disc diameter is too large or too small for the actual oil density, the interface moves out of the optimal zone and separation quality suffers.</p>
          <p><strong class="text-navy">Symptoms:</strong> Separation was good on a previous batch but is now poor on a new batch. Water content in the oil phase is high. Oil is appearing in the water discharge (carry-over). The problem appeared after a product change, not after maintenance.</p>
          <p><strong class="text-navy">Diagnosis:</strong> Check the specific gravity of the current process fluid against the gravity disc selection chart in the machine manual. If processing a new oil grade or batch with different density characteristics, the gravity disc may need to change. Measure oil specific gravity at operating temperature with a hydrometer or density meter.</p>
          <p><strong class="text-navy">Fix:</strong> Select the correct gravity disc for the measured specific gravity. Most machines come with a set of gravity discs covering a range of densities. Trial and error with adjacent sizes (one size larger or smaller than current) is acceptable and safe. Document the correct gravity disc selection for each product to avoid this issue on future batch changes.</p>
          <img src="/images/disc-stack-centrifuge-bad-separation/disc-centrifuge-oil-water-interface-400.jpg" alt="Disc centrifuge oil-water interface position diagram showing effect of gravity disc selection" width="400" height="133" loading="lazy" class="rounded-lg w-full mt-4" />
        </div>
      </div>

      <!-- Cause 2 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">2</span>
          <h2 class="text-xl font-bold text-navy">Wrong Feed Rate (Over-Feeding)</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p><strong class="text-navy">Failure mode:</strong> Every disc centrifuge has a maximum rated throughput (flow rate) for a given application. When the feed rate exceeds the machine's processing capacity, the residence time of fluid in the disc stack decreases below the minimum required for effective separation. Solids and droplets that would normally settle and be captured are carried through with the product.</p>
          <p><strong class="text-navy">Symptoms:</strong> Separation quality degrades when throughput is increased. Quality improves when flow rate is reduced. Output becomes turbid or shows visible contamination. The machine runs without any mechanical fault indication.</p>
          <p><strong class="text-navy">Diagnosis:</strong> Measure actual feed flow rate and compare against the rated capacity for the specific fluid and application. Note that rated capacity varies with fluid viscosity &mdash; a machine rated at 1,000 L/hr for light mineral oil may only handle 400 L/hr effectively for a heavier, more viscous fluid.</p>
          <p><strong class="text-navy">Fix:</strong> Reduce feed rate to within the rated capacity. If throughput requirements have increased beyond the machine's capacity, consider adding a second centrifuge in parallel or upgrading to a larger model. <a href="/industrial-centrifuge-sample-testing/" class="text-navy font-semibold hover:text-gold transition-colors">Dolphin Centrifuge's sample testing service</a> can verify the achievable throughput for your specific fluid.</p>
        </div>
      </div>

      <!-- Cause 3 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">3</span>
          <h2 class="text-xl font-bold text-navy">Process Temperature Too Low</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p><strong class="text-navy">Failure mode:</strong> Centrifugal separation efficiency depends on the density difference between the phases being separated and on the viscosity of the continuous phase. Both are strongly temperature-dependent. At lower temperatures, oil viscosity increases significantly, droplet rise velocity decreases, and separation becomes dramatically less effective. Water in cold oil is particularly difficult to separate because the oil's high viscosity impedes water droplet movement toward the bowl wall.</p>
          <p><strong class="text-navy">Symptoms:</strong> Separation quality is good in summer or warm conditions but deteriorates in winter or after the heater is turned off. Water content in the oil phase increases. Problem correlates directly with feed temperature.</p>
          <p><strong class="text-navy">Diagnosis:</strong> Measure actual feed temperature at the centrifuge inlet and compare against the recommended operating temperature in the machine manual. For fuel oils and lubricating oils, 60&ndash;95&deg;C (140&ndash;203&deg;F) is typically required. For vegetable oils, 60&ndash;75&deg;C. For light mineral oils, 50&ndash;70&deg;C.</p>
          <p><strong class="text-navy">Fix:</strong> Restore feed temperature to the recommended range. Check the feed heater (steam or electric) for correct operation. Inspect for scaling or fouling inside the heater that reduces heat transfer. Insulate feed piping to prevent heat loss between the heater and the centrifuge. Do not process cold, thick oils through the centrifuge &mdash; this is both ineffective and potentially damaging to the disc stack.</p>
          <img src="/images/disc-stack-centrifuge-bad-separation/oil-viscosity-vs-temperature-400.jpg" alt="Oil viscosity versus temperature chart showing how lower temperatures dramatically increase viscosity and reduce centrifuge separation efficiency" width="400" height="256" loading="lazy" class="rounded-lg w-full mt-4" />
        </div>
      </div>

      <!-- Cause 4 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">4</span>
          <h2 class="text-xl font-bold text-navy">Worn or Fouled Disc Stack</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p><strong class="text-navy">Failure mode:</strong> The disc stack is the heart of a disc centrifuge's separation capability. Each disc provides additional laminar separation surface area. When discs are fouled with scale, organic deposits, or wax, the effective separation area is reduced and separation efficiency drops. Physically worn or damaged discs (warped, corroded, or cracked) disrupt the laminar flow pattern inside the disc stack, reducing separation quality directly.</p>
          <p><strong class="text-navy">Symptoms:</strong> Gradual decline in separation quality over months. Quality does not improve when other parameters (temperature, flow rate, gravity disc) are corrected. Machine history shows long intervals since last disc cleaning.</p>
          <p><strong class="text-navy">Diagnosis:</strong> Disassemble and inspect the disc stack. Deposits on the disc surfaces will be visible. Check for discs that are warped (will not lie flat), corroded (pitting or edge attack), or cracked. Count the discs and compare against the required disc count in the manual.</p>
          <p><strong class="text-navy">Fix:</strong> Clean discs using appropriate solvents or cleaning chemicals for the deposit type (alkaline cleaner for organic deposits, acid cleaner for mineral scale). Replace damaged discs. Ensure all discs are correct for the machine &mdash; using discs of the wrong angle, diameter, or thickness reduces separation efficiency. <a href="/contact-for-alfa-laval-centrifuges/" class="text-navy font-semibold hover:text-gold transition-colors">Dolphin Centrifuge supplies correct replacement disc sets for all major models</a>.</p>
        </div>
      </div>

      <!-- Cause 5 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">5</span>
          <h2 class="text-xl font-bold text-navy">Incorrect Ejection Timing (Over- or Under-Ejecting)</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p><strong class="text-navy">Failure mode (under-ejecting):</strong> If sludge ejection intervals are too long, the sludge space in the bowl fills up completely. Excess solids begin to compact and overflow into the disc stack, reducing effective separation volume and fouling the discs. Separation quality declines progressively between ejections and partially recovers immediately after each ejection.</p>
          <p><strong class="text-navy">Failure mode (over-ejecting):</strong> If ejections are too frequent or the ejection volume is too large (total ejection), excessive product is lost with each discharge, and the liquid seal may be disturbed, allowing air ingress. Separation quality is inconsistent, with good quality interrupted by poor quality immediately after each ejection event.</p>
          <p><strong class="text-navy">Diagnosis:</strong> Monitor separation quality over time relative to the ejection cycle. Quality that declines between ejections then recovers indicates under-ejection. Quality that shows a sudden drop immediately after ejection and gradually improves indicates over-ejection or liquid seal disturbance.</p>
          <img src="/images/disc-stack-centrifuge-bad-separation/disc-centrifuge-sludge-space-400.jpg" alt="Disc centrifuge bowl cross-section showing sludge holding space capacity and ejection mechanism" width="400" height="180" loading="lazy" class="rounded-lg w-full my-4" />
          <p><strong class="text-navy">Fix:</strong> Adjust ejection intervals to match the actual solids load in the feed. See the <a href="/disc-stack-centrifuge-sludge-ejection-cycle-time/" class="text-navy font-semibold hover:text-gold transition-colors">sludge ejection cycle timing guide</a> for a systematic approach to setting optimal intervals. For variable feed solids content, consider turbidity-based automatic ejection control rather than timer-based control.</p>
        </div>
      </div>

      <!-- Cause 6 -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold text-navy font-bold w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-sm">6</span>
          <h2 class="text-xl font-bold text-navy">Feed Contamination or Emulsification</h2>
        </div>
        <div class="space-y-3 text-text-light">
          <p><strong class="text-navy">Failure mode:</strong> Disc centrifuges are designed to separate mechanical mixtures (droplets and particles suspended in a continuous phase). When the feed contains emulsifying agents &mdash; surfactants, detergents, soaps, or bio-emulsifiers &mdash; the oil and water form a stable emulsion that centrifugal force alone cannot break. No adjustment of centrifuge settings will resolve this; the emulsification must be addressed at the source.</p>
          <p><strong class="text-navy">Symptoms:</strong> Persistent poor separation despite correct temperature, gravity disc, flow rate, and a clean disc stack. The output is a stable emulsion rather than distinct oil and water phases. A simple bottle test (placing a sample in a clear bottle and allowing it to settle) shows little or no phase separation after 30 minutes at temperature.</p>
          <p><strong class="text-navy">Common emulsifiers found in centrifuge feeds:</strong></p>
          <ul class="list-disc list-inside space-y-1 ml-2">
            <li>Detergent-contaminated fuel (from tank cleaning operations)</li>
            <li>Biodegraded oil (bacterial activity produces natural surfactants)</li>
            <li>Demulsifier overdose (paradoxically, excess demulsifier can re-stabilize an emulsion)</li>
            <li>Excessive agitation of the feed before entry to the centrifuge</li>
            <li>Alkaline process water contamination in lube oil service</li>
          </ul>
          <p><strong class="text-navy">Fix:</strong> Identify and eliminate the emulsification source. For biodegraded or contaminated batches, adding the correct dosage of a compatible demulsifier chemical upstream of the centrifuge can restore separability. Adjust demulsifier dose carefully &mdash; the correct dose must be determined by trial on a small sample before treating the full batch. <a href="/industrial-centrifuge-sample-testing/" class="text-navy font-semibold hover:text-gold transition-colors">Submit a sample to Dolphin Centrifuge's testing lab</a> to evaluate treatability before processing a difficult batch.</p>
        </div>
      </div>

      <!-- Summary table -->
      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-6">Quick Reference: Symptom to Cause</h2>
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-8 overflow-x-auto">
        <table class="w-full text-sm text-text-light">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="text-left text-navy font-bold pb-3 pr-4">Symptom</th>
              <th class="text-left text-navy font-bold pb-3">Most Likely Cause</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr><td class="py-2 pr-4">Water in oil after product change</td><td class="py-2">Wrong gravity disc</td></tr>
            <tr><td class="py-2 pr-4">Poor quality increases with throughput</td><td class="py-2">Over-feeding (excess flow rate)</td></tr>
            <tr><td class="py-2 pr-4">Seasonal or post-heater-failure decline</td><td class="py-2">Feed temperature too low</td></tr>
            <tr><td class="py-2 pr-4">Gradual decline over months</td><td class="py-2">Fouled or worn disc stack</td></tr>
            <tr><td class="py-2 pr-4">Cyclic quality with ejection timing</td><td class="py-2">Incorrect ejection interval</td></tr>
            <tr><td class="py-2 pr-4">Persistent poor quality, nothing else explains it</td><td class="py-2">Feed emulsification</td></tr>
          </tbody>
        </table>
      </div>

      <p class="text-text-light leading-relaxed mb-6">If separation quality problems persist after working through this guide, contact Dolphin Centrifuge for a process review. We can evaluate your fluid, machine configuration, and operating parameters to identify the root cause. Call <a href="tel:+12485222573" class="text-navy font-semibold hover:text-gold transition-colors">(248) 522-2573</a> or email <a href="mailto:sales@dolphincentrifuge.com" class="text-navy font-semibold hover:text-gold transition-colors">sales@dolphincentrifuge.com</a>.</p>

      <!-- FAQ -->
      <div id="faq" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mt-10 mb-6">
        <h2 class="text-xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">Why is my disc stack centrifuge not separating properly?</h3>
            <p class="text-text-light text-sm">Poor separation is typically caused by: wrong gravity disc size (incorrect back pressure), process fluid temperature too low (high viscosity), feed flow rate exceeding rated capacity, fouled or clogged disc stack, incorrect sludge ejection timing, or emulsifying agents in the fluid.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">How does temperature affect disc centrifuge separation quality?</h3>
            <p class="text-text-light text-sm">Higher temperature reduces fluid viscosity and improves separation efficiency. Most industrial oils separate best at 60–90°C. Operating below the recommended temperature significantly reduces separation quality and throughput. Always verify the centrifuge feed temperature matches application requirements.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">Can the gravity disc cause bad separation in a disc centrifuge?</h3>
            <p class="text-text-light text-sm">Yes — the gravity disc is one of the most common causes of poor separation. If undersized, back pressure is too low and the liquid interface floods the light phase outlet with heavy phase. If oversized, back pressure is too high and light phase spills into the heavy phase outlet. Select the gravity disc based on density difference between the phases.</p>
          </div>
        </div>
      </div>
      <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

      <!-- Related Articles -->
      <div class="mt-10">
        <h2 class="text-xl font-bold text-navy mb-4">Related Articles</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a href="/disc-stack-centrifuge-troubleshooting-bowl-leaking/" class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm hover:border-gold transition-colors">
