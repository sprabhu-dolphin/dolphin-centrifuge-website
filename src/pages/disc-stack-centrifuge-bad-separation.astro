      <div class="flex flex-wrap justify-center gap-3">
        <a href="/industrial-centrifuge-sample-testing/" class="inline-flex items-center gap-2 bg-gold hover:bg-yellow-500 text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Send Us Your Sample</a>
