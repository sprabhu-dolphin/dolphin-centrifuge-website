---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const title = "Centrifuge Guides — Setup, Operation & Optimization";
const description = "Step-by-step guides for selecting, installing, operating, and optimizing industrial disc stack and decanter centrifuges. Expert advice from Dolphin Centrifuge.";

const faqItems = [
  {
    question: "What centrifuge setup and installation guides does Dolphin Centrifuge publish?",
    answer: "Dolphin Centrifuge publishes a complete installation guide covering foundation requirements, piping connections, electrical hookup, and commissioning procedures for disc stack centrifuges. Additional guides cover gravity disc selection, operating water settings, and first-run startup checklist items based on 40+ years of field experience."
  },
  {
    question: "How do I optimize sludge ejection cycle timing on a disc stack centrifuge?",
    answer: "Sludge ejection cycle timing depends on solids loading in the feed, the centrifuge bowl volume, and the desired separation quality. Ejecting too frequently wastes product; too infrequently causes bowl overflow and liquid contamination. Our sludge ejection cycle guide covers timing calculation, operating water requirements, and adjustment procedures for both timer-based and turbidity-triggered discharge systems."
  },
  {
    question: "What is the difference between rated and actual centrifuge capacity?",
    answer: "Rated capacity is measured under ideal conditions with low-viscosity, low-solids fluid. Actual capacity depends on feed viscosity, temperature, solids content, separation difficulty, and gravity disc selection. Real-world throughput is typically 50–80% of rated capacity for viscous or high-solids applications. Our capacity guide explains these factors and how to set realistic throughput expectations."
  },
  {
    question: "How do I select the correct gravity disc for my disc stack centrifuge?",
    answer: "Gravity disc selection determines the oil/water interface position inside the bowl. The correct gravity disc size depends on the density difference between the two liquid phases and the desired separation endpoint. Too large a gravity disc causes water carryover into the oil outlet; too small causes oil loss in the water discharge. Our selection guide covers the gravity disc calculation method and trial procedure."
  },
  {
    question: "Where can I find a complete illustrated guide to disc centrifuge parts?",
    answer: "Our Disc Centrifuge Parts Glossary provides an illustrated reference to every major component — bowl, disc stack, distributor, paring disc, gravity disc, spindle, operating slide, horizontal and vertical drive, and more. Each component includes its function, typical failure modes, and maintenance interval. Access it at /disc-centrifuge-parts-glossary/."
  }
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer.replace(/<[^>]*>/g, '') }
  }))
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Centrifuge Guides & How-To — Setup, Operation & Optimization",
  "description": description,
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/knowledge-guides/",
  "mainEntityOfPage": "https://dolphincentrifuge.com/knowledge-guides/"
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Centrifuge Guides & How-To",
  "description": description,
  "url": "https://dolphincentrifuge.com/knowledge-guides/",
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "email": "sales@dolphincentrifuge.com",
  },
};

const toc = [
  { id: "setup-operation-optimization", label: "Setup, Operation & Optimization Guides" },
  { id: "disc-stack-guides", label: "Disc Stack Centrifuge Guides" },
  { id: "decanter-guides", label: "Decanter Centrifuge Guides" },
  { id: "explore-other-categories", label: "Explore Other Knowledge Categories" },
];

const articles = [
  {
    title: "9 Steps to Picking the Right Centrifuge",
    href: "/picking-the-right-industrial-centrifuge/",
    description: "A systematic guide to selecting the right industrial centrifuge for your application — covering fluid properties, throughput, separation goals, and budget.",
    tag: "Start Here",
  },
  {
    title: "Centrifuge Selection Guide",
    href: "/alfa-laval-centrifuge-selection-guide/",
    description: "Comprehensive guide to choosing between disc stack and decanter centrifuges based on your specific process requirements and fluid characteristics.",
  },
  {
    title: "Disc Centrifuge Parts Glossary (Illustrated)",
    href: "/disc-centrifuge-parts-glossary/",
    description: "Visual reference guide to every major component in a disc stack centrifuge — bowl, disc stack, paring disc, gravity disc, spindle, and more.",
  },
  {
    title: "Installation Guide",
    href: "/disc-stack-centrifuge-installation/",
    description: "Best practices for installing a disc stack centrifuge system — foundation requirements, piping connections, electrical hookup, and commissioning.",
  },
  {
    title: "Lubrication Guide",
    href: "/disc-stack-centrifuge-lubrication/",
    description: "Proper lubrication practices for disc stack centrifuges — oil types, change intervals, bearing greasing, and common lubrication mistakes to avoid.",
  },
  {
    title: "Operating Water — 7 Key Factors",
    href: "/disc-stack-centrifuge-operating-water/",
    description: "Everything you need to know about operating water for self-cleaning disc stack centrifuges — pressure, flow, quality, and timing requirements.",
  },
  {
    title: "Sludge Ejection Cycle Timing",
    href: "/disc-stack-centrifuge-sludge-ejection-cycle-time/",
    description: "How to optimize sludge discharge timing for maximum separation efficiency and minimum product loss during bowl ejections.",
  },
  {
    title: "Decanter Centrifuge Optimization",
    href: "/decanter-centrifuge-optimization/",
    description: "Advanced techniques for optimizing decanter centrifuge performance — differential speed, pond depth, feed rate, and polymer dosing adjustments.",
  },
  {
    title: "Increase Centrifuge Efficiency",
    href: "/disc-stack-centrifuge-efficiency/",
    description: "Practical strategies to improve disc stack centrifuge separation efficiency — temperature control, flow optimization, and maintenance best practices.",
  },
  {
    title: "Performance Factors",
    href: "/disc-stack-centrifuge-performance/",
    description: "The key variables that affect disc stack centrifuge performance — feed rate, temperature, viscosity, solids loading, and gravity disc selection.",
  },
  {
    title: "Rated vs Actual Capacity",
    href: "/disc-stack-centrifuge-capacity/",
    description: "Understanding the difference between rated and actual centrifuge throughput capacity — and the factors that determine real-world performance.",
  },
  {
    title: "Differential Speed (Decanter)",
    href: "/decanter-centrifuge-differential-speed/",
    description: "How differential speed between the bowl and scroll affects decanter centrifuge separation, cake dryness, and clarification performance.",
  },
  {
    title: "Pond Depth Effects (Decanter)",
    href: "/decanter-centrifuge-pond-depth/",
    description: "How pond depth settings affect decanter centrifuge performance — balancing clarification quality against cake dryness and throughput.",
  },
  {
    title: "Options & Alternatives",
    href: "/disc-stack-centrifuge-options/",
    description: "Overview of disc stack centrifuge configuration options — hermetic vs semi-open, solids-ejecting vs nozzle, and specialized bowl designs.",
  },
  {
    title: "Containerized Industrial Centrifuge",
    href: "/containerized-industrial-centrifuge/",
    description: "Complete guide to containerized centrifuge systems — advantages, applications, configuration options, and deployment considerations.",
  },
];

const discStackArticles = articles.filter(a =>
  !a.href.includes('decanter') && !a.href.includes('picking') && !a.href.includes('selection-guide') && !a.href.includes('containerized')
);
const decanterArticles = articles.filter(a => a.href.includes('decanter'));
const generalArticles = articles.filter(a =>
  a.href.includes('picking') || a.href.includes('selection-guide') || a.href.includes('containerized')
);
---

<ApplicationLayout
  title={title}
  description={description}
  canonicalUrl="https://dolphincentrifuge.com/knowledge-guides/"
  category="knowledge"
  categoryLabel="Knowledge Base"
  heroImage="/images/disc-stack-centrifuge/alfa-laval-disc-centrifuge-bowl-cross-section-400-1.webp"
  heroImageAlt="Alfa Laval disc centrifuge bowl cross-section showing internal disc stack and separation chamber"
  toc={[...toc, { id: "faq", label: "Frequently Asked Questions" }]}
  relatedApplications={[
    { label: "Waste Oil Centrifuge", href: "/waste-oil-centrifuge/" },
    { label: "Fuel Oil Centrifuge", href: "/fuel-oil-centrifuge/" },
  ]}
  relatedProducts={[
    { label: "DMPX-042 Disc Centrifuge", href: "/centrifuges/dmpx-042/" },
    { label: "DMPX-028 Disc Centrifuge", href: "/centrifuges/dmpx-028/" },
  ]}
  jsonLd={[jsonLd, articleJsonLd, faqJsonLd]}
>
  <article class="prose-dolphin max-w-none">
    <div class="not-prose bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-8">
      <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge publishes industrial centrifuge how-to guides covering setup, operation, optimization, and maintenance — including startup procedures, gravity disc selection, sludge ejection cycle optimization, feed rate adjustment, and lubrication schedules for Alfa Laval disc stack centrifuges.</p>
    </div>

    <h2 id="setup-operation-optimization">Setup, Operation & Optimization Guides</h2>
    <p>From selecting the right centrifuge to optimizing separation performance — these step-by-step guides are built on 40+ years of hands-on industrial centrifuge experience. Whether you need help with <a href="/disc-stack-centrifuge-installation/">installation</a>, <a href="/disc-stack-centrifuge-lubrication/">lubrication</a>, or <a href="/disc-stack-centrifuge-efficiency/">improving efficiency</a>, start here.</p>

    <div class="not-prose grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 my-8">
      {generalArticles.map((article) => (
        <a href={article.href} class="group bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg hover:border-blue-300/40 transition-all duration-300 overflow-hidden flex flex-col">
          <div class="relative h-32 bg-gradient-to-br from-blue-500/10 to-blue-600/5 flex items-center justify-center">
            <svg class="w-12 h-12 text-blue-400/30 group-hover:text-blue-400/50 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
            {article.tag && (
              <span class="absolute top-3 left-3 bg-gold text-navy text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">{article.tag}</span>
            )}
          </div>
          <div class="p-5 flex-1 flex flex-col">
            <h3 class="text-lg font-bold font-heading text-navy group-hover:text-blue-600 transition-colors mb-2">{article.title}</h3>
            <p class="text-sm text-text-light leading-relaxed flex-1">{article.description}</p>
            <div class="mt-4 flex items-center gap-1 text-gold font-semibold text-sm">
              Read Guide
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <h2 id="disc-stack-guides">Disc Stack Centrifuge Guides</h2>
    <p>In-depth technical guides for <a href="/disc-stack-centrifuge-options/">disc stack centrifuge</a> operation, maintenance, and performance optimization. These cover everything from parts identification to sludge ejection timing.</p>

    <div class="not-prose grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 my-8">
      {discStackArticles.map((article) => (
        <a href={article.href} class="group bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg hover:border-blue-300/40 transition-all duration-300 overflow-hidden flex flex-col">
          <div class="relative h-32 bg-gradient-to-br from-blue-500/10 to-blue-600/5 flex items-center justify-center">
            <svg class="w-12 h-12 text-blue-400/30 group-hover:text-blue-400/50 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <div class="p-5 flex-1 flex flex-col">
            <h3 class="text-lg font-bold font-heading text-navy group-hover:text-blue-600 transition-colors mb-2">{article.title}</h3>
            <p class="text-sm text-text-light leading-relaxed flex-1">{article.description}</p>
            <div class="mt-4 flex items-center gap-1 text-gold font-semibold text-sm">
              Read Guide
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <h2 id="decanter-guides">Decanter Centrifuge Guides</h2>
    <p>Specialized guides for <a href="/decanter-centrifuge-optimization/">decanter centrifuge optimization</a>, covering differential speed, pond depth, and performance tuning for solids-heavy applications.</p>

    <div class="not-prose grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 my-8">
      {decanterArticles.map((article) => (
        <a href={article.href} class="group bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg hover:border-blue-300/40 transition-all duration-300 overflow-hidden flex flex-col">
          <div class="relative h-32 bg-gradient-to-br from-blue-500/10 to-blue-600/5 flex items-center justify-center">
            <svg class="w-12 h-12 text-blue-400/30 group-hover:text-blue-400/50 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <div class="p-5 flex-1 flex flex-col">
            <h3 class="text-lg font-bold font-heading text-navy group-hover:text-blue-600 transition-colors mb-2">{article.title}</h3>
            <p class="text-sm text-text-light leading-relaxed flex-1">{article.description}</p>
            <div class="mt-4 flex items-center gap-1 text-gold font-semibold text-sm">
              Read Guide
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Mid-page CTA -->
    <div class="bg-gold/10 border-l-4 border-gold rounded-r-lg p-5 my-8 not-prose">
      <p class="text-navy font-bold text-lg mb-1">Have a specific centrifuge question?</p>
      <p class="text-text-light text-sm mb-3">Our engineers provide free application guidance and sample testing. Contact us directly for sizing, troubleshooting, or centrifuge selection advice.</p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold text-navy font-bold px-5 py-2.5 rounded-lg hover:bg-yellow-500 transition-colors text-sm">Get Expert Advice</a>
        <a href="/industrial-centrifuge-sample-testing/" class="inline-block border border-navy text-navy font-semibold px-5 py-2.5 rounded-lg hover:bg-navy/5 transition-colors text-sm">Free Sample Testing</a>
      </div>
    </div>

    <h2 id="explore-other-categories">Explore Other Knowledge Categories</h2>
    <p>Continue learning with our other knowledge resources. From <a href="/knowledge-troubleshooting/">troubleshooting guides</a> to <a href="/knowledge-comparisons/">centrifuge comparisons</a>, we cover every aspect of industrial centrifuge ownership.</p>

    <div class="not-prose grid grid-cols-2 md:grid-cols-4 gap-4 my-6">
      <a href="/knowledge-troubleshooting/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-red-300/40 hover:shadow-md transition-all">
        <div class="w-10 h-10 rounded-lg bg-red-50 text-red-500 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" /></svg>
        </div>
        <span class="text-sm font-bold text-navy group-hover:text-red-600 transition-colors">Troubleshooting</span>
      </a>
      <a href="/knowledge-comparisons/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-emerald-300/40 hover:shadow-md transition-all">
        <div class="w-10 h-10 rounded-lg bg-emerald-50 text-emerald-500 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z" /></svg>
        </div>
        <span class="text-sm font-bold text-navy group-hover:text-emerald-600 transition-colors">Comparisons</span>
      </a>
      <a href="/knowledge-product-brand/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-amber-300/40 hover:shadow-md transition-all">
        <div class="w-10 h-10 rounded-lg bg-amber-50 text-amber-500 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.991l1.004.827c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        </div>
        <span class="text-sm font-bold text-navy group-hover:text-amber-600 transition-colors">Product & Brand</span>
      </a>
      <a href="/knowledge-case-studies/" class="group flex items-center gap-3 bg-warm-white rounded-xl p-4 border border-gray-200 hover:border-purple-300/40 hover:shadow-md transition-all">
        <div class="w-10 h-10 rounded-lg bg-purple-50 text-purple-500 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
        </div>
        <span class="text-sm font-bold text-navy group-hover:text-purple-600 transition-colors">Case Studies & FAQ</span>
      </a>
    </div>

    <!-- FAQ Section -->
    <h2 id="faq" class="text-2xl font-bold text-navy font-heading mt-10 mb-4">Frequently Asked Questions</h2>
    <div class="not-prose space-y-3">
      {faqItems.map(item => (
        <details class="border-l-4 border-gold bg-white rounded-r-xl shadow-sm p-5">
          <summary class="font-semibold text-navy cursor-pointer list-none flex items-center gap-2">
            <span class="text-gold font-bold">+</span> {item.question}
          </summary>
          <p class="text-text-light mt-3 text-sm leading-relaxed">{item.answer}</p>
        </details>
      ))}
    </div>
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

