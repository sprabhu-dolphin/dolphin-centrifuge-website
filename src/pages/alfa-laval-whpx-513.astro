  <h3 id="fopx-613-specifications">Specifications</h3>

  <div class="not-prose overflow-x-auto border border-gray-100 rounded-xl">
    <table>
      <tbody>
        <tr><td>Model Type</td><td>Alfa Laval FOPX 613 TGD 24-60</td></tr>
