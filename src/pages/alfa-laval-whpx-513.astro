---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the rated capacity of the Alfa Laval WHPX 513?",
      "acceptedAnswer": { "@type": "Answer", "text": "The WHPX 513 is rated at 72 GPM on diesel fuel (13 cSt viscosity). On lighter fluids throughput can exceed 90+ GPM. On heavier fluids like intermediate fuel oil, throughput is reduced proportionally to viscosity. The WHPX 513 is powered by a 15 HP motor with a 3.87-gallon sludge space." }
    },
    {
      "@type": "Question",
      "name": "What is the difference between the WHPX 513 and the FOPX 613?",
      "acceptedAnswer": { "@type": "Answer", "text": "The WHPX 513 is a three-phase self-cleaning disc centrifuge suited for diesel, waste oil, and intermediate fuel oil. The FOPX 613 is a partial-discharge centrifuge specifically engineered for heavy fuel oil (HFO) processing at 380 cSt viscosity, rated at 30 GPM on bunker fuel. Choose the FOPX 613 when processing heavy bunker fuel with high wax content." }
    },
    {
      "@type": "Question",
      "name": "Is the WHPX 513 available in explosion-proof configuration?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. The WHPX 513 is available with explosion-proof (Class 1 Div 1 / ATEX Zone 1) motors and controls for installation in hazardous locations. Dolphin Centrifuge supplies explosion-proof WHPX 513 systems as complete skid packages with explosion-proof controls and wiring. Contact Dolphin Centrifuge for hazardous-area specifications." }
    }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval WHPX 513 Diesel Fuel Oil Centrifuge",
  "description": "Alfa Laval WHPX 513 self-cleaning disc stack centrifuge for diesel, fuel oil, and waste oil. 72 GPM on diesel, 15 HP. Also covers FOPX 613 and MOPX 213.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/alfa-laval-whpx-513/",
};
---

<BaseLayout
  title="Alfa Laval WHPX 513 Fuel Centrifuge"
  description="Alfa Laval WHPX 513 self-cleaning disc stack centrifuge for diesel, fuel oil, and waste oil. 72 GPM on diesel, 15 HP. Also covers FOPX 613 and MOPX 213."
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-whpx-513/"
  breadcrumbs={[{label: 'Products', href: '/disc-stack-centrifuge/'}, {label: 'WHPX 513'}]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">Products</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">Alfa Laval WHPX 513 Diesel Fuel Oil Centrifuge</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">Dolphin Centrifuge provides expert service, genuine parts, and fully reconditioned units for this model. The largest Alfa Laval self-cleaning disc stack centrifuge in the 500-series, delivering up to 72 GPM on diesel fuel. The WHPX 513 is the go-to choice for high-volume diesel purification, heavy fuel oil treatment, waste oil reclamation, and industrial fluid processing.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Request a Quote</a>
        <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
      </div>
    </div>
  </section>

  <!-- Specs & Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-4xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
        <p class="text-sm text-text-light leading-relaxed italic">The Alfa Laval WHPX 513 is the largest self-cleaning disc stack centrifuge in the 500-series, rated at 72 GPM on diesel fuel and up to 90+ GPM on lighter fluids. Dolphin Centrifuge supplies the WHPX 513 as the DMPX-070 complete centrifuge module — a fully integrated system for diesel, heavy fuel oil, waste oil, and crude oil processing. Available in explosion-proof configurations for marine and industrial hazardous area installations. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of experience in WHPX-series centrifuge systems.</p>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Overview</h2>
      <p class="text-text-light mb-4">
        The Alfa Laval WHPX 513 is a self-cleaning <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">disc stack centrifuge</a> built for the three-phase separation of mixed fluids and sludge. Powered by a 15 HP motor, the WHPX 513 achieves a bowl speed of 4,150 RPM and can process 72 GPM of diesel fuel.
      </p>
      <p class="text-text-light mb-8">
        This centrifuge is widely used across marine and industrial applications, from shipboard fuel treatment to refinery slop oil processing. Its large bowl volume and generous sludge space make it particularly suited for high-throughput applications where solids loading is moderate to heavy.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">WHPX 513 Specifications</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <tbody>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Model Type</td>
              <td class="px-4 py-3 font-mono text-text-light">Alfa Laval WHPX 513 TGD 24-60</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Rated Capacity</td>
              <td class="px-4 py-3 font-mono text-text-light">72 GPM on 13 cSt Diesel Fuel</td>
            </tr>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Sludge Space</td>
              <td class="px-4 py-3 font-mono text-text-light">3.87 Gallons</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Motor HP</td>
              <td class="px-4 py-3 font-mono text-text-light">15 HP</td>
            </tr>
            <tr class="bg-white">
              <td class="px-4 py-3 font-semibold text-navy">Voltages</td>
              <td class="px-4 py-3 font-mono text-text-light">230 / 460 V</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Applications</h2>
      <div class="grid md:grid-cols-2 gap-x-8 gap-y-2 mb-8">
        <ul class="text-text-light space-y-2">
          <li>&#8226; <a href="/diesel-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Diesel fuel purification</a></li>
          <li>&#8226; <a href="/black-diesel-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Black diesel separation</a></li>
          <li>&#8226; <a href="/fuel-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Intermediate &amp; heavy fuel oils (IFO, HFO)</a></li>
        </ul>
        <ul class="text-text-light space-y-2">
          <li>&#8226; <a href="/waste-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Waste oil reclamation</a></li>
          <li>&#8226; <a href="/machine-coolant-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Industrial fluids &amp; machining coolants</a></li>
          <li>&#8226; <a href="/lube-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Lubricating oils</a></li>
        </ul>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Also Available: FOPX 613 for Heavy Fuel Oil</h2>
      <p class="text-text-light mb-4">
        The Alfa Laval FOPX 613 is a partial-discharge disc stack centrifuge specifically designed for heavy fuel oil (HFO) treatment. The "FO" designation stands for Fuel Oil. Available in Class 1 Div 1 explosion-proof configuration.
      </p>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <tbody>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Model Type</td>
              <td class="px-4 py-3 font-mono text-text-light">Alfa Laval FOPX 613 TGD 24-60</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Rated Capacity</td>
              <td class="px-4 py-3 font-mono text-text-light">30 GPM on 380 cSt Heavy Fuel Oil</td>
            </tr>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Sludge Space</td>
              <td class="px-4 py-3 font-mono text-text-light">3.95 Gallons</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Motor HP</td>
              <td class="px-4 py-3 font-mono text-text-light">15 HP</td>
            </tr>
            <tr class="bg-white">
              <td class="px-4 py-3 font-semibold text-navy">Voltages</td>
              <td class="px-4 py-3 font-mono text-text-light">230 / 460 V</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Also Available: MOPX 213 Total-Discharge</h2>
      <p class="text-text-light mb-4">
        The Alfa Laval MOPX 213 is a total-discharge centrifuge for three-phase separation of <a href="/fuel-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">fuel oil</a>, <a href="/hydraulic-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">hydraulic oil</a>, <a href="/cutting-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">cutting oil</a>, and other mineral oils and fuels. It processes 42 GPM of used engine oil at 180&deg;F.
      </p>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <tbody>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Model Type</td>
              <td class="px-4 py-3 font-mono text-text-light">Alfa Laval MOPX 213 TGT 20-60</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Rated Capacity</td>
              <td class="px-4 py-3 font-mono text-text-light">42 GPM on Used Motor Oil @ 180&deg;F</td>
            </tr>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Sludge Space</td>
              <td class="px-4 py-3 font-mono text-text-light">3.61 Gallons</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Motor HP</td>
              <td class="px-4 py-3 font-mono text-text-light">15 HP</td>
            </tr>
            <tr class="bg-white">
              <td class="px-4 py-3 font-semibold text-navy">Voltages</td>
              <td class="px-4 py-3 font-mono text-text-light">230 / 460 V</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Related Resources</h2>
      <ul class="text-text-light space-y-2 mb-4">
        <li>&#8226; <a href="/alfa-laval-whpx-513-clarifier-centrifuge-module/" class="text-navy font-semibold hover:text-gold transition-colors">WHPX 513 Clarifier Module (Turnkey System)</a></li>
        <li>&#8226; <a href="/disc-stack-centrifuge-faq/" class="text-navy font-semibold hover:text-gold transition-colors">101 Disc Stack Centrifuge FAQs</a></li>
        <li>&#8226; <a href="/alfa-laval-centrifuge-parts/" class="text-navy font-semibold hover:text-gold transition-colors">Centrifuge Parts &amp; Spares</a></li>
      </ul>

      <p class="text-text-light mb-8">
        <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Looking for a complete turnkey system? See our disc stack centrifuge systems &rarr;</a>
      </p>

      <!-- FAQ -->
      <div id="faq" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-6">
        <h2 class="text-xl font-bold text-navy mb-6">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What is the rated capacity of the Alfa Laval WHPX 513?</h3>
            <p class="text-text-light text-sm">The WHPX 513 is rated at 72 GPM on diesel fuel (13 cSt viscosity). On lighter fluids throughput can exceed 90+ GPM. On heavier fluids like intermediate fuel oil, throughput is reduced proportionally to viscosity. The WHPX 513 is powered by a 15 HP motor with a 3.87-gallon sludge space.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">What is the difference between the WHPX 513 and the FOPX 613?</h3>
            <p class="text-text-light text-sm">The WHPX 513 is a three-phase self-cleaning disc centrifuge suited for diesel, waste oil, and intermediate fuel oil. The FOPX 613 is a partial-discharge centrifuge specifically engineered for heavy fuel oil (HFO) processing at 380 cSt viscosity, rated at 30 GPM on bunker fuel. Choose the FOPX 613 when processing heavy bunker fuel with high wax content.</p>
          </div>
          <div>
            <h3 class="text-base font-semibold text-navy mb-2">Is the WHPX 513 available in explosion-proof configuration?</h3>
            <p class="text-text-light text-sm">Yes. The WHPX 513 is available with explosion-proof (Class 1 Div 1 / ATEX Zone 1) motors and controls for installation in hazardous locations. Dolphin Centrifuge supplies explosion-proof WHPX 513 systems as complete skid packages with explosion-proof controls and wiring. Contact Dolphin Centrifuge for hazardous-area specifications.</p>
          </div>
        </div>
      </div>
      <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

      <!-- Bottom CTA -->
      <div class="bg-navy rounded-xl p-8 text-center mt-12">
        <h2 class="text-2xl font-bold text-white mb-3">Interested in This Centrifuge?</h2>
        <p class="text-gray-300 mb-6 max-w-lg mx-auto">Contact our team for pricing, availability, and system configuration options.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Quote</a>
          <a href="tel:2485222573" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">(248) 522-2573</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
