          <span class="text-navy font-medium group-hover:text-gold transition-colors">NX-418 Decanter</span>
        </a>
        <a href="/decanter-centrifuge-applications/" class="group flex items-center gap-3 p-4 bg-warm-white rounded-lg hover:bg-gray-100 transition">
