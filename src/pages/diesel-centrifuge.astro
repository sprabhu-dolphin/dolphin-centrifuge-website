---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "Can a centrifuge clean contaminated diesel fuel?",
    answer: "Yes. A disc stack centrifuge removes all free water, rust, sludge, and solid particles down to 1 micron from diesel fuel in a single continuous pass. Operating at up to 8,000 Gs of centrifugal force, it separates contaminants that filters miss — including water, which filters cannot remove at all."
  },
  {
    question: "What size diesel fuel centrifuge do I need?",
    answer: "Diesel centrifuge sizing depends on your fuel throughput requirements. Systems range from 4 GPM manual-clean units for workboats and small generators up to 72 GPM self-cleaning systems for tank farms and fuel depots. <a href='/contact-for-alfa-laval-centrifuges/'>Contact us</a> with your fuel volume and application for a sizing recommendation."
  },
  {
    question: "Are explosion-proof diesel centrifuges available?",
    answer: "Yes. Dolphin Centrifuge offers Class 1, Division 2 (C1D2) certified diesel centrifuge systems with explosion-proof motors, certified control panels, and approved wiring methods. These are required for fuel tank farms, marine engine rooms, and petroleum storage facilities where flammable vapors may be present."
  },
  {
    question: "Can a centrifuge separate diesel fuel from engine oil?",
    answer: "No. Disc stack centrifuges separate <em>immiscible</em> liquids — liquids that do not dissolve in each other. Diesel and engine oil are miscible (they dissolve into each other), so centrifugal force cannot separate them. A centrifuge can, however, remove water and solid contaminants from either fluid independently."
  },
  {
    question: "How does a diesel centrifuge compare to a fuel filter?",
    answer: "A centrifuge removes both water and solids simultaneously, while filters can only capture solid particles. Centrifuge performance remains constant over time, whereas filters lose efficiency as they clog. Centrifuges also have no consumable media — no replacement elements to buy or dispose of — resulting in significantly lower operating costs over the equipment's 30+ year lifespan."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "url": "https://dolphincentrifuge.com/diesel-centrifuge/",
  "name": "Diesel Fuel Centrifuge System",
  "description": "Diesel fuel centrifuges separate sludge, rust, and water from diesel fuel. Self-cleaning and manual-clean models from 4 to 72 GPM, including Class 1 Div 2 explosion proof.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "category": "Industrial Centrifuges",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const jsonLd = [productJsonLd, faqJsonLd];

const toc = [
  { id: 'overview', label: 'Diesel Fuel Centrifuge' },
  { id: 'operation', label: 'How It Works' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'benefits', label: 'Benefits' },
  { id: 'explosion-proof', label: 'Explosion Proof (C1D2)' },
  { id: 'workboat', label: 'Workboat Applications' },
  { id: 'models', label: 'Available Systems' },
];

const relatedApplications = [
  { label: 'Fuel Oil Centrifuge', href: '/fuel-oil-centrifuge/' },
  { label: 'Black Diesel Centrifuge', href: '/black-diesel-centrifuge/' },
  { label: 'Oil Centrifuge (General)', href: '/oil-centrifuge/' },
  { label: 'Biodiesel Centrifuge', href: '/biodiesel-centrifuge/' },
  { label: 'Waste Oil Centrifuge', href: '/waste-oil-centrifuge/' },
];

const relatedProducts = [
  { label: 'DMB-004 Manual-Clean', href: '/centrifuges/dmb-004/', description: 'Small: 4 GPM diesel purification' },
  { label: 'DMB-007 Manual-Clean', href: '/centrifuges/dmb-007/', description: 'Medium: 7 GPM diesel workboats' },
  { label: 'DMPX-014 Self-Cleaning', href: '/centrifuges/dmpx-014/', description: '13-16 GPM continuous diesel' },
  { label: 'DMPX-042 Self-Cleaning', href: '/centrifuges/dmpx-042/', description: '32-47 GPM large-scale diesel' },
];
