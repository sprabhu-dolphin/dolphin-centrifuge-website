---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "What is the rated capacity of the Alfa Laval WSPX 303 centrifuge?",
    answer: "The WSPX 303 TGD is rated at 8 GPM on water-based coolant. It is a self-cleaning 3-phase disc centrifuge suited for central coolant systems serving multiple CNC machines or grinding operations in mid-size machining facilities."
  },
  {
    question: "What does a coolant centrifuge remove from metalworking fluid?",
    answer: "A coolant centrifuge removes metal fines (chips, grinding swarf, particles down to 1 micron), tramp oil (hydraulic and machine oils that contaminate coolant), and other dense solid contaminants. Removing these contaminants extends coolant life, reduces biocide consumption, and prevents surface finish degradation on machined parts."
  },
  {
    question: "How often does the WSPX 303 need to discharge sludge?",
    answer: "The WSPX 303 discharges accumulated sludge automatically at programmable intervals, typically every 30–120 minutes depending on contamination load. Discharge takes only a few seconds and does not interrupt fluid flow. Higher-contamination applications require more frequent discharge cycles."
  }
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval WSPX 303 TGD Coolant Centrifuge",
  "description": "Alfa Laval WSPX 303 TGD self-cleaning 3-phase disc centrifuge for industrial coolant and metalworking fluid recycling. 8 GPM, 9,200 RPM, 8,000+ Gs.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/alfa-laval-wspx-303-centrifuge/",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" },
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const jsonLd = [productJsonLd, faqJsonLd];

const toc = [
  { id: 'overview', label: 'WSPX 303 Operation' },
  { id: 'specifications', label: 'WSPX 303 Specifications' },
  { id: 'applications', label: 'Applications' },
  { id: 'wspx-series', label: 'Related WSPX Models' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedApplications = [
  { label: 'Machine Coolant Centrifuge', href: '/machine-coolant-centrifuge/' },
  { label: 'Cutting Oil Centrifuge', href: '/cutting-oil-centrifuge/' },
  { label: 'Industrial Washer Fluid Centrifuge', href: '/industrial-washer-fluid-centrifuge/' },
];

const relatedProducts = [
  { label: 'WSPX 207 Centrifuge', href: '/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/', description: '100–200 LPH entry-level' },
  { label: 'WSPX 307 Centrifuge', href: '/alfa-laval-wspx-307/', description: '400–800 LPH high-volume' },
  { label: 'WSPX 407 Centrifuge', href: '/alfa-laval-wspx-407/', description: '800+ LPH highest capacity' },
];
---

<ApplicationLayout
  title="Alfa Laval WSPX 303 Self-Cleaning Coolant Centrifuge | Dolphin Centrifuge"
  description="Alfa Laval WSPX 303 TGD self-cleaning disc centrifuge for coolant clarification and tramp oil removal. 8 GPM capacity, 9,200 RPM, 8,000+ Gs. Dolphin Centrifuge."
  category="products"
  categoryLabel="Products"
  heroImage="/images/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/Alfa-Laval-Industrial-Centrifuge-Coolant-1000.webp"
  heroImageAlt="Alfa Laval Industrial Centrifuge Coolant 1000"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-wspx-303-centrifuge/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies the Alfa Laval WSPX 303 TGD, a self-cleaning 3-phase disc centrifuge rated at 8 GPM. Operating at 9,200 RPM and 8,000+ Gs, it removes sub-micron particles and tramp oil from metalworking coolant in mid-size machining facilities.</p>
  </div>

  <h2 id="overview">WSPX 303 Operation</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-1/2">
      <p>
        The Alfa Laval WSPX 303 TGD is a 3-phase <a href="/disc-stack-centrifuge/">disc stack centrifuge</a> designed to separate tramp oil and small particles from <a href="/machine-coolant-centrifuge/">machine coolant</a>. The WSPX 303 bowl rotates at 9,200 RPM exerting over 8,000 G-Force, making it ideal for <a href="/industrial-washer-fluid-centrifuge/">cleaning wash liquids</a>, machining coolants, and de-oiling of water.
      </p>
      <p>
        At 8 GPM on water-based coolant, the WSPX 303 is well matched to multi-machine coolant circuits serving groups of CNC machining centers, transfer lines, or grinding cells. Its automatic sludge discharge cycle allows continuous unattended operation, extending coolant service life and reducing both disposal frequency and fluid replacement cost.
      </p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/Alfa-Laval-Stainless-Steel-Centrifuge-600.webp"
        alt="Alfa Laval Stainless Steel Centrifuge 600"
        width="600"
        height="400"
        loading="lazy"
        class="rounded-lg w-full"
      />
    </div>
  </div>

  <h2 id="specifications">WSPX 303 Specifications</h2>

  <table>
    <tbody>
      <tr><td><strong>Model Type</strong></td><td>Alfa Laval WSPX 303 TGD</td></tr>
      <tr><td><strong>Rated Capacity</strong></td><td>8 GPM on Water-Based Coolant</td></tr>
      <tr><td><strong>Sludge Space</strong></td><td>0.14 Gallons</td></tr>
      <tr><td><strong>Motor HP</strong></td><td>4 HP</td></tr>
      <tr><td><strong>Voltages</strong></td><td>230 / 460 V</td></tr>
      <tr><td><strong>Bowl Speed</strong></td><td>9,200 RPM</td></tr>
      <tr><td><strong>G-Force</strong></td><td>8,000+</td></tr>
    </tbody>
  </table>

  <h2 id="applications">Applications</h2>

  <div class="grid md:grid-cols-2 gap-x-8 gap-y-2 mb-8 not-prose">
    <ul class="text-text-light space-y-2">
      <li>&#8226; <a href="/machine-coolant-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Central coolant system recovery</a></li>
      <li>&#8226; <a href="/cutting-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Cutting and grinding fluid clarification</a></li>
      <li>&#8226; Multi-machine CNC coolant circuits</li>
      <li>&#8226; Transfer line coolant recycling</li>
    </ul>
    <ul class="text-text-light space-y-2">
      <li>&#8226; Metal fines and swarf removal</li>
      <li>&#8226; Tramp oil separation</li>
      <li>&#8226; Honing fluid recovery</li>
      <li>&#8226; <a href="/industrial-washer-fluid-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Wash liquid and parts-cleaning fluid clarification</a></li>
      <li>&#8226; De-oiling of water</li>
    </ul>
  </div>

  <h2 id="wspx-series">Related WSPX Models</h2>

  <p>
    The WSPX 303 fits between the smaller <a href="/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/">WSPX 207</a> and the higher-capacity <a href="/alfa-laval-wspx-307/">WSPX 307</a>. For the highest throughput requirements, the <a href="/alfa-laval-wspx-407/">WSPX 407</a> handles 800+ LPH. Dolphin Centrifuge can help you size the correct model based on your system flow rate and contamination profile.
  </p>

  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8 not-prose">
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2"><a href="/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/" class="text-navy hover:text-gold transition-colors">WSPX 207</a></h3>
      <p class="text-sm text-text-light">100–200 LPH. Individual machine or small cell installations.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border-2 border-gold">
      <h3 class="text-lg font-bold text-navy mb-2">WSPX 303 — Current</h3>
      <p class="text-sm text-text-light">8 GPM. Central coolant and multi-machine circuits.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2"><a href="/alfa-laval-wspx-307/" class="text-navy hover:text-gold transition-colors">WSPX 307</a></h3>
      <p class="text-sm text-text-light">400–800 LPH. High-volume automotive and aerospace facilities.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2"><a href="/alfa-laval-wspx-407/" class="text-navy hover:text-gold transition-colors">WSPX 407</a></h3>
      <p class="text-sm text-text-light">800+ LPH. Highest capacity for large-scale industrial operations.</p>
    </div>
  </div>

  <FAQ items={faqItems} />

  <div class="bg-navy rounded-xl p-8 text-center mt-12 not-prose">
    <h2 class="text-2xl font-bold text-white mb-3">Interested in the WSPX 303?</h2>
    <p class="text-gray-300 mb-6 max-w-lg mx-auto">Contact our team for pricing, system integration support, and application evaluation. Paid sample testing is available.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Quote</a>
      <a href="tel:2485222573" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">(248) 522-2573</a>
    </div>
  </div>

</ApplicationLayout>
