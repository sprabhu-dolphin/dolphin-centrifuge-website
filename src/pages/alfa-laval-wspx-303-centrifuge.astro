---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval WSPX 303 Coolant Centrifuge",
  "description": "Alfa Laval WSPX 303 self-cleaning disc centrifuge for industrial coolant and metalworking fluid recycling.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/alfa-laval-wspx-303-centrifuge/",
};
---

<BaseLayout
  title="Alfa Laval WSPX 303 Coolant Centrifuge"
  description="Alfa Laval WSPX 303 self-cleaning disc centrifuge for industrial coolant and metalworking fluid recycling."
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-wspx-303-centrifuge/"
  breadcrumbs={[{label: 'Products', href: '/disc-stack-centrifuge/'}, {label: 'WSPX 303'}]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">Products</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">Alfa Laval WSPX 303 Self-Cleaning Coolant Centrifuge</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">A mid-size self-cleaning disc centrifuge for continuous coolant recovery in central coolant systems and large machining operations. The WSPX 303 delivers 200–400 LPH throughput while continuously removing metal fines and tramp oil from water-based fluids.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Request a Quote</a>
        <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
      </div>
    </div>
  </section>

  <!-- Specs & Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-4xl">

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Operation</h2>
      <p class="text-text-light mb-4">
        The Alfa Laval WSPX 303 is a self-cleaning <a href="/disc-stack-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">disc stack centrifuge</a> designed for the mid-range demands of central coolant systems in industrial metalworking facilities. Its automatic sludge discharge cycle allows continuous unattended operation — eliminating the manual bowl-cleaning intervals required by manual-discharge centrifuges.
      </p>
      <p class="text-text-light mb-8">
        At 200–400 LPH, the WSPX 303 is well matched to multi-machine coolant circuits serving groups of CNC machining centers, transfer lines, or grinding cells. It removes sub-micron metal fines and separates tramp oil, extending coolant service life and reducing both disposal frequency and fluid replacement cost.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">WSPX 303 Specifications</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <tbody>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Centrifuge Model</td>
              <td class="px-4 py-3 font-mono text-text-light">Alfa Laval WSPX 303</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Typical Flow Rate</td>
              <td class="px-4 py-3 font-mono text-text-light">200–400 LPH (application-dependent)</td>
            </tr>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Bowl Type</td>
              <td class="px-4 py-3 font-mono text-text-light">Self-Cleaning (Automatic Discharge)</td>
            </tr>
            <tr class="bg-gray-50 border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Separation Type</td>
              <td class="px-4 py-3 font-mono text-text-light">Concentrator (Liquid-Solid)</td>
            </tr>
            <tr class="bg-white border-b border-gray-200">
              <td class="px-4 py-3 font-semibold text-navy">Ideal For</td>
              <td class="px-4 py-3 font-mono text-text-light">Central coolant systems, multi-machine circuits</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-4 py-3 font-semibold text-navy">Voltages</td>
              <td class="px-4 py-3 font-mono text-text-light">230 / 460 V; 3-Phase</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Applications</h2>
      <div class="grid md:grid-cols-2 gap-x-8 gap-y-2 mb-8">
        <ul class="text-text-light space-y-2">
          <li>&#8226; <a href="/machine-coolant-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Central coolant system recovery</a></li>
          <li>&#8226; <a href="/cutting-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">Cutting and grinding fluid clarification</a></li>
          <li>&#8226; Multi-machine CNC coolant circuits</li>
          <li>&#8226; Transfer line coolant recycling</li>
        </ul>
        <ul class="text-text-light space-y-2">
          <li>&#8226; Metal fines and swarf removal</li>
          <li>&#8226; Tramp oil separation</li>
          <li>&#8226; Honing fluid recovery</li>
          <li>&#8226; Washer and parts-cleaning fluid clarification</li>
        </ul>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Related WSPX Models</h2>
      <p class="text-text-light mb-4">
        The WSPX 303 fits between the smaller <a href="/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">WSPX 207</a> and the higher-capacity <a href="/alfa-laval-wspx-307/" class="text-navy font-semibold hover:text-gold transition-colors">WSPX 307</a>. Dolphin Centrifuge can help you size the correct model based on your system flow rate and contamination profile.
      </p>
      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2">WSPX 207</h3>
          <p class="text-sm text-text-light">100–200 LPH. Individual machine or small cell installations.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border-2 border-gold">
          <h3 class="text-lg font-bold text-navy mb-2">WSPX 303 — Current</h3>
          <p class="text-sm text-text-light">200–400 LPH. Central coolant and multi-machine circuits.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="text-lg font-bold text-navy mb-2"><a href="/alfa-laval-wspx-307/" class="text-navy hover:text-gold transition-colors">WSPX 307</a></h3>
          <p class="text-sm text-text-light">400–800 LPH. High-volume automotive and aerospace facilities.</p>
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="bg-navy rounded-xl p-8 text-center mt-12">
        <h2 class="text-2xl font-bold text-white mb-3">Interested in the WSPX 303?</h2>
        <p class="text-gray-300 mb-6 max-w-lg mx-auto">Contact our team for pricing, system integration support, and application evaluation. Paid sample testing is available.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Quote</a>
          <a href="tel:2485222573" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">(248) 522-2573</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
