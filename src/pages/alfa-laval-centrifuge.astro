  "description": "Complete guide to Alfa Laval centrifuges covering industrial applications, operating principles, capacity, cost, types (disc stack and decanter), specifications, and used centrifuge options.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Engineering Manager",
    "worksFor": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  },
  "datePublished": "2021-08-01",
  "dateModified": "2026-01-01",
  "mainEntityOfPage": "https://dolphincentrifuge.com/alfa-laval-centrifuge/"
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What types of Alfa Laval centrifuges does Dolphin Centrifuge supply?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dolphin Centrifuge supplies Alfa Laval disc stack centrifuges (MOPX, WHPX, MAPX, MAB, WSB series) and Alfa Laval decanter centrifuges (NX-314, NX-418, NX-428) as complete system modules. The Dolphin DMPX and DMB series are purpose-built centrifuge modules using Alfa Laval centrifuge bowls as the core separation component."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between an Alfa Laval disc stack and decanter centrifuge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Alfa Laval disc stack centrifuges (MOPX, MAPX, WHPX series) operate at 7,000+ Gs and excel at liquid-liquid separation (oil/water) with fine particle removal down to 0.5 microns. They are used for diesel, lube oil, and coolant purification. Alfa Laval decanter centrifuges (NX series) operate at 3,000+ Gs and handle high-solids sludge dewatering, drilling mud processing, and crude oil tank bottom recovery."
      }
    },
    {
      "@type": "Question",
      "name": "How much does an Alfa Laval centrifuge cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Alfa Laval centrifuge pricing varies widely by model and configuration. A used or remanufactured small disc stack centrifuge (MOPX 207 / DMB-028 equivalent) starts around $15,000–$30,000. A new Dolphin DMPX-028 complete system module runs $35,000–$55,000. Larger models (DMPX-070) and decanter systems range from $75,000–$200,000+. Contact Dolphin Centrifuge at (248) 522-2573 for current pricing."
      }
    },
    {
      "@type": "Question",
      "name": "What industries use Alfa Laval centrifuges?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Alfa Laval centrifuges are used in marine (fuel and lube oil purification), power generation (turbine lube oil), oil and gas (crude oil dehydration, diesel polishing), food and beverage (edible oil, dairy, beer/wine), pharmaceutical (cell separation, broth clarification), wastewater treatment, and industrial manufacturing (coolant recovery, metalworking fluids)."
      }
    },
    {
      "@type": "Question",
      "name": "Does Dolphin Centrifuge supply used Alfa Laval centrifuges?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Dolphin Centrifuge rebuilds and remanufactures used Alfa Laval centrifuges to like-new condition, replacing all wear components, gaskets, and bearings. Remanufactured units are tested before shipment and include a warranty. This is a cost-effective alternative to new equipment — typically 40–60% of new cost. Contact (248) 522-2573 for current inventory."
      }
    }
  ]
};
---

<BaseLayout
  title="Alfa Laval Centrifuge: Applications, Types & Specs"
  description="Complete guide to Alfa Laval centrifuges: working principle, 30+ industrial applications, capacity tables, equipment cost, disc stack vs decanter types, specifications, and used centrifuge options."
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-centrifuge/"
  breadcrumbs={[
    { label: 'Knowledge Center', href: '/disc-stack-centrifuge-faq/' },
    { label: 'Alfa Laval Centrifuge Guide' }
  ]}
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <section class="bg-navy text-white py-14 md:py-20">
    <div class="container-dolphin max-w-5xl">
      <div class="md:flex md:items-center md:gap-10">
        <div class="md:w-1/2">
          <h1 class="text-3xl md:text-4xl font-bold leading-tight mb-4">
            Alfa Laval Centrifuge
          </h1>
          <p class="text-lg text-blue-100 mb-2">
            Applications, Benefits, Cost, Types, Specs &amp; Sizes
          </p>
          <p class="text-blue-200 text-base leading-relaxed">
            A complete technical guide to Alfa Laval centrifuges — the global standard for high-quality, reliable separation equipment used across manufacturing and processing industries.
          </p>
      <div class="flex flex-wrap gap-3 mt-6">
            <a href="/contact-for-alfa-laval-centrifuges/" class="bg-[#E8A317] hover:bg-yellow-500 text-white font-semibold px-6 py-3 rounded-lg transition">Request a Quote</a>
            <a href="tel:+12485222573" class="border border-white/70 text-white hover:bg-white hover:text-[#1B3A5C] font-semibold px-6 py-3 rounded-lg transition">(248) 522-2573</a>
          </div>
        </div>
        <div class="md:w-1/2 mt-8 md:mt-0">
          <img
            src="/images/alfa-laval-centrifuge/Alfa-Laval-Centrifuge-Separator-Type-MAPX-210.jpg"
            alt="Alfa Laval Centrifuge Separator Type MAPX-210"
            width="600" height="450"
            loading="eager"
            class="rounded-xl w-full object-cover shadow-lg"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-4xl">

      <div class="bg-navy/5 border-l-4 border-gold rounded-r-lg p-4 mb-6">
        <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies Alfa Laval disc stack centrifuges and decanter centrifuges for industrial oil, fuel, coolant, and wastewater separation — including MAB (manual-clean), MOPX/WHPX (self-cleaning oil purifiers), WSPX (self-cleaning coolant), BTPX (biotech), and NX/G2 decanter series. All models are available as complete turnkey centrifuge modules with controls, pumping, and piping. Based in Warren, Michigan, Dolphin Centrifuge has over 40 years of Alfa Laval centrifuge sales, service, and system integration experience.</p>
      </div>

      <!-- Intro -->
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <p class="text-gray-700 leading-relaxed text-lg">
          An Alfa Laval centrifuge is an <a href="/industrial-centrifuge/" class="text-navy underline hover:text-gold">industrial centrifuge</a> manufactured by Alfa Laval, a global standard for high-quality, reliable separation equipment. These centrifuges find various uses in all manufacturing and processing industries.
        </p>

        <!-- Table of Contents -->
        <div class="mt-6 bg-gray-50 rounded-lg p-5">
          <h2 class="text-base font-semibold text-navy mb-3">Table of Contents</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-1 text-sm">
            <ul class="space-y-1">
              <li><a href="#working-principle" class="text-navy hover:text-gold">Working Principle</a></li>
              <li><a href="#operation" class="text-navy hover:text-gold">Operation</a></li>
              <li><a href="#setup" class="text-navy hover:text-gold">Setup</a></li>
              <li><a href="#plant-layout" class="text-navy hover:text-gold">Plant Layout</a></li>
              <li><a href="#industrial-applications" class="text-navy hover:text-gold">Industrial Applications</a></li>
              <li><a href="#beverages" class="text-navy hover:text-gold">— Beverages (Beer, Kombucha, Juice, Wine)</a></li>
              <li><a href="#chemicals" class="text-navy hover:text-gold">— Chemicals</a></li>
              <li><a href="#pharmaceutical" class="text-navy hover:text-gold">— Pharmaceutical</a></li>
              <li><a href="#oil-and-gas" class="text-navy hover:text-gold">— Oil and Gas</a></li>
              <li><a href="#industrial-fluids" class="text-navy hover:text-gold">— Industrial Fluids</a></li>
            </ul>
            <ul class="space-y-1">
              <li><a href="#metalworking-fluids" class="text-navy hover:text-gold">— Metalworking Fluids</a></li>
              <li><a href="#fuel-and-lube-oil" class="text-navy hover:text-gold">— Fuel and Lube Oil</a></li>
              <li><a href="#waste-fluid-recycling" class="text-navy hover:text-gold">— Waste Fluid Recycling</a></li>
              <li><a href="#special-applications" class="text-navy hover:text-gold">— Special Applications</a></li>
              <li><a href="#benefits" class="text-navy hover:text-gold">Benefits</a></li>
              <li><a href="#capacity" class="text-navy hover:text-gold">Capacity</a></li>
              <li><a href="#cost" class="text-navy hover:text-gold">Cost</a></li>
              <li><a href="#types" class="text-navy hover:text-gold">Types</a></li>
              <li><a href="#specifications" class="text-navy hover:text-gold">Specifications &amp; Sizes</a></li>
              <li><a href="#used-centrifuges" class="text-navy hover:text-gold">Used Centrifuges</a></li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Working Principle -->
      <div id="working-principle" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-navy mb-4">Working Principle</h2>
        <p class="text-gray-700 leading-relaxed">
          An Alfa Laval centrifuge is a sedimentation type of centrifuge that utilizes the enhanced force of gravity to separate liquids from other liquids or solids. The centrifuge features a rotating bowl assembly that exerts a centrifugal force over <strong>8,000 times the force of gravity</strong>. This high force causes instant sedimentation of the heavy particles, causing the fluid separation from contaminating solids.
        </p>
      </div>

      <!-- Operation -->
      <div id="operation" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-navy mb-4">Operation</h2>
        <p class="text-gray-700 leading-relaxed mb-4">
          The operation of Alfa Laval centrifuges is as follows. The contaminated fluid enters the rotating bowl through a stationary tube or feed pipe. The fluid accelerates quickly to the bowl's rotating speed, which causes centrifugal forces to act on the fluids and solids, causing the heavier solids and liquid to settle and the lighter fluid to separate and exit the bowl through an outlet chamber.
        </p>
        <p class="text-gray-700 leading-relaxed">
          The separated solids accumulate on the bowl wall and are self-ejected through a sludge discharge mechanism.
        </p>

        <!-- Setup -->
        <div id="setup" class="mt-6">
          <h3 class="text-xl font-semibold text-navy mb-3">Setup</h3>
          <p class="text-gray-700 leading-relaxed">
            A typical Alfa Laval centrifuge setup consists of a supply tank that holds the slurry or contaminated fluid. A transfer pump feeds this fluid to the centrifuge, which separates the fluids and solids by sedimentation under high centrifugal forces. The clear separated fluid exits the centrifuge through a discreet fluid outlet into a centrate tank.
          </p>
          <p class="text-gray-700 leading-relaxed mt-3">
            Similarly, the heavy fluid also discharges through a heavy phase outlet into a local collection tank. The separated sludge is ejected or pushed out and falls under gravity into a collection tank below the centrifuge installation.
          </p>
        </div>

        <!-- Plant Layout -->
        <div id="plant-layout" class="mt-6">
          <h3 class="text-xl font-semibold text-navy mb-3">Plant Layout</h3>
          <p class="text-gray-700 leading-relaxed mb-4">
            The diagram below shows the typical layout of the Alfa Laval centrifuge in a processing industry application.
          </p>
          <img
            src="/images/alfa-laval-centrifuge/Alfa-Laval-Centrifuge-Plant-Layout-900.jpg"
            alt="Alfa Laval Centrifuge Plant Layout showing supply tank, pump, centrifuge, and centrate/sludge collection"
            width="900" height="454"
            loading="lazy"
            class="rounded-lg w-full"
          />
          <p class="text-sm text-gray-500 mt-2 text-center">Alfa Laval Centrifuge Plant Layout</p>
        </div>
      </div>

      <!-- Industrial Applications -->
      <div id="industrial-applications" class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 md:p-8 mb-8">
        <h2 class="text-2xl font-bold text-navy mb-4">Industrial Applications</h2>
        <p class="text-gray-700 leading-relaxed">
          All industries that use fluids have applications for Alfa Laval centrifuges. The following is a brief description of the industrial applications of these centrifuges.
        </p>

        <!-- Beverages -->
        <div id="beverages" class="mt-8">
          <h3 class="text-xl font-semibold text-navy mb-4">Beverages</h3>
          <p class="text-gray-700 leading-relaxed mb-4">
            The beverage industry typically involves separating the final product from the source of ingredients used for their production.
          </p>

          <!-- Beer -->
          <div id="beer" class="md:flex md:gap-6 items-start mb-6">
            <div class="md:w-1/3 mb-4 md:mb-0 flex-shrink-0">
              <img
                src="/images/alfa-laval-centrifuge/Alfa-Laval-BRPX313-Beer-Wine-Centrifuge.jpg"
                alt="Alfa Laval Beer and Wine Centrifuge BRPX 313"
                width="300" height="300"
                loading="lazy"
                class="rounded-lg w-full"
              />
              <p class="text-xs text-gray-500 mt-1 text-center">Alfa Laval Beer Centrifuge</p>
            </div>
            <div class="md:w-2/3">
              <h4 class="text-lg font-semibold text-navy mb-2">Beer</h4>
              <p class="text-gray-700 leading-relaxed">
                The commercial production of beer in large quantities requires the separation of hops and yeast from the beer. Alfa Laval has a line of beer centrifuges specifically designed to assist in the continuous production of beer. These are food-grade centrifuges with all wetted parts made of high-grade stainless steel.
              </p>
              <p class="text-gray-700 leading-relaxed mt-2">
                These disc stack centrifuges exert a high centrifugal force to remove the small suspended yeast and organic particles to produce clear beer.
              </p>
            </div>
          </div>

          <!-- Kombucha -->
          <div id="kombucha" class="mb-6">
            <h4 class="text-lg font-semibold text-navy mb-2">Kombucha</h4>
            <p class="text-gray-700 leading-relaxed">
              Kombucha is a relatively new beverage that ferments tea leaves and other organic ingredients. The commercial production of kombucha requires the continuous separation of organic sediment to produce a clear beverage. Filtration is not a feasible method for the large-scale production of kombucha.
            </p>
            <p class="text-gray-700 leading-relaxed mt-2">
              A stainless steel food-grade centrifuge of the disc stack type separates the tiny organic particles from the water to produce a fine beverage.
            </p>
          </div>

          <!-- Juice -->
          <div id="juice-cider" class="mb-6">
            <h4 class="text-lg font-semibold text-navy mb-2">Juice (Cider)</h4>
            <p class="text-gray-700 leading-relaxed">
              The primary separation step in commercial juice production is the separation of pulp from fruit juice. The soft pulp particles clog up filters quickly, and therefore, filtration is not suitable for juice production.
            </p>
            <p class="text-gray-700 leading-relaxed mt-2">
              A high-speed disc stack centrifuge uses mechanical separation to concentrate the smallest pulp particles from the juice to produce clear juice for sale.
            </p>
          </div>

          <!-- Wine -->
          <div id="wine" class="mb-2">
            <h4 class="text-lg font-semibold text-navy mb-2">Wine</h4>
            <p class="text-gray-700 leading-relaxed">
              Like fruit juice production, separating grape remnants from grape juice is a critical step in the large-scale production of wine. A self-cleaning Alfa Laval centrifuge is ideal for separating the organic grape juice from the sediment after fermentation to produce clear wine. All wine producers, including red, white, and carbonated wines, use Alfa Laval wine centrifuges to process wine.
            </p>
          </div>
        </div>

        <!-- Chemicals -->
        <div id="chemicals" class="mt-8 pt-6 border-t border-gray-100">
          <h3 class="text-xl font-semibold text-navy mb-4">Chemicals</h3>
          <p class="text-gray-700 leading-relaxed mb-4">
            Alfa Laval centrifuges can separate the fine suspended solids from the liquid from acceptable aluminum salts to zinc compounds. Also, being a flow-through type separator, the separation efficiency of an Alfa Laval centrifuge is consistent compared to filters that need media replacement.
          </p>

          <!-- Precipitate -->
          <div id="precipitate" class="mb-6">
            <h4 class="text-lg font-semibold text-navy mb-2">Precipitate</h4>
            <p class="text-gray-700 leading-relaxed">
              A reaction between different solutions precipitates chemical ingredients. The reaction creates ingredients in the form of small or nano-suspended particles. Often, the specific gravity of these particles is much higher than the solution; therefore, they are easy to separate with an Alfa Laval disc centrifuge.
            </p>
          </div>

          <!-- Catalyst Recovery -->
          <div id="catalyst-recovery" class="mb-6">
            <h4 class="text-lg font-semibold text-navy mb-2">Catalyst Recovery</h4>
            <p class="text-gray-700 leading-relaxed">
              Chemical reactions use catalysts to enable the reaction process to take place. These catalysts are reusable, and their recovery is therefore necessary. Metal catalysts in the form of fine powders are quickly recovered post-reaction by an Alfa Laval industrial centrifuge. The higher specific gravity of the catalyst makes it easy to separate from the centrate under the high centrifugal force of an industrial centrifuge.
            </p>
          </div>

          <!-- Water Wash -->
          <div id="water-wash" class="md:flex md:gap-6 items-start">
            <div class="md:w-1/3 mb-4 md:mb-0 flex-shrink-0">
              <img
                src="/images/alfa-laval-centrifuge/alfa-laval-wash-water-centrifuge-wspx-303.jpg"
                alt="Alfa Laval WSPX 303 Wash Water Concentrator Centrifuge"
                width="300" height="344"
                loading="lazy"
                class="rounded-lg w-full"
              />
              <p class="text-xs text-gray-500 mt-1 text-center">Alfa Laval WSPX 303 Wash Water Centrifuge</p>
            </div>
            <div class="md:w-2/3">
              <h4 class="text-lg font-semibold text-navy mb-2">Water Wash</h4>
              <p class="text-gray-700 leading-relaxed">
                Some chemical raw ingredients are water washed to remove some undesirable contaminants. Since the contaminants are water-soluble, a water wash quickly removes the contaminants from the base chemical through a water wash.
              </p>
              <p class="text-gray-700 leading-relaxed mt-2">
                Deionized water and the raw chemical are vigorously agitated. The DI water is then separated from the chemical by an Alfa Laval centrifuge which separates the fluids based on their specific gravity.
              </p>
            </div>
          </div>
        </div>

        <!-- Pharmaceutical -->
        <div id="pharmaceutical" class="mt-8 pt-6 border-t border-gray-100">
          <h3 class="text-xl font-semibold text-navy mb-4">Pharmaceutical</h3>
          <p class="text-gray-700 leading-relaxed mb-4">
            The pharmaceutical industry has a variety of separation applications where cultivated biological cell harvesting is a critical process. Alfa Laval stainless steel centrifuges play an important role in such extraction processes.
          </p>

          <!-- Bulk Drug Ingredients -->
          <div id="bulk-drug-ingredients" class="mb-6">
            <h4 class="text-lg font-semibold text-navy mb-2">Bulk Drug Ingredients</h4>
            <p class="text-gray-700 leading-relaxed">
              Medical drug manufacturing requires raw ingredients in bulk. These ingredients often require Alfa Laval centrifugal separators to separate the solid ingredients from liquid chemicals.
            </p>
          </div>

          <!-- Cannabis Extract -->
          <div id="cannabis-extract" class="mb-6">
            <div class="md:flex md:gap-6 items-start">
              <div class="md:w-1/3 mb-4 md:mb-0 flex-shrink-0">
                <img
                  src="/images/alfa-laval-centrifuge/THC-Cannabis-Solvent-Clarifier-Centrifuge-600.jpg"
                  alt="THC Cannabis Solvent Clarifier Centrifuge for ethanol extraction"
                  width="600" height="600"
                  loading="lazy"
                  class="rounded-lg w-full"
                />
                <p class="text-xs text-gray-500 mt-1 text-center">THC Cannabis Solvent Clarifier Centrifuge</p>
              </div>
              <div class="md:w-2/3">
                <h4 class="text-lg font-semibold text-navy mb-2">Cannabis Extract</h4>
                <p class="text-gray-700 leading-relaxed">
                  The commercial production of CBD oil and THC extract uses an ethanol extraction process wherein the ethanol immerses the source biomass and absorbs the cannabinoid from the biomass. The subsequent separation of biomass and ethanol purification uses Alfa Laval centrifuges for efficient extraction.
                </p>
              </div>
            </div>

            <!-- Ethanol Biomass Separation -->
            <div id="ethanol-biomass" class="mt-4 ml-0 md:ml-4">
              <div class="md:flex md:gap-6 items-start">
                <div class="md:w-1/3 mb-4 md:mb-0 flex-shrink-0">
                  <img
                    src="/images/alfa-laval-centrifuge/Alfa-Laval-NX418-Decanter-C1D2-for-Hemp-Ethanol-Processing-Texted-600.jpg"
                    alt="Alfa Laval NX 418 Decanter C1D2 for Hemp Ethanol Processing"
                    width="600" height="320"
                    loading="lazy"
                    class="rounded-lg w-full"
                  />
                  <p class="text-xs text-gray-500 mt-1 text-center">Alfa Laval NX 418 Decanter C1D2 for Hemp Ethanol Processing</p>
                </div>
                <div class="md:w-2/3">
                  <h5 class="text-base font-semibold text-navy mb-2">Ethanol Biomass Separation</h5>
                  <p class="text-gray-700 leading-relaxed">
                    Separating bulk hemp or cannabis biomass from ethanol is the primary step in commercializing THC or CBD oil. Basket-type centrifuges have low bowl rpm and therefore have a limited centrifugal force. This reduced force prevents these centrifuges from extracting all the ethanol from the biomass.
                  </p>
                  <p class="text-gray-700 leading-relaxed mt-2">
                    Alfa Laval centrifuges have a much higher g-force, allowing these centrifuges to extract a high percentage of ethanol, leading to higher yields for cannabinoid processors.
                  </p>
                </div>
              </div>
            </div>

            <!-- Ethanol Polishing Pre-Winterization -->
            <div id="ethanol-polishing" class="mt-4 ml-0 md:ml-4">
              <h5 class="text-base font-semibold text-navy mb-2">Ethanol Polishing Pre-Winterization</h5>
              <p class="text-gray-700 leading-relaxed">
                The ethanol post-extraction carries waxes, lipids, chlorophyll, and other undesirable elements in the alcohol. These lipids and waxes are sticky and block downstream filter elements quickly, rendering them ineffective.
              </p>
              <p class="text-gray-700 leading-relaxed mt-2">
                An Alfa Laval disc stack centrifuge has the high centrifugal force to separate these small, suspended particles from the ethanol. The clarified ethanol still has the dissolved cannabinoids but is clearer, reducing the load on winterization filters.
              </p>
            </div>
          </div>
        </div>

        <!-- Oil and Gas -->
        <div id="oil-and-gas" class="mt-8 pt-6 border-t border-gray-100">
          <h3 class="text-xl font-semibold text-navy mb-4">Oil and Gas</h3>
          <p class="text-gray-700 leading-relaxed mb-4">
            The oil and gas production processes involve Alfa Laval centrifuges at various steps of the petroleum processing process. The following are some of the process steps that utilize Alfa Laval centrifugal separators.
          </p>

          <!-- Crude Oil Tank Bottoms -->
          <div id="crude-oil-tank-bottoms" class="md:flex md:gap-6 items-start mb-6">
            <div class="md:w-1/2 mb-4 md:mb-0 flex-shrink-0">
              <img
                src="/images/alfa-laval-centrifuge/crude-oil-tank-bottom-centrifuge-1-e1605467045511.jpg"
                alt="Crude Oil Tank Bottom Recovery Centrifuge separating oil, water, and sludge"
                width="599" height="217"
                loading="lazy"
                class="rounded-lg w-full"
              />
              <p class="text-xs text-gray-500 mt-1 text-center">Crude Oil Tank Bottom — Alfa Laval Centrifuge</p>
            </div>
            <div class="md:w-1/2">
              <h4 class="text-lg font-semibold text-navy mb-2">Crude Oil Tank Bottoms</h4>
              <p class="text-gray-700 leading-relaxed">
                Crude oil storage is standard in tanks in oilfields. The water and sludge from the crude oil settle out by gravity creating tank bottoms. Tank bottoms, therefore, are a mix of water, sludge, and crude oil. Tank bottoms recovery systems featuring Alfa Laval centrifuges are the most efficient way of recovering crude oil.
              </p>
            </div>
          </div>

          <!-- Crude Oil Heavy Metal Removal -->
          <div id="crude-oil-heavy-metal" class="mb-6">
            <h4 class="text-lg font-semibold text-navy mb-2">Crude Oil Heavy Metal Removal</h4>
            <p class="text-gray-700 leading-relaxed">
              Some crude oil has a high percentage of heavy metals such as cadmium, arsenic, iron, etc. Removing these metals is essential for the downstream processing of crude oil. Alfa Laval centrifuges separate the wash water from crude oil to produce oil with reduced levels of heavy metals.
            </p>
          </div>

          <!-- Crude Oil Recovery at SWD -->
          <div id="crude-oil-swd" class="md:flex md:gap-6 items-start">
            <div class="md:w-1/3 mb-4 md:mb-0 flex-shrink-0">
              <img
