---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Centrifuge Sample Testing",
  "description": "Send your fluid sample for industrial centrifuge testing. We test, analyze, and recommend the right separator system. Fast turnaround on results.",
  "provider": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com",
    "telephone": "+1-248-522-2573",
    "address": { "@type": "PostalAddress", "streetAddress": "24248 Gibson Dr.", "addressLocality": "Warren", "addressRegion": "MI", "postalCode": "48089", "addressCountry": "US" },
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "url": "https://dolphincentrifuge.com/industrial-centrifuge-sample-testing/",
};
---

<BaseLayout
  title="Centrifuge Sample Testing"
  description="Send your fluid sample for industrial centrifuge testing. We test, analyze, and recommend the right separator system. Fast turnaround on results."
  canonicalUrl="https://dolphincentrifuge.com/industrial-centrifuge-sample-testing/"
  breadcrumbs={[
    { label: 'Services', href: '/industrial-centrifuge-design/' },
    { label: 'Sample Testing' },
  ]}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-dolphin py-12 md:py-16">
      <span class="text-gold text-xs font-bold tracking-wider uppercase">Services</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-heading mt-2 mb-4">Centrifuge Sample Testing</h1>
      <p class="text-gray-300 text-lg max-w-2xl mb-6">
        Dolphin Centrifuge offers professional lab-scale centrifuge testing for your fluid samples. Send us a sample of your material and we will run it through our test centrifuges, measure the separation results, and deliver a detailed report with system recommendations.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors">Send a Sample</a>
        <a href="tel:2485222573" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors">(248) 522-2573</a>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="bg-warm-white">
    <div class="container-dolphin py-12 md:py-16 max-w-4xl">

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Why Test Before You Buy?</h2>
      <p class="text-text-muted mb-4">
        Every fluid is different. Viscosity, temperature, particle size distribution, emulsion stability, and chemical composition all affect how well a centrifuge will separate your material. Lab-scale testing on an actual centrifuge eliminates the guesswork and gives you hard data before you invest in a full-scale system.
      </p>
      <p class="text-text-muted mb-8">
        Our sample testing program helps you find the right separation solution with real data. We test hundreds of samples per year across industries including <a href="/oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">oil purification</a>, <a href="/wastewater-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">wastewater treatment</a>, food processing, chemical manufacturing, and more.
      </p>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">How the Testing Process Works</h2>
      <ol class="list-decimal list-inside space-y-4 text-text-muted mb-8 ml-4">
        <li>
          <strong>Contact Us &amp; Ship Your Sample:</strong> Call <a href="tel:2485222573" class="text-navy font-semibold hover:text-gold transition-colors">(248) 522-2573</a> or email <a href="mailto:sales@dolphincentrifuge.com" class="text-navy font-semibold hover:text-gold transition-colors">sales@dolphincentrifuge.com</a> to arrange testing. Ship 1&ndash;5 gallons of your material to our lab at 24248 Gibson Dr, Warren, MI 48089. Include a brief description of what you want to achieve (e.g., remove water from oil, clarify a liquid, dewater a sludge).
        </li>
        <li>
          <strong>We Run the Tests:</strong> Our engineers process your sample through lab-scale and pilot centrifuges at various speeds, temperatures, and flow rates to determine optimal separation parameters. We photograph before-and-after results and collect analytical data.
        </li>
        <li>
          <strong>You Receive a Detailed Report:</strong> Within 5&ndash;7 business days, you receive a comprehensive test report including separation data, photos, and our recommended centrifuge model and system configuration.
        </li>
        <li>
          <strong>We Recommend a System:</strong> Based on the test results and your production requirements (flow rate, operating hours, automation level), we recommend a specific centrifuge system and provide a quotation.
        </li>
      </ol>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">What the Test Report Includes</h2>
      <p class="text-text-muted mb-4">
        Our test reports are thorough and designed to give you the confidence to make an informed purchasing decision:
      </p>
      <ul class="list-disc list-inside space-y-2 text-text-muted mb-8 ml-4">
        <li><strong>Before &amp; After Photos:</strong> Visual comparison of your sample before and after centrifuge processing</li>
        <li><strong>Separation Data:</strong> Measured water content, solids content, particle size removal, and clarity readings</li>
        <li><strong>Optimal Parameters:</strong> Recommended bowl speed, flow rate, temperature, and discharge frequency</li>
        <li><strong>Centrifuge Type Recommendation:</strong> Whether your application requires a disc stack separator, decanter, or both</li>
        <li><strong>Model &amp; System Recommendation:</strong> Specific Dolphin centrifuge model, system configuration, and capacity</li>
        <li><strong>ROI Considerations:</strong> Estimated operating costs, consumable savings vs. filters, and payback timeline</li>
      </ul>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Sample Requirements</h2>
      <p class="text-text-muted mb-4">
        To get the most useful results from testing, please follow these guidelines when shipping your sample:
      </p>
      <ul class="list-disc list-inside space-y-2 text-text-muted mb-8 ml-4">
        <li><strong>Volume:</strong> 1&ndash;5 gallons is ideal. We can work with as little as 1 quart for initial screening</li>
        <li><strong>Container:</strong> Use a sealed, leak-proof container. Plastic jugs or pails work well</li>
        <li><strong>Labeling:</strong> Include your company name, contact information, and material description</li>
        <li><strong>Temperature:</strong> Ship at ambient temperature. Note if the material needs to be heated for processing</li>
        <li><strong>Safety Data:</strong> Include an SDS (Safety Data Sheet) if the material is hazardous</li>
        <li><strong>Shipping:</strong> Standard ground shipping is fine. We can provide a UPS or FedEx label if needed</li>
      </ul>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">Common Materials We Test</h2>
      <p class="text-text-muted mb-4">
        We have tested thousands of different fluids and slurries over 40+ years. Common materials include:
      </p>
      <div class="grid md:grid-cols-2 gap-4 mb-8">
        <ul class="list-disc list-inside space-y-1 text-text-muted ml-4">
          <li><a href="/waste-oil-centrifuge/" class="text-navy hover:text-gold transition-colors">Waste oil and used oil</a></li>
          <li><a href="/diesel-centrifuge/" class="text-navy hover:text-gold transition-colors">Diesel fuel and biodiesel</a></li>
          <li><a href="/hydraulic-oil-centrifuge/" class="text-navy hover:text-gold transition-colors">Hydraulic and lube oils</a></li>
          <li><a href="/crude-oil-centrifuge/" class="text-navy hover:text-gold transition-colors">Crude oil and tank bottoms</a></li>
          <li><a href="/cutting-oil-centrifuge/" class="text-navy hover:text-gold transition-colors">Cutting fluids and coolants</a></li>
        </ul>
        <ul class="list-disc list-inside space-y-1 text-text-muted ml-4">
          <li>Wastewater and process water</li>
          <li>Food-grade oils and fats</li>
          <li>Chemical process liquids</li>
          <li>Sludge and slurries for dewatering</li>
          <li>Any fluid requiring clarification</li>
        </ul>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold font-heading text-navy mb-4">What Happens After Testing?</h2>
      <p class="text-text-muted mb-4">
        Once you have your test results, you can use the data to:
      </p>
      <ul class="list-disc list-inside space-y-2 text-text-muted mb-8 ml-4">
        <li><strong>Purchase a system:</strong> We provide a complete quotation for the recommended centrifuge and turnkey system from our <a href="/industrial-centrifuge-design/" class="text-navy font-semibold hover:text-gold transition-colors">design and engineering team</a></li>
        <li><strong>Rent first:</strong> Start with a <a href="/disc-stack-centrifuge-rental/" class="text-navy font-semibold hover:text-gold transition-colors">centrifuge rental</a> to validate performance at full scale in your facility</li>
        <li><strong>Keep the data:</strong> The test report is yours. Use it for internal justification, budgeting, or comparison</li>
      </ul>

    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-navy">
    <div class="container-dolphin py-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Send Us Your Sample</h2>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">Ship 1&ndash;5 gallons to our lab and get a detailed separation report with system recommendations.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3.5 rounded-lg transition-colors">Arrange Sample Testing</a>
        <a href="tel:2485222573" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3.5 rounded-lg transition-colors">Call (248) 522-2573</a>
      </div>
    </div>
  </section>
</BaseLayout>
