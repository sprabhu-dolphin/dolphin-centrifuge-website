                  <td class="border border-gray-200 px-3 py-2 text-center font-bold text-yellow-700">Medium</td>
                </tr>
                <tr class="bg-gray-50">
                  <td class="border border-gray-200 px-3 py-2 font-bold">Total Cost of Ownership</td>
                  <td class="border border-gray-200 px-3 py-2 text-center text-green-700 font-bold">Low</td>
                  <td class="border border-gray-200 px-3 py-2 text-center text-red-600 font-bold">High</td>
