---
import ApplicationLayout from '../layouts/ApplicationLayout.astro';

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Alfa Laval WSPX 307 Coolant Centrifuge",
  "description": "Alfa Laval WSPX 307 TGD 3-phase disc centrifuge. 22 GPM, 8,600 RPM, 7,000+ G-Force. Self-cleaning coolant centrifuge for tramp oil and particle separation.",
  "brand": { "@type": "Brand", "name": "Dolphin Centrifuge" },
  "manufacturer": { "@type": "Organization", "name": "Dolphin Centrifuge", "url": "https://dolphincentrifuge.com" },
  "url": "https://dolphincentrifuge.com/alfa-laval-wspx-307/",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": { "@type": "Organization", "name": "Dolphin Centrifuge" }
  }
};

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Alfa Laval WSPX 307 Self-Cleaning Coolant Centrifuge",
  "description": "Technical overview of the Alfa Laval WSPX 307 TGD self-cleaning 3-phase disc centrifuge for tramp oil and particle removal from machine coolant at 22 GPM.",
  "author": {
    "@type": "Person",
    "name": "Sanjay Prabhu MSME",
    "jobTitle": "Centrifuge Applications Engineer",
    "worksFor": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  },
  "url": "https://dolphincentrifuge.com/alfa-laval-wspx-307/"
};

const jsonLd = [productJsonLd, articleJsonLd];

const toc = [
  { id: 'overview', label: 'WSPX 307 Operation' },
  { id: 'specifications', label: 'WSPX 307 Specifications' },
  { id: 'applications', label: 'Applications' },
  { id: 'wspx-series', label: 'WSPX Series Positioning' },
  { id: 'faq', label: 'Frequently Asked Questions' },
];

const relatedApplications = [
  { label: 'Machine Coolant Centrifuge', href: '/machine-coolant-centrifuge/' },
  { label: 'Cutting Oil Centrifuge', href: '/cutting-oil-centrifuge/' },
];

const relatedProducts = [
  { label: 'WSPX 207 Centrifuge', href: '/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/', description: 'Entry-level coolant centrifuge' },
  { label: 'WSPX 303 Centrifuge', href: '/alfa-laval-wspx-303-centrifuge/', description: 'Mid-size coolant centrifuge' },
  { label: 'WSPX 407 Centrifuge', href: '/alfa-laval-wspx-407/', description: 'Highest capacity coolant centrifuge' },
];
---

<ApplicationLayout
  title="Alfa Laval WSPX 307 Coolant Centrifuge | Dolphin"
  description="Alfa Laval WSPX 307 TGD self-cleaning disc centrifuge — 22 GPM, 8,600 RPM, 7,000+ G-Force. Tramp oil and particle removal from machine coolant. Dolphin."
  category="products"
  categoryLabel="Products"
  heroImage="/images/alfa-laval-wspx-307/Alfa-Laval-WSPX-307-Water-Based-Coolant-Centrifuge.webp"
  heroImageAlt="Alfa Laval WSPX 307 water-based coolant centrifuge for tramp oil removal"
  canonicalUrl="https://dolphincentrifuge.com/alfa-laval-wspx-307/"
  jsonLd={jsonLd}
  toc={toc}
  relatedApplications={relatedApplications}
  relatedProducts={relatedProducts}
>

  <div class="bg-navy/5 border-l-4 border-gold/40 rounded-r-lg p-4 mb-6 not-prose">
    <p class="text-sm text-text-light leading-relaxed italic">Dolphin Centrifuge supplies parts, repairs, and remanufactured Alfa Laval WSPX 307 3-phase disc centrifuges operating at 8,600 RPM (7,000+ G-Force) with a rated capacity of 22 GPM. Ideal for tramp oil and sub-micron particle removal from machine coolant in automotive, aerospace, and precision machining facilities. Warren, Michigan — over 40 years of experience.</p>
  </div>

  <h2 id="overview">WSPX 307 Operation</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-1/2">
      <p>
        The Alfa Laval WSPX-307 Disc Centrifuge is a 3-phase separator designed to separate tramp oil and small particles from machine coolant. It is a self-cleaning <a href="/disc-stack-centrifuge/">disc stack centrifuge</a> engineered for high-volume coolant processing in production machining facilities.
      </p>
      <p>
        The centrifuge bowl rotates at 8,600 RPM exerting over 7,000 G-Force. Like all WSPX models, the WSPX 307 uses automatic (self-cleaning) sludge discharge to maintain continuous operation without manual bowl maintenance. This makes it ideal for <a href="/machine-coolant-centrifuge/">central coolant recovery</a> and <a href="/cutting-oil-centrifuge/">cutting oil purification</a> in 24/7 production schedules.
      </p>
    </div>
    <div class="md:w-1/2">
      <img
        src="/images/alfa-laval-wspx-307/Alfa-Laval-WSPX-307-Water-Based-Coolant-Centrifuge.webp"
        alt="Alfa Laval WSPX 307 water-based coolant centrifuge"
        width="1000"
        height="673"
        loading="lazy"
        class="rounded-lg w-full"
      />
    </div>
  </div>

  <p>
    This is a proven solution in automotive powertrain machining, aerospace structural component manufacturing, and other high-volume metalworking operations. For ongoing service, Dolphin Centrifuge offers full <a href="/industrial-disc-centrifuge-repair/">centrifuge repair and rebuild services</a> for the WSPX series.
  </p>

  <div class="bg-gold/10 border-l-4 border-gold rounded-r-xl p-5 my-8 not-prose">
    <p class="text-base font-semibold text-navy mb-1">Need parts, repairs, or a remanufactured WSPX 307?</p>
    <p class="text-sm text-text-light mb-3">Dolphin Centrifuge supplies the WSPX 307 along with rebuild services and application support. <a href="/industrial-centrifuge-sample-testing/" class="text-navy font-semibold hover:text-gold">Sample testing</a> is available to validate coolant separation performance. The newer <a href="/alfa-laval-wspx-407/" class="text-navy font-semibold hover:text-gold">WSPX 407</a> model is also available.</p>
    <a href="/contact-for-alfa-laval-centrifuges/" class="inline-block bg-gold hover:bg-gold/80 text-navy font-bold px-6 py-2 rounded-lg transition-colors text-sm">Request a Quote &rarr;</a>
  </div>

  <h2 id="specifications">WSPX 307 Specifications</h2>

  <table>
    <tbody>
      <tr><td><strong>Model Type</strong></td><td>Alfa Laval WSPX 307 TGD</td></tr>
      <tr><td><strong>Rated Capacity</strong></td><td>22 GPM</td></tr>
      <tr><td><strong>Sludge Space</strong></td><td>0.87 Gallons</td></tr>
      <tr><td><strong>Motor HP</strong></td><td>10 HP</td></tr>
      <tr><td><strong>Bowl Speed</strong></td><td>8,600 RPM</td></tr>
      <tr><td><strong>G-Force</strong></td><td>7,000+</td></tr>
      <tr><td><strong>Bowl Type</strong></td><td>Self-Cleaning (Automatic Discharge)</td></tr>
      <tr><td><strong>Voltages</strong></td><td>230 / 460 V</td></tr>
    </tbody>
  </table>

  <h2 id="applications">Applications</h2>

  <div class="grid md:grid-cols-2 gap-x-8 gap-y-2 mb-8 not-prose">
    <ul class="text-text-light space-y-2">
      <li>&#8226; <a href="/machine-coolant-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">High-volume central coolant recovery</a></li>
      <li>&#8226; Automotive powertrain machining lines</li>
      <li>&#8226; Aerospace structural component machining</li>
      <li>&#8226; Large transfer line coolant systems</li>
    </ul>
    <ul class="text-text-light space-y-2">
      <li>&#8226; <a href="/cutting-oil-centrifuge/" class="text-navy font-semibold hover:text-gold transition-colors">High-volume cutting fluid recycling</a></li>
      <li>&#8226; Grinding fluid clarification</li>
      <li>&#8226; Metal fines and swarf removal</li>
      <li>&#8226; Tramp oil separation at scale</li>
    </ul>
  </div>

  <h2 id="wspx-series">WSPX Series — Where the 307 Fits</h2>

  <p>
    The newer model <a href="/alfa-laval-wspx-407/">Alfa Laval WSPX 407</a> is now available. The previous version of this coolant centrifuge, <a href="/alfa-laval-wspx-207-self-cleaning-coolant-centrifuge/">Alfa Laval WSPX 207</a>, is also available. For mid-range systems, the <a href="/alfa-laval-wspx-303-centrifuge/">WSPX 303</a> handles central multi-machine coolant circuits.
  </p>

  <div class="grid md:grid-cols-3 gap-6 mb-8 not-prose">
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2"><a href="/alfa-laval-wspx-303-centrifuge/" class="text-navy hover:text-gold transition-colors">WSPX 303</a></h3>
      <p class="text-sm text-text-light">8 GPM. Central coolant and multi-machine circuits.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border-2 border-gold">
      <h3 class="text-lg font-bold text-navy mb-2">WSPX 307 — Current</h3>
      <p class="text-sm text-text-light">22 GPM, 10 HP. Automotive and aerospace machining facilities.</p>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-navy mb-2"><a href="/alfa-laval-wspx-407/" class="text-navy hover:text-gold transition-colors">WSPX 407</a></h3>
      <p class="text-sm text-text-light">25 GPM. Large central coolant plants.</p>
    </div>
  </div>

  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What is the flow capacity of the Alfa Laval WSPX 307?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The WSPX 307 has a rated capacity of 22 GPM. The centrifuge bowl rotates at 8,600 RPM exerting over 7,000 G-Force, making it a high-volume self-cleaning disc centrifuge for central coolant systems in automotive, aerospace, and precision machining facilities.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What industries use the WSPX 307 coolant centrifuge?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The WSPX 307 is used in automotive powertrain machining, aerospace structural component manufacturing, precision grinding, and other high-volume metalworking environments where a central coolant system serves many machines and requires continuous high-throughput coolant recirculation and purification.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      How does the WSPX 307 compare to the WSPX 207 and WSPX 407?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The WSPX 207 is the entry-level self-cleaning coolant centrifuge at 20 GPM. The WSPX 307 (22 GPM, 10 HP) is the mid-range model for large central systems. The WSPX 407 (25 GPM) is the highest-capacity model for the largest central coolant plants. All three use the same automatic self-cleaning bowl technology.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      What particles does the WSPX 307 remove from coolant?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">The WSPX 307 removes metal fines, grinding swarf, and tramp oil from water-based coolant at 7,000+ Gs. Its 3-phase separation simultaneously removes both solid particles and free oil from the coolant stream, eliminating the need for separate oil skimmers or filter presses.</p>
  </details>
  <details class="border-l-4 border-gold/40 pl-4 mb-3 group">
    <summary class="cursor-pointer font-semibold text-navy py-2 list-none flex justify-between items-center">
      Can Dolphin Centrifuge supply parts or rebuild the WSPX 307?
      <span class="text-gold ml-2 group-open:rotate-180 transition-transform">&#9660;</span>
    </summary>
    <p class="text-text-light mt-2 pb-2">Yes. Dolphin Centrifuge supplies genuine and compatible replacement parts for the WSPX 307, including disc stacks, seals, bearings, and discharge valve components. Complete bowl rebuilds and remanufactured WSPX 307 centrifuges are available. Contact us for parts availability and service scheduling.</p>
  </details>

  <div class="bg-navy rounded-xl p-8 text-center mt-12 not-prose">
    <h2 class="text-2xl font-bold text-white mb-3">Parts, Repairs &amp; Remanufactured WSPX 307</h2>
    <p class="text-gray-300 mb-6 max-w-lg mx-auto">Contact Dolphin Centrifuge for pricing, system design support, and application evaluation. Sample testing available for qualifying projects.</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/contact-for-alfa-laval-centrifuges/" class="bg-gold hover:bg-gold/80 text-navy font-bold px-8 py-3 rounded-lg transition-colors">Get a Quote</a>
      <a href="/industrial-centrifuge-sample-testing/" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">Sample Testing</a>
      <a href="tel:+12485222573" class="border border-white/30 hover:border-gold text-white font-semibold px-8 py-3 rounded-lg transition-colors">(248) 522-2573</a>
    </div>
  </div>

</ApplicationLayout>
