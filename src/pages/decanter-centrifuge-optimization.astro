    "author": {
      "@type": "Person",
      "name": "Sanjay Prabhu MSME",
      "jobTitle": "Centrifuge Applications Engineer",
      "worksFor": {
        "@type": "Organization",
        "name": "Dolphin Centrifuge"
      }
    },
    "publisher": {
      "@type": "Organization",
      "name": "Dolphin Centrifuge",
