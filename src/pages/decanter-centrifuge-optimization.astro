---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are the main ways to improve decanter centrifuge separation performance?",
      "acceptedAnswer": { "@type": "Answer", "text": "The five primary optimization parameters are: pond depth (weir plate position), bowl speed (G-force), differential speed (scroll vs. bowl), scroll pitch angle, and process fluid temperature. Adjusting these in sequence — starting with pond depth then bowl speed — allows operators to tune the machine for both cake dryness and centrate clarity without hardware changes." }
    },
    {
      "@type": "Question",
      "name": "What happens if bowl speed is set too high on a decanter centrifuge?",
      "acceptedAnswer": { "@type": "Answer", "text": "Excessively high bowl speed increases G-force but also increases bearing wear and mechanical stress. Higher speed can also create finer particle fragmentation that may resist sedimentation. For most applications, operating at the manufacturer's recommended bowl speed is optimal — over-speeding rarely improves performance and accelerates wear." }
    },
    {
      "@type": "Question",
      "name": "How does process fluid temperature affect decanter centrifuge performance?",
      "acceptedAnswer": { "@type": "Answer", "text": "Higher process temperature reduces fluid viscosity, allowing finer solids to sediment faster under centrifugal force. Heating feed to 60–80°C for oil-water systems can significantly improve separation quality without changing any mechanical settings. Dolphin Centrifuge supplies fluid heating systems for viscous oil processing applications." }
    }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "5 Ways to Optimize Decanter Centrifuge Performance — Illustrated Guide",
  "description": "How to optimize decanter centrifuge performance by adjusting pond depth, bowl speed, auger speed, auger pitch, and process fluid temperature. Includes performance curves and illustrated diagrams.",
  "author": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dolphin Centrifuge",
    "url": "https://dolphincentrifuge.com"
  },
  "datePublished": "2021-02-01",
  "dateModified": "2024-06-01"
};
---

<BaseLayout
  title="5 Ways to Optimize Decanter Performance | Illustrated Guide"
  description="Optimize decanter centrifuge performance by adjusting pond depth, bowl speed, auger differential speed, auger pitch, and temperature. Illustrated guide."
  canonicalUrl="https://dolphincentrifuge.com/decanter-centrifuge-optimization/"
