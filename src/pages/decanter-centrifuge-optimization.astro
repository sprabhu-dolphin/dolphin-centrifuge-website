            <circle cx="80" cy="232" r="4" fill="#E8A317"/>
            <circle cx="200" cy="198" r="4" fill="#E8A317"/>
            <circle cx="290" cy="148" r="4" fill="#E8A317"/>
            <circle cx="390" cy="100" r="4" fill="#E8A317"/>
            <circle cx="460" cy="80" r="4" fill="#E8A317"/>

            <!-- Bearing Wear curve — Red #DC2626 — moderate rise -->
            <path d="M 80 234 C 150 222, 220 195, 290 162 S 390 118, 460 100" fill="none" stroke="#DC2626" stroke-width="3" stroke-linecap="round"/>
            <circle cx="80" cy="234" r="4" fill="#DC2626"/>
            <circle cx="200" cy="204" r="4" fill="#DC2626"/>
            <circle cx="290" cy="162" r="4" fill="#DC2626"/>
            <circle cx="390" cy="120" r="4" fill="#DC2626"/>
            <circle cx="460" cy="100" r="4" fill="#DC2626"/>

            <!-- Vibration curve — Gray #6B7280 — gentle rise -->
