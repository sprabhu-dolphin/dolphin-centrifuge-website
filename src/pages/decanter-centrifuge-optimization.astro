    "dateModified": "2024-06-01"
  }
];

const toc = [
  { id: "summary-takeaway", label: "30 Second Summary Takeaway" },
  { id: "pond-depth", label: "Pond Depth" },
  { id: "bowl-speed", label: "Bowl Rotation or Bowl Speed" },
  { id: "auger-speed", label: "Auger (Scroll) Speed" },
  { id: "auger-pitch", label: "Auger Pitch" },
  { id: "temperature", label: "Process Fluid Temperature" },
  { id: "summary", label: "Summary" },
];

const relatedProducts = [
  { label: "NX-314 Decanter Centrifuge", href: "/alfa-laval-nx-314-decanter-centrifuge/", description: "2-phase decanter, up to 3,000 RPM" },
  { label: "NX-418 Decanter Centrifuge", href: "/alfa-laval-nx-418-decanter-centrifuge/", description: "3-phase decanter for oil-water-solids" },
  { label: "G2-40 Decanter Centrifuge", href: "/alfa-laval-g2-40-decanter/", description: "High-capacity industrial decanter" },
];

const relatedApplications = [
  { label: "Decanter Centrifuge Applications", href: "/decanter-centrifuge-applications/" },
  { label: "Decanter Differential Speed", href: "/decanter-centrifuge-differential-speed/" },
  { label: "Decanter Pond Depth", href: "/decanter-centrifuge-pond-depth/" },
  { label: "Decanter vs Disc Stack", href: "/difference-between-decanter-centrifuge-disc-centrifuge/" },
  { label: "Decanter Centrifuge Vibration", href: "/decanter-centrifuge-vibration/" },
