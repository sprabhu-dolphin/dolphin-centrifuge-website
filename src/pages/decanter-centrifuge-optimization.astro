            <circle cx="290" cy="100" r="4" fill="#1B3A5C"/>
            <circle cx="390" cy="56" r="4" fill="#1B3A5C"/>
            <circle cx="460" cy="44" r="4" fill="#1B3A5C"/>

            <!-- Noise Level curve — Gold #E8A317 — moderate rise -->
