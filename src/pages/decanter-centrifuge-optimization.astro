            <circle cx="80" cy="236" r="4" fill="#6B7280"/>
            <circle cx="200" cy="214" r="4" fill="#6B7280"/>
            <circle cx="290" cy="188" r="4" fill="#6B7280"/>
            <circle cx="390" cy="158" r="4" fill="#6B7280"/>
            <circle cx="460" cy="142" r="4" fill="#6B7280"/>

            <!-- Axis labels -->
            <text x="85" y="262" font-family="monospace" font-size="10" fill="#6b7280">Low</text>
            <text x="440" y="262" font-family="monospace" font-size="10" fill="#6b7280">High</text>
            <text x="270" y="278" font-family="'Plus Jakarta Sans', sans-serif" font-size="11" fill="#1B3A5C" font-weight="600" text-anchor="middle">← Bowl Speed →</text>

            <!-- Y-axis label (rotated) -->
