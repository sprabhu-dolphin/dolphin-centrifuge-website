  <!-- ── Centrifuge Operation ── -->
  <h2 id="centrifuge-operation">WVO Centrifuge Operation</h2>

  <div class="flex flex-col md:flex-row gap-6 items-start mb-6">
    <div class="md:w-[40%] shrink-0">
      <img
        src="/images/wvo-centrifuge-separator/Alfa-Laval-MOPX-209-Centrifuge-for-WVO-Installation.webp"
