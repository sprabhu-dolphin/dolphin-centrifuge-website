---
// "What are you separating?" application tiles — with WebP icons and sub-links
const tiles = [
  {
    title: 'Used - Waste Oil Separation',
    icon: '/images/icons/applications/waste-oil-centrifuge-recycling.webp',
    href: '/waste-oil-centrifuge/',
    links: [
      { label: 'Waste Oil', href: '/waste-oil-centrifuge/' },
      { label: 'Used Oil', href: '/used-oil-centrifuge/' },
      { label: 'WVO', href: '/wvo-centrifuge-separator/' },
      { label: 'Biodiesel', href: '/biodiesel-centrifuge/' },
    ],
  },
  {
    title: 'Fuel Separation',
    icon: '/images/icons/applications/fuel-lube-oil-centrifuge-purification.webp',
    href: '/diesel-centrifuge/',
    links: [
      { label: 'Diesel', href: '/diesel-centrifuge/' },
      { label: 'HFO / Fuel Oil', href: '/fuel-oil-centrifuge/' },
      { label: 'Pyrolysis Oil', href: '/pyrolysis-oil-centrifuge/' },
    ],
  },
  {
    title: 'Industrial Fluids',
    icon: '/images/icons/applications/metalworking-centrifuge-coolant-filtration.webp',
    href: '/machine-coolant-centrifuge/',
    links: [
      { label: 'Coolant', href: '/machine-coolant-centrifuge/' },
      { label: 'Cutting Oil', href: '/cutting-oil-centrifuge/' },
      { label: 'Quench Oil', href: '/quench-oil-centrifuge/' },
    ],
  },
  {
    title: 'Lube & Hydraulic Oil',
    icon: '/images/icons/applications/oil-gas-centrifuge-separation.webp',
    href: '/lube-oil-centrifuge/',
    links: [
      { label: 'Lube Oil', href: '/lube-oil-centrifuge/' },
      { label: 'Hydraulic Oil', href: '/hydraulic-oil-centrifuge/' },
    ],
  },
  {
    title: 'Crude Oil & BS&W',
    icon: '/images/icons/applications/oil-gas-centrifuge-separation.webp',
    href: '/crude-oil-centrifuge/',
    links: [
      { label: 'Crude Oil', href: '/crude-oil-centrifuge/' },
      { label: 'Tank Bottoms', href: '/crude-oil-tank-bottom-recovery-centrifuge/' },
    ],
  },
  {
    title: 'Biomass & Organics',
    icon: '/images/icons/applications/botanical-extraction-centrifuge.webp',
    href: '/algae-centrifuge/',
    links: [
      { label: 'Algae', href: '/algae-centrifuge/' },
      { label: 'Manure', href: '/manure-centrifuge-separator/' },
      { label: 'Humus', href: '/liquid-humus-centrifuge/' },
    ],
  },
  {
    title: 'Wastewater',
    icon: '/images/icons/applications/wastewater-centrifuge-treatment.webp',
    href: '/wastewater-centrifuge/',
    links: [
      { label: 'Wastewater', href: '/wastewater-centrifuge/' },
      { label: 'Dewatering', href: '/dewatering-centrifuge/' },
    ],
  },
  {
    title: 'Beverage & Seafood',
    icon: '/images/icons/applications/food-beverage-centrifuge-processing.webp',
    href: '/beer-wine-centrifuge/',
    links: [
      { label: 'Beer / Wine', href: '/beer-wine-centrifuge/' },
      { label: 'Fish Processing', href: '/fish-processing-centrifuge/' },
    ],
  },
];
---

<section class="py-16 md:py-20 lg:py-24 bg-light-bg">
  <div class="container-dolphin">
    <div class="text-center mb-12">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-navy">
        What Are You Separating?
      </h2>
      <p class="mt-3 text-text-muted text-base max-w-xl mx-auto">
        Select your industry to find the right centrifuge solution for your application.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6 max-w-[1180px] mx-auto">
      {tiles.map((tile) => (
        <div
          class="group bg-white rounded-xl p-6 border border-gray-200 hover:border-navy/30 transition-all duration-200 hover:-translate-y-1 hover:shadow-lg cursor-pointer"
          onclick={`window.location.href='${tile.href}'`}
          role="link"
          tabindex="0"
        >
          {/* Icon badge */}
          <div class="mb-4">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-navy/5 group-hover:bg-navy transition-colors">
              <img
                src={tile.icon}
                alt={tile.title}
                class="w-8 h-8 object-contain group-hover:brightness-0 group-hover:invert transition-all"
                loading="lazy"
              />
            </div>
          </div>

          {/* Title */}
          <h3 class="font-heading font-bold text-lg text-navy uppercase tracking-wide mb-3 group-hover:text-navy-light transition-colors">
            {tile.title}
          </h3>

          {/* Sub-links */}
          <div class="flex flex-wrap items-center gap-x-1 gap-y-1" onclick="event.stopPropagation()">
            {tile.links.map((link, i) => (
              <>
                <a
                  href={link.href}
                  class="text-sm text-text-muted hover:text-gold-dark transition-colors"
                >
                  {link.label}
                </a>
                {i < tile.links.length - 1 && (
                  <span class="text-gray-300 text-xs">•</span>
                )}
              </>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
