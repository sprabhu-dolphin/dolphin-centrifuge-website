---
// "What are you separating?" quick selector section
const options = [
  { label: 'Waste Oil / Used Oil', href: '/applications/oil-gas/waste-oil/', icon: '🛢️' },
  { label: 'Machining Coolant', href: '/applications/metalworking/machining-coolant/', icon: '⚙️' },
  { label: 'Diesel / Fuel Oil', href: '/applications/oil-gas/diesel-fuel/', icon: '⛽' },
  { label: 'Wastewater / Sludge', href: '/applications/water-treatment/wastewater/', icon: '🌊' },
  { label: 'Crude Oil / Tank Bottoms', href: '/applications/oil-gas/crude-oil/', icon: '🏗️' },
  { label: 'Hemp / Cannabis Extract', href: '/applications/cannabis/', icon: '🌿' },
  { label: 'Food & Beverage', href: '/applications/food-beverage/', icon: '🍺' },
  { label: 'Something Else', href: '/contact/', icon: '❓' },
];
---

<section class="py-16 md:py-20 bg-light-bg">
  <div class="container-dolphin">
    <div class="text-center mb-10">
      <p class="inline-flex items-center gap-2 text-gold-dark font-bold text-xs uppercase tracking-[0.2em] mb-3">
        <span class="w-6 h-0.5 bg-gold rounded"></span>
        Find Your Solution
        <span class="w-6 h-0.5 bg-gold rounded"></span>
      </p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-navy">
        What Are You Separating?
      </h2>
      <p class="text-text-light text-lg mt-3 max-w-xl mx-auto">
        Select your application to find the right centrifuge for your process.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 max-w-4xl mx-auto">
      {options.map((opt) => (
        <a
          href={opt.href}
          class="group flex items-center gap-3 bg-white hover:bg-navy hover:text-white text-text p-4 rounded-xl border border-gray-200 hover:border-navy transition-all duration-200 shadow-sm hover:shadow-lg"
        >
          <span class="text-2xl shrink-0">{opt.icon}</span>
          <span class="text-sm font-semibold leading-snug group-hover:text-white transition-colors">
            {opt.label}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
