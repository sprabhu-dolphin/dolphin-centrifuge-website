---
// Hero section with optional background image slider
// Slider mode: shows initialImage first, then rotates sliderImages right-to-left
// Static mode: shows single imageSrc as background

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  /* Static mode */
  imageSrc?: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  /* Slider mode */
  initialImage?: { src: string; alt: string };
  sliderImages?: Array<{ src: string; alt: string }>;
  /* Common */
  ctaLabel?: string;
  ctaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
  compact?: boolean;
  overlay?: 'dark' | 'navy' | 'gradient' | 'frost';
  categoryLabel?: string;
}

const {
  title,
  subtitle,
  description,
  imageSrc,
  imageAlt,
  imageWidth,
  imageHeight,
  initialImage,
  sliderImages,
  ctaLabel,
  ctaHref,
  secondaryCtaLabel,
  secondaryCtaHref,
  compact = false,
  overlay = 'gradient',
  categoryLabel,
} = Astro.props;

const isSlider = !!(initialImage && sliderImages?.length);
const isFrost = overlay === 'frost';

const overlayClass = {
  dark: 'bg-black/60',
  navy: 'bg-navy/75',
  gradient: 'bg-gradient-to-r from-navy-dark/90 via-navy/70 to-transparent',
  frost: 'bg-navy/55',
}[overlay];

const heightClass = compact
  ? 'min-h-[240px] md:min-h-[300px]'
  : 'min-h-[320px] md:min-h-[380px] lg:min-h-[420px]';
---

<section
  class={`relative ${heightClass} flex items-center overflow-hidden`}
  data-hero-slider={isSlider ? 'true' : undefined}
>
  {/* ── Background: either slider or static ── */}
  {isSlider ? (
    <div class="hero-slider-track absolute inset-0">
      {/* Slide A — starts visible with the initial (branding) image */}
      <div class="hero-slide hero-slide--active absolute inset-0" data-slide="A">
        <img
          src={initialImage.src}
          alt={initialImage.alt}
          class="w-full h-full object-cover"
          loading="eager"
          decoding="async"
        />
      </div>
      {/* Slide B — starts off-screen right, used for incoming image */}
      <div class="hero-slide hero-slide--next absolute inset-0" data-slide="B">
        <img
          src={sliderImages[0].src}
          alt={sliderImages[0].alt}
          class="w-full h-full object-cover"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  ) : (
    <img
      src={imageSrc}
      alt={imageAlt}
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      width={imageWidth}
      height={imageHeight}
    />
  )}

  {/* ── Overlay ── */}
  <div class={`absolute inset-0 ${overlayClass} z-[1]`}></div>

  {/* ── Subtle texture ── */}
  <div
    class="absolute inset-0 opacity-[0.03] z-[1]"
    style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"
  ></div>

  {/* ── Content ── */}
  <div class="relative z-10 container-dolphin w-full">
    <div class={`${compact ? 'py-8' : 'py-10 md:py-14'} ${isFrost ? '' : 'max-w-2xl'}`}>
      {isFrost ? (
        /* ── Frosted Glass Box ── */
        <div class="hero-frost-box max-w-[95%] lg:max-w-[55%] bg-navy/55 backdrop-blur-xl rounded-2xl border border-white/10 p-6 md:p-8">
          {categoryLabel && (
            <p class="inline-flex items-center gap-2 text-gold font-bold text-xs md:text-sm uppercase tracking-[0.2em] mb-3">
              <span class="w-2 h-2 bg-gold rounded-full"></span>
              {categoryLabel}
            </p>
          )}

          {subtitle && !categoryLabel && (
            <p class="inline-flex items-center gap-2 text-gold font-bold text-xs md:text-sm uppercase tracking-[0.2em] mb-3">
              <span class="w-8 h-0.5 bg-gold rounded"></span>
              {subtitle}
            </p>
          )}

          <h1 class={`text-white font-bold leading-[1.1] tracking-tight ${
            compact
              ? 'text-2xl md:text-4xl'
              : 'text-2xl md:text-4xl lg:text-5xl'
          }`}>
            {title}
          </h1>

          {description && (
            <p class={`text-gray-200 leading-relaxed mt-3 md:mt-4 ${compact ? 'text-base' : 'text-base md:text-lg'}`}>
              {description}
            </p>
          )}

          {(ctaLabel || secondaryCtaLabel) && (
            <div class="flex flex-col sm:flex-row gap-3 mt-6">
              {ctaLabel && ctaHref && (
                <a
                  href={ctaHref}
                  class="inline-flex items-center justify-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold px-6 py-3 rounded-lg transition-colors shadow-lg shadow-gold/25 text-sm"
                >
                  {ctaLabel}
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                </a>
              )}
              {secondaryCtaLabel && secondaryCtaHref && (
                <a
                  href={secondaryCtaHref}
                  class="inline-flex items-center justify-center gap-2 border-2 border-white/40 hover:border-white text-white font-semibold px-6 py-3 rounded-lg transition-all text-sm hover:bg-white/10"
                >
                  {secondaryCtaLabel}
                </a>
              )}
            </div>
          )}
        </div>
      ) : (
        /* ── Original (non-frost) content ── */
        <Fragment>
          {subtitle && (
            <p class="inline-flex items-center gap-2 text-gold font-bold text-xs md:text-sm uppercase tracking-[0.2em] mb-4">
              <span class="w-8 h-0.5 bg-gold rounded"></span>
              {subtitle}
            </p>
          )}

          <h1 class={`text-white font-bold leading-[1.1] tracking-tight ${
            compact
              ? 'text-2xl md:text-4xl'
              : 'text-3xl md:text-5xl lg:text-[3.5rem]'
          }`}>
            {title}
          </h1>

          {description && (
            <p class={`text-gray-200 leading-relaxed mt-4 md:mt-6 ${compact ? 'text-base' : 'text-lg md:text-xl'}`}>
              {description}
            </p>
          )}

          {(ctaLabel || secondaryCtaLabel) && (
            <div class="flex flex-col sm:flex-row gap-3 mt-8">
              {ctaLabel && ctaHref && (
                <a
                  href={ctaHref}
                  class="inline-flex items-center justify-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold px-7 py-3.5 rounded-lg transition-colors shadow-lg shadow-gold/25 text-base"
                >
                  {ctaLabel}
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                </a>
              )}
              {secondaryCtaLabel && secondaryCtaHref && (
                <a
                  href={secondaryCtaHref}
                  class="inline-flex items-center justify-center gap-2 border-2 border-white/40 hover:border-white text-white font-semibold px-7 py-3.5 rounded-lg transition-all text-base hover:bg-white/10"
                >
                  {secondaryCtaLabel}
                </a>
              )}
            </div>
          )}
        </Fragment>
      )}
    </div>
  </div>

  {/* ── Bottom gradient fade ── */}
  {!compact && (
    <div class="absolute bottom-0 left-0 right-0 h-20 bg-gradient-to-t from-warm-white to-transparent z-[2]"></div>
  )}

  {/* ── Slider image data (hidden, read by JS) ── */}
  {isSlider && (
    <script
      type="application/json"
      id="hero-slider-data"
      set:html={JSON.stringify(sliderImages.map(img => ({ src: img.src, alt: img.alt })))}
    />
  )}
</section>

<style>
  /* ── Slider transitions ── */
  .hero-slide {
    will-change: transform;
    transition: transform 1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Active slide: visible at translateX(0) */
  .hero-slide--active {
    transform: translateX(0);
  }

  /* Next slide: waiting off-screen to the right */
  .hero-slide--next {
    transform: translateX(100%);
  }

  /* Exiting slide: sliding out to the left */
  .hero-slide--exit {
    transform: translateX(-100%);
  }
</style>

<script>
  // Hero background image slider
  // Shows initial image once, then rotates through slider images right-to-left
  (function heroSlider() {
    const section = document.querySelector('[data-hero-slider]');
    if (!section) return;

    const dataEl = document.getElementById('hero-slider-data');
    if (!dataEl) return;

    const images: Array<{ src: string; alt: string }> = JSON.parse(dataEl.textContent || '[]');
    if (images.length === 0) return;

    const slideA = section.querySelector('[data-slide="A"]') as HTMLElement;
    const slideB = section.querySelector('[data-slide="B"]') as HTMLElement;
    if (!slideA || !slideB) return;

    let currentSlide = slideA;
    let nextSlide = slideB;
    let imageIndex = 0; // next image to show is images[0], already preloaded in slide B

    // Preload all rotating images
    images.forEach(img => {
      const link = document.createElement('link');
      link.rel = 'prefetch';
      link.as = 'image';
      link.href = img.src;
      document.head.appendChild(link);
    });

    function doTransition() {
      // Current slide exits left
      currentSlide.classList.remove('hero-slide--active');
      currentSlide.classList.add('hero-slide--exit');

      // Next slide enters from right
      nextSlide.classList.remove('hero-slide--next');
      nextSlide.classList.add('hero-slide--active');

      // After transition completes, recycle the exited slide
      setTimeout(() => {
        // Move exited slide to "next" position (off-screen right, no transition)
        currentSlide.style.transition = 'none';
        currentSlide.classList.remove('hero-slide--exit');
        currentSlide.classList.add('hero-slide--next');

        // Force reflow to apply instant repositioning
        currentSlide.offsetHeight;

        // Re-enable transitions
        currentSlide.style.transition = '';

        // Advance index (loop through all rotating images)
        imageIndex = (imageIndex + 1) % images.length;

        // Preload the next image into the recycled slide
        const img = currentSlide.querySelector('img') as HTMLImageElement;
        if (img) {
          img.src = images[imageIndex].src;
          img.alt = images[imageIndex].alt;
        }

        // Swap references
        const temp = currentSlide;
        currentSlide = nextSlide;
        nextSlide = temp;
      }, 1050); // slightly longer than the 1s CSS transition
    }

    // First transition after 4 seconds (exit branding image)
    setTimeout(() => {
      doTransition();
      // Then rotate every 5.5 seconds
      setInterval(doTransition, 5500);
    }, 4000);
  })();
</script>
