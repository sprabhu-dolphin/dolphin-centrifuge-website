---
// Hero section — reusable across pages
// On homepage: large hero with overlay text
// On subpages: compact hero with breadcrumb

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  imageSrc: string;
  imageAlt: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
  compact?: boolean;
  overlay?: 'dark' | 'navy' | 'gradient';
}

const {
  title,
  subtitle,
  description,
  imageSrc,
  imageAlt,
  ctaLabel,
  ctaHref,
  secondaryCtaLabel,
  secondaryCtaHref,
  compact = false,
  overlay = 'gradient',
} = Astro.props;

const overlayClass = {
  dark: 'bg-black/60',
  navy: 'bg-navy/75',
  gradient: 'bg-gradient-to-r from-navy-dark/90 via-navy/70 to-transparent',
}[overlay];

const heightClass = compact
  ? 'min-h-[240px] md:min-h-[300px]'
  : 'min-h-[480px] md:min-h-[600px] lg:min-h-[680px]';
---

<section class={`relative ${heightClass} flex items-center overflow-hidden`}>
  {/* Background image */}
  <img
    src={imageSrc}
    alt={imageAlt}
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    decoding="async"
  />

  {/* Overlay */}
  <div class={`absolute inset-0 ${overlayClass}`}></div>

  {/* Subtle pattern overlay for texture */}
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

  {/* Content */}
  <div class="relative z-10 container-dolphin w-full">
    <div class={`max-w-2xl ${compact ? 'py-8' : 'py-12 md:py-16'}`}>
      {subtitle && (
        <p class="inline-flex items-center gap-2 text-gold font-bold text-xs md:text-sm uppercase tracking-[0.2em] mb-4">
          <span class="w-8 h-0.5 bg-gold rounded"></span>
          {subtitle}
        </p>
      )}

      <h1
        class={`text-white font-bold leading-[1.1] tracking-tight ${
          compact
            ? 'text-2xl md:text-4xl'
            : 'text-3xl md:text-5xl lg:text-[3.5rem]'
        }`}
      >
        {title}
      </h1>

      {description && (
        <p class={`text-gray-200 leading-relaxed mt-4 md:mt-6 ${compact ? 'text-base' : 'text-lg md:text-xl'}`}>
          {description}
        </p>
      )}

      {(ctaLabel || secondaryCtaLabel) && (
        <div class="flex flex-col sm:flex-row gap-3 mt-8">
          {ctaLabel && ctaHref && (
            <a
              href={ctaHref}
              class="inline-flex items-center justify-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold px-7 py-3.5 rounded-lg transition-colors shadow-lg shadow-gold/25 text-base"
            >
              {ctaLabel}
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          )}
          {secondaryCtaLabel && secondaryCtaHref && (
            <a
              href={secondaryCtaHref}
              class="inline-flex items-center justify-center gap-2 border-2 border-white/40 hover:border-white text-white font-semibold px-7 py-3.5 rounded-lg transition-all text-base hover:bg-white/10"
            >
              {secondaryCtaLabel}
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  {/* Bottom gradient fade */}
  {!compact && (
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-warm-white to-transparent"></div>
  )}
</section>
