---

<section class="py-16 md:py-20 lg:py-24 bg-light-bg">
  <div class="container-dolphin">
    <div class="text-center mb-12">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-navy">
        From Our Knowledge Center
      </h2>
      <p class="mt-3 text-text-muted text-base max-w-xl mx-auto">
        Expert guides and articles on industrial centrifuge technology.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6">
      {articles.map((article) => (
        <a href={article.href} class="group block bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-lg hover:-translate-y-1 transition-all duration-200">
          {/* Icon header */}
          <div class="bg-navy/5 h-28 flex items-center justify-center">
            <svg class="w-10 h-10 text-navy/20 group-hover:text-navy/40 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[article.icon]} />
            </svg>
          </div>

          {/* Content */}
          <div class="p-4">
            <h3 class="font-heading font-bold text-sm text-navy leading-snug group-hover:text-gold-dark transition-colors">
              {article.title}
            </h3>
            <p class="mt-1.5 text-text-muted text-xs leading-relaxed line-clamp-2">
              {article.description}
            </p>
            <span class="mt-2 inline-flex items-center text-xs font-semibold text-gold-dark group-hover:text-gold transition-colors">
              Read More
              <svg class="w-3.5 h-3.5 ml-1 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href="/disc-stack-centrifuge-applications/"
        class="inline-flex items-center gap-2 text-navy hover:text-gold-dark font-semibold transition-colors border-b-2 border-navy/20 hover:border-gold pb-1"
      >
        Browse All Applications
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
