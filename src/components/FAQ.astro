---
// Reusable FAQ component with accordion-style details/summary
// Generates FAQPage JSON-LD schema automatically

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  heading?: string;
}

const { items, heading = "Frequently Asked Questions" } = Astro.props;
---

<section id="faq" class="mt-10">
  <h2 class="font-heading text-2xl font-extrabold text-navy mb-6 pb-3 border-b-2 border-gray-200 scroll-mt-20">
    {heading}
  </h2>
  <div class="space-y-3">
    {items.map((item, i) => (
      <details class="group bg-white rounded-xl border border-gray-200 border-l-4 border-l-gold/40 shadow-sm overflow-hidden" open={i === 0}>
        <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer text-navy font-semibold text-[0.95rem] leading-snug hover:bg-light-bg transition-colors select-none list-none [&::-webkit-details-marker]:hidden">
          <span>{item.question}</span>
          <svg class="w-5 h-5 text-gold shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-5 pb-4 text-sm text-text-light leading-relaxed border-t border-gray-100 pt-3">
          <Fragment set:html={item.answer} />
        </div>
      </details>
    ))}
  </div>
</section>
