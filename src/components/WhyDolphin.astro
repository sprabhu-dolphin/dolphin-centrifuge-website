---
// Why Dolphin Centrifuge — trust-building section with checkmark bullets + facility photo
const trustPoints = [
  {
    title: 'Complete Turnkey Systems',
    description: 'Every centrifuge ships as a fully engineered module — centrifuge, pumps, heaters, PLC controls, and piping on a single skid. Plug in and run.',
  },
  {
    title: '40+ Years of Specialization',
    description: 'Deep expertise in Alfa Laval centrifuges means we understand every model, every application, and every process variable that affects your separation.',
  },
  {
    title: 'In-House Rebuild & Testing',
    description: 'Our 30,000 sq ft Warren, MI facility rebuilds centrifuges to OEM specs with genuine parts. Every unit is wet-tested before shipping.',
  },
  {
    title: 'Pilot Testing with Your Material',
    description: 'Send us your sample. We run it through the right centrifuge in our lab and deliver data-backed recommendations — no guesswork.',
  },
  {
    title: '150+ Centrifuges in Stock',
    description: 'The largest inventory of reconditioned Alfa Laval centrifuges in North America. Fast delivery on turnkey systems and spare parts.',
  },
];
---

<section class="py-16 md:py-24 bg-warm-white">
  <div class="container-dolphin">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      {/* Left — trust points with checkmarks */}
      <div>
        <p class="inline-flex items-center gap-2 text-gold-dark font-bold text-xs uppercase tracking-[0.2em] mb-3">
          <span class="w-6 h-0.5 bg-gold rounded"></span>
          Why Engineers Trust Us
        </p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-navy leading-tight mb-8">
          Why Dolphin Centrifuge
        </h2>

        <div class="space-y-5">
          {trustPoints.map((point) => (
            <div class="flex gap-4">
              {/* Checkmark icon */}
              <div class="shrink-0 mt-0.5">
                <div class="w-7 h-7 rounded-full bg-green-100 flex items-center justify-center">
                  <svg class="w-4 h-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="font-heading text-base font-bold text-navy mb-1">{point.title}</h3>
                <p class="text-sm text-text-light leading-relaxed">{point.description}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/about-dolphin-centrifuge/"
            class="inline-flex items-center gap-2 bg-navy hover:bg-navy-light text-white font-bold text-sm px-6 py-3 rounded-lg transition-colors"
          >
            About Dolphin Centrifuge
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="/industrial-centrifuge-sample-testing/"
            class="inline-flex items-center gap-2 border border-gray-300 hover:border-navy text-text font-semibold text-sm px-6 py-3 rounded-lg transition-colors"
          >
            Request Sample Testing
          </a>
        </div>
      </div>

      {/* Right — facility photo with overlay stats */}
      <div class="relative">
        <div class="rounded-2xl overflow-hidden shadow-xl">
          <img
            src="/images/homepage/hero/decanter-warehouse.webp"
            alt="Dolphin Centrifuge warehouse facility in Warren, Michigan with centrifuge inventory"
            class="w-full h-auto object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
        {/* Stats overlay card */}
        <div class="absolute -bottom-6 -left-4 md:-left-6 bg-navy text-white rounded-xl p-5 shadow-xl max-w-[240px]">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-gold/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <span class="block text-2xl font-extrabold font-heading leading-none">500+</span>
              <span class="text-xs text-gray-300">Systems Delivered</span>
            </div>
          </div>
          <p class="text-xs text-gray-400 leading-relaxed">Every system custom-built and wet-tested in our Warren, MI facility.</p>
        </div>
      </div>
    </div>
  </div>
</section>
