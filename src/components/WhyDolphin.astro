---

<section class="py-16 md:py-24 bg-warm-white">
  <div class="container-dolphin">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      {/* Left — intro text */}
      <div>
        <p class="inline-flex items-center gap-2 text-gold-dark font-bold text-xs uppercase tracking-[0.2em] mb-3">
          <span class="w-6 h-0.5 bg-gold rounded"></span>
          Why Dolphin Centrifuge
        </p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-navy leading-tight mb-6">
          Engineered for Your Exact Separation Challenge
        </h2>
        <p class="text-text-light text-lg leading-relaxed mb-8">
          Dolphin Centrifuge is an industrial centrifuge manufacturer specializing in Alfa Laval centrifuges. We manufacture complete turnkey systems engineered for all industrial and commercial centrifuge applications.
        </p>
        <a
          href="/about/"
          class="inline-flex items-center gap-2 text-navy hover:text-gold-dark font-semibold transition-colors border-b-2 border-navy/20 hover:border-gold pb-1"
        >
          Learn More About Us
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>

      {/* Right — feature grid */}
      <div class="grid sm:grid-cols-2 gap-5">
        {features.map((feature) => (
          <div class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-11 h-11 rounded-lg bg-navy/5 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
              </svg>
            </div>
            <h3 class="font-heading text-base font-bold text-navy mb-2">{feature.title}</h3>
            <p class="text-sm text-text-light leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
