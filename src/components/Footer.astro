---
// Footer — shared across every page
const currentYear = new Date().getFullYear();

const footerSections = [
  {
    title: 'Applications',
    links: [
      { label: 'Oil & Fuel', href: '/applications/oil-fuel/' },
      { label: 'Industrial Fluids', href: '/applications/industrial-fluids/' },
      { label: 'Food & Beverage', href: '/applications/food-beverage/' },
      { label: 'Water & Environment', href: '/applications/water-environment/' },
      { label: 'Waste Oil', href: '/waste-oil-centrifuge/' },
      { label: 'Wastewater', href: '/wastewater-centrifuge/' },
      { label: 'All Applications A-Z', href: '/disc-stack-centrifuge-applications/' },
    ],
  },
  {
    title: 'Centrifuges',
    links: [
      { label: 'Disc Stack', href: '/disc-stack-centrifuge/' },
      { label: 'Decanter', href: '/decanter-centrifuge/' },
      { label: 'Explosion Proof', href: '/explosion-proof-centrifuge/' },
      { label: 'Stainless Steel', href: '/stainless-steel-centrifuge/' },
      { label: 'Parts & Spares', href: '/alfa-laval-centrifuge-parts/' },
      { label: 'Control Systems', href: '/industrial-centrifuge-controls/' },
    ],
  },
  {
    title: 'Services',
    links: [
      { label: 'Centrifuge Repair', href: '/industrial-disc-centrifuge-repair/' },
      { label: 'Disc Stack Rental', href: '/disc-stack-centrifuge-rental/' },
      { label: 'Decanter Rental', href: '/decanter-centrifuge-rental/' },
      { label: 'Sample Testing', href: '/industrial-centrifuge-sample-testing/' },
      { label: 'Design & Engineering', href: '/industrial-centrifuge-design/' },
      { label: 'Training', href: '/industrial-centrifuge-training/' },
      { label: 'Buyback', href: '/industrial-centrifuge-buyback/' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Selection Guide', href: '/alfa-laval-centrifuge-selection-guide/' },
      { label: 'Troubleshooting', href: '/disc-stack-centrifuge-mechanical-issues-fixes/' },
      { label: 'Disc Stack FAQ', href: '/disc-stack-centrifuge-faq/' },
      { label: 'Industrial Centrifuge FAQ', href: '/industrial-centrifuges-faq/' },
      { label: 'About Us', href: '/about-dolphin-centrifuge/' },
      { label: 'Testimonials', href: '/dolphin-centrifuge-customer-testimonials/' },
    ],
  },
];
---

<footer class="bg-navy-dark text-gray-300">
  {/* CTA Banner */}
  <div class="bg-navy">
    <div class="container-dolphin py-12 md:py-16 text-center">
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-white mb-3">
        Ready to Solve Your Separation Challenge?
      </h2>
      <p class="text-gray-400 text-lg mb-8 max-w-2xl mx-auto">
        With 40+ years of Alfa Laval centrifuge expertise, we'll engineer the right solution for your application.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/contact-for-alfa-laval-centrifuges/"
          class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold px-8 py-3.5 rounded-lg transition-colors shadow-lg shadow-gold/20 text-base"
        >
          Get a Free Consultation
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="tel:+12485222573"
          class="inline-flex items-center gap-2 border-2 border-white/30 hover:border-gold hover:text-gold text-white font-semibold px-8 py-3.5 rounded-lg transition-all text-base"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          (248) 522-2573
        </a>
      </div>
    </div>
  </div>

  {/* Main footer links */}
  <div class="container-dolphin py-12 md:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      {footerSections.map((section) => (
        <div>
          <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">
            {section.title}
          </h3>
          <ul class="space-y-2.5">
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-300 hover:text-gold transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  {/* Bottom bar */}
  <div class="border-t border-white/10">
    <div class="container-dolphin py-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-full bg-gold flex items-center justify-center">
          <svg viewBox="0 0 32 32" class="w-5 h-5 text-navy" fill="currentColor">
            <path d="M16 4c-1.5 0-3 1-4 3-1.5 3-1 6 0 8l3 4c1 1.3 2 1 2-.5 0-2-1-5-1-7s1-4 3-4c1.5 0 2.5 1 3 2.5.3.8.5 2 .3 3-.5 2-2 4-4 5l-3 2c-2 1.3-3.5 3-3.5 5.5 0 1.5.5 3 2 4 1 .7 2.5 1 4 .5s3-2 3.5-3.5c.3-1 .2-2-.3-3-.5-.8-1.5-1.5-2.5-1.5" />
          </svg>
        </div>
        <div class="text-sm">
          <span class="text-gray-400">&copy; {currentYear} Dolphin Centrifuge.</span>
          <span class="text-gray-500"> All rights reserved.</span>
        </div>
      </div>
      <div class="flex items-center gap-4 text-xs text-gray-500">
        <span>24248 Gibson Dr., Warren MI 48089</span>
        <span class="hidden sm:inline">|</span>
        <a href="mailto:sales@dolphincentrifuge.com" class="text-gray-400 hover:text-gold transition-colors">sales@dolphincentrifuge.com</a>
      </div>
    </div>
  </div>
</footer>
