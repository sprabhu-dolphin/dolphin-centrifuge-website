---
// Header / Navigation — shared across every page
// Sticky, slim-on-scroll, mobile hamburger

const navItems = [
  {
    label: 'Applications',
    href: '/disc-stack-centrifuge-applications/',
    flyout: true,
    appItems: [
      { label: 'Beer, Wine, Cider & Juice', href: '/beer-wine-centrifuge/' },
      { label: 'Biomass & Organics', href: '#', children: [
        { label: 'Algae Harvesting - Large Scale', href: '/algae-centrifuge/' },
        { label: 'Liquid Humus Fertilizer', href: '/liquid-humus-centrifuge/' },
        { label: 'Manure Centrifuge Separator', href: '/manure-centrifuge-separator/' },
        { label: 'Ethanol Extraction', href: '/ethanol-extraction-centrifuges-technical-comparison/' },
      ]},
      { label: 'Crude Oil & BS&W', href: '#', children: [
        { label: 'Crude Oil Centrifuge', href: '/crude-oil-centrifuge/' },
        { label: 'Tank Bottom Recovery', href: '/crude-oil-tank-bottom-recovery-centrifuge/' },
      ]},
      { label: 'Fish Processing Centrifuge', href: '/fish-processing-centrifuge/' },
      { label: 'Fuel Separation', href: '#', children: [
        { label: 'Diesel Fuel Purification', href: '/diesel-centrifuge/' },
        { label: 'Fuel Oil / HFO Separator', href: '/fuel-oil-centrifuge/' },
        { label: 'Pyrolysis Oil Centrifuge', href: '/pyrolysis-oil-centrifuge/' },
      ]},
      { label: 'Industrial Fluids (Coolant, Cutting Oil..)', href: '#', children: [
        { label: 'Cutting Oil Centrifuge', href: '/cutting-oil-centrifuge/' },
        { label: 'Industrial Washer Fluid', href: '/industrial-washer-fluid-centrifuge/' },
        { label: 'Machining Coolant Centrifuge', href: '/machine-coolant-centrifuge/' },
        { label: 'Quench Oil Filtration', href: '/quench-oil-centrifuge/' },
      ]},
      { label: 'Lube & Hydraulic Oil Purification', href: '#', children: [
        { label: 'Lube Oil Centrifuge', href: '/lube-oil-centrifuge/' },
        { label: 'Hydraulic Oil Centrifuge', href: '/hydraulic-oil-centrifuge/' },
      ]},
      { label: 'Used - Waste Oil Separation', href: '#', children: [
        { label: 'Waste Oil Centrifuge', href: '/waste-oil-centrifuge/' },
        { label: 'Used Oil Centrifuge', href: '/used-oil-centrifuge/' },
        { label: 'WVO Centrifuge', href: '/wvo-centrifuge-separator/' },
        { label: 'Black Diesel Centrifuge', href: '/black-diesel-centrifuge/' },
        { label: 'Biodiesel Separation', href: '/biodiesel-centrifuge/' },
      ]},
      { label: 'Wastewater Centrifuge', href: '/wastewater-centrifuge/' },
    ],
    footerLink: { label: 'View All Applications A-Z', href: '/disc-stack-centrifuge-applications/' },
  },
  {
    label: 'Centrifuges',
    href: '/alfa-laval-centrifuges/',
    children: [
      { label: 'Disc Stack Centrifuges', href: '/disc-stack-centrifuge/' },
      { label: 'Decanter Centrifuges', href: '/decanter-centrifuge/' },
      { label: 'Explosion Proof', href: '/explosion-proof-centrifuge/' },
      { label: 'Stainless Steel', href: '/stainless-steel-centrifuge/' },
      { label: 'Parts & Spares', href: '/alfa-laval-centrifuge-parts/' },
      { label: 'Control Systems', href: '/industrial-centrifuge-controls/' },
    ],
  },
  {
    label: 'Services',
    href: '/industrial-centrifuge-design/',
    children: [
      { label: 'Centrifuge Repair', href: '/industrial-disc-centrifuge-repair/' },
      { label: 'Disc Stack Rental', href: '/disc-stack-centrifuge-rental/' },
      { label: 'Decanter Rental', href: '/decanter-centrifuge-rental/' },
      { label: 'Sample Testing', href: '/industrial-centrifuge-sample-testing/' },
      { label: 'Design & Engineering', href: '/industrial-centrifuge-design/' },
      { label: 'Training', href: '/industrial-centrifuge-training/' },
      { label: 'Buyback', href: '/industrial-centrifuge-buyback/' },
    ],
  },
  {
    label: 'Knowledge',
    href: '/knowledge-center/',
    children: [
      { label: 'Troubleshooting', href: '/knowledge-troubleshooting/' },
      { label: 'Guides & How-To', href: '/knowledge-guides/' },
      { label: 'Comparisons & Explainers', href: '/knowledge-comparisons/' },
      { label: 'Product & Brand Info', href: '/knowledge-product-brand/' },
      { label: 'Case Studies & FAQ', href: '/knowledge-case-studies/' },
    ],
  },
  { label: 'About', href: '/about-dolphin-centrifuge/' },
];
---

<header
  id="site-header"
  class="sticky top-0 z-50 bg-navy text-white transition-all duration-300"
>
  {/* Top utility bar */}
  <div class="bg-navy-dark text-xs hidden md:block">
    <div class="container-dolphin flex items-center justify-between py-1.5">
      <div class="flex items-center gap-4 text-gray-300">
        <a href="tel:+12485222573" class="flex items-center gap-1.5 hover:text-gold transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          (248) 522-2573
        </a>
        <a href="mailto:sales@dolphincentrifuge.com" class="flex items-center gap-1.5 hover:text-gold transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          sales@dolphincentrifuge.com
        </a>
      </div>
      <span class="text-gray-400">Warren, MI &mdash; Serving Industry for 40+ Years</span>
    </div>
  </div>

  {/* Main nav bar */}
  <nav class="container-dolphin flex items-center justify-between h-16 md:h-[72px]">
    {/* Logo */}
    <a href="/" class="flex items-center shrink-0" aria-label="Dolphin Centrifuge Home">
      <img
        src="/images/homepage/dolphin-centrifuge-logo.png"
        alt="Dolphin Centrifuge"
        class="h-10 md:h-12 w-auto"
        width="180"
        height="48"
      />
    </a>

    {/* Desktop nav links */}
    <div class="hidden lg:flex items-center gap-1">
      {navItems.map((item) => (
        <div class="relative group">
          <a
            href={item.href}
            class="flex items-center gap-1 px-3 py-2 text-sm font-semibold text-gray-200 hover:text-white rounded-md hover:bg-white/10 transition-all"
          >
            {item.label}
            {(item.children || item.flyout) && (
              <svg class="w-3.5 h-3.5 opacity-60 group-hover:opacity-100 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>
          {/* Flyout dropdown (Applications) — LW-style progressive disclosure */}
          {item.flyout && item.appItems && (
            <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              <div class="bg-white rounded-xl shadow-2xl shadow-black/15 border border-gray-100 py-2 min-w-[280px]">
                {item.appItems.map((app) => (
                  app.children ? (
                    <div class="app-flyout-group relative">
                      <a
                        href={app.href}
                        class="flex items-center justify-between px-4 py-2.5 text-sm font-semibold text-navy hover:bg-light-bg hover:text-gold-dark transition-colors"
                      >
                        {app.label}
                        <svg class="w-3.5 h-3.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                        </svg>
                      </a>
                      <div class="app-flyout-sub absolute left-full top-0 pl-1 opacity-0 invisible transition-all duration-150">
                        <div class="bg-white rounded-lg shadow-xl border border-gray-100 py-2 min-w-[240px]">
                          {app.children.map((sub) => (
                            <a href={sub.href} class="block px-4 py-2 text-sm text-gray-600 hover:text-navy hover:bg-light-bg transition-colors">
                              {sub.label}
                            </a>
                          ))}
                        </div>
                      </div>
                    </div>
                  ) : (
                    <a href={app.href} class="block px-4 py-2.5 text-sm font-semibold text-navy hover:bg-light-bg hover:text-gold-dark transition-colors">
                      {app.label}
                    </a>
                  )
                ))}
                {item.footerLink && (
                  <div class="mt-1 pt-2 border-t border-gray-100 px-4 pb-2">
                    <a href={item.footerLink.href} class="text-sm text-gray-400 hover:text-navy italic transition-colors">
                      {item.footerLink.label} &rarr;
                    </a>
                  </div>
                )}
              </div>
            </div>
          )}
          {/* Simple dropdown (other nav items) */}
          {item.children && !item.mega && (
            <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              <div class="bg-white rounded-xl shadow-2xl shadow-black/15 border border-gray-100 py-2 min-w-[220px]">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-light-bg hover:text-navy font-medium transition-colors"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}
    </div>

    {/* CTA + Mobile toggle */}
    <div class="flex items-center gap-3">
      <a
        href="/contact-for-alfa-laval-centrifuges/"
        class="hidden md:inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-5 py-2.5 rounded-lg transition-colors shadow-md shadow-gold/20"
      >
        Contact Us
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>

      {/* Hamburger (mobile) */}
      <button
        id="mobile-menu-btn"
        class="lg:hidden flex items-center justify-center w-10 h-10 rounded-md hover:bg-white/10 transition-colors"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  {/* Mobile menu panel */}
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-navy-dark border-t border-white/10 max-h-[calc(100vh-4rem)] overflow-y-auto"
  >
    <div class="container-dolphin py-4 space-y-1">
      {navItems.map((item) => (
        <div>
          <a
            href={item.href}
            class="block px-4 py-3 text-base font-semibold text-gray-200 hover:text-white hover:bg-white/5 rounded-lg transition-colors"
          >
            {item.label}
          </a>
          {/* Flyout menu mobile (Applications) */}
          {item.flyout && item.appItems && (
            <div class="pl-6 space-y-1">
              {item.appItems.map((app) => (
                app.children ? (
                  <div class="mt-2">
                    <div class="px-4 py-1 text-xs font-bold text-gray-500 uppercase tracking-wider">{app.label}</div>
                    {app.children.map((sub) => (
                      <a href={sub.href} class="block px-6 py-1.5 text-sm text-gray-400 hover:text-gold transition-colors">
                        {sub.label}
                      </a>
                    ))}
                  </div>
                ) : (
                  <a href={app.href} class="block px-4 py-2 text-sm text-gray-300 font-medium hover:text-gold transition-colors">
                    {app.label}
                  </a>
                )
              ))}
              {item.footerLink && (
                <a href={item.footerLink.href} class="block px-4 py-2 text-sm text-gray-500 italic hover:text-gold transition-colors mt-2">
                  {item.footerLink.label} &rarr;
                </a>
              )}
            </div>
          )}
          {/* Regular children (non-mega) */}
          {item.children && !item.mega && (
            <div class="pl-6 space-y-0.5">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="block px-4 py-2 text-sm text-gray-400 hover:text-gold transition-colors"
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
      <div class="pt-3 border-t border-white/10 mt-3">
        <a
          href="/contact-for-alfa-laval-centrifuges/"
          class="block text-center bg-gold text-navy font-bold py-3 rounded-lg hover:bg-gold-light transition-colors"
        >
          Contact Us
        </a>
        <div class="flex flex-col items-center gap-2 mt-4 text-sm text-gray-400">
          <a href="tel:+12485222573" class="hover:text-gold transition-colors">(248) 522-2573</a>
          <a href="mailto:sales@dolphincentrifuge.com" class="hover:text-gold transition-colors">sales@dolphincentrifuge.com</a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const header = document.getElementById('site-header');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
  });

  // Slim header on scroll
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const utilityBar = header?.querySelector('.bg-navy-dark');
    if (window.scrollY > 60) {
      utilityBar?.classList.add('!hidden');
    } else {
      utilityBar?.classList.remove('!hidden');
    }
    lastScroll = window.scrollY;
  }, { passive: true });
</script>

<style>
  /* Applications flyout — show sub-menu on hover */
  .app-flyout-group:hover > .app-flyout-sub {
    opacity: 1 !important;
    visibility: visible !important;
  }
</style>
