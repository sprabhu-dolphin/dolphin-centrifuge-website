---
/**
 * ProductCard — Reusable product/model card with semantic image markup.
 *
 * STRUCTURAL RULE: All ProductCard images use figure/figcaption with
 * img-cap-* classes. Width/height must match native image file dimensions.
 *
 * Usage:
 * <div class="grid grid-cols-1 md:grid-cols-3 gap-6 not-prose">
 *   <ProductCard title="Model X" href="/model-x/" image="/images/model-x.webp" imageAlt="..." imageWidth={300} imageHeight={300} :specs={specs} />
 * </div>
 */

interface Spec {
  label: string;
  value: string;
}

interface Props {
  title: string;
  href: string;
  image: string;
  imageAlt: string;
  imageWidth?: number;
  imageHeight?: number;
  caption?: string;
  specs?: Spec[];
}

const { title, href, image, imageAlt, imageWidth, imageHeight, caption, specs = [] } = Astro.props;
---

<div class="product-card border border-gray-200 rounded-xl overflow-hidden hover:shadow-md hover:border-gold transition-all bg-white">
  {/* ── Image — semantic figure/figcaption ── */}
  <figure>
    <a href={href} class="block">
      <img
        src={image}
        alt={imageAlt}
        width={imageWidth}
        height={imageHeight}
        loading="lazy"
        class="img-cap-300"
      />
    </a>
    <figcaption>{caption || title}</figcaption>
  </figure>

  {/* ── Content ── */}
  <div class="p-4">
    <h3 class="font-bold text-navy mb-3">
      <a href={href} class="hover:text-gold transition-colors">{title}</a>
    </h3>

    {specs.length > 0 && (
      <table class="w-full text-xs">
        <tbody>
          {specs.map((spec, i) => (
            <tr class={i < specs.length - 1 ? 'border-b border-gray-100' : ''}>
              <td class="py-1 font-semibold text-navy">{spec.label}:</td>
              <td class="py-1 font-mono" set:html={spec.value} />
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</div>

