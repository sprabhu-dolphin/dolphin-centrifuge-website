---
// Trust signals bar — used on homepage and key landing pages
const signals = [
  {
    icon: 'calendar',
    stat: '40+',
    label: 'Years Experience',
  },
  {
    icon: 'globe',
    stat: '50+',
    label: 'Countries Served',
  },
  {
    icon: 'cog',
    stat: '1000+',
    label: 'Systems Delivered',
  },
  {
    icon: 'shield',
    stat: '100%',
    label: 'Turnkey Solutions',
  },
];

const iconPaths: Record<string, string> = {
  calendar: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  globe: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
  cog: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
};
---

<section class="relative -mt-12 z-20">
  <div class="container-dolphin">
    <div class="bg-white rounded-2xl shadow-xl shadow-black/8 border border-gray-100 p-6 md:p-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        {signals.map((signal) => (
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 md:w-14 md:h-14 rounded-xl bg-navy/5 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 md:w-7 md:h-7 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[signal.icon]} />
              </svg>
            </div>
            <div>
              <div class="text-2xl md:text-3xl font-extrabold text-navy leading-none">{signal.stat}</div>
              <div class="text-xs md:text-sm text-text-muted font-medium mt-0.5">{signal.label}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
