---
// Featured products section for homepage
const products = [
  {
    name: 'Disc Stack Centrifuges',
    description: 'Self-cleaning and manual-clean Alfa Laval disc stack separators for oil, fuel, coolant, and wastewater applications.',
    image: '/images/homepage/Alfa-Laval-MOPX-207-System-for-Industrial-Oils.jpg',
    href: '/centrifuges/disc-stack/',
    specs: ['Up to 60 GPM', '7,000+ G-Force', 'Self-Cleaning Bowl'],
  },
  {
    name: 'Decanter Centrifuges',
    description: 'High-capacity Alfa Laval decanters for sludge dewatering, hemp extraction, and heavy-solids separation.',
    image: '/images/homepage/Sharples-P-3000-Waste-Water-Decanter-Centrifuge.jpg',
    href: '/centrifuges/decanter/',
    specs: ['Up to 150 GPM', '4,000 RPM', '40% Solids Capacity'],
  },
  {
    name: 'Explosion-Proof Systems',
    description: 'ATEX and C1D1/C1D2 rated centrifuge systems for hazardous environments including offshore and chemical processing.',
    image: '/images/homepage/Fuel-Oil-Centrifuge-Package-for-ATEX-Zone-2.jpg',
    href: '/centrifuges/explosion-proof/',
    specs: ['ATEX Zone 1 & 2', 'C1D1 / C1D2', 'Full Duplex Available'],
  },
];
---

<section class="py-16 md:py-24 bg-warm-white">
  <div class="container-dolphin">
    {/* Section header */}
    <div class="text-center mb-12 md:mb-16">
      <p class="inline-flex items-center gap-2 text-gold-dark font-bold text-xs uppercase tracking-[0.2em] mb-3">
        <span class="w-6 h-0.5 bg-gold rounded"></span>
        Our Equipment
        <span class="w-6 h-0.5 bg-gold rounded"></span>
      </p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-navy leading-tight">
        Industrial Centrifuge Systems
      </h2>
      <p class="text-text-light text-lg mt-3 max-w-2xl mx-auto">
        Complete turnkey centrifuge modules engineered for your specific separation application.
      </p>
    </div>

    {/* Product cards */}
    <div class="grid md:grid-cols-3 gap-6 md:gap-8">
      {products.map((product) => (
        <a href={product.href} class="group block bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 hover:border-gold/30">
          {/* Image */}
          <div class="relative h-52 md:h-56 overflow-hidden">
            <img
              src={product.image}
              alt={product.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
          </div>

          {/* Content */}
          <div class="p-6">
            <h3 class="font-heading text-xl font-bold text-navy group-hover:text-gold-dark transition-colors">
              {product.name}
            </h3>
            <p class="text-text-light text-sm mt-2 leading-relaxed">
              {product.description}
            </p>

            {/* Spec badges */}
            <div class="flex flex-wrap gap-2 mt-4">
              {product.specs.map((spec) => (
                <span class="inline-flex items-center px-3 py-1 text-xs font-semibold text-navy bg-light-bg rounded-full">
                  {spec}
                </span>
              ))}
            </div>

            {/* Link */}
            <div class="flex items-center gap-2 mt-5 text-sm font-bold text-gold-dark group-hover:text-gold uppercase tracking-wider">
              View Details
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    {/* View all link */}
    <div class="text-center mt-10">
      <a
        href="/centrifuges/"
        class="inline-flex items-center gap-2 text-navy hover:text-gold-dark font-semibold transition-colors border-b-2 border-navy/20 hover:border-gold pb-1"
      >
        View All Centrifuge Models
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
