---
// Featured centrifuge systems — 4-card grid with WebP product images
const products = [
  {
    name: 'Disc Stack Centrifuge',
    description: 'Self-cleaning, high-speed separation up to 12,000 × g for oil, fuel, coolant, and water applications.',
    image: '/images/homepage/products/disc-stack-card.webp',
    href: '/centrifuges/disc-stack/',
    specs: ['Up to 60 GPM', '12,000 × g', 'Self-Cleaning'],
  },
  {
    name: 'Decanter Centrifuge',
    description: 'Heavy-duty continuous sludge separation for high-solids applications including hemp and wastewater.',
    image: '/images/homepage/products/decanter-card.webp',
    href: '/centrifuges/decanter/',
    specs: ['Up to 150 GPM', '4,000 RPM', '40% Solids'],
  },
  {
    name: 'Explosion Proof',
    description: 'NEC Class 1 Div 1/2 and ATEX certified systems for hazardous locations and chemical processing.',
    image: '/images/homepage/products/explosion-proof-card.webp',
    href: '/centrifuges/explosion-proof/',
    specs: ['ATEX Zone 1 & 2', 'C1D1 / C1D2', 'Full Duplex'],
  },
  {
    name: 'Stainless Steel',
    description: 'Corrosion-resistant systems for sanitary food-grade, pharmaceutical, and chemical processing.',
    image: '/images/homepage/products/stainless-steel-card.webp',
    href: '/centrifuges/stainless-steel/',
    specs: ['316L SS', 'FDA Compliant', 'CIP Ready'],
  },
];
---

<section class="py-16 md:py-20 lg:py-24 bg-warm-white">
  <div class="container-dolphin">
    <div class="text-center mb-12">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-navy">
        Featured Centrifuge Systems
      </h2>
      <p class="mt-3 text-text-muted text-base max-w-xl mx-auto">
        Industry-proven centrifuge platforms for every separation challenge.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {products.map((product) => (
        <a href={product.href} class="group block bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-xl hover:-translate-y-1 transition-all duration-200">
          {/* Image */}
          <div class="h-48 bg-light-bg overflow-hidden flex items-center justify-center">
            <img
              src={product.image}
              alt={`Dolphin Centrifuge ${product.name} system`}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              decoding="async"
            />
          </div>

          {/* Content */}
          <div class="p-5">
            <h3 class="font-heading text-lg font-bold text-navy group-hover:text-gold-dark transition-colors">
              {product.name}
            </h3>
            <p class="text-text-muted text-sm mt-2 leading-relaxed">
              {product.description}
            </p>

            {/* Spec badges */}
            <div class="flex flex-wrap gap-1.5 mt-4">
              {product.specs.map((spec) => (
                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium text-navy bg-light-bg rounded-full">
                  {spec}
                </span>
              ))}
            </div>

            {/* Link */}
            <span class="mt-4 inline-flex items-center text-sm font-semibold text-gold-dark group-hover:text-gold transition-colors">
              Learn More
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
