---
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/Hero.astro';

interface TocItem {
  id: string;
  label: string;
  subItems?: TocItem[];
}

interface RelatedLink {
  label: string;
  href: string;
  description?: string;
}

interface Props {
  title: string;
  pageTitle?: string;
  description?: string;
  heroImage?: string;
  heroImageAlt?: string;
  category?: string;
  categoryLabel?: string;
  categoryHref?: string;
  toc?: TocItem[];
  relatedApplications?: RelatedLink[];
  relatedProducts?: RelatedLink[];
  canonicalUrl?: string;
  ogImage?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  disableTitleSuffix?: boolean;
}

const {
  title,
  pageTitle,
  description,
  heroImage,
  heroImageAlt = '',
  category = 'applications',
  categoryLabel = 'Applications',
  categoryHref,
  toc = [],
  relatedApplications = [],
  relatedProducts = [],
  canonicalUrl,
  ogImage,
  jsonLd,
  disableTitleSuffix = false,
} = Astro.props;

const resolvedCategoryHref = categoryHref
  ? categoryHref
  : category === 'applications'
    ? '/disc-stack-centrifuge-applications/'
    : undefined;

const breadcrumbs = [
  resolvedCategoryHref
    ? { label: categoryLabel, href: resolvedCategoryHref }
    : { label: categoryLabel },
  { label: title },
];
---

<BaseLayout
  title={pageTitle || title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLd}
  disableTitleSuffix={disableTitleSuffix}
>
  {/* ── Application Hero — Frosted Glass Backdrop ── */}
  <Hero
    title={title}
    categoryLabel={categoryLabel}
    description={description}
    imageSrc={heroImage}
    imageAlt={heroImageAlt}
    overlay="frost"
    ctaLabel="Get a Quote"
    ctaHref="/contact-for-alfa-laval-centrifuges/"
    secondaryCtaLabel="(248) 522-2573"
    secondaryCtaHref="tel:+12485222573"
  />

  {/* ── Main Content Area ── */}
  <section class="bg-warm-white">
    <div class="container-dolphin py-10 md:py-14">
      <div class="flex flex-col lg:flex-row gap-10 lg:gap-14">

        {/* Main Content Column */}
        <div class="flex-1 min-w-0">
          {/* Table of Contents */}
          {toc.length > 0 && (
            <nav class="bg-white rounded-xl p-5 md:p-6 mb-10 border border-gray-200 shadow-sm" aria-label="Table of Contents">
              <h2 class="text-sm font-bold text-navy uppercase tracking-wider mb-3">On This Page</h2>
              <ol class="columns-1 md:columns-2 gap-x-6 space-y-1.5">
                {toc.map((item, i) => (
                  <li class="break-inside-avoid">
                    <a
                      href={`#${item.id}`}
                      class="flex items-start gap-2 text-sm text-text-light hover:text-navy transition-colors py-0.5"
                    >
                      <span class="text-gold font-mono text-xs mt-0.5 shrink-0">{String(i + 1).padStart(2, '0')}</span>
                      {item.label}
                    </a>
                    {item.subItems && item.subItems.length > 0 && (
                      <ol class="ml-6 mt-1 space-y-1">
                        {item.subItems.map((subItem) => (
                          <li>
                            <a
                              href={`#${subItem.id}`}
                              class="flex items-start gap-2 text-sm text-text-light hover:text-navy transition-colors py-0.5"
                            >
                              <span class="text-gray-400 font-mono text-xs mt-0.5 shrink-0">-</span>
                              {subItem.label}
                            </a>
                          </li>
                        ))}
                      </ol>
                    )}
                  </li>
                ))}
              </ol>
            </nav>
          )}

          {/* Article Content */}
          <article class="prose-dolphin">
            <slot />
          </article>
        </div>

        {/* Sidebar */}
        <aside class="lg:w-72 xl:w-80 shrink-0">
          <div class="lg:sticky lg:top-24 space-y-5">

            {/* Quick Contact Card */}
            <div class="bg-navy rounded-xl p-4 text-white">
              <h3 class="text-sm font-bold font-heading mb-1">Talk to an Engineer</h3>
              <p class="text-xs text-gray-300 mb-3">Get expert advice for your specific application.</p>
              <a
                href="tel:+12485222573"
                class="flex items-center gap-2 text-gold hover:text-gold-light font-bold text-base transition-colors mb-2"
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                (248) 522-2573
              </a>
              <a
                href="mailto:sales@dolphincentrifuge.com"
                class="flex items-center gap-2 text-xs text-gray-300 hover:text-white transition-colors"
              >
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                sales@dolphincentrifuge.com
              </a>
              <a
                href="/contact-for-alfa-laval-centrifuges/"
                class="block text-center bg-gold text-navy font-bold text-sm py-2 rounded-lg mt-3 hover:bg-gold-light transition-colors"
              >
                Request a Quote
              </a>
            </div>

            {/* Recommended Centrifuges */}
            {relatedProducts.length > 0 && (
              <div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm">
                <h3 class="text-sm font-bold text-navy uppercase tracking-wider mb-3">Recommended Systems</h3>
                <ul class="space-y-2.5">
                  {relatedProducts.map((link) => (
                    <li>
                      <a href={link.href} class="group block p-2.5 rounded-lg hover:bg-light-bg transition-colors -mx-1">
                        <span class="block text-sm font-semibold text-navy group-hover:text-gold-dark transition-colors">{link.label}</span>
                        {link.description && (
                          <span class="block text-xs text-text-muted mt-0.5">{link.description}</span>
                        )}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {/* Related Applications */}
            {relatedApplications.length > 0 && (
              <div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm">
                <h3 class="text-sm font-bold text-navy uppercase tracking-wider mb-3">Related Applications</h3>
                <ul class="space-y-1">
                  {relatedApplications.map((link) => (
                    <li>
                      <a
                        href={link.href}
                        class="flex items-center gap-2 text-sm text-text-light hover:text-navy font-medium transition-colors py-1.5"
                      >
                        <svg class="w-3 h-3 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                        </svg>
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {/* Trust Badge */}
            <div class="bg-light-bg rounded-xl p-5 border border-gray-200 text-center">
              <div class="w-10 h-10 rounded-full bg-gold/15 flex items-center justify-center mx-auto mb-2">
                <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <p class="text-sm font-bold text-navy">40+ Years of Expertise</p>
              <p class="text-xs text-text-muted mt-0.5">150+ centrifuges in stock</p>
            </div>
          </div>
        </aside>
      </div>

      {/* ── Bottom CTA ── */}
      <div class="mt-10 bg-navy rounded-2xl p-5 md:p-7 text-white text-center md:text-left md:flex md:items-center md:justify-between">
        <div class="mb-4 md:mb-0">
          <h3 class="text-lg md:text-xl font-bold font-heading mb-1">Ready to discuss your application?</h3>
          <p class="text-gray-300 text-sm">Our engineers will help you select and size the right centrifuge system.</p>
        </div>
        <div class="flex flex-wrap justify-center md:justify-end gap-2">
          <a
            href="/contact-for-alfa-laval-centrifuges/"
            class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-5 py-2.5 rounded-lg transition-colors"
          >
            Get a Quote
          </a>
          <a
            href="/industrial-centrifuge-sample-testing/"
            class="inline-flex items-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition-colors"
          >
            Sample Testing
          </a>
          <a
            href="tel:+12485222573"
            class="inline-flex items-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition-colors"
          >
            (248) 522-2573
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* == Prose styling for application page content == */
  .prose-dolphin {
    font-family: var(--font-family-body);
    color: var(--color-text);
    line-height: 1.75;
  }

  .prose-dolphin h2 {
    font-family: var(--font-family-heading);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-navy);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
    scroll-margin-top: 5rem;
  }

  .prose-dolphin h3 {
    font-family: var(--font-family-heading);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    scroll-margin-top: 5rem;
  }

  .prose-dolphin h4 {
    font-family: var(--font-family-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }

  /* When a container has text-white class (e.g. CTA boxes on dark backgrounds),
     let headings inherit that white color instead of forcing navy */
  .prose-dolphin [class*="text-white"] h2,
  .prose-dolphin [class*="text-white"] h3,
  .prose-dolphin [class*="text-white"] h4 {
    color: inherit;
    border-bottom-color: rgba(255, 255, 255, 0.15);
  }

  .prose-dolphin p {
    margin-bottom: 1.125rem;
  }

  .prose-dolphin strong {
    font-weight: 600;
    color: var(--color-text);
  }

  /* Prose link styles - scoped to inline content only, not CTA buttons */
  .prose-dolphin p a,
  .prose-dolphin li a,
  .prose-dolphin td a,
  .prose-dolphin th a,
  .prose-dolphin blockquote a,
  .prose-dolphin h2 a,
  .prose-dolphin h3 a,
  .prose-dolphin h4 a {
    color: var(--color-navy);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: var(--color-gold);
    text-underline-offset: 3px;
    transition: color 0.15s;
  }

  /* Override: links with text-white class (e.g. inside dark navy CTA boxes)
     must stay white - prose rule above would make them invisible otherwise */
  .prose-dolphin p a.text-white,
  .prose-dolphin li a.text-white {
    color: #ffffff !important;
  }
  .prose-dolphin p a.text-white:hover,
  .prose-dolphin li a.text-white:hover {
    color: var(--color-gold) !important;
  }

  /* Override: headings with text-white class on dark navy CTA boxes
     must also stay white — prose h2/h3/h4 rules force navy otherwise */
  .prose-dolphin h2.text-white,
  .prose-dolphin h3.text-white,
  .prose-dolphin h4.text-white {
    color: #ffffff !important;
    border-bottom-color: rgba(255, 255, 255, 0.15) !important;
  }

  /* UNIVERSAL INVISIBLE-LINK FIX (added 2026-04-21)
     The .prose-dolphin th a / td a / p a rules force link color to navy.
     On any dark background that makes links invisible. Override: any
     link with an explicit .text-gold class, and any link inside a
     tr.bg-navy cell, render gold with !important.
  */

  .prose-dolphin p a.text-gold,
  .prose-dolphin li a.text-gold,
  .prose-dolphin td a.text-gold,
  .prose-dolphin th a.text-gold,
  .prose-dolphin blockquote a.text-gold,
  .prose-dolphin h2 a.text-gold,
  .prose-dolphin h3 a.text-gold,
  .prose-dolphin h4 a.text-gold,
  a.text-gold {
    color: var(--color-gold) !important;
  }

  .prose-dolphin p a.text-gold:hover,
  .prose-dolphin li a.text-gold:hover,
  .prose-dolphin td a.text-gold:hover,
  .prose-dolphin th a.text-gold:hover,
  a.text-gold:hover {
    color: var(--color-gold-light) !important;
  }

  .prose-dolphin tr.bg-navy td a,
  .prose-dolphin tr.bg-navy th a,
  tr.bg-navy td a,
  tr.bg-navy th a {
    color: var(--color-gold) !important;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose-dolphin tr.bg-navy td a:hover,
  .prose-dolphin tr.bg-navy th a:hover,
  tr.bg-navy td a:hover,
  tr.bg-navy th a:hover {
    color: #ffffff !important;
  }

  [class~="bg-navy"] p a:not(.text-gold):not([class*="text-white"]),
  [class~="bg-navy"] li a:not(.text-gold):not([class*="text-white"]) {
    color: #ffffff !important;
    text-decoration: underline;
    text-decoration-color: var(--color-gold);
  }

  .prose-dolphin p a:hover,
  .prose-dolphin li a:hover,
  .prose-dolphin td a:hover,
  .prose-dolphin blockquote a:hover,
  .prose-dolphin h2 a:hover,
  .prose-dolphin h3 a:hover,
  .prose-dolphin h4 a:hover {
    color: var(--color-gold-dark);
  }

  .prose-dolphin ul, .prose-dolphin ol {
    margin-bottom: 1.125rem;
    padding-left: 1.5rem;
  }

  .prose-dolphin ul { list-style: disc; }
  .prose-dolphin ol { list-style: decimal; }

  .prose-dolphin li {
    margin-bottom: 0.375rem;
  }

  .prose-dolphin img {
    display: block;
    height: auto;
    border-radius: 0.625rem;
    margin: 1.25rem auto;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  /* Named size caps - use class="img-cap-N" on <img> to cap width. !important beats everything. */
  .prose-dolphin img.img-cap-300 { max-width: 300px !important; width: 100% !important; }
  .prose-dolphin img.img-cap-400 { max-width: 400px !important; width: 100% !important; }
  .prose-dolphin img.img-cap-450 { max-width: 450px !important; width: 100% !important; }
  .prose-dolphin img.img-cap-500 { max-width: 500px !important; width: 100% !important; }
  .prose-dolphin img.img-cap-600 { max-width: 600px !important; width: 100% !important; }
  .prose-dolphin img.img-cap-700 { max-width: 700px !important; width: 100% !important; }
  .prose-dolphin img.img-cap-800 { max-width: 800px !important; width: 100% !important; }

  .prose-dolphin table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.875rem;
    border-radius: 0.625rem;
    overflow: hidden;
    border: 1px solid #e5e7eb;
  }

  .prose-dolphin thead th,
  .prose-dolphin th {
    background-color: var(--color-navy);
    color: white;
    font-weight: 600;
    text-align: left;
    padding: 0.625rem 0.875rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .prose-dolphin td {
    padding: 0.5rem 0.875rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .prose-dolphin tbody tr:nth-child(even) td {
    background-color: var(--color-light-bg);
  }

  /* Navy highlight rows must not be overridden by the zebra-stripe rule above.
     Also forces white text on th/td inside not-prose tables where prose-dolphin
     thead styles don't cascade. */
  .prose-dolphin tbody tr.bg-navy td,
  .prose-dolphin tbody tr.bg-navy th,
  .prose-dolphin thead tr.bg-navy td,
  .prose-dolphin thead tr.bg-navy th,
  tr.bg-navy td,
  tr.bg-navy th {
    background-color: var(--color-navy) !important;
    color: white !important;
  }

  .prose-dolphin blockquote {
    border-left: 4px solid var(--color-gold);
    padding: 0.875rem 1.25rem;
    margin: 1.25rem 0;
    background-color: var(--color-light-bg);
    border-radius: 0 0.5rem 0.5rem 0;
    color: var(--color-text-light);
    font-style: italic;
  }

  /* Global Body Image Styling */
  .prose-dolphin figure {
    margin: 1.5rem auto;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    overflow: hidden;
    background-color: #f9fafb;
    width: fit-content;
    max-width: 100%;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .prose-dolphin figure img {
    margin: 0 !important;
    display: block;
    width: 100%;
    border-radius: 0 !important;
    box-shadow: none !important;
  }

  .prose-dolphin figure figcaption {
    margin: 0;
    background-color: #f9fafb;
    border-top: 1px solid #e5e7eb;
    text-align: center;
    font-size: 0.75rem;
    color: var(--color-text-light);
    padding: 0.5rem 1rem;
  }

  .prose-dolphin hr {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 2rem 0;
  }

  /* Global not-prose escape */
  .prose-dolphin .not-prose :where(h1, h2, h3, h4, p, li, strong, a, span) {
    color: inherit;
  }

  .prose-dolphin .not-prose :where(a) {
    text-decoration: inherit;
    text-decoration-color: inherit;
  }
</style>
