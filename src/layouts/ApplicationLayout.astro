---
import BaseLayout from './BaseLayout.astro';

interface TocItem {
  id: string;
  label: string;
}

interface RelatedLink {
  label: string;
  href: string;
  description?: string;
}

interface Props {
  title: string;
  description?: string;
  heroImage?: string;
  heroImageAlt?: string;
  category?: string;
  categoryLabel?: string;
  toc?: TocItem[];
  relatedApplications?: RelatedLink[];
  relatedProducts?: RelatedLink[];
  canonicalUrl?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
}

const {
  title,
  description,
  heroImage,
  heroImageAlt = '',
  category = 'applications',
  categoryLabel = 'Applications',
  toc = [],
  relatedApplications = [],
  relatedProducts = [],
  canonicalUrl,
  jsonLd,
} = Astro.props;

const breadcrumbs = [
  { label: categoryLabel, href: '/disc-stack-centrifuge-applications/' },
  { label: title },
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLd}
>
  {/* ── Application Hero — light bg, image right ── */}
  <section class="bg-white border-b border-gray-200">
    <div class="container-dolphin py-8 md:py-12 lg:py-14">
      <div class="flex flex-col lg:flex-row items-start gap-8 lg:gap-12">
        {/* Left: Title + Description + CTAs */}
        <div class="flex-1 min-w-0">
          <span class="inline-block text-gold text-xs font-bold tracking-wider uppercase mb-2">{categoryLabel}</span>
          <h1 class="text-3xl md:text-4xl lg:text-[2.625rem] font-extrabold font-heading leading-tight text-navy mb-4">{title}</h1>
          {description && (
            <p class="text-base md:text-lg text-text-light leading-relaxed mb-6 max-w-xl">{description}</p>
          )}
          <div class="flex flex-wrap gap-3">
            <a
              href="/contact-for-alfa-laval-centrifuges/"
              class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-5 py-2.5 rounded-lg transition-colors shadow-sm"
            >
              Get a Free Quote
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a
              href="tel:2485222573"
              class="inline-flex items-center gap-2 border border-gray-300 hover:border-navy text-text font-semibold text-sm px-5 py-2.5 rounded-lg transition-colors"
            >
              <svg class="w-4 h-4 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              (248) 522-2573
            </a>
          </div>
        </div>

        {/* Right: Hero product image */}
        {heroImage && (
          <div class="lg:w-[380px] xl:w-[440px] shrink-0">
            <div class="rounded-xl overflow-hidden bg-light-bg border border-gray-200 shadow-sm">
              <img
                src={heroImage}
                alt={heroImageAlt}
                class="w-full h-auto object-contain"
                width="440"
                height="330"
                loading="eager"
                fetchpriority="high"
              />
            </div>
            {heroImageAlt && (
              <p class="text-xs text-text-muted text-center mt-2 italic">{heroImageAlt}</p>
            )}
          </div>
        )}
      </div>
    </div>
  </section>

  {/* ── Main Content Area ── */}
  <section class="bg-warm-white">
    <div class="container-dolphin py-10 md:py-14">
      <div class="flex flex-col lg:flex-row gap-10 lg:gap-14">

        {/* Main Content Column */}
        <div class="flex-1 min-w-0">
          {/* Table of Contents */}
          {toc.length > 0 && (
            <nav class="bg-white rounded-xl p-5 md:p-6 mb-10 border border-gray-200 shadow-sm" aria-label="Table of Contents">
              <h2 class="text-sm font-bold text-navy uppercase tracking-wider mb-3">On This Page</h2>
              <ol class="columns-1 md:columns-2 gap-x-6 space-y-1.5">
                {toc.map((item, i) => (
                  <li class="break-inside-avoid">
                    <a
                      href={`#${item.id}`}
                      class="flex items-start gap-2 text-sm text-text-light hover:text-navy transition-colors py-0.5"
                    >
                      <span class="text-gold font-mono text-xs mt-0.5 shrink-0">{String(i + 1).padStart(2, '0')}</span>
                      {item.label}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          )}

          {/* Article Content */}
          <article class="prose-dolphin">
            <slot />
          </article>
        </div>

        {/* Sidebar */}
        <aside class="lg:w-72 xl:w-80 shrink-0">
          <div class="lg:sticky lg:top-24 space-y-5">

            {/* Quick Contact Card */}
            <div class="bg-navy rounded-xl p-5 text-white">
              <h3 class="text-base font-bold font-heading mb-2">Talk to an Engineer</h3>
              <p class="text-sm text-gray-300 mb-4">Get expert advice for your specific application.</p>
              <a
                href="tel:2485222573"
                class="flex items-center gap-2 text-gold hover:text-gold-light font-bold text-lg transition-colors mb-3"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                (248) 522-2573
              </a>
              <a
                href="mailto:sales@dolphincentrifuge.com"
                class="flex items-center gap-2 text-sm text-gray-300 hover:text-white transition-colors"
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                sales@dolphincentrifuge.com
              </a>
              <a
                href="/contact-for-alfa-laval-centrifuges/"
                class="block text-center bg-gold text-navy font-bold text-sm py-2.5 rounded-lg mt-4 hover:bg-gold-light transition-colors"
              >
                Request a Quote
              </a>
            </div>

            {/* Recommended Centrifuges */}
            {relatedProducts.length > 0 && (
              <div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm">
                <h3 class="text-sm font-bold text-navy uppercase tracking-wider mb-3">Recommended Systems</h3>
                <ul class="space-y-2.5">
                  {relatedProducts.map((link) => (
                    <li>
                      <a href={link.href} class="group block p-2.5 rounded-lg hover:bg-light-bg transition-colors -mx-1">
                        <span class="block text-sm font-semibold text-navy group-hover:text-gold-dark transition-colors">{link.label}</span>
                        {link.description && (
                          <span class="block text-xs text-text-muted mt-0.5">{link.description}</span>
                        )}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {/* Related Applications */}
            {relatedApplications.length > 0 && (
              <div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm">
                <h3 class="text-sm font-bold text-navy uppercase tracking-wider mb-3">Related Applications</h3>
                <ul class="space-y-1">
                  {relatedApplications.map((link) => (
                    <li>
                      <a
                        href={link.href}
                        class="flex items-center gap-2 text-sm text-text-light hover:text-navy font-medium transition-colors py-1.5"
                      >
                        <svg class="w-3 h-3 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                        </svg>
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {/* Trust Badge */}
            <div class="bg-light-bg rounded-xl p-5 border border-gray-200 text-center">
              <div class="w-10 h-10 rounded-full bg-gold/15 flex items-center justify-center mx-auto mb-2">
                <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <p class="text-sm font-bold text-navy">40+ Years of Expertise</p>
              <p class="text-xs text-text-muted mt-0.5">150+ centrifuges in stock</p>
            </div>
          </div>
        </aside>
      </div>

      {/* ── Bottom CTA ── */}
      <div class="mt-14 bg-navy rounded-2xl p-8 md:p-10 text-white text-center md:text-left md:flex md:items-center md:justify-between">
        <div class="mb-6 md:mb-0">
          <h3 class="text-xl md:text-2xl font-bold font-heading mb-2">Ready to discuss your application?</h3>
          <p class="text-gray-300 text-sm">Our engineers will help you select and size the right centrifuge system.</p>
        </div>
        <div class="flex flex-wrap justify-center md:justify-end gap-3">
          <a
            href="/contact-for-alfa-laval-centrifuges/"
            class="inline-flex items-center gap-2 bg-gold hover:bg-gold-light text-navy font-bold text-sm px-6 py-3 rounded-lg transition-colors"
          >
            Get a Free Quote
          </a>
          <a
            href="/industrial-centrifuge-sample-testing/"
            class="inline-flex items-center gap-2 border border-white/30 hover:bg-white/10 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors"
          >
            Sample Testing
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* ── Prose styling for application page content ── */
  .prose-dolphin {
    font-family: var(--font-family-body);
    color: var(--color-text);
    line-height: 1.75;
  }

  .prose-dolphin h2 {
    font-family: var(--font-family-heading);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-navy);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
    scroll-margin-top: 5rem;
  }

  .prose-dolphin h3 {
    font-family: var(--font-family-heading);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    scroll-margin-top: 5rem;
  }

  .prose-dolphin h4 {
    font-family: var(--font-family-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .prose-dolphin p {
    margin-bottom: 1.125rem;
  }

  .prose-dolphin strong {
    font-weight: 600;
    color: var(--color-text);
  }

  .prose-dolphin a {
    color: var(--color-navy);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: var(--color-gold);
    text-underline-offset: 3px;
    transition: color 0.15s;
  }

  .prose-dolphin a:hover {
    color: var(--color-gold-dark);
  }

  .prose-dolphin ul, .prose-dolphin ol {
    margin-bottom: 1.125rem;
    padding-left: 1.5rem;
  }

  .prose-dolphin ul { list-style: disc; }
  .prose-dolphin ol { list-style: decimal; }

  .prose-dolphin li {
    margin-bottom: 0.375rem;
  }

  .prose-dolphin img {
    max-width: 100%;
    height: auto;
    border-radius: 0.625rem;
    margin: 1.25rem 0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .prose-dolphin table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.875rem;
    border-radius: 0.625rem;
    overflow: hidden;
    border: 1px solid #e5e7eb;
  }

  .prose-dolphin thead th,
  .prose-dolphin th {
    background-color: var(--color-navy);
    color: white;
    font-weight: 600;
    text-align: left;
    padding: 0.625rem 0.875rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .prose-dolphin td {
    padding: 0.5rem 0.875rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .prose-dolphin tbody tr:nth-child(even) td {
    background-color: var(--color-light-bg);
  }

  .prose-dolphin blockquote {
    border-left: 4px solid var(--color-gold);
    padding: 0.875rem 1.25rem;
    margin: 1.25rem 0;
    background-color: var(--color-light-bg);
    border-radius: 0 0.5rem 0.5rem 0;
    color: var(--color-text-light);
    font-style: italic;
  }

  .prose-dolphin hr {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 2rem 0;
  }
</style>
